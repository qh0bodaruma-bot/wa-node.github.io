---
import HydrogenLayout from '../../layouts/HydrogenLayout.astro';
---

<HydrogenLayout title="Top">
    <main>
        <!-- Hero Section -->
        <section style="height: 100vh; display: flex; align-items: center; background: radial-gradient(circle at 70% 30%, rgba(0, 212, 255, 0.15) 0%, transparent 50%); position: relative; overflow: hidden;">
            <div style="content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: url('/images/hydrogen-hero.png') no-repeat center center/cover; opacity: 0.3; z-index: -1;"></div>
            <div class="container">
                <div style="max-width: 800px;">
                    <span class="reveal" style="color: var(--primary); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.2em;" data-ja="日本発、水素の力で未来を変える" data-en="Unlocking the Power of Hydrogen from Japan">日本発、水素の力で未来を変える</span>
                    <h1 class="reveal" style="font-size: clamp(3rem, 8vw, 5rem); line-height: 1.1; margin: 1.5rem 0;" data-ja="エネルギーの常識を、<br>塗り替える。" data-en="Redefining <br>Energy Standards.">エネルギーの常識を、<br>塗り替える。</h1>
                    <p class="reveal" style="font-size: 1.2rem; color: var(--text-dim); margin-bottom: 2.5rem;" data-ja="私たちは最先端の水素製造技術により、脱炭素社会の実現を加速させるディープテック・ベンチャーです。" data-en="We are a deep-tech venture accelerating the realization of a decarbonized society with cutting-edge hydrogen production technology.">私たちは最先端の水素製造技術により、脱炭素社会の実現を加速させるディープテック・ベンチャーです。</p>
                    <div class="reveal" style="display: flex; gap: 1rem;">
                        <a href="/hydrogen/products" class="btn btn-primary" data-ja="製品を見る" data-en="View Products">製品を見る</a>
                        <a href="/hydrogen/business" class="btn" style="border: 1px solid var(--text-dim); color: #fff;" data-ja="技術について" data-en="About Technology">技術について</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Feature Grid (SmartHR inspired) -->
        <section class="container" style="padding: 6rem 0;">
            <!-- Simulated News Bar -->
            <div class="glass reveal" style="margin-bottom: 4rem; padding: 1.5rem 2rem; display: flex; gap: 2rem; align-items: center; border: 1px solid var(--primary);">
                <div style="font-size: 0.8rem; color: var(--text-dim);">2026.05.11</div>
                <div style="background: var(--primary); color: #fff; font-size: 0.6rem; padding: 0.2rem 0.6rem; border-radius: 4px; font-weight: 700;">NEWS</div>
                <div id="topNewsText" style="font-weight: 600;" data-ja="次世代水素製造ユニットの受注を開始いたしました。" data-en="Now accepting orders for next-gen hydrogen units.">
                    次世代水素製造ユニットの受注を開始いたしました。
                </div>
            </div>

            <div class="grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem;">
                <div class="glass reveal" style="padding: 3rem;">
                    <h3 style="margin-bottom: 1rem;" data-ja="革新的な技術" data-en="Innovative Tech">革新的な技術</h3>
                    <p style="color: var(--text-dim);" data-ja="経産省・NEDOと連携した次世代水素製造ソリューション。" data-en="Next-gen hydrogen production in collaboration with METI and NEDO.">経産省・NEDOと連携した次世代水素製造ソリューション。</p>
                </div>
                <div class="glass reveal" style="padding: 3rem;">
                    <h3 style="margin-bottom: 1rem;" data-ja="グローバル展開" data-en="Global Expansion">グローバル展開</h3>
                    <p style="color: var(--text-dim);" data-ja="世界市場を見据えた多言語・標準化対応。" data-en="Multi-language and standardized for global markets.">世界市場を見据えた多言語・標準化対応。</p>
                </div>
                <div class="glass reveal" style="padding: 3rem;">
                    <h3 style="margin-bottom: 1rem;" data-ja="確かな信頼" data-en="Proven Trust">確かな信頼</h3>
                    <p style="color: var(--text-dim);" data-ja="大手電力・重工業会社への導入実績とパートナーシップ。" data-en="Partnerships and proven results with major power and industrial companies.">大手電力・重工業会社への導入実績とパートナーシップ。</p>
                </div>
            </div>
        </section>
    </main>

    <script is:inline>
        function updateTopNews() {
            const newsJp = localStorage.getItem('demo-news-jp');
            const newsEn = localStorage.getItem('demo-news-en');
            const currentLang = localStorage.getItem('hydrogen-lang') || 'ja';
            const targetEl = document.getElementById('topNewsText');

            if (targetEl) {
                if (newsJp) targetEl.setAttribute('data-ja', newsJp);
                if (newsEn) targetEl.setAttribute('data-en', newsEn);
                
                targetEl.textContent = currentLang === 'en' ? 
                    (newsEn || targetEl.getAttribute('data-en')) : 
                    (newsJp || targetEl.getAttribute('data-ja'));
            }
        }

        // Initialize and listen
        updateTopNews();
        window.addEventListener('storage', updateTopNews);
        setInterval(updateTopNews, 1000);
    </script>
</HydrogenLayout>
