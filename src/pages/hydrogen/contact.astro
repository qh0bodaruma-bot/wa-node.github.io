---
import HydrogenLayout from '../../layouts/HydrogenLayout.astro';
---

<HydrogenLayout title="お問い合わせ">
    <main style="height: 60vh; display: flex; align-items: center; justify-content: center; text-align: center;">
        <div class="reveal">
            <h1 style="font-size: 4rem; margin-bottom: 1rem;" data-ja="お問い合わせ" data-en="Inquiry">お問い合わせ</h1>
            <p style="color: var(--text-dim); max-width: 600px;" data-ja="（現在、4種CTA対応の分岐フォームを構築中）" data-en="(Branching Form Under Construction)">(現在、4種CTA対応の分岐フォームを構築中)</p>
            <div style="margin-top: 2rem; display: inline-block; padding: 1rem 2rem; border: 1px dashed var(--primary); border-radius: 8px; color: var(--primary); font-size: 0.9rem;">
                Branching Form Engine Placeholder
            </div>
        </div>
    </main>
</HydrogenLayout>
