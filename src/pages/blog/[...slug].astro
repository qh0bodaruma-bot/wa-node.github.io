---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConsultationFlow from '../../components/ConsultationFlow.astro';
import { getBlogs, getBlogDetail } from '../../library/microcms';

export async function getStaticPaths() {
  const response = await getBlogs({ fields: ["id"] });
  return response.contents.map((blog) => ({
    params: { slug: blog.id },
  }));
}

const { slug } = Astro.params;
const post = await getBlogDetail(slug);
const cleanBlogTitle = (title: string) => title.replace(/^\s*大見出し[：:]\s*/, "");
const cleanBlogContent = (content: string) => content
  .replace(/(<h[2-3]\b[^>]*>)\s*中見出し[：:]\s*/g, "$1")
  .replace(/<h[2-3]\b[^>]*>\s*設定用ハッシュタグ\s*<\/h[2-3]>/g, "")
  .replace(/設定用ハッシュタグ\s*/g, "");
const displayTitle = cleanBlogTitle(post.title);
const cleanedContent = cleanBlogContent(post.content);
---

<BaseLayout title={`${displayTitle}｜和-Node 知恵袋`} description={post.description} image={post.eyecatch?.url}>
  <article class="post-single">
    <div class="post-header">
      <div class="container-narrow">
        <div class="post-meta">
          <time datetime={post.publishedAt}>
            {new Date(post.publishedAt).toLocaleDateString('ja-JP', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          {post.tags && post.tags.length > 0 && (
            <div class="tags">
              {post.tags.map(tag => <span>#{tag}</span>)}
            </div>
          )}
        </div>
        <h1>{displayTitle}</h1>
      </div>
    </div>

    <div class="post-hero">
      <div class="container-narrow">
        {post.eyecatch && (
          <img src={post.eyecatch.url} alt="" class="hero-image" />
        )}
      </div>
    </div>

    <div class="post-body">
      <div class="container-narrow">
        <div class="content-wrap">
          <div set:html={cleanedContent} />
        </div>
      </div>
    </div>

    <footer class="post-footer">
      <div class="container">
        <ConsultationFlow id="contact" />
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-single { padding-bottom: 0; }
  .container-narrow { max-width: 800px; margin: 0 auto; padding: 0 20px; }
  
  .post-header { padding: 100px 0 40px; text-align: center; }
  .post-meta { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; color: var(--muted); font-size: 0.9rem; }
  .tags { display: flex; gap: 12px; justify-content: center; }
  .tags span { color: var(--accent); font-weight: 800; }
  
  .post-header h1 { font-size: clamp(1.8rem, 5vw, 2.8rem); font-weight: 900; line-height: 1.3; color: var(--text); }

  .post-hero { margin-bottom: 60px; }
  .hero-image { width: 100%; border-radius: 32px; box-shadow: var(--shadow); border: 1px solid var(--line); }

  .post-body { padding-bottom: 100px; }
  .content-wrap { font-size: 1.1rem; line-height: 1.8; color: #444; }
  
  /* Markdown Styles */
  .content-wrap :global(h2) { font-size: 1.8rem; font-weight: 900; margin: 60px 0 24px; color: var(--text); border-left: 6px solid var(--accent); padding-left: 20px; }
  .content-wrap :global(h3) { font-size: 1.4rem; font-weight: 800; margin: 40px 0 20px; color: var(--text); }
  .content-wrap :global(p) { margin-bottom: 1.8rem; }
  .content-wrap :global(strong) { color: var(--accent); font-weight: 800; }
  .content-wrap :global(ul) { margin-bottom: 1.8rem; padding-left: 1.5em; }
  .content-wrap :global(li) { margin-bottom: 12px; }

  .post-footer { background: #fffdf9; border-top: 1px solid var(--line); }

  @media (max-width: 768px) {
    .post-header { padding: 60px 0 30px; }
    .content-wrap { font-size: 1rem; }
    .content-wrap :global(h2) { font-size: 1.5rem; margin-top: 40px; }
  }
</style>
