---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="コラム・知恵袋｜和-Node" description="心理学とITの交差点。成約率を高めるWeb制作のヒントや、AI活用の現場知見、心の健康を守る方法などを発信しています。">
  <main class="blog-index">
    <header class="blog-header">
      <div class="container">
        <span class="eyebrow">Insights & Column</span>
        <h1>和-Nodeの<br/><span class="accent-text">知恵袋。</span></h1>
        <p class="lead">心理学 × IT × 当事者視点。<br/>日々の制作やカウンセリングから得た、一歩進むためのヒントを綴ります。</p>
      </div>
    </header>

    <div class="container">
      <div class="post-grid">
        {posts.map((post) => (
          <article class="post-card reveal">
            <a href={`/blog/${post.slug}/`}>
              <div class="post-image">
                {post.data.heroImage ? (
                  <img src={post.data.heroImage} alt="" />
                ) : (
                  <div class="image-placeholder">No Image</div>
                )}
              </div>
              <div class="post-content">
                <div class="post-meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('ja-JP', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  {post.data.tags && (
                    <div class="tags">
                      {post.data.tags.map(tag => <span>#{tag}</span>)}
                    </div>
                  )}
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="read-more">詳しく見る →</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .blog-index { padding-bottom: 120px; }
  .blog-header { padding: 120px 0 60px; text-align: center; }
  .eyebrow { font-size: 0.85rem; font-weight: 900; color: var(--accent2); letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 16px; display: block; }
  .blog-header h1 { font-size: clamp(2.2rem, 6vw, 4rem); font-weight: 900; line-height: 1.15; margin-bottom: 24px; }
  .accent-text { color: var(--accent2); }
  .lead { font-size: 1.15rem; color: var(--muted); max-width: 700px; margin: 0 auto; line-height: 1.8; }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 40px;
    margin-top: 40px;
  }

  .post-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 32px;
    overflow: hidden;
    transition: 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }
  .post-card a { text-decoration: none; color: inherit; display: block; height: 100%; }
  
  .post-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(70, 52, 32, 0.1);
    border-color: var(--accent2);
  }

  .post-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #f8f1e9;
    overflow: hidden;
  }
  .post-image img { width: 100%; height: 100%; object-fit: cover; transition: 0.6s; }
  .post-card:hover .post-image img { transform: scale(1.05); }

  .post-content { padding: 32px; }
  
  .post-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; font-size: 0.85rem; color: var(--muted); }
  .tags { display: flex; gap: 8px; }
  .tags span { color: var(--accent); font-weight: 700; }

  .post-content h2 { font-size: 1.4rem; font-weight: 800; margin-bottom: 12px; line-height: 1.4; color: var(--text); }
  .post-content p { font-size: 0.95rem; color: #666; line-height: 1.6; margin-bottom: 24px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  
  .read-more { font-weight: 800; color: var(--accent); font-size: 0.9rem; border-bottom: 2px solid var(--soft); padding-bottom: 2px; }

  @media (max-width: 768px) {
    .blog-header { padding: 80px 20px 40px; }
    .post-grid { grid-template-columns: 1fr; gap: 30px; }
  }
</style>
