---
// src/pages/showcase-hydrogen.astro
const title = "Hydrogen-X | Leading the Green Revolution";
const description = "Next-generation hydrogen technology solutions for a sustainable future.";
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Outfit:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #00d4ff;
            --primary-dark: #008fb3;
            --bg-deep: #0b1120;
            --bg-card: rgba(255, 255, 255, 0.05);
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
            --accent: #10b981;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-deep);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        h1, h2, h3 {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
        }

        /* --- Components --- */

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* --- Animations --- */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 1s ease, transform 1s ease;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            padding: 1rem 2.5rem;
            border-radius: 9999px;
            font-weight: 600;
            text-decoration: none;
            transition: var(--transition);
            cursor: pointer;
            border: none;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: #fff;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0, 212, 255, 0.4);
        }

        /* --- Mission Section (Heralbony inspired) --- */
        .mission-section {
            padding: 12rem 0;
            text-align: center;
            background: linear-gradient(180deg, var(--bg-deep) 0%, rgba(0, 212, 255, 0.05) 50%, var(--bg-deep) 100%);
        }

        .mission-text {
            font-size: clamp(1.5rem, 4vw, 3rem);
            font-weight: 300;
            line-height: 1.4;
            max-width: 900px;
            margin: 0 auto;
            font-family: 'Outfit', sans-serif;
        }

        .mission-text b {
            color: var(--primary);
            font-weight: 700;
        }

        /* --- Footer (TOPPAN inspired) --- */
        footer {
            background: #050810;
            padding: 6rem 0 3rem;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr repeat(3, 1fr);
            gap: 4rem;
            margin-bottom: 4rem;
        }

        .footer-logo {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            color: var(--primary);
        }

        .footer-link-group h4 {
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            color: var(--text-main);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .footer-link-group ul {
            list-style: none;
        }

        .footer-link-group li {
            margin-bottom: 0.8rem;
        }

        .footer-link-group a {
            color: var(--text-dim);
            text-decoration: none;
            font-size: 0.9rem;
            transition: var(--transition);
        }

        .footer-link-group a:hover {
            color: var(--primary);
        }

        .copyright {
            text-align: center;
            color: var(--text-dim);
            font-size: 0.8rem;
            padding-top: 3rem;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* --- Refined Elements --- */
        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .case-card {
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .case-card:hover {
            border-color: var(--primary);
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.1);
        }

        @media (max-width: 768px) {
            .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
            .footer-grid > div:first-child { grid-column: span 2; }
        }
    </style>
</head>
<body>

    <header id="header">
        <div class="container nav-inner">
            <div class="logo">HYDROGEN-X</div>
            <div class="lang-toggle">
                <button class="lang-btn active" onclick="setLang('ja')">JP</button>
                <button class="lang-btn" onclick="setLang('en')">EN</button>
            </div>
        </div>
    </header>

    <main>
        <!-- Hero Section -->
        <section class="hero">
            <div class="container">
                <div class="hero-content">
                    <span class="case-tag reveal" data-ja="クリーンエネルギーの未来" data-en="Future of Clean Energy">クリーンエネルギーの未来</span>
                    <h1 class="reveal" data-ja="水素技術で、<br>地球を塗り替える。" data-en="Redefining Earth <br>with Hydrogen.">水素技術で、<br>地球を塗り替える。</h1>
                    <p class="reveal" data-ja="私たちは、日本発のディープテック企業として、持続可能なエネルギー社会の基盤となる革新的な水素製造・管理ソリューションを提供します。" 
                       data-en="As a Japan-born deep tech venture, we provide innovative hydrogen production and management solutions that form the foundation of a sustainable energy society.">
                        私たちは、日本発のディープテック企業として、持続可能なエネルギー社会の基盤となる革新的な水素製造・管理ソリューションを提供します。
                    </p>
                    <div class="reveal">
                        <a href="#contact" class="btn btn-primary" data-ja="技術相談を予約する" data-en="Book a Technical Consultation">技術相談を予約する</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Mission Section -->
        <section class="mission-section">
            <div class="container">
                <p class="mission-text reveal" data-ja="見えないエネルギーを、<b>見える信頼</b>へ。私たちは水素の力を解き放ち、次世代に青い地球を手渡します。" 
                   data-en="Turning invisible energy into <b>visible trust</b>. We unlock the power of hydrogen to pass on a blue planet to the next generation.">
                    見えないエネルギーを、<b>見える信頼</b>へ。私たちは水素の力を解き放ち、次世代に青い地球を手渡します。
                </p>
            </div>
        </section>

        <!-- Case Studies -->
        <section class="container" style="padding: 8rem 0;">
            <div class="section-title reveal">
                <h2 data-ja="技術実績 & ケーススタディ" data-en="Technical Achievements & Case Studies">技術実績 & ケーススタディ</h2>
                <p data-ja="5つの異なる領域での課題解決実績" data-en="Proven solutions across 5 distinct domains">5つの異なる領域での課題解決実績</p>
            </div>
            <div class="grid">
                <!-- Case 1 -->
                <div class="case-card glass reveal">
                    <span class="case-tag">Case 01</span>
                    <h3 data-ja="次世代エネルギー管理システム" data-en="Next-Gen Energy Management">次世代エネルギー管理システム</h3>
                    <p data-ja="IoTを活用した水素流量のリアルタイム監視と最適化を実現。" data-en="Real-time monitoring and optimization of hydrogen flow using IoT.">IoTを活用した水素流量のリアルタイム監視と最適化を実現。</p>
                </div>
                <!-- Case 2 -->
                <div class="case-card glass reveal">
                    <span class="case-tag">Case 02</span>
                    <h3 data-ja="グローバル製造ポータル" data-en="Global Manufacturing Portal">グローバル製造ポータル</h3>
                    <p data-ja="多言語対応のセキュアな技術情報共有プラットフォームの構築。" data-en="Construction of a secure, multi-language technical information sharing platform.">多言語対応のセキュアな技術情報共有プラットフォームの構築。</p>
                </div>
                <!-- Case 3 -->
                <div class="case-card glass reveal">
                    <span class="case-tag">Case 03</span>
                    <h3 data-ja="ディープテック特化型ポートフォリオ" data-en="Deep Tech Portfolio">ディープテック特化型ポートフォリオ</h3>
                    <p data-ja="複雑な技術情報を視覚的に伝えるB2Bマーケティング支援。" data-en="B2B marketing support visually communicating complex technical information.">複雑な技術情報を視覚的に伝えるB2Bマーケティング支援。</p>
                </div>
                <!-- Case 4 -->
                <div class="case-card glass reveal">
                    <span class="case-tag">Case 04</span>
                    <h3 data-ja="公共セクター向けクリーンエネルギLP" data-en="Public Sector Energy LP">公共セクター向けクリーンエネルギLP</h3>
                    <p data-ja="自治体連携を促進するアクセシビリティに優れた広報ページ。" data-en="Highly accessible PR page promoting municipal collaboration.">自治体連携を促進するアクセシビリティに優れた広報ページ。</p>
                </div>
                <!-- Case 5 -->
                <div class="case-card glass reveal">
                    <span class="case-tag">Case 05</span>
                    <h3 data-ja="拡張性の高い水素製造ダッシュボード" data-en="Scalable Hydrogen Dashboard">拡張性の高い水素製造ダッシュボード</h3>
                    <p data-ja="マイクロサービス構成による高可用な監視システムの実装。" data-en="Implementation of a high-availability monitoring system using microservices.">マイクロサービス構成による高可用な監視システムの実装。</p>
                </div>
            </div>
        </section>

        <!-- Branching Contact Form -->
        <section id="contact" class="contact-section">
            <div class="container">
                <div class="form-grid">
                    <div class="form-info reveal">
                        <h2 data-ja="共に、未来を創る。" data-en="Shape the Future Together.">共に、未来を創る。</h2>
                        <p data-ja="お問い合わせの目的に合わせ、専門の担当者が迅速に対応いたします。" data-en="Our specialized team will respond promptly according to your inquiry's purpose.">お問い合わせの目的に合わせ、専門の担当者が迅速に対応いたします。</p>
                        <div style="margin-top: 2rem; color: var(--accent); font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            <span>Protected by Google reCAPTCHA v3</span>
                        </div>
                    </div>
                    <div class="glass reveal" style="padding: 3rem;">
                        <form id="hydrogenForm">
                            <div class="form-control">
                                <label data-ja="お問い合わせの種類" data-en="Inquiry Type">お問い合わせの種類</label>
                                <select id="inquiryType" required>
                                    <option value="" disabled selected data-ja="選択してください" data-en="Please select">選択してください</option>
                                    <option value="product" data-ja="製品に関するお問い合わせ" data-en="Product Inquiry">製品に関するお問い合わせ</option>
                                    <option value="tech" data-ja="技術相談・共同研究" data-en="Technical / R&D Consultation">技術相談・共同研究</option>
                                    <option value="media" data-ja="取材・登壇のご依頼" data-en="Media / Speaking Request">取材・登壇のご依頼</option>
                                    <option value="recruit" data-ja="採用について" data-en="Careers">採用について</option>
                                </select>
                            </div>

                            <!-- Dynamic Branching Fields -->
                            <div id="branchProduct" class="branch-fields">
                                <div class="form-control">
                                    <label data-ja="ご検討中の製品" data-en="Product of Interest">ご検討中の製品</label>
                                    <select>
                                        <option data-ja="可搬式発電装置" data-en="Portable Generator">可搬式発電装置</option>
                                        <option data-ja="加水分解装置" data-en="Hydrolysis Unit">加水分解装置</option>
                                        <option data-ja="水素製造装置" data-en="Hydrogen Production Unit">水素製造装置</option>
                                    </select>
                                </div>
                            </div>

                            <div id="branchTech" class="branch-fields">
                                <div class="form-control">
                                    <label data-ja="相談内容の概要" data-en="Consultation Summary">相談内容の概要</label>
                                    <textarea rows="3" placeholder="受託設計、共同研究のテーマなど"></textarea>
                                </div>
                            </div>

                            <div class="form-control">
                                <label data-ja="お名前" data-en="Name">お名前</label>
                                <input type="text" required placeholder="田中 太郎">
                            </div>
                            <div class="form-control">
                                <label data-ja="貴社名" data-en="Company Name">貴社名</label>
                                <input type="text" required placeholder="株式会社〇〇">
                            </div>
                            <div class="form-control">
                                <label data-ja="メールアドレス" data-en="Email">メールアドレス</label>
                                <input type="email" required placeholder="email@example.com">
                            </div>
                            <div class="form-control">
                                <label data-ja="お問い合わせ内容" data-en="Message">お問い合わせ内容</label>
                                <textarea rows="5" required></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;" data-ja="送信する" data-en="Send Message">送信する</button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="container">
            <div class="footer-grid">
                <div>
                    <div class="footer-logo">HYDROGEN-X</div>
                    <p style="color: var(--text-dim); font-size: 0.9rem;">Leading the global energy transition through innovative hydrogen technology.</p>
                </div>
                <div class="footer-link-group">
                    <h4 data-ja="技術情報" data-en="Technology">技術情報</h4>
                    <ul>
                        <li><a href="#" data-ja="製造装置" data-en="Production">製造装置</a></li>
                        <li><a href="#" data-ja="管理システム" data-en="Management">管理システム</a></li>
                        <li><a href="#" data-ja="研究開発" data-en="R&D">研究開発</a></li>
                    </ul>
                </div>
                <div class="footer-link-group">
                    <h4 data-ja="会社情報" data-en="Company">会社情報</h4>
                    <ul>
                        <li><a href="#" data-ja="私たちについて" data-en="About Us">私たちについて</a></li>
                        <li><a href="#" data-ja="ニュース" data-en="News">ニュース</a></li>
                        <li><a href="#" data-ja="採用情報" data-en="Careers">採用情報</a></li>
                    </ul>
                </div>
                <div class="footer-link-group">
                    <h4 data-ja="規約・方針" data-en="Policies">規約・方針</h4>
                    <ul>
                        <li><a href="#" data-ja="プライバシーポリシー" data-en="Privacy Policy">プライバシーポリシー</a></li>
                        <li><a href="#" data-ja="利用規約" data-en="Terms">利用規約</a></li>
                    </ul>
                </div>
            </div>
            <div class="copyright">
                &copy; 2026 HYDROGEN-X Inc. All Rights Reserved. Prototype by Antigravity.
            </div>
        </div>
    </footer>

    <script is:inline>
        // Language Toggle Logic
        function setLang(lang) {
            document.querySelectorAll('[data-ja]').forEach(el => {
                const targetText = lang === 'en' ? el.getAttribute('data-en') : el.getAttribute('data-ja');
                if (targetText) {
                    el.innerHTML = targetText; // Use innerHTML to support <b> tags
                }
            });

            document.querySelectorAll('.lang-btn').forEach(btn => {
                btn.classList.toggle('active', btn.textContent.toLowerCase() === lang);
            });
        }

        // Branching Form Logic
        const typeSelect = document.getElementById('inquiryType');
        const branches = {
            product: document.getElementById('branchProduct'),
            tech: document.getElementById('branchTech')
        };

        typeSelect.addEventListener('change', (e) => {
            Object.values(branches).forEach(b => b.style.display = 'none');
            if (branches[e.target.value]) {
                branches[e.target.value].style.display = 'block';
            }
        });

        // Scroll Reveal Logic
        const observerOptions = {
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        // Header Scroll Effect
        window.addEventListener('scroll', () => {
            const header = document.getElementById('header');
            header.classList.toggle('scrolled', window.scrollY > 50);
        });
    </script>
</body>
</html>
