---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "起業記念20%OFFキャンペーン | 和-Node",
  "description": "心理学・ICT・AIを統合したWeb制作「和-Node」の起業記念キャンペーン。制作メニュー・オプションすべて20%OFF。2026年7月31日まで。",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "和-Node", "item": "https://www.wa-node.com/" },
      { "@type": "ListItem", "position": 2, "name": "起業記念キャンペーン" }
    ]
  }
};
---

<BaseLayout 
  title="【20%OFF】起業記念キャンペーン｜心理学・ICT・AIWeb制作｜和-Node" 
  description="和-Nodeの起業記念。心理導線LP制作からAI・LINE自動化システム構築まで、全メニュー20%OFF。毎月先着3名様限定の特別オファー。"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  
  <main class="campaign-page">
    <!-- Hero Section -->
    <section class="hero-campaign">
      <div class="hero-bg-accent"></div>
      <div class="container">
        <div class="anniversary-badge-large reveal">
          <span class="badge-text">1st ANNIVERSARY</span>
          <span class="badge-sub">Startup Campaign</span>
        </div>
        <h1 class="reveal">
          <span class="eyebrow-red">起業記念・限定特別オファー</span>
          <br/>心理学・ICT・AIを活用した<br/>Web制作・コンサルティング キャンペーン
        </h1>
        <p class="hero-lead"><strong>「想い」と「技術」を、もっとも優しい形で結ぶ。</strong></p>
        <p class="hero-price reveal">
          制作メニュー・オプション <span class="highlight">すべて20% OFF</span>
        </p>
        <p class="hero-limit reveal">
          毎月先着 <strong>3名様</strong> 限定 / 2026年7月31日まで
        </p>
        <div class="hero-btns reveal">
          <a href="#plans" class="btn-primary-gold">限定プランを見る</a>
          <a href="/contact" class="btn-secondary-white">無料で相談する</a>
        </div>
      </div>
    </section>

    <!-- Value Section -->
    <section class="value-section">
      <div class="container">
        <div class="section-title reveal">
          <span class="eyebrow">Why Wa-Node?</span>
          <h2>単なる制作ではない、<br/>和-Nodeだけの「三位一体」設計</h2>
        </div>
        <div class="value-grid">
          <div class="value-card reveal">
            <div class="v-icon">🧠</div>
            <h3>心理学の視点</h3>
            <p>不安を煽るのではなく「安心して選べる」導線。訪問者の心を整え、自然な行動を促します。</p>
          </div>
          <div class="value-card reveal" style="transition-delay: 0.1s;">
            <div class="v-icon">⚡</div>
            <h3>ICT/AIの視点</h3>
            <p>LINE・ChatGPT連携・自動化。24時間働き、あなたの時間を創り出す仕組みを構築します。</p>
          </div>
          <div class="value-card reveal" style="transition-delay: 0.2s;">
            <div class="v-icon">♿</div>
            <h3>当事者の視点</h3>
            <p>車いすユーザーとしてのバリアフリー設計。たった1ピクセルの「不親切」も逃しません。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Plan Section -->
    <section class="plan-section" id="plans">
      <div class="container">
        <div class="section-title reveal">
          <span class="eyebrow">Special Plans</span>
          <h2>キャンペーン限定・3つの提案</h2>
          <p>制作費だけでなく、高度なオプションまで一律20%OFFが適用されます。</p>
        </div>

        <div class="plan-grid">
          <!-- Plan A -->
          <div class="plan-card reveal">
            <div class="p-header">
              <span class="p-tag">整える</span>
              <h3>心理導線・速戦LP案</h3>
            </div>
            <div class="p-price">
              <span class="p-old">60,000円</span>
              <span class="p-new">48,000<small>円</small></span>
            </div>
            <ul class="p-features">
              <li>心理導線に基づいた構成設計</li>
              <li>スマホ最適化レスポンシブ</li>
              <li>基本SEO設定</li>
              <li>無料たたき台作成（1P）</li>
              <li class="plus">特典：60分無料整理相談</li>
            </ul>
            <a href="/anniversary-speed" class="btn-outline">この案を詳しく見る</a>
          </div>

          <!-- Plan B -->
          <div class="plan-card featured reveal">
            <div class="p-featured-badge">人気 No.1</div>
            <div class="p-header">
              <span class="p-tag">進む</span>
              <h3>ICT・自動化フル強化案</h3>
            </div>
            <div class="p-price">
              <span class="p-old">150,000円</span>
              <span class="p-new">120,000<small>円</small></span>
            </div>
            <ul class="p-features">
              <li><strong>Plan A の全内容</strong></li>
              <li>LINE連携 / フォーム自動化</li>
              <li>オリジナル図解・イラスト制作</li>
              <li>高度な内部SEO対策</li>
              <li class="plus">特典：LINEリッチメニュー作成</li>
            </ul>
            <a href="/anniversary-automation" class="btn-primary-gold">この案を詳しく見る</a>
          </div>

          <!-- Plan C -->
          <div class="plan-card reveal">
            <div class="p-header">
              <span class="p-tag">和（む）</span>
              <h3>和-Node 伴走型特注案</h3>
            </div>
            <div class="p-price">
              <span class="p-old">250,000円</span>
              <span class="p-new">200,000<small>円</small></span>
            </div>
            <ul class="p-features">
              <li><strong>Plan B の全内容</strong></li>
              <li>AI活用・ChatGPT導入支援</li>
              <li>3ヶ月の継続並走コンサル</li>
              <li>法人メンタル窓口セットアップ</li>
              <li class="plus">特典：運用保守3ヶ月無料</li>
            </ul>
            <a href="/anniversary-premium" class="btn-outline">この案を詳しく見る</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Option Heavy Showcase -->
    <section class="option-showcase">
      <div class="container">
        <div class="showcase-box reveal">
          <h2>「オプション盛り盛り」で<br class="sp-only"/>あなたの理想をすべて叶える</h2>
          <p>今回のキャンペーンは、制作本体だけでなく**「あったら嬉しいオプション」もすべて20%OFF**です。和-Nodeが提供できる「盛り盛り」の技術をご覧ください。</p>
          
          <div class="showcase-grid">
            <div class="s-item">
              <h4>ChatGPT連携</h4>
              <p>お問い合わせ内容をAIが自動要約。返信案まで生成する「超効率」の仕組み。</p>
            </div>
            <div class="s-item">
              <h4>LINE Mini App</h4>
              <p>アプリ不要でスマホに常駐。予約や会員証、診断ツールをLINE内で完結。</p>
            </div>
            <div class="s-item">
              <h4>心理テスト・診断ツール</h4>
              <p>ユーザーが楽しみながら価値を知る、成約率を底上げする「診断型」コンテンツ。</p>
            </div>
            <div class="s-item">
              <h4>バリアフリー診断・改善</h4>
              <p>アクセシビリティのプロが、あらゆる人が使いやすい「真の親切」を実装。</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CEO Section -->
    <section class="ceo-message">
      <div class="container">
        <div class="ceo-card reveal">
          <div class="ceo-image">
            <img src="/images/avatar.png" alt="代表 高野紘純" />
          </div>
          <div class="ceo-text">
            <span class="eyebrow">Message</span>
            <h3>「技術の前に、心がある。」<br/>その信念を、カタチにしました。</h3>
            <p>起業から今日まで、多くの方の「想い」に触れてきました。ITは冷たい道具ではなく、あなたの想いを乗せて遠くへ運ぶ「船」であるべきです。このキャンペーンが、あなたの素晴らしい事業を、もっと多くの人に届けるきっかけになれば、これ以上の喜びはありません。まずは、ゆっくりお話ししましょう。</p>
            <p class="ceo-name">和-Node 代表　<strong>高野 紘純</strong></p>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="campaign-cta">
      <div class="container reveal">
        <h2>今の不安を、未来の安心に変える。</h2>
        <p>制作依頼が固まっていなくても大丈夫です。「何を整理すべきか」を一緒に考えるところから始めましょう。</p>
        <div class="cta-btns">
          <a href="/contact" class="btn-main">キャンペーン価格で相談する</a>
          <p class="cta-note">※無理な勧誘は一切ありません。ご安心ください。</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :root {
    --gold: #c5a059;
    --gold-dark: #a38241;
    --gold-light: #e2c891;
    --campaign-bg: #fdfcf9;
    --text-deep: #2c2c2c;
  }

  .campaign-page {
    background: var(--campaign-bg);
    color: var(--text-deep);
    overflow-x: hidden;
  }

  /* Hero */
  .hero-campaign {
    position: relative;
    padding: 120px 0 100px;
    text-align: center;
    background: linear-gradient(135deg, #f9f7f2 0%, #ffffff 100%);
    border-bottom: 1px solid rgba(197, 160, 89, 0.2);
  }

  .hero-bg-accent {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(197, 160, 89, 0.08) 0%, transparent 70%);
    z-index: 0;
  }

  .anniversary-badge-large {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 30px;
    padding: 20px 40px;
    background: white;
    border: 2px solid var(--gold);
    border-radius: 100px;
    box-shadow: 0 10px 30px rgba(197, 160, 89, 0.1);
  }

  .badge-text {
    font-family: 'Outfit', sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--gold);
    letter-spacing: 0.1em;
  }

  .badge-sub {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .hero-campaign h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.2;
    margin-bottom: 24px;
    font-weight: 800;
  }

  .eyebrow-red {
    font-size: 1.2rem;
    color: #d14d3a;
    font-weight: 800;
    display: block;
    margin-bottom: 10px;
  }

  .hero-price {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 10px;
  }

  .hero-price .highlight {
    color: #d14d3a;
    font-size: 2.4rem;
    text-decoration: underline;
    text-underline-offset: 8px;
  }

  .hero-limit {
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 40px;
  }

  .hero-btns {
    display: flex;
    justify-content: center;
    gap: 20px;
  }

  /* Plan Cards */
  .plan-section { padding: 100px 0; }

  .plan-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
    margin-top: 60px;
  }

  .plan-card {
    background: white;
    padding: 40px 30px;
    border-radius: 20px;
    border: 1px solid var(--line);
    transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .plan-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 50px rgba(197, 160, 89, 0.15);
  }

  .plan-card.featured {
    border: 3px solid var(--gold);
    background: #fffefb;
  }

  .p-featured-badge {
    position: absolute;
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: white;
    padding: 5px 20px;
    border-radius: 50px;
    font-weight: 800;
    font-size: 0.9rem;
  }

  .p-tag {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--gold);
    background: rgba(197, 160, 89, 0.1);
    padding: 4px 12px;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 10px;
  }

  .p-price {
    margin: 24px 0;
    display: flex;
    flex-direction: column;
  }

  .p-old {
    font-size: 1rem;
    color: var(--muted);
    text-decoration: line-through;
  }

  .p-new {
    font-size: 2.5rem;
    font-weight: 800;
    color: #d14d3a;
  }

  .p-new small { font-size: 1rem; }

  .p-features {
    list-style: none;
    padding: 0;
    margin: 0 0 40px;
    flex: 1;
  }

  .p-features li {
    padding: 12px 0;
    border-bottom: 1px solid #f0f0f0;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .p-features li::before { content: '✓'; color: var(--gold); font-weight: 800; }
  .p-features li.plus { color: var(--gold); font-weight: 700; background: #fff9f0; padding: 12px; border-radius: 8px; border-bottom: none; }
  .p-features li.plus::before { content: '🎁'; }

  /* Buttons */
  .btn-primary-gold {
    background: var(--gold);
    color: white;
    padding: 18px 36px;
    border-radius: 50px;
    font-weight: 800;
    transition: 0.3s;
    text-decoration: none;
  }

  .btn-primary-gold:hover {
    background: var(--gold-dark);
    transform: scale(1.05);
  }

  .btn-secondary-white {
    background: white;
    color: var(--gold);
    border: 2px solid var(--gold);
    padding: 16px 36px;
    border-radius: 50px;
    font-weight: 800;
    transition: 0.3s;
    text-decoration: none;
  }

  .btn-outline {
    border: 2px solid var(--gold);
    color: var(--gold);
    text-align: center;
    padding: 14px;
    border-radius: 50px;
    font-weight: 800;
    text-decoration: none;
    transition: 0.3s;
  }

  .btn-outline:hover { background: var(--gold); color: white; }

  /* Showcase */
  .option-showcase { background: #1a1a1a; color: white; padding: 120px 0; }
  
  .showcase-box {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 60px;
    border-radius: 40px;
    backdrop-filter: blur(10px);
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 40px;
    margin-top: 60px;
  }

  .s-item h4 { color: var(--gold-light); font-size: 1.2rem; margin-bottom: 12px; border-bottom: 1px solid var(--gold); padding-bottom: 8px; display: inline-block; }
  .s-item p { font-size: 0.9rem; opacity: 0.8; line-height: 1.6; }

  /* CTA */
  .campaign-cta {
    padding: 120px 0;
    text-align: center;
    background: var(--gold);
    color: white;
  }

  .btn-main {
    display: inline-block;
    background: white;
    color: var(--gold);
    padding: 24px 60px;
    border-radius: 100px;
    font-size: 1.4rem;
    font-weight: 900;
    text-decoration: none;
    box-shadow: 0 15px 40px rgba(0,0,0,0.1);
    transition: 0.3s;
    margin-top: 40px;
  }

  .btn-main:hover { transform: translateY(-5px); box-shadow: 0 20px 60px rgba(0,0,0,0.2); }
  .cta-note { margin-top: 20px; font-size: 0.9rem; opacity: 0.9; }

  @media (max-width: 768px) {
    .hero-btns { flex-direction: column; padding: 0 40px; }
    .showcase-box { padding: 40px 20px; }
  }
</style>
