---
import BaseLayout from '../layouts/BaseLayout.astro';

const CAMPAIGN_END_DATE = "2026年7月31日";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "起業記念20%OFFキャンペーン | 和-Node",
  "description": `心理学・ICT・AIを統合したWeb制作「和-Node」の起業記念キャンペーン。全メニュー20%OFF。${CAMPAIGN_END_DATE}まで。`,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "和-Node", "item": "https://www.wa-node.com/" },
      { "@type": "ListItem", "position": 2, "name": "起業記念キャンペーン" }
    ]
  }
};
---

<BaseLayout 
  title="【20%OFF】起業記念キャンペーン｜心理学・ICT・AIWeb制作｜和-Node" 
  description="心理学×Web制作、ICT活用、AI導入を対象にした和-Node起業記念キャンペーン。全メニュー20%OFFで、月3名様まで丁寧に伴走します。"
>
  <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap" rel="stylesheet">
  
  <div class="campaign-page">
    <div class="sakura-container" id="sakura-container"></div>
    
    <section class="hero-campaign-premium">
      <div class="hero-key-visual">
        <img src="/images/campaign-key-visual.png" alt="" class="parallax-bg" />
        <div class="hero-overlay"></div>
      </div>
      <div class="container">
        <div class="hero-content-wrap">
          <div class="anniversary-badge-large reveal">
            <span class="badge-text">1st ANNIVERSARY</span>
            <span class="badge-sub">Startup Campaign</span>
          </div>
          <h1 class="reveal premium-heading">
            <span class="eyebrow-red">起業記念・限定特別オファー</span>
            <br/>ビジネスを整える、<br/>和の叡智と最先端の技術.
          </h1>
          <p class="hero-lead"><strong>「想い」と「技術」を、もっとも優しい形で結ぶ。</strong></p>
          <div class="hero-price-box reveal">
            <p class="price-label">ALL PRODUCTION & OPTIONS</p>
            <p class="price-value">20% <span class="unit">OFF</span></p>
          </div>
          <div class="hero-btns reveal">
            <a href="#plans" class="btn-primary-gold">限定プランを詳しく見る</a>
            <a href="/contact/" class="btn-secondary-white">無料で相談する</a>
          </div>
        </div>
      </div>
    </section>

    <section class="campaign-conditions-banner">
      <div class="container">
        <div class="conditions-grid reveal">
          <div class="cond-item">
            <span class="label">お申込期限</span>
            <span class="value">{CAMPAIGN_END_DATE}まで</span>
          </div>
          <div class="cond-item">
            <span class="label">限定枠</span>
            <span class="value">月3名様まで丁寧に対応</span>
          </div>
          <div class="cond-item">
            <span class="label">対象外条件</span>
            <span class="value">公序良俗に反するサイト、アダルト、投資・ギャンブル系、その他不適切と判断される場合</span>
          </div>
        </div>
      </div>
    </section>

    <section class="value-section">
      <div class="container">
        <div class="section-title reveal">
          <span class="eyebrow">Why Wa-Node?</span>
          <h2>和-Nodeが選ばれる3つの理由</h2>
        </div>
        <div class="value-grid">
          <div class="value-card reveal">
            <div class="v-icon">🧠</div>
            <h3>心理学の導線</h3>
            <p>「安心」を設計し、離脱を防ぐ。</p>
          </div>
          <div class="value-card reveal">
            <div class="v-icon">⚡</div>
            <h3>自動化の技術</h3>
            <p>AIとICTで、あなたの時間を創る。</p>
          </div>
          <div class="value-card reveal">
            <div class="v-icon">♿</div>
            <h3>当事者の視点</h3>
            <p>心理的不親切も見逃さない設計。</p>
          </div>
        </div>
      </div>
    </section>

    <section class="plan-section" id="plans">
      <div class="container">
        <div class="section-title reveal">
          <span class="eyebrow">Special Plans</span>
          <h2>キャンペーン限定・3つの提案</h2>
          <p class="section-desc">※すべての価格は税込表記です。</p>
        </div>
        <div class="plan-grid">
          <div class="plan-card featured reveal">
            <div class="p-featured-badge">主軸プラン</div>
            <div class="p-header"><h3>心理導線LP制作案</h3></div>
            <p class="p-target">「まずはWeb・LPの反応を整えたい」方に</p>
            <div class="p-price"><span class="p-old">66,000円</span><span class="p-new">52,800<small>円</small></span></div>
            <a href="/anniversary-speed/" class="btn-primary-gold">プラン詳細を見る</a>
          </div>
          <div class="plan-card reveal">
            <div class="p-header"><h3>ICT・自動化フル強化案</h3></div>
            <p class="p-target">「問い合わせ対応や業務導線も整えたい」方に</p>
            <div class="p-price"><span class="p-old">165,000円</span><span class="p-new">132,000<small>円</small></span></div>
            <a href="/anniversary-automation/" class="btn-outline">プラン詳細を見る</a>
          </div>
          <div class="plan-card reveal">
            <div class="p-header"><h3>ビジネスの副操縦士（継続改善案）</h3></div>
            <p class="p-target">「Web改善・AI活用を継続して整えたい」方に</p>
            <div class="p-price"><span class="p-old">275,000円</span><span class="p-new">220,000<small>円</small></span></div>
            <a href="/anniversary-premium/" class="btn-outline">プラン詳細を見る</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="comparison-section">
      <div class="container">
        <div class="section-title reveal">
          <span class="eyebrow">Comparison</span>
          <h2>プラン比較表</h2>
        </div>
        <div class="table-scroll reveal">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>機能・サービス</th>
                <th>Plan A (速戦)</th>
                <th>Plan B (自動化)</th>
                <th>Plan C (特注)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>心理導線設計</td><td>○</td><td>○</td><td>◎</td></tr>
              <tr><td>LINE連携</td><td>オプション</td><td>○</td><td>○</td></tr>
              <tr><td>AI返信支援</td><td>-</td><td>○</td><td>◎</td></tr>
              <tr><td>オリジナル図解制作</td><td>-</td><td>3点まで</td><td>無制限</td></tr>
              <tr><td>継続コンサルティング</td><td>-</td><td>-</td><td>3ヶ月間</td></tr>
              <tr><td>心理背景をふまえた相談設計</td><td>-</td><td>-</td><td>○</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <div class="section-title reveal">
          <span class="eyebrow">FAQ</span>
          <h2>よくあるご質問</h2>
        </div>
        <div class="faq-accordion reveal">
          <div class="faq-item">
            <button class="faq-question">追加料金が発生することはありますか？ <span class="icon"></span></button>
            <div class="faq-answer">
              <p>各プランの範囲内であれば追加料金は一切かかりません。大幅な仕様変更や特殊な機能追加をご希望の場合のみ、事前にご相談の上お見積りいたします。</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question">制作期間はどのくらいですか？ <span class="icon"></span></button>
            <div class="faq-answer">
              <p>Plan Aは最短2週間、Plan B・Cは1ヶ月〜1.5ヶ月程度が目安です。お客様の素材準備状況により前後いたします。</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question">ITに詳しくなくても大丈夫ですか？ <span class="icon"></span></button>
            <div class="faq-answer">
              <p>もちろんです。「難しいことを難しくなく」お伝えするのが和-Nodeの役割です。操作方法から運用のコツまで、丁寧にお伝えします。</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question">月額費用などはかかりますか？ <span class="icon"></span></button>
            <div class="faq-answer">
              <p>Web維持に必要な実費（月額1,000円程度）以外、和-Nodeへの継続的なお支払いは発生いたしません（Plan Cの支援期間終了後）。</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="campaign-cta">
      <div class="container reveal">
        <h2>今の不安を、未来の安心に変える。</h2>
        <a href="/contact/" class="btn-main">キャンペーン価格で相談する</a>
      </div>
    </section>
  </div>

  <script is:inline>
    function initCampaign() {
      const container = document.getElementById('sakura-container');
      if (container) {
        container.innerHTML = '';
        for (let i = 0; i < 60; i++) {
          const petal = document.createElement('div');
          petal.className = 'petal';
          petal.style.left = Math.random() * 100 + '%';
          petal.style.width = Math.random() * 10 + 5 + 'px';
          petal.style.height = petal.style.width;
          petal.style.animationDuration = Math.random() * 5 + 5 + 's';
          petal.style.animationDelay = Math.random() * 5 + 's';
          container.appendChild(petal);
        }
      }

      // FAQ Accordion Logic
      const faqQuestions = document.querySelectorAll('.faq-question');
      faqQuestions.forEach(q => {
        q.addEventListener('click', () => {
          const item = q.parentElement;
          const isActive = item.classList.contains('active');
          
          // Close all others
          document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
          
          if (!isActive) {
            item.classList.add('active');
          }
        });
      });

      const bg = document.querySelector('.parallax-bg');
      window.addEventListener('scroll', () => {
        if (bg) bg.style.transform = `translateY(${window.pageYOffset * 0.4}px)`;
      });
    }
    initCampaign();
    document.addEventListener('astro:page-load', initCampaign);
  </script>
</BaseLayout>

<style is:global>
  :root {
    --gold: #c5a059;
    --gold-light: #e2c891;
    --campaign-bg: #fdfcf9;
    --text-deep: #2c2c2c;
    --sakura: #ffb7c5;
    --border-soft: rgba(197, 160, 89, 0.2);
  }
  body {
    background: #fdfcf9 !important;
  }
  body::before {
    content: "" !important;
    position: fixed !important;
    top: 0; left: 0; width: 100%; height: 100%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3FfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3F/filter%3E%3Frect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3F/svg%3E") !important;
    opacity: 0.15 !important;
    pointer-events: none !important;
    z-index: 9999 !important;
  }
  .campaign-page {
    background: transparent !important;
    color: var(--text-deep) !important;
    overflow-x: hidden;
    position: relative;
    font-family: 'Shippori Mincho', serif !important;
  }
  .sakura-container {
    position: fixed !important;
    top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none !important;
    z-index: 9998 !important;
  }
  .petal {
    position: absolute !important;
    background: var(--sakura) !important;
    border-radius: 150% 0 150% 0 !important;
    opacity: 0.9 !important;
    box-shadow: 0 0 5px white;
    animation: fall linear infinite;
  }
  @keyframes fall {
    0% { transform: translateY(-10vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.9; }
    90% { opacity: 0.9; }
    100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
  }
  .hero-campaign-premium {
    position: relative;
    height: 100vh; min-height: 800px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; color: white !important; text-align: center;
    background: black;
  }
  .hero-key-visual { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
  .parallax-bg { width: 100%; height: 130%; object-fit: cover; }
  .hero-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: radial-gradient(circle, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.8) 100%) !important;
    z-index: 2;
  }
  .hero-content-wrap { position: relative; z-index: 3; max-width: 1000px; padding: 20px; }
  .premium-heading { font-size: clamp(2rem, 5vw, 3.5rem) !important; line-height: 1.2 !important; text-shadow: 0 5px 20px rgba(0,0,0,0.8) !important; font-weight: 800 !important; }
  .eyebrow-red { color: #ff4d4d !important; font-size: 1.3rem !important; font-weight: 800 !important; display: block; margin-bottom: 15px; }
  .hero-price-box {
    margin: 40px auto; padding: 30px 60px;
    background: rgba(255,255,255,0.15) !important; backdrop-filter: blur(15px) !important;
    border: 1px solid rgba(255,255,255,0.3) !important; border-radius: 20px;
  }
  .price-value { font-size: 6rem !important; font-weight: 900 !important; color: var(--gold-light) !important; text-shadow: 0 0 20px rgba(197,160,89,0.5); }

  .campaign-conditions-banner {
    background: white; padding: 40px 0;
    border-bottom: 1px solid var(--border-soft);
  }
  .conditions-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
  }
  .cond-item { border-left: 3px solid var(--gold); padding-left: 20px; }
  .cond-item .label { display: block; font-size: 0.9rem; color: #666; margin-bottom: 5px; }
  .cond-item .value { display: block; font-size: 1.1rem; font-weight: 800; color: var(--text-deep); }

  .plan-card {
    background: white !important; padding: 40px; border-radius: 24px; border: 1px solid #eee;
    transition: 0.4s; display: flex; flex-direction: column; position: relative;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }
  .plan-card:hover {
    transform: translateY(-15px) !important;
    box-shadow: 0 30px 60px rgba(197, 160, 89, 0.3), inset 0 0 30px rgba(197, 160, 89, 0.2) !important;
    border-color: var(--gold) !important;
  }
  .p-target {
    font-size: 0.9rem;
    color: var(--gold);
    font-weight: 700;
    margin: 10px 0 20px;
    line-height: 1.5;
  }
  .plan-card.featured { border: 4px solid var(--gold) !important; animation: pulse-glow 3s infinite !important; }
  
  .comparison-section { padding: 100px 0; background: #fff; }
  .table-scroll { overflow-x: auto; margin-top: 40px; }
  .comparison-table {
    width: 100%; border-collapse: collapse; min-width: 600px;
    background: white; border-radius: 15px; overflow: hidden;
  }
  .comparison-table th, .comparison-table td {
    padding: 25px; border: 1px solid #f0f0f0; text-align: center;
  }
  .comparison-table th { background: #f9f6f0; font-weight: 800; color: var(--gold); }
  .comparison-table td:first-child { text-align: left; font-weight: 700; background: #fdfcf9; }

  .faq-section { padding: 100px 0; }
  .faq-accordion {
    max-width: 800px;
    margin: 40px auto 0;
  }
  .faq-item {
    background: white;
    border: 1px solid #eee;
    border-radius: 12px;
    margin-bottom: 15px;
    overflow: hidden;
    transition: 0.3s;
  }
  .faq-question {
    width: 100%;
    padding: 20px 30px;
    background: none;
    border: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text-deep);
    cursor: pointer;
    text-align: left;
  }
  .faq-question .icon::before {
    content: "+";
    font-size: 1.5rem;
    color: var(--gold);
  }
  .faq-item.active .faq-question .icon::before {
    content: "−";
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
    background: #fdfcf9;
  }
  .faq-item.active .faq-answer {
    max-height: 200px;
  }
  .faq-answer p {
    padding: 0 30px 25px;
    line-height: 1.8;
    font-size: 0.95rem;
    margin: 0;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(197, 160, 89, 0.2); }
    50% { box-shadow: 0 0 50px rgba(197, 160, 89, 0.5); }
  }
  .btn-primary-gold { background: var(--gold) !important; color: white !important; padding: 18px 40px; border-radius: 50px; text-decoration: none; font-weight: 900; display: inline-block; transition: 0.3s; }
  .btn-primary-gold:hover { transform: scale(1.05); filter: brightness(1.1); }
  .btn-outline { border: 2.5px solid var(--gold) !important; color: var(--gold) !important; padding: 15px; border-radius: 50px; text-decoration: none; text-align: center; font-weight: 800; transition: 0.3s; }
  .btn-outline:hover { background: var(--gold); color: white !important; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
  .section-title { text-align: center; margin-bottom: 60px; }
  .section-title h2 { font-size: 2.5rem; margin-top: 10px; }
  .section-desc { color: #666; margin-top: 10px; }
  .reveal { opacity: 1 !important; visibility: visible !important; }

  @media (max-width: 768px) {
    .faq-grid { grid-template-columns: 1fr; }
    .price-value { font-size: 4rem !important; }
  }
</style>
