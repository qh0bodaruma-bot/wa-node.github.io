---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LabPreview from '../../../components/LabPreview.astro';
import MaterialIcon from '../../../components/MaterialIcon.astro';
import { serviceLabTopics } from '../../../data/labCases';
import {
  createBreadcrumbSchema,
  createWebPageSchema,
  organizationSchema,
} from '../../../data/structuredData';

const title = '相談型サービスLPの改善事例｜Web改善ラボ｜和-Node';
const description = '相談型サービスLPのHero・料金・FAQ・CTAを題材に、確認した事実、読み手の迷い、変更内容、検証方法をBefore・Afterで比較します。';
const image = '/images/ogp-lab.png';
const structuredData = [
  organizationSchema,
  createWebPageSchema({ name: title, description, path: '/lab/cases/service-lp/', type: 'Article' }),
  createBreadcrumbSchema([
    { name: 'ホーム', path: '/' },
    { name: 'Web改善ラボ', path: '/lab/' },
    { name: '相談型サービスLP', path: '/lab/cases/service-lp/' },
  ]),
];
---

<BaseLayout title={title} description={description} image={image} structuredData={structuredData}>
  <main class="case-page" data-glossary-skip>
    <section class="case-hero">
      <div class="container">
        <a class="case-back" href="/lab/"><MaterialIcon name="arrow_back" /> Web改善ラボ</a>
        <div class="case-hero__heading">
          <div>
            <p class="case-kicker">CASE 01 / 相談型サービスLP</p>
            <h1>初見の不安を、<br />判断材料へ変える。</h1>
          </div>
          <p>変えたのは、派手さではありません。対象・料金・FAQ・CTAに残っていた説明不足を、読み手が自分で判断できる情報へ置き換えました。</p>
        </div>
      </div>
    </section>

    <section class="case-workspace" aria-labelledby="workspace-title">
      <div class="container">
        <div class="case-workspace__head">
          <div>
            <p class="case-kicker">INTERACTIVE REVIEW</p>
            <h2 id="workspace-title">どこを変えると、何が変わるのか。</h2>
          </div>
          <p>架空の相談サービスを題材に、ページ内の事実と改善仮説を分けて示します。</p>
        </div>

        <div class="case-topic-tabs" role="tablist" aria-label="改善テーマ">
          {serviceLabTopics.map((topic, index) => (
            <button
              type="button"
              role="tab"
              id={`topic-tab-${topic.id}`}
              aria-controls={`topic-panel-${topic.id}`}
              aria-selected={index === 0 ? 'true' : 'false'}
              tabindex={index === 0 ? '0' : '-1'}
              data-topic={topic.id}
            >
              <span>0{index + 1}</span>{topic.label}
            </button>
          ))}
        </div>

        <div class="case-mode-toggle" aria-label="表示する状態">
          <button type="button" class="is-active" aria-pressed="true" data-mode="before">Before</button>
          <button type="button" aria-pressed="false" data-mode="after">After</button>
        </div>

        <div class="case-topic-panels" data-mobile-mode="before">
          {serviceLabTopics.map((topic, index) => (
            <section
              class="case-topic-panel"
              id={`topic-panel-${topic.id}`}
              role="tabpanel"
              aria-labelledby={`topic-tab-${topic.id}`}
              data-panel={topic.id}
              hidden={index !== 0}
            >
              <div class="case-topic-panel__title">
                <span>{topic.label}</span>
                <h3>{topic.title}</h3>
              </div>

              <div class="case-comparison">
                <div class="case-preview case-preview--before" data-preview="before">
                  <div class="case-preview__label"><span>Before</span><small>変更前</small></div>
                  <LabPreview mode="before" topic={topic} />
                </div>

                <div class="case-preview case-preview--after" data-preview="after">
                  <div class="case-preview__label"><span>After</span><small>変更案</small></div>
                  <LabPreview mode="after" topic={topic} />
                </div>
              </div>

              <dl class="case-reasoning">
                <div>
                  <dt><span>01</span>確認できた事実</dt>
                  <dd>{topic.fact}</dd>
                </div>
                <div>
                  <dt><span>02</span>読み手が迷うという仮説</dt>
                  <dd>{topic.hypothesis}</dd>
                </div>
                <div>
                  <dt><span>03</span>最初に試す変更</dt>
                  <dd>{topic.change}</dd>
                </div>
                <div>
                  <dt><span>04</span>変更後に確認する方法</dt>
                  <dd>{topic.verify}</dd>
                </div>
              </dl>
            </section>
          ))}
        </div>
      </div>
    </section>

    <section class="case-small-change">
      <div class="container case-small-change__grid">
        <div>
          <p class="case-kicker">SMALL DIFFERENCE</p>
          <h2>この修正で得られた変化は、<br />これだけだと感じましたか？</h2>
        </div>
        <div class="case-small-change__copy">
          <p>たかがこれだけ、と見えるかもしれません。けれど、初めて来た読み手には商品への愛着がまだなく、説明不足を好意的に補ってくれる理由もありません。</p>
          <p>小さな迷いは、そのまま離れる理由になりえます。ブランドを守るには、強い言葉で一度だけ動かすことより、判断を妨げる小さな要因を一つずつ減らす姿勢が欠かせません。</p>
        </div>
      </div>
    </section>

    <section class="case-evidence" aria-labelledby="evidence-title">
      <div class="container">
        <div class="case-evidence__head">
          <div>
            <p class="case-kicker">EVIDENCE & LIMITS</p>
            <h2 id="evidence-title">根拠は、言える範囲まで。</h2>
          </div>
          <p>ガイドラインやユーザー調査の考え方は改善仮説を支えますが、この架空ページのCVR向上を証明するものではありません。</p>
        </div>

        <div class="case-evidence__grid">
          <article>
            <span>01</span>
            <h3>利用者のニーズから始める</h3>
            <p>作り手の都合ではなく、利用者が達成したいことと、その途中で困ることを起点にします。</p>
            <a href="https://www.gov.uk/service-manual/user-research/start-by-learning-user-needs" target="_blank" rel="noreferrer">GOV.UK Service Manual <MaterialIcon name="open_in_new" /></a>
          </article>
          <article>
            <span>02</span>
            <h3>入力前に必要な情報を示す</h3>
            <p>フォームのラベルや説明を整え、読み手が入力内容と次の行動を予測できる状態を目指します。</p>
            <a href="https://www.w3.org/WAI/tutorials/forms/instructions/" target="_blank" rel="noreferrer">W3C WAI Forms Tutorial <MaterialIcon name="open_in_new" /></a>
          </article>
          <article>
            <span>03</span>
            <h3>公開後も利用者から学ぶ</h3>
            <p>変更案を完成形と決めつけず、数字と相談内容を見ながら次の仮説へつなげます。</p>
            <a href="https://www.gov.uk/service-manual/user-research/how-user-research-improves-service-design" target="_blank" rel="noreferrer">GOV.UK User Research <MaterialIcon name="open_in_new" /></a>
          </article>
        </div>
      </div>
    </section>

    <section class="case-verification" aria-labelledby="verification-title">
      <div class="container case-verification__grid">
        <div>
          <p class="case-kicker">NEXT CHECK</p>
          <h2 id="verification-title">公開後に、何を確かめるか。</h2>
        </div>
        <ol>
          <li><span>1</span><div><strong>行動</strong><p>CTA到達、クリック、フォーム完了のどこで止まるか。</p></div></li>
          <li><span>2</span><div><strong>理解</strong><p>対象者・支援内容・料金範囲を、読み手が説明できるか。</p></div></li>
          <li><span>3</span><div><strong>相談内容</strong><p>質問の重複や認識違いが減り、具体性が増えたか。</p></div></li>
          <li><span>4</span><div><strong>信頼</strong><p>強い訴求で急がせず、納得して進めたという反応があるか。</p></div></li>
        </ol>
      </div>
    </section>

    <section class="case-footer">
      <div class="container case-footer__inner">
        <div>
          <p class="case-kicker">WEB IMPROVEMENT LAB</p>
          <h2>次の事例も、判断過程から公開します。</h2>
        </div>
        <a class="case-button" href="/lab/">事例一覧へ戻る <MaterialIcon name="arrow_forward" /></a>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  function initServiceLab() {
    const panelsRoot = document.querySelector<HTMLElement>('.case-topic-panels');
    if (!panelsRoot || panelsRoot.dataset.initialized === 'true') return;
    panelsRoot.dataset.initialized = 'true';

    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-topic]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-panel]'));
    const modeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-mode]'));

    function selectTopic(topicId: string, focus = false) {
      tabs.forEach((tab) => {
        const active = tab.dataset.topic === topicId;
        tab.setAttribute('aria-selected', String(active));
        tab.tabIndex = active ? 0 : -1;
        if (active && focus) tab.focus();
      });
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.panel !== topicId;
      });
    }

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => selectTopic(tab.dataset.topic ?? 'hero'));
      tab.addEventListener('keydown', (event) => {
        if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;
        event.preventDefault();
        let nextIndex = index;
        if (event.key === 'ArrowLeft') nextIndex = (index - 1 + tabs.length) % tabs.length;
        if (event.key === 'ArrowRight') nextIndex = (index + 1) % tabs.length;
        if (event.key === 'Home') nextIndex = 0;
        if (event.key === 'End') nextIndex = tabs.length - 1;
        selectTopic(tabs[nextIndex].dataset.topic ?? 'hero', true);
      });
    });

    modeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const mode = button.dataset.mode ?? 'before';
        panelsRoot.dataset.mobileMode = mode;
        modeButtons.forEach((item) => {
          const active = item === button;
          item.classList.toggle('is-active', active);
          item.setAttribute('aria-pressed', String(active));
        });
      });
    });
  }

  initServiceLab();
  document.addEventListener('astro:page-load', initServiceLab);
</script>

<style>
  :global(body) {
    background: #fff;
  }

  .case-page {
    --lab-ink: #132622;
    --lab-muted: #586964;
    --lab-line: #cdd8d4;
    --lab-green: #0f4c5c;
    --lab-red: #c7352f;
    --lab-gold: #bf921f;
    overflow: hidden;
    background: #fff;
    color: var(--lab-ink);
  }

  .case-page :global(.container) {
    width: min(1240px, calc(100% - 48px));
    margin: 0 auto;
  }

  .case-kicker {
    margin: 0 0 16px;
    color: var(--lab-green);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0;
  }

  .case-back {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 52px;
    color: var(--lab-muted);
    font-size: 0.85rem;
    font-weight: 800;
    text-decoration: none;
  }

  .case-back:hover {
    color: var(--lab-green);
  }

  .case-back :global(.material-symbols-rounded) {
    font-size: 1.1rem;
  }

  .case-hero {
    padding: 54px 0 80px;
    border-bottom: 1px solid var(--lab-line);
  }

  .case-hero__heading {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.6fr);
    gap: 80px;
    align-items: end;
  }

  .case-hero h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(3.4rem, 7vw, 6.8rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .case-hero__heading > p {
    max-width: 430px;
    margin: 0 0 8px;
    color: var(--lab-muted);
    font-size: 1rem;
    line-height: 2;
  }

  .case-workspace {
    padding: 88px 0 110px;
  }

  .case-workspace__head,
  .case-evidence__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.52fr);
    gap: 64px;
    align-items: end;
    margin-bottom: 44px;
  }

  .case-workspace__head h2,
  .case-evidence__head h2,
  .case-small-change h2,
  .case-verification h2,
  .case-footer h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 1.25;
    letter-spacing: 0;
  }

  .case-workspace__head > p,
  .case-evidence__head > p {
    margin: 0;
    color: var(--lab-muted);
    line-height: 1.9;
  }

  .case-topic-tabs {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--lab-line);
    border-bottom: 1px solid var(--lab-line);
  }

  .case-topic-tabs button {
    display: flex;
    min-height: 70px;
    gap: 14px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-right: 1px solid var(--lab-line);
    background: #fff;
    color: var(--lab-muted);
    font: inherit;
    font-size: 1rem;
    font-weight: 900;
    cursor: pointer;
  }

  .case-topic-tabs button:last-child {
    border-right: 0;
  }

  .case-topic-tabs button span {
    font-size: 0.68rem;
    font-weight: 900;
  }

  .case-topic-tabs button[aria-selected='true'] {
    background: var(--lab-green);
    color: #fff;
  }

  .case-topic-tabs button:focus-visible,
  .case-mode-toggle button:focus-visible {
    outline: 3px solid var(--lab-gold);
    outline-offset: -3px;
  }

  .case-mode-toggle {
    display: none;
  }

  .case-topic-panel {
    padding-top: 52px;
  }

  .case-topic-panel__title {
    display: grid;
    grid-template-columns: 80px minmax(0, 1fr);
    gap: 24px;
    align-items: start;
    margin-bottom: 32px;
  }

  .case-topic-panel__title > span {
    padding-top: 9px;
    color: var(--lab-red);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .case-topic-panel__title h3 {
    max-width: 850px;
    margin: 0;
    font-size: clamp(1.6rem, 3vw, 2.45rem);
    line-height: 1.45;
    letter-spacing: 0;
  }

  .case-comparison {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 26px;
  }

  .case-preview {
    min-width: 0;
  }

  .case-preview__label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .case-preview__label span {
    font-size: 1.05rem;
    font-weight: 900;
  }

  .case-preview--before .case-preview__label span {
    color: #6e7d78;
  }

  .case-preview--after .case-preview__label span {
    color: var(--lab-green);
  }

  .case-preview__label small {
    color: var(--lab-muted);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .case-reasoning {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: 42px 0 0;
    border-top: 1px solid var(--lab-line);
    border-left: 1px solid var(--lab-line);
  }

  .case-reasoning > div {
    min-height: 180px;
    padding: 28px;
    border-right: 1px solid var(--lab-line);
    border-bottom: 1px solid var(--lab-line);
  }

  .case-reasoning dt {
    display: flex;
    gap: 12px;
    align-items: baseline;
    margin-bottom: 16px;
    color: var(--lab-green);
    font-size: 0.9rem;
    font-weight: 900;
  }

  .case-reasoning dt span {
    color: var(--lab-red);
    font-size: 0.66rem;
  }

  .case-reasoning dd {
    margin: 0;
    color: #42534e;
    line-height: 1.85;
  }

  .case-small-change {
    padding: 110px 0;
    background: #0f4c5c;
    color: #fff;
  }

  .case-small-change .case-kicker {
    color: #f2c452;
  }

  .case-small-change__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.8fr);
    gap: 80px;
    align-items: start;
  }

  .case-small-change__copy p {
    margin: 0 0 24px;
    color: rgba(255, 255, 255, 0.86);
    font-size: 1.03rem;
    line-height: 2;
  }

  .case-evidence {
    padding: 110px 0;
    border-bottom: 1px solid var(--lab-line);
  }

  .case-evidence__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--lab-line);
    border-left: 1px solid var(--lab-line);
  }

  .case-evidence article {
    min-height: 300px;
    padding: 32px;
    border-right: 1px solid var(--lab-line);
    border-bottom: 1px solid var(--lab-line);
  }

  .case-evidence article > span {
    color: var(--lab-red);
    font-size: 0.7rem;
    font-weight: 900;
  }

  .case-evidence h3 {
    margin: 26px 0 15px;
    font-size: 1.25rem;
    line-height: 1.5;
    letter-spacing: 0;
  }

  .case-evidence article p {
    margin: 0 0 24px;
    color: var(--lab-muted);
    line-height: 1.85;
  }

  .case-evidence article a {
    display: inline-flex;
    gap: 7px;
    align-items: center;
    color: var(--lab-green);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .case-evidence article a :global(.material-symbols-rounded) {
    font-size: 1rem;
  }

  .case-verification {
    padding: 110px 0;
  }

  .case-verification__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.65fr) minmax(340px, 1fr);
    gap: 90px;
  }

  .case-verification ol {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--lab-line);
  }

  .case-verification li {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    gap: 18px;
    padding: 25px 0;
    border-bottom: 1px solid var(--lab-line);
  }

  .case-verification li > span {
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border: 1px solid var(--lab-green);
    color: var(--lab-green);
    font-size: 0.72rem;
    font-weight: 900;
  }

  .case-verification strong {
    display: block;
    margin-bottom: 5px;
  }

  .case-verification li p {
    margin: 0;
    color: var(--lab-muted);
    line-height: 1.75;
  }

  .case-footer {
    padding: 72px 0;
    border-top: 1px solid var(--lab-line);
    background: #f5f8f7;
  }

  .case-footer__inner {
    display: flex;
    gap: 40px;
    align-items: center;
    justify-content: space-between;
  }

  .case-footer h2 {
    font-size: clamp(1.6rem, 3vw, 2.6rem);
  }

  .case-button {
    display: inline-flex;
    min-height: 52px;
    flex: 0 0 auto;
    gap: 12px;
    align-items: center;
    justify-content: center;
    padding: 12px 20px;
    border: 1px solid var(--lab-green);
    border-radius: 3px;
    background: var(--lab-green);
    color: #fff;
    font-weight: 900;
    text-decoration: none;
  }

  .case-button:hover {
    background: #0b3d49;
  }

  @media (max-width: 900px) {
    .case-hero__heading,
    .case-workspace__head,
    .case-evidence__head,
    .case-small-change__grid,
    .case-verification__grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .case-comparison {
      grid-template-columns: 1fr;
    }

    .case-mode-toggle {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: 22px;
      border: 1px solid var(--lab-line);
    }

    .case-mode-toggle button {
      min-height: 48px;
      border: 0;
      background: #fff;
      color: var(--lab-muted);
      font: inherit;
      font-weight: 900;
    }

    .case-mode-toggle button + button {
      border-left: 1px solid var(--lab-line);
    }

    .case-mode-toggle button.is-active {
      background: var(--lab-green);
      color: #fff;
    }

    .case-topic-panels[data-mobile-mode='before'] [data-preview='after'],
    .case-topic-panels[data-mobile-mode='after'] [data-preview='before'] {
      display: none;
    }

    .case-evidence__grid {
      grid-template-columns: 1fr;
    }

    .case-evidence article {
      min-height: auto;
    }
  }

  @media (max-width: 640px) {
    .case-page :global(.container) {
      width: min(100% - 28px, 1240px);
    }

    .case-hero {
      padding: 28px 0 56px;
    }

    .case-back {
      margin-bottom: 34px;
    }

    .case-hero h1 {
      font-size: 2.65rem;
    }

    .case-workspace,
    .case-evidence,
    .case-verification,
    .case-small-change {
      padding: 72px 0;
    }

    .case-topic-tabs {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .case-topic-tabs button {
      min-height: 56px;
      border-bottom: 1px solid var(--lab-line);
    }

    .case-topic-tabs button:nth-child(2) {
      border-right: 0;
    }

    .case-topic-tabs button:nth-child(n + 3) {
      border-bottom: 0;
    }

    .case-topic-panel {
      padding-top: 36px;
    }

    .case-topic-panel__title {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .case-topic-panel__title > span {
      padding: 0;
    }

