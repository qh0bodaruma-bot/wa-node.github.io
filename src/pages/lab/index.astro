---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LabPreview from '../../components/LabPreview.astro';
import MaterialIcon from '../../components/MaterialIcon.astro';
import { labCases, serviceLabTopics } from '../../data/labCases';
import {
  createBreadcrumbSchema,
  createWebPageSchema,
  organizationSchema,
} from '../../data/structuredData';

const title = 'Web改善ラボ｜Before・Afterと改善根拠を公開｜和-Node';
const description = 'HP・LPのBeforeとAfterだけでなく、確認した事実、読み手の迷い、修正理由、検証方法まで公開する和-NodeのWeb改善ポートフォリオです。';
const image = '/images/ogp-lab.png';
const firstTopic = serviceLabTopics[0];
const structuredData = [
  organizationSchema,
  createWebPageSchema({ name: title, description, path: '/lab/', type: 'CollectionPage' }),
  createBreadcrumbSchema([
    { name: 'ホーム', path: '/' },
    { name: 'Web改善ラボ', path: '/lab/' },
  ]),
];

const steps = [
  ['観察', 'ページにある事実を集める'],
  ['理由', 'なぜ迷う可能性があるか考える'],
  ['仮説', 'どの判断を助けるか決める'],
  ['修正', 'コピー・配置・導線へ落とす'],
  ['検証', '結果を確かめ、次へ活かす'],
];
---

<BaseLayout title={title} description={description} image={image} structuredData={structuredData}>
  <main class="lab-page" data-glossary-skip>
    <section class="lab-hero">
      <div class="container">
        <div class="lab-hero__top">
          <div class="lab-hero__copy">
            <h1>小さな迷いを、<br />改善の根拠に変える。</h1>
            <p>BeforeとAfterだけでなく、何を見て、なぜ変え、どう確かめるかまで公開します。</p>
          </div>
          <div class="lab-hero__actions">
            <a class="lab-button" href="/lab/cases/service-lp/">
              最初の事例を見る
              <MaterialIcon name="arrow_forward" />
            </a>
            <a class="lab-text-link" href="#approach">
              改善の見方を確認
              <MaterialIcon name="south" />
            </a>
          </div>
        </div>

        <div class="lab-hero__workspace" aria-label="相談型サービスLPの改善例">
          <div class="lab-hero__pane">
            <span class="lab-hero__pane-label">Before</span>
            <LabPreview mode="before" topic={firstTopic} />
          </div>

          <div class="lab-hero__reason">
            <h2>改善の理由</h2>
            <ol>
              <li>
                <span>1</span>
                <div><strong>価値が伝わりにくい見出し</strong><p>対象者と支援内容が見えず、自分向けか判断できません。</p></div>
              </li>
              <li>
                <span>2</span>
                <div><strong>次の行動が予測できない</strong><p>押した先や相談後の流れが分からず、行動が重くなります。</p></div>
              </li>
              <li>
                <span>3</span>
                <div><strong>強みが比較材料になっていない</strong><p>抽象語を、選ぶための条件へ翻訳します。</p></div>
              </li>
            </ol>
            <a href="/lab/cases/service-lp/">理由と仮説をすべて見る <MaterialIcon name="arrow_forward" /></a>
          </div>

          <div class="lab-hero__pane">
            <span class="lab-hero__pane-label">After</span>
            <LabPreview mode="after" topic={firstTopic} />
          </div>
        </div>

        <ol class="lab-progress" id="approach" aria-label="Web改善ラボの進め方">
          {steps.map(([name, detail], index) => (
            <li class={index === 0 ? 'active' : ''}>
              <span>{index + 1}</span>
              <strong>{name}</strong>
              <small>{detail}</small>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="lab-cases section" aria-labelledby="lab-cases-title">
      <div class="container">
        <div class="lab-section-head">
          <div>
            <h2 id="lab-cases-title">改善事例</h2>
            <p>架空または掲載許可を得た題材を使い、成果を保証せず、判断過程と確かめ方を示します。</p>
          </div>
          <a href="/works/">制作例・デモも見る <MaterialIcon name="arrow_forward" /></a>
        </div>

        <div class="lab-case-list">
          {labCases.map((item, index) => (
            <article class:list={['lab-case-row', index === 0 && 'is-live']}>
              <div class="lab-case-row__number">0{index + 1}</div>
              <div class="lab-case-row__copy">
                <div class="lab-case-row__meta">
                  <span>{item.status}</span>
                  <ul aria-label="扱うテーマ">
                    {item.topics.map((topic) => <li>{topic}</li>)}
                  </ul>
                </div>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
              </div>
              {index === 0 ? (
                <a href="/lab/cases/service-lp/" aria-label={`${item.title}の事例を見る`}>
                  <MaterialIcon name="arrow_forward" />
                </a>
              ) : (
                <span class="lab-case-row__pending">順次公開</span>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="lab-small-difference section" aria-labelledby="small-difference-title">
      <div class="container">
        <div class="lab-small-difference__grid">
          <div>
            <h2 id="small-difference-title">「変わったのは、これだけ？」<br />そう見える修正も扱います。</h2>
          </div>
          <div>
            <p>初めてページへ来た読み手には、まだ商品やブランドへの愛着も、十分な信頼も育っていません。</p>
            <p>既存のお客様なら補って読んでくれる小さな説明不足も、初見の人には読み進めない理由になりえます。ブランドを守るとは、信頼を削る小さな要因を放置しないことでもあります。</p>
          </div>
        </div>
        <div class="lab-difference-flow" aria-label="小さな改善が信頼につながる流れ">
          <span>迷いを一つ減らす</span><MaterialIcon name="arrow_forward" />
          <span>自分で判断できる</span><MaterialIcon name="arrow_forward" />
          <span>押しつけられない</span><MaterialIcon name="arrow_forward" />
          <strong>信頼を削らない</strong>
        </div>
      </div>
    </section>

    <section class="lab-policy section" aria-labelledby="lab-policy-title">
      <div class="container lab-policy__grid">
        <div class="lab-policy__intro">
          <h2 id="lab-policy-title">改善案と、確認できた成果を分けます。</h2>
          <p>見た目が整ったことを、CVR向上の証明とは扱いません。根拠の種類と適用範囲を明記し、公開後に確認する方法まで残します。</p>
        </div>
        <dl>
          <div><dt>Fact</dt><dd>画面・計測・利用者から確認できた事実</dd></div>
          <div><dt>Hypothesis</dt><dd>読み手が迷う可能性についての仮説</dd></div>
          <div><dt>Evidence</dt><dd>研究・ガイドライン・実務知見の区別</dd></div>
          <div><dt>Verification</dt><dd>変更後に見る数字・質問・問い合わせ内容</dd></div>
        </dl>
      </div>
    </section>

    <section class="lab-final section">
      <div class="container lab-final__inner">
        <div>
          <h2>最初の事例を、実際に切り替えてみる。</h2>
          <p>Hero・料金・FAQ・CTAを選ぶと、Before／Afterと判断メモが連動して変わります。</p>
        </div>
        <a class="lab-button" href="/lab/cases/service-lp/">
          相談型サービスLPを見る
          <MaterialIcon name="arrow_forward" />
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .lab-page {
    --lab-ink: #132622;
    --lab-green: #0f4c5c;
    --lab-teal: #1f6f78;
    --lab-red: #c7352f;
    --lab-gold: #a47b23;
    --lab-line: #cbd8d3;
    background: #fff;
    color: var(--lab-ink);
  }

  .lab-hero {
    padding: 68px 0 0;
    border-bottom: 1px solid var(--lab-line);
  }

  .lab-hero__top {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(300px, 0.5fr);
    gap: 56px;
    align-items: end;
    margin-bottom: 46px;
  }

  .lab-hero h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(2.25rem, 5vw, 4.4rem);
    line-height: 1.18;
    letter-spacing: 0;
  }

  .lab-hero__copy > p {
    max-width: 760px;
    margin: 20px 0 0;
    color: #455752;
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    line-height: 1.85;
  }

  .lab-hero__actions {
    display: grid;
    gap: 18px;
  }

  .lab-button {
    display: inline-flex;
    min-height: 54px;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 14px 22px;
    border-radius: 4px;
    background: var(--lab-red);
    color: #fff;
    font-weight: 800;
    line-height: 1.5;
    box-shadow: 0 12px 24px rgba(199, 53, 47, 0.18);
  }

  .lab-button:hover {
    background: #b62f29;
    color: #fff;
    opacity: 1;
    transform: translateY(-2px);
  }

  .lab-text-link,
  .lab-section-head > a {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid var(--lab-green);
    color: var(--lab-green);
    font-weight: 800;
  }

  .lab-hero__workspace {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(230px, 0.48fr) minmax(0, 1fr);
    gap: 22px;
    align-items: start;
  }

  .lab-hero__pane {
    min-width: 0;
  }

  .lab-hero__pane-label {
    display: block;
    margin-bottom: 10px;
    color: var(--lab-green);
    font-size: 1.02rem;
    font-weight: 800;
    text-align: center;
  }

  .lab-hero__reason {
    padding-top: 34px;
  }

  .lab-hero__reason h2 {
    margin: 0 0 20px;
    font-size: 1rem;
    text-align: center;
  }

  .lab-hero__reason ol {
    display: grid;
    gap: 18px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .lab-hero__reason li {
    display: grid;
    grid-template-columns: 30px 1fr;
    gap: 10px;
  }

  .lab-hero__reason li > span {
    display: grid;
    width: 30px;
    height: 30px;
    place-items: center;
    border-radius: 50%;
    background: var(--lab-green);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 800;
  }

  .lab-hero__reason strong,
  .lab-hero__reason p {
    display: block;
    margin: 0;
    font-size: 0.76rem;
    line-height: 1.65;
  }

  .lab-hero__reason p {
    margin-top: 4px;
    color: #5b6a66;
  }

  .lab-hero__reason > a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 22px 0 0 40px;
    color: var(--lab-gold);
    font-size: 0.75rem;
    font-weight: 800;
  }

  .lab-progress {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    margin: 36px 0 0;
    padding: 0 0 30px;
    list-style: none;
  }

  .lab-progress li {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 4px;
    color: #7a8783;
    text-align: center;
  }

  .lab-progress li::before {
    content: '';
    position: absolute;
    top: 14px;
    right: 50%;
    left: -50%;
    height: 1px;
    background: var(--lab-line);
    z-index: 0;
  }

  .lab-progress li:first-child::before {
    display: none;
  }

  .lab-progress span {
    position: relative;
    z-index: 1;
    display: grid;
    width: 28px;
    height: 28px;
    place-items: center;
    border-radius: 50%;
    background: #a7b0ad;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
  }

  .lab-progress .active span {
    background: var(--lab-green);
  }

  .lab-progress strong {
    color: var(--lab-ink);
    font-size: 0.82rem;
  }

  .lab-progress small {
    max-width: 150px;
    font-size: 0.67rem;
    line-height: 1.45;
  }

  .lab-section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 30px;
    margin-bottom: 32px;
  }

  .lab-section-head h2,
  .lab-small-difference h2,
  .lab-policy h2,
  .lab-final h2 {
    margin: 0;
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    line-height: 1.35;
    letter-spacing: 0;
  }

  .lab-section-head p,
  .lab-policy p,
  .lab-final p {
    max-width: 720px;
    margin: 12px 0 0;
    color: #53635e;
  }

  .lab-case-list {
    border-top: 1px solid var(--lab-line);
  }

  .lab-case-row {
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr) 72px;
    gap: 22px;
    align-items: center;
    padding: 28px 0;
    border-bottom: 1px solid var(--lab-line);
  }

  .lab-case-row__number {
    color: var(--lab-gold);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .lab-case-row__meta {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .lab-case-row__meta > span {
    color: var(--lab-green);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .lab-case-row__meta ul {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .lab-case-row__meta li {
    color: #71807b;
    font-size: 0.68rem;
  }

  .lab-case-row h3 {
    margin: 8px 0 4px;
    font-size: 1.32rem;
  }

  .lab-case-row p {
    margin: 0;
    color: #55645f;
    font-size: 0.9rem;
  }

  .lab-case-row > a {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border: 1px solid var(--lab-green);
    border-radius: 50%;
    color: var(--lab-green);
  }

  .lab-case-row > a:hover {
    background: var(--lab-green);
    color: #fff;
    opacity: 1;
  }

  .lab-case-row__pending {
    color: #89938f;
    font-size: 0.72rem;
    text-align: right;
  }

  .lab-small-difference {
    border-block: 1px solid var(--lab-line);
    background: #f4f8f6;
  }

  .lab-small-difference__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 72px;
  }

  .lab-small-difference__grid p {
    margin: 0 0 16px;
    color: #3f514b;
    font-size: 1rem;
    line-height: 1.95;
  }

  .lab-difference-flow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-top: 38px;
    padding-top: 26px;
    border-top: 1px solid var(--lab-line);
    color: var(--lab-green);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .lab-difference-flow strong {
    color: var(--lab-red);
  }

  .lab-policy__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 72px;
    align-items: start;
  }

  .lab-policy dl {
    margin: 0;
    border-top: 1px solid var(--lab-line);
  }

  .lab-policy dl > div {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 20px;
    padding: 18px 0;
    border-bottom: 1px solid var(--lab-line);
  }

  .lab-policy dt {
    color: var(--lab-gold);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .lab-policy dd {
    margin: 0;
    color: #41534d;
  }

  .lab-final {
    background: var(--lab-green);
    color: #fff;
  }

  .lab-final__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .lab-final p {
    color: rgba(255,255,255,0.78);
  }

  .lab-final .lab-button {
    min-width: 290px;
    flex-shrink: 0;
  }

  @media (max-width: 1020px) {
    .lab-hero__workspace {
      grid-template-columns: 1fr 1fr;
    }

    .lab-hero__reason {
      grid-column: 1 / -1;
      grid-row: 2;
      padding: 0;
    }

    .lab-hero__reason ol {
      grid-template-columns: repeat(3, 1fr);
    }

    .lab-hero__reason > a {
      margin-left: 0;
    }
  }

  @media (max-width: 760px) {
    .lab-hero {
      padding-top: 42px;
    }

    .lab-hero__top,
    .lab-small-difference__grid,
    .lab-policy__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .lab-hero h1 {
      font-size: clamp(2rem, 11vw, 3.1rem);
    }

    .lab-hero__workspace {
      grid-template-columns: 1fr;
    }

    .lab-hero__pane:first-child {
      display: none;
    }

    .lab-hero__reason {
      grid-column: auto;
      grid-row: auto;
    }

    .lab-hero__reason ol {
      grid-template-columns: 1fr;
    }

    .lab-progress {
      grid-template-columns: 1fr;
      gap: 14px;
      margin-top: 26px;
    }

    .lab-progress li {
      grid-template-columns: 30px 70px 1fr;
      justify-items: start;
      align-items: center;
      text-align: left;
    }

    .lab-progress li::before {
      display: none;
    }

    .lab-progress small {
      max-width: none;
    }

    .lab-section-head,
    .lab-final__inner {
      align-items: flex-start;
      flex-direction: column;
    }

    .lab-case-row {
      grid-template-columns: 42px minmax(0, 1fr);
      gap: 12px;
    }

    .lab-case-row > a,
    .lab-case-row__pending {
      grid-column: 2;
    }

    .lab-case-row__meta {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
    }

    .lab-difference-flow {
      align-items: flex-start;
      flex-direction: column;
    }

    .lab-difference-flow :global(.material-symbols-rounded) {
      transform: rotate(90deg);
    }

    .lab-policy dl > div {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .lab-final .lab-button {
      width: 100%;
      min-width: 0;
    }
  }
</style>
