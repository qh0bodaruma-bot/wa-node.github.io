---
import BaseLayout from '../layouts/BaseLayout.astro';
import AvailabilityStatus from '../components/AvailabilityStatus.astro';
---

<BaseLayout title="お問い合わせ・無料相談｜和-Node" description="心理導線Web制作、AI活用、カウンセリングに関するお問い合わせ・無料相談はこちらから。お客様の課題に寄り添い、最適な解決策をご提案します。">
  <main class="contact-page">
    <header class="contact-header">
      <div class="container">
        <!-- Anniversary Mini Banner -->
        <div class="contact-ann-notice reveal">
          <span class="badge">1st ANNIVERSARY</span>
          <p>起業記念キャンペーン実施中：制作メニュー <strong>20% OFF</strong></p>
        </div>

        <span class="eyebrow">Contact</span>
        <h1 class="premium-heading">心と技術を、<br/><span class="accent-text">結ぶ窓口。</span></h1>
        <p class="lead">あなたの想いを、形にする第一歩。<br/>今の状況を、そのままお聞かせください。</p>
      </div>
    </header>

    <div class="container">
      <div class="contact-grid">
        <!-- Info Column -->
        <aside class="contact-info">
          <div class="info-card">
            <h3 class="premium-heading">ご相談の前に</h3>
            <p>和-Nodeでは、単なる制作作業ではなく、お客様の「想い」と「ビジネスの成果」を繋ぐことを大切にしています。</p>
            <ul class="benefit-list">
              <li><span>初回最大60分の無料相談（特典利用時）</span></li>
              <li><span>心理学的知見に基づくお悩み整理</span></li>
              <li><span>今なら制作メニュー 20% OFF 適用可</span></li>
            </ul>
          </div>
          <!-- ... availability and line cards ... -->

          <AvailabilityStatus />

          <div class="line-card">
            <h3>LINEでのご相談</h3>
            <p>「まずはチャットで軽く聞きたい」という方は、公式LINEもご利用いただけます。</p>
            <a href="https://lin.ee/o5QFPwc" target="_blank" rel="noopener" class="line-btn shine-effect">
              <img src="https://vignette.wikia.nocookie.net/line/images/b/bb/Line_logo.png/revision/latest?cb=20150524021545" alt="LINE" class="line-icon" style="filter: brightness(0) invert(1); width: 24px; height: 24px;" />
              LINEで相談する
            </a>
          </div>
        </aside>

        <!-- Form Column -->
        <section class="form-section">
          <div class="glass-panel">
            <div class="form-intro" style="margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid var(--line);">
              <p style="font-weight: 800; color: var(--accent); margin-bottom: 8px;">今の状況を、そのまま教えてください。</p>
              <p class="small" style="color: var(--muted); line-height: 1.6;">「まだ何も決まっていない」という状態でも大丈夫です。あなたのペースで、一つずつ言葉にすることから始めましょう。</p>
            </div>
            <form action="https://formspree.io/f/xojrldrq" method="POST" class="contact-form" autocomplete="off">
              <input type="hidden" name="_next" value="https://wa-node.com/thanks" />
              <div class="form-group">
                <label for="name">お名前 <span class="required">必須</span></label>
                <input type="text" id="name" name="name" required placeholder="和 太郎" />
              </div>

              <div class="form-group">
                <label for="email">メールアドレス <span class="required">必須</span></label>
                <input type="email" id="email" name="email" required placeholder="example@wa-node.com" />
              </div>

              <div class="form-group">
                <label for="category">ご相談内容 <span class="required">必須</span></label>
                <select id="category" name="category" required>
                  <option value="" disabled selected>選択してください</option>
                  <option value="web">Webサイト・LP制作</option>
                  <option value="line">LINE Mini App制作・LINE導線相談</option>
                  <option value="ai">AI活用・業務効率化</option>
                  <option value="counseling">カウンセリング・メンタル支援</option>
                  <option value="corporate">法人向けメンタル窓口</option>
                  <option value="other">その他のお問い合わせ</option>
                </select>
              </div>

              <div class="form-group">
                <label for="message">メッセージ内容 <span class="required">必須</span></label>
                <textarea id="message" name="message" rows="6" required placeholder="ご相談内容や現状の課題など、どのようなことでもお気軽にご記入ください。&#13;&#10;具体的な希望日時がございましたら「第一希望：○月○日 10:00〜」のようにお書き添えいただけますと幸いです。内容を確認の上、日程の調整について改めてご連絡させていただきます。"></textarea>
              </div>

              <div class="form-consent">
                <p class="privacy-note">
                  送信前に、<a href="/terms" target="_blank">利用規約</a>、<a href="/privacy" target="_blank">プライバシーポリシー</a>、および<a href="/counseling-notes" target="_blank">カウンセリング注意事項</a>をご確認ください。<br />
                  <span style="font-size: 0.8rem; opacity: 0.8;">※送信された内容はサーバーには保存されず、メール転送後、速やかに破棄されます。</span>
                </p>
                <label class="checkbox-label">
                  <input type="checkbox" required />
                  <span>各規約および注意事項に同意します</span>
                </label>
              </div>

              <button type="submit" class="submit-btn">
                <span>この内容で送信する</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
              </button>
            </form>
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

  :root {
    --accent: #c5a059;
    --accent-dark: #b18e4a;
    --accent-red: #d14d3a;
    --line: rgba(197, 160, 89, 0.2);
  }

  .premium-heading {
    font-family: 'Shippori Mincho', serif !important;
    font-weight: 800 !important;
    letter-spacing: 0.05em;
  }

  .contact-page {
    padding-bottom: 120px;
    background: #fdfcf9;
    font-family: 'Shippori Mincho', serif !important;
  }
  .contact-page::before {
    content: ""; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3FfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3F/filter%3E%3Frect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3F/svg%3E");
    opacity: 0.03; pointer-events: none; z-index: -1;
  }

  .contact-header { padding: 80px 0 60px; text-align: center; }
  
  /* Anniversary Mini Banner */
  .contact-ann-notice {
    display: inline-flex; align-items: center; gap: 12px;
    background: #fff; border: 1px solid var(--accent-red);
    padding: 8px 20px; border-radius: 50px; margin-bottom: 30px;
    box-shadow: 0 10px 20px rgba(209, 77, 58, 0.05);
  }
  .contact-ann-notice .badge {
    background: var(--accent-red); color: #fff; font-size: 0.65rem; font-weight: 800;
    padding: 2px 10px; border-radius: 4px;
  }
  .contact-ann-notice p { font-size: 0.85rem; color: #2c2c2c; margin: 0; }
  .contact-ann-notice strong { color: var(--accent-red); }

  .eyebrow { font-size: 0.85rem; font-weight: 800; color: var(--accent); letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 16px; display: block; }
  .contact-header h1 { font-size: clamp(2.2rem, 6vw, 3.6rem); font-weight: 800; line-height: 1.2; margin-bottom: 24px; }
  .accent-text { color: var(--accent-red); }
  .lead { font-size: 1.1rem; color: #555; line-height: 1.8; }

  .contact-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 60px; margin-top: 40px; }

  /* Info Column */
  .info-card, .line-card { background: #fff; border: 1px solid var(--line); border-radius: 32px; padding: 40px; margin-bottom: 30px; }
  .info-card h3, .line-card h3 { font-size: 1.4rem; margin-bottom: 20px; color: #2c2c2c; }
  
  .benefit-list { list-style: none; padding: 0; }
  .benefit-list li { position: relative; padding-left: 28px; margin-bottom: 16px; font-weight: 700; font-size: 0.95rem; }
  .benefit-list li::before { content: "✓"; position: absolute; left: 0; color: var(--accent-red); font-weight: 900; }

  .line-btn {
    display: flex; align-items: center; justify-content: center; gap: 12px;
    background: #06C755; color: #fff; text-decoration: none; padding: 18px; border-radius: 999px;
    font-weight: 800; transition: 0.3s;
  }
  .line-btn:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(6, 199, 85, 0.2); }

  /* Form Column */
  .glass-panel { background: #fff; border: 1px solid var(--line); border-radius: 40px; padding: 50px; box-shadow: 0 20px 50px rgba(0,0,0,0.02); }
  .form-group { margin-bottom: 30px; }
  .form-group label { display: block; font-weight: 800; font-size: 0.9rem; margin-bottom: 10px; color: #2c2c2c; }
  .required { color: var(--accent-red); font-size: 0.7rem; margin-left: 5px; }
  
  input, select, textarea {
    width: 100%; padding: 16px 20px; border-radius: 12px; border: 1px solid var(--line);
    background: #fdfcf9; font-size: 1rem; font-family: inherit; transition: 0.3s;
  }
  input:focus, select:focus, textarea:focus { outline: none; border-color: var(--accent-red); background: #fff; }

  .submit-btn {
    width: 100%; padding: 22px; border-radius: 999px; border: none;
    background: var(--accent-dark); color: #fff; font-size: 1.1rem; font-weight: 800;
    cursor: pointer; transition: 0.4s; display: flex; align-items: center; justify-content: center; gap: 12px;
  }
  .submit-btn:hover { background: #2c2c2c; transform: translateY(-3px); }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .glass-panel { padding: 30px 20px; }
  }
</style>
