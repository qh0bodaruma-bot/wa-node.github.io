---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactFormContent from '../components/ContactFormContent.astro';
import {
  createBreadcrumbSchema,
  createWebPageSchema,
  organizationSchema,
} from '../data/structuredData';

const title = "お問い合わせ・無料相談｜和-Node";
const description = "行動心理に基づくWeb制作、ホームページ・LP制作、AI・ICT活用に関するお問い合わせ・無料相談はこちらから。課題整理から最適な進め方をご提案します。";
const structuredData = [
  organizationSchema,
  createWebPageSchema({ name: title, description, path: "/contact/", type: "ContactPage" }),
  createBreadcrumbSchema([
    { name: "ホーム", path: "/" },
    { name: "お問い合わせ・無料相談", path: "/contact/" },
  ]),
];
---
<BaseLayout lang="ja" title={title} description={description} structuredData={structuredData}>
  <ContactFormContent lang="ja" />
</BaseLayout>
