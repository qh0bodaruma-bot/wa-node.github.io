---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="KDP Publishing Portfolio | Wa-Node" description="Amazon Kindle Self-Publishing (KDP) portfolio by Hirozumi Takano. Featuring traditional Japanese visual coloring books like Ukiyo-e and Choju-giga designed for global readers." lang="en">
  <!-- Decorative background for the whole page -->
  <div class="kdp-bg-overlay"></div>

  <main>
    <div class="kdp-header">
      <div class="container fade-in">
        <span class="eyebrow">Design Strategy & Publishing</span>
        <h1 class="kdp-title">KDP Publishing Portfolio</h1>
        <p class="kdp-desc">
          Bringing traditional Japanese aesthetic beauty (Ukiyo-e and Choju-giga) to global readers via Amazon Kindle (KDP).<br />
          Designing high-conversion book covers and calming reading experiences tailored for international markets.
        </p>
      </div>
    </div>

    <!-- Why Coloring? Art Therapy Section -->
    <section class="kdp-concept-section reveal">
      <div class="section-container">
        <div class="concept-grid">
          <div class="concept-text">
            <span class="concept-badge float-animation">Why Coloring?</span>
            <h2>Why Coloring Books?</h2>
            <p class="concept-lead">
              Coloring is globally recognized as a form of "Art Therapy" that extends far beyond a simple creative hobby.
            </p>
            <div class="benefit-cards">
              <div class="benefit-card">
                <span class="icon">🧘</span>
                <h4>Mindfulness & Stress Relief</h4>
                <p>Immersing yourself in choosing and applying colors induces a meditative state, focusing the brain on "the here and now" and helping soothe daily anxieties.</p>
              </div>
              <div class="benefit-card">
                <span class="icon">🧠</span>
                <h4>Right-Brain Activation & Catharsis</h4>
                <p>Expressing unspoken emotions through colors releases built-up mental stress and fosters creative cognitive clarity.</p>
              </div>
            </div>
            <p class="concept-final">
              As a practicing psychological counselor, I design these coloring books hoping that people worldwide can experience effortless mindfulness through traditional Japanese art, reclaiming their inner peace.
            </p>
          </div>
          <div class="concept-visual">
            <img src="/images/art-therapy.png" alt="Traditional Japanese Art & Art Therapy" class="concept-img" />
            <div class="visual-accent"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 1: 江戸の旅シリーズ (Traditional premium) -->
    <section class="kdp-section premium-dark">
      <div class="section-container">
        <span class="badge float-animation">Edo Series</span>
        <h2 class="section-title">Edo Journey Series</h2>
        <p class="section-concept">
          Calming coloring books for adults, featuring traditional Ukiyo-e woodblock styles and Choju-giga scrolls.
        </p>
        <div class="book-showcase">
          {/* Item 1 */}
          <div class="book-item reveal" data-concept="A high-trust contrast of deep indigo and soft beige, projecting elegance and calm.">
            <div class="book-3d-wrap">
              <div class="book-3d">
                <div class="book-cover"><img src="/images/KDP/江戸旅行記/江戸旅行記vol.01 ラグドール.png" alt="Edo Journey: Ragdoll" /></div>
                <div class="book-spine"></div>
              </div>
            </div>
            <div class="book-meta">
              <h3 class="title">Edo Journey: Ragdoll</h3>
              <p class="price">$12.99 / €12.99</p>
              <div class="links">
                <a href="https://www.amazon.com/dp/B0GWDRMFHJ" target="_blank" class="store-link us">🇺🇸 Amazon US</a>
                <a href="https://www.amazon.fr/dp/B0GWDP7P5G" target="_blank" class="store-link fr">🇫🇷 Amazon FR</a>
