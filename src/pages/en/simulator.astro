---
import BaseLayout from '../../layouts/BaseLayout.astro';
const CAMPAIGN_END_DATE = "July 31, 2026";
---

<BaseLayout title="Web Design & Development Pricing Simulator | Wa-Node" description="Calculate the estimated cost and delivery time for your psychology-driven landing pages or website in real-time. Our special launch discount (20% OFF) is automatically applied.">
  <!-- Background Decoration -->
  <div class="bg-decoration">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="grid-overlay"></div>
  </div>

  <div class="demo-banner">
    <strong class="banner-title">【Demo Sample】</strong> You can integrate interactive tools like this pricing calculator into your own website. <a href="/en/contact" class="banner-cta">Contact Us Today</a>
  </div>

  <main class="sim-container">
    <header class="sim-header fade-in">
      <span class="eyebrow">Interactive Pricing</span>
      <h1 class="sim-title">Pricing Simulator</h1>
      <p class="sim-desc">
        Combine different plans and options to estimate your project budget and timeframe.<br />
        <span class="campaign-text">We are currently automatically applying our <strong>Special 20% Launch Discount!</strong></span><br />
        <span style="font-size: 0.85rem; opacity: 0.8;">*Limited to 3 clients per month / Offer ends {CAMPAIGN_END_DATE} / Excludes ongoing support, monthly agreements, and third-party expenses.</span>
      </p>
    </header>

    <div class="sim-grid">
      <!-- Left: Form Section -->
      <div class="sim-form">
        
        <section class="sim-section glass-card">
          <div class="sec-head">
            <span class="sec-num">01</span>
            <h2>Select Production Plan</h2>
          </div>
          <div class="choices-grid">
            <label class="choice-card">
              <input type="radio" name="type" value="30000" data-days="2" data-label="Simple LP" />
              <div class="card-inner">
                <div class="icon-wrap" style="height: 80px; margin-bottom: 15px; border-radius: 12px; overflow: hidden;">
                  <img src="/portfolio-lp/images/hero_event.png" alt="Simple LP" style="width: 100%; height: 100%; object-fit: cover;" />
                </div>
                <div class="info">
                  <b>Simple LP</b>
                  <span>Single-page basic landing page</span>
                </div>
                <div class="price">¥30,000〜</div>
              </div>
            </label>
            <label class="choice-card selected">
              <input type="radio" name="type" value="50000" data-days="3" data-label="Simple HP" checked />
              <div class="card-inner">
                <div class="icon-wrap" style="height: 80px; margin-bottom: 15px; border-radius: 12px; overflow: hidden;">
                  <img src="/portfolio-lp/images/hero_corporate.png" alt="Simple HP" style="width: 100%; height: 100%; object-fit: cover;" />
                </div>
                <div class="info">
                  <b>Simple HP</b>
                  <span>Standard multi-page business website</span>
                </div>
                <div class="price">¥50,000〜</div>
              </div>
            </label>
            <label class="choice-card">
              <input type="radio" name="type" value="60000" data-days="5" data-label="Psychological LP" />
              <div class="card-inner">
                <div class="icon-wrap" style="height: 80px; margin-bottom: 15px; border-radius: 12px; overflow: hidden;">
                  <img src="/portfolio-lp/images/hero_clinic.png" alt="Psychology LP" style="width: 100%; height: 100%; object-fit: cover;" />
                </div>
                <div class="info">
                  <b>Psychological LP</b>
                  <span>Funnel architecture optimized for maximum conversion</span>
                </div>
                <div class="price">¥60,000〜</div>
              </div>
            </label>
            <label class="choice-card">
              <input type="radio" name="type" value="120000" data-days="8" data-label="Psychological HP" />
              <div class="card-inner">
                <div class="icon-wrap" style="height: 80px; margin-bottom: 15px; border-radius: 12px; overflow: hidden;">
                  <img src="/portfolio-lp/images/hero_beauty.png" alt="Psychology HP" style="width: 100%; height: 100%; object-fit: cover;" />
                </div>
                <div class="info">
                  <b>Psychological HP</b>
                  <span>Trust-building multi-page business site</span>
                </div>
                <div class="price">¥120,000〜</div>
              </div>
            </label>
          </div>
        </section>

        <section class="sim-section glass-card">
          <div class="sec-head">
            <span class="sec-num">02</span>
            <h2>Page Scale Adjustment</h2>
          </div>
          <div class="choices-grid">
            <label class="choice-card selected">
              <input type="radio" name="pages" value="0" data-days="0" data-label="1 Page" checked />
              <div class="card-inner">
                <div class="icon">1️⃣</div>
                <div class="info"><b>1 Page</b><span>LPs, one-pagers</span></div>
                <div class="price">+¥0</div>
              </div>
            </label>
            <label class="choice-card">
              <input type="radio" name="pages" value="30000" data-days="3" data-label="2–5 Pages" />
              <div class="card-inner">
                <div class="icon">🔢</div>
                <div class="info"><b>2–5 Pages</b><span>Standard scale</span></div>
                <div class="price">+¥30,000</div>
              </div>
            </label>
            <label class="choice-card">
              <input type="radio" name="pages" value="80000" data-days="6" data-label="6+ Pages" />
              <div class="card-inner">
                <div class="icon">📑</div>
                <div class="info"><b>6+ Pages</b><span>Large-scale structure</span></div>
                <div class="price">+¥80,000</div>
              </div>
            </label>
          </div>
        </section>

        <section class="sim-section glass-card">
          <div class="sec-head">
            <span class="sec-num">03</span>
            <h2>Optional Features</h2>
          </div>
          <div class="choices-grid">
            <label class="choice-card">
              <input type="checkbox" name="feature" value="10000" data-days="1" data-label="Contact Form" />
              <div class="card-inner">
                <div class="icon">✉️</div>
                <div class="info"><b>Contact Form Setup</b></div>
                <div class="price">+¥10,000</div>
              </div>
            </label>
            <label class="choice-card">
              <input type="checkbox" name="feature" value="30000" data-days="3" data-label="Blog/CMS Feature" />
              <div class="card-inner">
                <div class="icon">📝</div>
                <div class="info"><b>Blog/CMS Integration</b></div>
                <div class="price">+¥30,000</div>
              </div>
            </label>
            <label class="choice-card">
              <input type="checkbox" name="feature" value="30000" data-days="3" data-label="Booking Integration" />
              <div class="card-inner">
                <div class="icon">📅</div>
                <div class="info"><b>Booking System Link</b></div>
                <div class="price">+¥30,000</div>
              </div>
            </label>
            <label class="choice-card">
              <input type="checkbox" name="feature" value="10000" data-days="1" data-label="Domain Setup Support" />
              <div class="card-inner">
                <div class="icon">🛠</div>
                <div class="info"><b>Domain Setup Assistance</b></div>
                <div class="price">+¥10,000</div>
              </div>
            </label>
            <label class="choice-card rush-card">
              <input type="checkbox" id="rushCheck" name="rush" value="1.5" data-days="-2" data-label="Rush Delivery" />
              <div class="card-inner">
                <div class="icon">🚀</div>
                <div class="info">
                  <b>Rush Delivery</b>
                  <span>1.5x speed multiplier for urgent timelines</span>
                </div>
                <div class="price">1.5x</div>
              </div>
            </label>
          </div>
        </section>

      </div>

      <!-- Right: Summary Sidebar -->
      <aside class="sim-sidebar">
        <div class="result-card glass-card-dark">
          <div class="gauge-section">
            <svg class="price-gauge" viewBox="0 0 100 50">
              <path class="gauge-bg" d="M 10 45 A 40 40 0 0 1 90 45" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="6" />
              <path id="gauge-fill" class="gauge-fill" d="M 10 45 A 40 40 0 0 1 90 45" fill="none" stroke="#639922" stroke-width="6" stroke-dasharray="125.6" stroke-dashoffset="125.6" />
            </svg>
            <div class="price-display">
              <div class="price-val" id="totalPrice">¥0</div>
              <div class="price-label">ESTIMATED TOTAL</div>
            </div>
          </div>

          <div id="resultPlaceholder" style="padding: 20px 0; text-align: center; color: #aaa; font-size: 0.9rem; line-height: 1.6;">
            Select options to view<br/>estimated cost and delivery timeframe.
          </div>
          <div id="resultDetails" style="display: none;">
            <div class="delivery-info">
              <div class="info-item">
                <span class="lbl">Estimated Delivery</span>
                <span class="val" id="deliveryDays">Approx. 0 business days</span>
              </div>
              <div class="info-item campaign-row" id="campaignRow">
                <span class="lbl">🎁 20% Launch Discount</span>
                <span class="val" id="discountVal">-¥0</span>
              </div>
            </div>
          </div>

          <div class="receipt-breakdown">
            <h3>Estimate Breakdown</h3>
            <div id="breakdownList">
              <!-- Dynamic rows -->
            </div>
          </div>

          <div class="cta-actions">
            <a href="#consultation-flow" class="primary-btn">Review Consultation Steps</a>
            <a href="/en/works" class="text-btn">View Our Production Portfolio →</a>
          </div>
          
          <p class="disclaimer">
            *All prices on this website are estimated and tax inclusive. Pricing may vary depending on project complexity.<br />
            *For projects processed through Coconala, CrowdWorks, or Lancers, the prices and terms displayed on those platforms will take precedence.
          </p>
        </div>
      </aside>
    </div>

    <!-- Consultation Flow Section -->
    <section id="consultation-flow" class="wanode-cta-box glass-card" style="margin-top: 80px; scroll-margin-top: 40px; padding: 40px; background: rgba(255,255,255,0.8); border: 1px solid var(--sim-accent); border-radius: 32px;">
      <div class="bonus-tag" style="background: var(--sim-accent); color: #fff; padding: 6px 16px; border-radius: 999px; font-size: 0.8rem; font-weight: 900; margin-bottom: 20px; display: inline-block;">🎁 Simulator Special Bonus</div>
      <h3 style="font-size: 1.6rem; font-weight: 900; margin-bottom: 20px; color: var(--text);">Map Out Your Custom Solution Based on Your Estimate</h3>
      <p style="font-size: 1rem; color: #555; line-height: 1.8; margin-bottom: 30px;">
        Great job completing your simulation! Based on these results, we can organize your priorities and craft a highly precise roadmap for your business. We will upgrade your free consultation from 30 minutes to **60 minutes**.
      </p>

      <div style="background: rgba(255,255,255,0.6); border: 1px solid var(--sim-accent); border-radius: 20px; padding: 30px; margin-bottom: 30px; text-align: left;">
        <h4 style="margin-top: 0; color: var(--sim-accent); font-size: 1.1rem; border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 10px; margin-bottom: 15px;">Free Consultation Steps</h4>
        <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.95rem; color: #444;">
          <li style="margin-bottom: 12px; display: flex; align-items: flex-start; gap: 10px;">
            <span style="background: var(--sim-accent); color: #fff; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.75rem; font-weight: 800;">1</span>
            <span><strong>First 30 Mins (Free):</strong> Understanding your current business challenges and goals (For everyone).</span>
          </li>
          <li style="display: flex; align-items: flex-start; gap: 10px;">
            <span style="background: var(--sim-accent); color: #fff; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.75rem; font-weight: 800;">2</span>
            <span><strong>Bonus 30 Mins (Free):</strong> Tailored strategic roadmap advice based on your simulation (One-time offer).</span>
          </li>
        </ul>
      </div>

      <div class="cta-btns" style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
        <a href="/en/contact" class="primary-btn" style="text-decoration: none; width: fit-content; padding-left: 40px; padding-right: 40px;">Request 60-Min Consult with Bonus</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
    :root {
      --sim-accent: #639922;
      --sim-accent-dark: #4d7a1a;
      --sim-bg: #1a1c1e;
      --glass-light: rgba(255, 255, 255, 0.7);
      --glass-dark: rgba(26, 28, 30, 0.9);
    }

    /* Background Decoration */
    .bg-decoration {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      z-index: -1; background: #fdfaf7; overflow: hidden;
    }
    .grid-overlay {
      position: absolute; width: 100%; height: 100%;
      background-image: radial-gradient(rgba(0,0,0,0.04) 1px, transparent 1px);
      background-size: 30px 30px;
    }
    .glow { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.3; }
    .glow-1 { width: 500px; height: 500px; background: #e8f0e5; top: -10%; right: -10%; }
    .glow-2 { width: 400px; height: 400px; background: #f3e9d2; bottom: -10%; left: -10%; }

    .demo-banner { background: rgba(0,0,0,0.02); border-bottom: 1px solid var(--line); padding: 12px; text-align: center; font-size: 0.85rem; backdrop-filter: blur(5px); }
    .banner-cta { color: var(--sim-accent); font-weight: 800; text-decoration: underline; margin-left: 8px; }

    .sim-container { max-width: 1200px; margin: 40px auto 100px; padding: 0 20px; }
    
    .sim-header { text-align: center; margin-bottom: 60px; }
    .eyebrow { font-size: 0.8rem; font-weight: 900; color: var(--sim-accent); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 12px; display: block; }
    .sim-title { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; color: var(--text); margin-bottom: 20px; }
    .sim-desc { font-size: 1.1rem; color: var(--muted); line-height: 1.8; }
    .campaign-text { color: var(--sim-accent); font-weight: 800; }

    .sim-grid { display: grid; grid-template-columns: 1fr 400px; gap: 40px; align-items: start; }

    /* Form Section */
    .sim-form { display: flex; flex-direction: column; gap: 30px; }
    .glass-card { background: var(--glass-light); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.5); border-radius: 32px; padding: 40px; box-shadow: 0 20px 50px rgba(0,0,0,0.05); }

    .sec-head { display: flex; align-items: center; gap: 15px; margin-bottom: 30px; }
    .sec-num { font-size: 0.9rem; font-weight: 900; color: var(--sim-accent); background: rgba(99, 153, 34, 0.1); padding: 4px 12px; border-radius: 999px; }
    .sec-head h2 { font-size: 1.4rem; font-weight: 800; color: var(--text); }

    .choices-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 15px; }
    
    .choice-card { cursor: pointer; position: relative; }
    .choice-card input { position: absolute; opacity: 0; cursor: pointer; }
    
    .card-inner {
      padding: 24px; background: #fff; border: 2px solid transparent; border-radius: 20px;
      display: flex; flex-direction: column; height: 100%; transition: 0.3s;
      box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }
    .choice-card:hover .card-inner { border-color: rgba(99, 153, 34, 0.3); transform: translateY(-3px); }
    .choice-card.selected .card-inner { border-color: var(--sim-accent); background: #fdfaf7; box-shadow: 0 10px 30px rgba(99, 153, 34, 0.1); }

    .icon { font-size: 2rem; margin-bottom: 15px; }
    .info b { display: block; font-size: 1.05rem; font-weight: 800; margin-bottom: 4px; }
    .info span { font-size: 0.8rem; color: var(--muted); line-height: 1.4; display: block; margin-bottom: 15px; }
    .price { margin-top: auto; font-size: 0.95rem; font-weight: 900; color: var(--sim-accent); }

    .rush-card .price { color: #e74c3c; }

    /* Sidebar */
    .sim-sidebar { position: sticky; top: 100px; }
    .glass-card-dark { background: var(--sim-bg); color: #fff; border-radius: 32px; padding: 40px; box-shadow: 0 30px 70px rgba(0,0,0,0.2); }

    .gauge-section { position: relative; text-align: center; margin-bottom: 40px; }
    .price-gauge { width: 100%; height: auto; }
    .gauge-fill { transition: stroke-dashoffset 0.8s cubic-bezier(0.23, 1, 0.32, 1); }
    .price-display { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 100%; }
    .price-val { font-size: 2.8rem; font-weight: 900; line-height: 1; margin-bottom: 4px; color: #fff; }
    .price-label { font-size: 0.7rem; font-weight: 900; color: var(--sim-accent); letter-spacing: 0.1em; }

    .delivery-info { border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1); padding: 20px 0; margin-bottom: 30px; }
    .info-item { display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 0.9rem; }
    .info-item .lbl { color: #aaa; font-weight: 700; }
    .info-item .val { font-weight: 900; }
    .campaign-row { color: var(--sim-accent); }

    .receipt-breakdown h3 { font-size: 0.8rem; font-weight: 900; color: #555; text-transform: uppercase; margin-bottom: 15px; letter-spacing: 0.1em; }
    .breakdown-row { display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 8px; opacity: 0.8; }
    .breakdown-row .r-price { font-weight: 800; color: #fff; }

    .cta-actions { display: flex; flex-direction: column; gap: 15px; margin-top: 35px; }
    .primary-btn { display: block; width: 100%; padding: 18px; background: var(--sim-accent); color: #fff; border-radius: 999px; font-weight: 800; font-size: 1.1rem; text-align: center; border: none; cursor: pointer; transition: 0.3s; text-decoration: none; }
    .primary-btn:hover { background: var(--sim-accent-dark); transform: translateY(-2px); }
    .text-btn { font-size: 0.9rem; color: #aaa; text-align: center; text-decoration: none; font-weight: 700; transition: 0.3s; }
    .text-btn:hover { color: #fff; }

    .disclaimer { font-size: 0.75rem; color: #555; text-align: center; margin-top: 25px; line-height: 1.5; }

    @media (max-width: 960px) {
      .sim-grid { grid-template-columns: 1fr; }
      .sim-sidebar { position: static; }
      .sim-header { margin-bottom: 40px; }
    }
</style>

<script is:inline>
    const yen = (n) => '¥' + Math.round(n).toLocaleString('en-US');
    let currentTotal = 0;

    function update() {
      let subtotal = 0;
      let days = 0;
      let rows = [];

      // Plan
      const type = document.querySelector('input[name="type"]:checked');
      if (type) {
        const v = parseInt(type.value);
        subtotal += v;
        days += parseInt(type.dataset.days);
        rows.push({ label: type.dataset.label, price: v });
      }

      // Pages
      const pages = document.querySelector('input[name="pages"]:checked');
      if (pages) {
        const v = parseInt(pages.value);
        subtotal += v;
        days += parseInt(pages.dataset.days);
        if (v > 0) rows.push({ label: pages.dataset.label, price: v });
      }

      // Features
      document.querySelectorAll('input[name="feature"]:checked').forEach(f => {
        const v = parseInt(f.value);
        subtotal += v;
        days += parseInt(f.dataset.days);
        rows.push({ label: f.dataset.label, price: v });
      });

      // Rush
      const rush = document.getElementById('rushCheck');
      if (rush && rush.checked) {
        subtotal *= 1.5;
        days = Math.max(2, Math.ceil(days * 0.7));
        rows.push({ label: 'Rush Delivery (1.5x)', price: 'Rush' });
      }

      // Campaign
      const discount = Math.round(subtotal * 0.2);
      const total = subtotal - discount;

      // Update Visuals
      document.querySelectorAll('.choice-card').forEach(card => {
        card.classList.toggle('selected', card.querySelector('input').checked);
      });

      // Total Price Animation
      const priceEl = document.getElementById('totalPrice');
      if (priceEl) {
        let start = currentTotal;
        let end = total;
        let duration = 400;
        let startTime = null;
        function animate(now) {
          if(!startTime) startTime = now;
          let progress = Math.min((now - startTime) / duration, 1);
          let current = Math.floor(progress * (end - start) + start);
          priceEl.textContent = yen(current);
          if(progress < 1) requestAnimationFrame(animate);
        }
        requestAnimationFrame(animate);
        currentTotal = total;
      }

      // Gauge Animation
      const gauge = document.getElementById('gauge-fill');
      const maxPossible = 300000;
      const pct = Math.min(total / maxPossible, 1);
      const circumference = 125.6;
      const offset = circumference - (pct * circumference);
      if(gauge) gauge.style.strokeDashoffset = offset;

      const placeholder = document.getElementById('resultPlaceholder');
      const details = document.getElementById('resultDetails');
      if (total > 0) {
        if(placeholder) placeholder.style.display = 'none';
        if(details) details.style.display = 'block';
      } else {
        if(placeholder) placeholder.style.display = 'block';
        if(details) details.style.display = 'none';
      }

      document.getElementById('deliveryDays').textContent = `Approx. ${days} business days`;
      document.getElementById('discountVal').textContent = `-${yen(discount)}`;
      
      const list = document.getElementById('breakdownList');
      if(list) {
        if (rows.length === 0) {
          list.innerHTML = '<div style="color: #666; font-size: 0.8rem; text-align: center; padding: 10px;">No options selected</div>';
        } else {
          list.innerHTML = rows.map(r => `
            <div class="breakdown-row">
              <span class="r-label">${r.label}</span>
              <span class="r-price">${typeof r.price === 'number' ? yen(r.price) : r.price}</span>
            </div>
          `).join('');
        }
      }
    }

    function initSimulator() {
      document.querySelectorAll('input').forEach(i => i.addEventListener('change', update));
      update();
    }

    document.addEventListener('astro:page-load', initSimulator);
</script>
