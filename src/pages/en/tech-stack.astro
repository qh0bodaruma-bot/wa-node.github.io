---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Technologies & Architecture (Tech Stack) | Wa-Node";
const description = "The technical foundation behind Wa-Node's web development. Discover how we leverage Astro, Cloudflare Pages, and Vanilla CSS to build fast, secure, and flexible websites.";
---

<BaseLayout title={title} description={description} lang="en">
  <main class="tech-page">
    <!-- Hero Section -->
    <section class="tech-hero section">
      <div class="container narrow reveal">
        <div class="eyebrow">Technology & Architecture</div>
        <h1>The Technology Behind<br/><span class="text-accent">Wa-Node</span></h1>
        <p class="lead">
          We don't just build visually stunning websites; we make them extremely lightweight, secure, and psychologically aligned with user behavior.<br/>
          Here is our core tech stack and the philosophy behind our choices.
        </p>
      </div>
    </section>

    <!-- Tech Stack Grid -->
    <section class="tech-stack-section section">
      <div class="container">
        
        <div class="tech-card reveal">
          <div class="tech-header">
            <h2 class="tech-title">Astro</h2>
            <span class="tech-badge">Framework</span>
          </div>
          <div class="tech-body">
            <h3>Blazing Fast Performance via "Zero JS"</h3>
            <p>
              Most modern web frameworks ship massive amounts of JavaScript to the user's browser. 
              Astro is built on a "Zero JS by default" philosophy, only rendering dynamic elements where needed using "Islands Architecture."
            </p>
            <p>
              This minimizes page load times, drastically reducing bounce rates while maximizing SEO potential.
            </p>
          </div>
        </div>

        <div class="tech-card reveal">
          <div class="tech-header">
            <h2 class="tech-title">Cloudflare Pages</h2>
            <span class="tech-badge">Infrastructure</span>
          </div>
          <div class="tech-body">
            <h3>Edge Computing & Enterprise-Grade Security</h3>
            <p>
              Instead of serving websites from a single server location, we distribute data globally via Cloudflare's edge network (CDN). 
              Files are served from the closest node to the user, ensuring fast performance regardless of their location.
            </p>
            <p>
              Additionally, this setup provides top-tier security out of the box, including DDoS protection and automatic SSL.
            </p>
          </div>
        </div>

        <div class="tech-card reveal">
          <div class="tech-header">
            <h2 class="tech-title">Vanilla CSS</h2>
            <span class="tech-badge">Styling</span>
          </div>
          <div class="tech-body">
            <h3>Precision Design for Psychological Funnels</h3>
            <p>
              We bypass popular CSS frameworks like Tailwind CSS to write pure, raw CSS. 
              This allows us to break free from framework limitations, keeping full control over "1px of spacing" and fine-tuning visual cues that guide user actions.
            </p>
            <p>
              Writing bespoke CSS also prevents styling bloat, keeping the overall page weight exceptionally low.
            </p>
          </div>
        </div>

        <div class="tech-card reveal">
          <div class="tech-header">
            <h2 class="tech-title">AI Driven Development</h2>
            <span class="tech-badge">Workflow</span>
          </div>
          <div class="tech-body">
            <h3>High-Quality, Rapid Automated Workflows</h3>
            <p>
              We integrate state-of-the-art generative AI into our code review, optimization, and testing pipelines. 
              This reduces human error, accelerates development timelines, and frees us to focus on what humans do best: strategic design and user psychology.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- Philosophy -->
    <section class="philosophy section">
      <div class="container narrow reveal">
        <div class="philosophy-box">
          <h2>Technology is But a Tool to Move Minds.</h2>
          <p>
            We don't chase the latest tech trends just to show off specs.<br/>
            Loading a page one second faster keeps visitors from turning away.<br/>
            A secure infrastructure allows users to reach out with peace of mind.<br/>
            Ultimately, <strong>every technology we use serves to remove friction and connect people.</strong>
          </p>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .tech-page { background-color: var(--bg); overflow-x: hidden; }
  .text-accent { color: var(--accent); }

  .tech-hero {
    text-align: center;
    padding: 120px 0 80px;
    border-bottom: 1px solid var(--line);
  }
  .tech-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.2;
    margin-bottom: 32px;
    font-weight: 800;
  }
  .tech-hero .lead {
    font-size: 1.15rem;
    color: var(--muted);
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.8;
  }

  .tech-stack-section { padding: 80px 0; }
  .tech-stack-section .container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }

  .tech-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 10px 30px rgba(138, 90, 50, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .tech-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(138, 90, 50, 0.1);
    border-color: rgba(138, 90, 50, 0.2);
  }

  .tech-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 16px;
  }
  .tech-title {
    font-size: 1.8rem;
    font-weight: 900;
    margin: 0;
    color: #2b241f;
  }
  .tech-badge {
    background: var(--soft);
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 800;
    padding: 6px 12px;
    border-radius: 999px;
    letter-spacing: 0.05em;
  }

  .tech-body h3 {
    font-size: 1.2rem;
    font-weight: 800;
    margin-bottom: 16px;
    color: var(--text);
  }
  .tech-body p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .tech-body p:last-child { margin-bottom: 0; }

  .philosophy { padding: 60px 0 120px; }
  .philosophy-box {
    background: linear-gradient(135deg, rgba(241, 230, 218, 0.6) 0%, rgba(253, 250, 245, 0.9) 100%);
    border: 1px solid var(--line);
    border-radius: 32px;
    padding: 60px 40px;
    text-align: center;
  }
  .philosophy-box h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 24px;
    color: var(--accent);
  }
  .philosophy-box p {
    font-size: 1.1rem;
    line-height: 1.9;
    color: var(--text);
    margin: 0;
  }

  @media (max-width: 900px) {
    .tech-stack-section .container { grid-template-columns: 1fr; }
    .tech-card { padding: 30px 24px; }
  }
  @media (max-width: 768px) {
    .tech-hero h1 { font-size: 2.2rem; }
    .philosophy-box { padding: 40px 20px; }
    .philosophy-box h2 { font-size: 1.6rem; }
  }
</style>
