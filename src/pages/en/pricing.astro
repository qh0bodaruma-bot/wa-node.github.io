---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConsultationFlow from '../../components/ConsultationFlow.astro';
import ProjectExecutionFlow from '../../components/ProjectExecutionFlow.astro';
import MaterialIcon from '../../components/MaterialIcon.astro';
---

<BaseLayout title="Pricing Plans & Packages | Wa-Node" description="Discover Wa-Node's transparent pricing. We offer conversion-optimized web and LP design using behavioral psychology, strategic monthly co-piloting, and system/AI integration designed to align your business for growth." lang="en">
  <main class="pricing-container">
    <section class="hero">
      <div class="hero-inner">
        <!-- Premium Anniversary Banner -->
        <div class="premium-ann-banner reveal">
          <div class="banner-inner">
            <span class="banner-badge">1st ANNIVERSARY</span>
            <div class="banner-main">
              <strong>Special Anniversary Offer: 20% OFF on all production menus!</strong>
              <p>Limited to 3 clients per month. High-end conversion design at an appreciative price. <span class="period">Until July 31, 2026</span></p>
            </div>
            <a href="/campaign-anniversary/?lang=en" class="banner-link">Visit Campaign Page →</a>
          </div>
        </div>

        <p class="eyebrow">Pricing</p>
        <h1 class="premium-heading">Pricing Plans & Packages</h1>
        <p class="lead">Flexible pricing estimates to optimize your conversion. Custom packages tailored to your budget are also available.</p>
        <p class="note">At Wa-Node, we harness behavioral psychology not to "induce anxiety," but to "create high-trust navigation paths where users feel completely secure."</p>
      </div>
    </section>

    <section class="section choice-guide">
      <p class="eyebrow">Start Here</p>
      <h2 class="premium-heading">Not sure where to start? Choose from these 4 entry points</h2>
      <p class="choice-lead">No need to select a detailed package upfront. Simply share your goals from one of these entry points, and we will tailor the best plan for you.</p>
      <div class="choice-grid">
        <a class="choice-card primary-choice" href="#web-production">
          <span class="choice-label">Most Popular</span>
          <h3>I want to build a Website or LP</h3>
          <p class="choice-fit">For establishing a trusted presence</p>
          <p>We structure and design high-converting LPs and websites optimized for trust.</p>
          <strong>Recommended from 64,000 JPY</strong>
        </a>
        <a class="choice-card" href="#copilot">
          <span class="choice-label">Funnel Review</span>
          <h3>I want to improve an existing site or LP</h3>
          <p class="choice-fit">For reducing hesitation before inquiries</p>
          <p>We review CTAs, pricing, forms, AI-search-ready structure, colors, motion, and readability.</p>
          <strong>From 15,000 JPY</strong>
        </a>
        <a class="choice-card" href="#copilot">
          <span class="choice-label">Ongoing Support</span>
          <h3>I want ongoing advice after launch</h3>
          <p class="choice-fit">For continuous optimization</p>
          <p>Your "Business Co-pilot" for monthly optimization, AI integration, and workflow streamlining.</p>
          <strong>From 15,000 JPY / mo</strong>
        </a>
        <a class="choice-card" href="#ict-ai">
          <span class="choice-label">One-off Advice</span>
          <h3>I want to optimize operations with AI & ICT</h3>
          <p class="choice-fit">For starting with workflow audits</p>
          <p>We resolve questions about ChatGPT, LINE, business tools, and simple automation in a single session.</p>
          <strong>From 5,000 JPY</strong>
        </a>
      </div>
      <p class="choice-footnote">If you are unsure, we recommend starting with "I want to build a Website or LP" or "I want to improve an existing site or LP."</p>
      <div class="decision-guide" aria-label="Recommended by Goal">
        <h3>Recommended by Goal</h3>
        <div class="decision-grid">
          <a href="#web-production">
            <span>Want to increase inquiries</span>
            <strong>Psychology LP Design</strong>
          </a>
          <a href="#web-production">
            <span>Want solid business foundations</span>
            <strong>Psychology Website Design</strong>
          </a>
          <a href="#copilot">
            <span>Want continuous improvement</span>
            <strong>Business Co-pilot</strong>
          </a>
        </div>
      </div>
    </section>

    <section class="section" id="web-production">
      <p class="eyebrow">01. Web & Lead Design</p>
      <h2 class="premium-heading">Psychology-Driven Web & LP Design</h2>
      <p>Eliminating digital friction and maximizing conversion. High-end websites engineered with behavioral insights.</p>
      <div class="campaign-notice-box">
        <strong>【1st Anniversary Campaign】 20% OFF Web Production!</strong>
        <p>Enjoy a 20% discount on the standard prices below (Limited to 3 clients per month).</p>
      </div>

      <!-- Anchoring Effect (Market Comparison) -->
      <div class="market-anchoring-box">
        <h3 class="anchoring-title">Web Production "Market Rates" vs Wa-Node</h3>
        <p class="anchoring-intro">When requesting web development, you might wonder, "Why is it so affordable? Is the quality reliable?" Let us explain why Wa-Node offers high quality at such reasonable prices compared to typical market rates.</p>
        
        <div class="anchoring-table-wrap">
          <div class="anchoring-row header">
            <div>Production Type</div>
            <div>Average Agency Rate</div>
            <div>Wa-Node (Campaign Rate)</div>
          </div>
          <div class="anchoring-row">
            <div class="type-name">Simple Website Design</div>
            <div class="market-price">Initial: 300k - 500k JPY<br><span class="sub">Maint.: 10k - 30k JPY/mo</span></div>
            <div class="wa-price">Initial: From 40,000 JPY<br><span class="sub">Maint.: Optional (10,000 JPY/mo)</span></div>
          </div>
          <div class="anchoring-row">
            <div class="type-name">Psychology LP (Recommended)</div>
            <div class="market-price">Initial: 150k - 500k JPY<br><span class="sub">Maint.: 10k - 30k JPY/mo</span></div>
            <div class="wa-price highlight">Initial: From 64,000 JPY<br><span class="sub">Maint.: Optional (10,000 JPY/mo)</span></div>
          </div>
          <div class="anchoring-row">
            <div class="type-name">Psychology Website</div>
            <div class="market-price">Initial: 500k - 1.2M JPY<br><span class="sub">Maint.: 15k - 50k JPY/mo</span></div>
            <div class="wa-price">Initial: From 144,000 JPY<br><span class="sub">Maint.: Optional (10,000 JPY/mo)</span></div>
          </div>
        </div>

        <div class="anchoring-reason">
          <h4>How We Deliver "High Quality at Reasonable Rates"</h4>
          <ul>
            <li><strong>No Middlemen or High Ad Spend:</strong> By eliminating aggressive marketing and high office maintenance fees, we operate solely on client referrals and organic web inquiries, passing the savings directly to you.</li>
            <li><strong>Vanilla CSS & In-House Templates:</strong> Instead of bloated CMS (like WordPress) or unnecessary systems, we build lightweight, lightning-fast code optimized in-house, significantly reducing developer hours.</li>
            <li><strong>Focusing on What Matters — Psychology Funnels:</strong> We skip flashy visual effects or over-complicated layouts, focusing purely on psychology-backed design that makes prospects feel secure and confident in choosing you.</li>
          </ul>
        </div>
      </div>

      <!-- Plan Selector Switch -->
      <div class="plan-tabs-wrapper reveal">
        <div class="plan-tabs" role="tablist">
          <button class="plan-tab-btn active" data-plan-tab="hp" role="tab" aria-selected="true">
            <MaterialIcon name="language" /> Homepage (HP) Design
          </button>
          <button class="plan-tab-btn" data-plan-tab="lp" role="tab" aria-selected="false">
            <MaterialIcon name="ads_click" /> Landing Page (LP) Design
          </button>
        </div>
      </div>

      <!-- HP Design Plans -->
      <div id="plan-content-hp" class="plan-content active-plan">
        <div class="recommended-price-grid">
          <article class="recommended-price-card">
            <span class="price-badge-ume">Basic (Ume)</span>
            <h3>Simple Website Design</h3>
            <p class="p-price">40,000 JPY〜 <small>Campaign Price</small></p>
            <p>A compact website (3-5 pages) serving as your digital business card. Ideal for establishing an online hub on a budget.</p>
          </article>
          <article class="recommended-price-card highlight-take">
            <span class="price-badge-take">Standard (Take) ★ Recommended・Most Popular</span>
            <h3>Psychology Website</h3>
            <p class="p-price">144,000 JPY〜 <small>Campaign Price</small></p>
            <p>A standard website (around 5 pages). We apply robust informational structuring so prospects can comfortably navigate toward inquiries or sales.</p>
          </article>
          <article class="recommended-price-card">
            <span class="price-badge-matsu">Premium (Matsu)</span>
            <h3>"Business 7" Website Package</h3>
            <p class="p-price">192,000 JPY〜 <small>Campaign Price</small></p>
            <p>A comprehensive 7-page website package including standard SEO optimization, premium visual styling, and multiple touchpoints to maximize conversion rates.</p>
          </article>
        </div>
      </div>

      <!-- LP Design Plans -->
      <div id="plan-content-lp" class="plan-content">
        <div class="recommended-price-grid">
          <article class="recommended-price-card">
            <span class="price-badge-ume">Basic (Ume)</span>
            <h3>Simple LP Design</h3>
            <p class="p-price">24,000 JPY〜 <small>Campaign Price</small></p>
            <p>A single-page, clean landing page. Perfect for introducing your business or event on a limited budget.</p>
          </article>
          <article class="recommended-price-card highlight-take">
            <span class="price-badge-take">Standard (Take) ★ Recommended・Most Popular</span>
            <h3>Psychology LP Design</h3>
            <p class="p-price">64,000 JPY〜 <small>Campaign Price</small></p>
            <p>Designed around behavioral psychology, aligning everything from the hero area to trust-building elements and CTAs. Our highest ROI package directly tied to conversions.</p>
          </article>
          <article class="recommended-price-card">
            <span class="price-badge-matsu">Premium (Matsu)</span>
            <h3>Premium Psychology LP</h3>
            <p class="p-price">120,000 JPY〜 <small>Campaign Price</small></p>
            <p>Our conversion-focused psychology LP bundled with backend automation systems (GAS automatic emails, LINE API integration, etc.) to streamline your operations.</p>
          </article>
        </div>
      </div>

      <details class="addon-details price-details">
        <summary>Show full price list (including simple designs, maintenance, and add-ons)</summary>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Service</th><th>Regular Price</th><th>Campaign Price</th><th>Details</th></tr>
            </thead>
            <tbody>
              <tr><td>Simple LP Design</td><td>30,000 JPY〜</td><td class="price-campaign">24,000 JPY〜</td><td>Lightweight single-page landing page for clean presentation</td></tr>
              <tr><td>Simple Website Design</td><td>50,000 JPY〜</td><td class="price-campaign">40,000 JPY〜</td><td>Compact business website (3 to 5 pages)</td></tr>
              <tr><td>Psychology LP Design</td><td>80,000 JPY〜</td><td class="price-campaign">64,000 JPY〜</td><td>Behavioral-psychology optimized LP (including wireframe draft)</td></tr>
              <tr><td>Premium Psychology LP</td><td>150,000 JPY〜</td><td class="price-campaign">120,000 JPY〜</td><td>High-end psychology LP plus post-inquiry automation such as GAS email automation and LINE integration</td></tr>
              <tr><td>Psychology Website</td><td>180,000 JPY〜</td><td class="price-campaign">144,000 JPY〜</td><td>High-end standard website (around 5 pages)</td></tr>
              <tr><td>Website Pack "Business 7"</td><td>240,000 JPY〜</td><td class="price-campaign">192,000 JPY〜</td><td>Standard 7 pages, Basic SEO setup, Premium polish finish</td></tr>
              <tr><td>Add-on Custom Options</td><td>5,000 JPY〜</td><td class="price-campaign">4,000 JPY〜</td><td>Infographics, Blog setup, Custom quiz/diagnostics, etc.</td></tr>
              <tr><td>Web Maintenance & Support</td><td>10,000 JPY〜 / mo</td><td>-</td><td>Security audits, platform updates, and minor text/image edits</td></tr>
            </tbody>
          </table>
        </div>
      </details>
    </section>

    <section class="section">
      <p class="eyebrow">02. Ongoing Support & AI</p>
      <h2 class="premium-heading">Business Co-pilot (Monthly Strategic Partnership)</h2>
      <p>We don't just "build and leave." We continuously solve system issues and assist you in integrating AI automation into your daily operations.</p>
      
      <div class="pricing-grid-simple">
        <div class="p-card-simple highlight">
          <span class="p-tag">Popular Choice</span>
          <h3>Business Co-pilot (Light Plan)</h3>
          <p class="p-price">15,000 JPY〜 <small>/ month</small></p>
          <p class="p-desc">1 monthly consultation + ongoing chat support. Perfect for continuous web updates and AI tooling advice.</p>
        </div>
        <div class="p-card-simple" id="ict-ai">
          <h3>ICT Spot Consultation</h3>
          <p class="p-price">5,000 JPY <small>/ 60 min</small></p>
          <p class="p-desc">Single-session troubleshooting for ChatGPT, LINE APIs, workflow tools, or generic web concerns.</p>
        </div>
        <div class="p-card-simple">
          <h3>AI Integration Start Pack</h3>
          <p class="p-price">30,000 JPY</p>
          <p class="p-desc">Initial configurations of ChatGPT, customized prompt templates, and real-work integration roadmaps.</p>
        </div>
      </div>

      <details class="addon-details">
        <summary>Show Additional Services & Custom Options</summary>
        <div class="table-wrap mini">
          <table>
            <thead>
              <tr><th>Package Name</th><th>Price</th><th>Details</th></tr>
            </thead>
            <tbody>
              <tr><td>Business Co-pilot (Standard)</td><td>45,000 JPY / mo</td><td>2 monthly consultations + strategic proposals + customized AI manuals</td></tr>
              <tr><td>Workflow Audit & Diagnostics</td><td>15,000 JPY</td><td>90-min session + workflow mapping to identify automation priorities</td></tr>
              <tr><td>Small DX Architecture Pack</td><td>50,000 JPY</td><td>Full visualization of workflow, tool selection, and custom deployment roadmap</td></tr>
              <tr><td>Corporate AI Training & Lectures</td><td>80,000 JPY〜</td><td>On-site workshops, security guidelines, and custom role-specific AI onboarding</td></tr>
              <tr><td>LINE Official Account Setup</td><td>20,000 JPY〜</td><td>Psychology-driven funnel design from welcome message to conversion</td></tr>
            </tbody>
          </table>
        </div>
      </details>
    </section>

    <section class="section">
      <p class="eyebrow">03. Organization & Communication</p>
      <h2 class="premium-heading">Corporate Support & Psychological Alignment</h2>
      <p>Applying expert psychology to corporate communication, team dynamics, and mental wellness support.</p>
      <div class="table-wrap">
        <table>
          <tbody>
            <tr>
              <td>Psychological Communication Support</td>
              <td>15,000 JPY〜 / mo</td>
              <td>Tailored for small businesses. Designing consultation desks and psychological safety training.</td>
            </tr>
            <tr>
              <td>Executive Counselor Session</td>
              <td>First session 5,000 JPY / 60 min<br />Standard 10,000 JPY / 60 min</td>
              <td>One-on-one mental structuring and cognitive clarity for founders & leaders, with an accessible first-session rate.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="section pricing-faq" aria-labelledby="pricing-faq-title">
      <p class="eyebrow">Before Consultation</p>
      <h2 id="pricing-faq-title" class="premium-heading">FAQ before Consultation</h2>
      <div class="faq-list">
        <details>
          <summary>Is it okay if I only consult without ordering?</summary>
          <p>Absolutely. If clarifying your current situation is all you need, we will not push any development or monthly plans.</p>
        </details>
        <details>
          <summary>Can I consult even if I haven't decided what to request?</summary>
          <p>Yes. We will work together to define where you should start among web design, LP development, AI/ICT integration, or ongoing optimization.</p>
        </details>
        <details>
          <summary>Will I be pressured into a contract after the session?</summary>
          <p>Never. We clarify the required scope, costs, and timeline, and we only begin officially once you are completely comfortable.</p>
        </details>
        <details>
          <summary>Will there be any unexpected price increases later?</summary>
          <p>If additional work is needed, we will confirm the scope and budget with you beforehand. No unsanctioned fees will ever be charged.</p>
        </details>
      </div>
    </section>

    <ConsultationFlow lang="en" />
    <ProjectExecutionFlow lang="en" />
  </main>
</BaseLayout>

<script>
  function initPlanTabs() {
    const tabButtons = document.querySelectorAll('.plan-tab-btn');
    const planContents = document.querySelectorAll('.plan-content');

    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        const targetTab = button.getAttribute('data-plan-tab');

        // Deactivate all buttons
        tabButtons.forEach(btn => {
          btn.classList.remove('active');
          btn.setAttribute('aria-selected', 'false');
        });

        // Hide all contents
        planContents.forEach(content => {
          content.classList.remove('active-plan');
        });

        // Activate selected button & content
        button.classList.add('active');
        button.setAttribute('aria-selected', 'true');
        
        const targetContent = document.getElementById(`plan-content-${targetTab}`);
        if (targetContent) {
          targetContent.classList.add('active-plan');
        }
      });
    });
  }

  // Support page transition in Astro (swup/barba/native)
  document.addEventListener('astro:page-load', initPlanTabs);
  document.addEventListener('DOMContentLoaded', initPlanTabs);
  initPlanTabs();
</script>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

  :root {
    --accent: #c5a059;
    --accent-dark: #b18e4a;
    --accent-red: #d14d3a;
    --trust: #0f4c5c;
    --trust-mid: #1f6f78;
    --trust-line: rgba(15, 76, 92, 0.18);
    --line: rgba(197, 160, 89, 0.2);
  }

  .premium-heading {
    font-family: 'Shippori Mincho', serif !important;
    font-weight: 800 !important;
    letter-spacing: 0.05em;
  }

  .pricing-container {
    background: #fdfcf9;
    font-family: 'Shippori Mincho', serif !important;
  }

  .hero { padding: 80px 0 60px; border-bottom: 1px solid var(--line); text-align: center; }
  .hero-inner, .section { max-width: 1000px; margin: 0 auto; padding: 0 20px; }
  
  .premium-ann-banner { margin-bottom: 50px; }
  .banner-inner {
    background: #fff; border: 1px solid var(--accent-red); border-radius: 24px;
    padding: 24px 32px; display: flex; align-items: center; gap: 30px;
    box-shadow: 0 15px 40px rgba(209, 77, 58, 0.08); position: relative;
  }
  .banner-badge {
    background: var(--accent-red); color: #fff; font-size: 0.7rem; font-weight: 800;
    padding: 4px 12px; border-radius: 4px; white-space: nowrap;
  }
  .banner-main { flex: 1; text-align: left; }
  .banner-main strong { display: block; font-size: 1.3rem; color: var(--accent-red); margin-bottom: 4px; }
  .banner-link {
    font-size: 0.95rem; font-weight: 800; color: var(--accent-red); text-decoration: none;
    padding: 12px 24px; border: 1px solid var(--accent-red); border-radius: 50px;
    transition: 0.3s; white-space: nowrap;
  }
  .banner-link:hover { background: var(--accent-red); color: #fff; }

  .lead { font-size: 1.1rem; color: #555; margin-bottom: 30px; }
  .note { background: #fff; border: 1px solid var(--line); padding: 20px; border-radius: 15px; color: #666; font-size: 0.95rem; }

  .section { padding: 80px 20px; }
  .eyebrow { font-size: 0.8rem; font-weight: 800; color: var(--accent); letter-spacing: 0.2em; margin-bottom: 10px; display: block; }
  h2 { font-size: 2.2rem; margin-bottom: 20px; color: #2c2c2c; }

  .choice-guide {
    padding-top: 70px;
    padding-bottom: 70px;
    text-align: center;
    border-bottom: 1px solid var(--line);
  }
  .choice-lead {
    max-width: 720px;
    margin: 0 auto 34px;
    color: #555;
    line-height: 1.8;
  }
  .choice-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin: 34px 0 20px;
  }
  .choice-card {
    display: flex;
    min-height: 260px;
    flex-direction: column;
    justify-content: space-between;
    gap: 14px;
    padding: 28px 24px;
    border: 1px solid var(--line);
    border-radius: 20px;
    background: #fff;
    color: #333;
    text-decoration: none;
    text-align: left;
    box-shadow: 0 16px 34px rgba(44, 44, 44, 0.04);
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }
  .choice-card:hover {
    border-color: var(--trust-mid);
    box-shadow: 0 20px 44px rgba(44, 44, 44, 0.08);
    transform: translateY(-3px);
  }
  .choice-card.primary-choice {
    border: 2px solid var(--trust-line);
    background: linear-gradient(135deg, rgba(15, 76, 92, 0.06), rgba(197, 160, 89, 0.06)), #fff;
  }
  .choice-label {
    align-self: flex-start;
    border-radius: 999px;
    background: rgba(15, 76, 92, 0.08);
    color: var(--trust);
    font-size: 0.75rem;
    font-weight: 800;
    padding: 5px 12px;
  }
  .choice-card h3 {
    margin: 0;
    color: #2c2c2c;
    font-size: 1.25rem;
    line-height: 1.45;
  }
  .choice-card p {
    margin: 0;
    color: #666;
    font-size: 0.92rem;
    line-height: 1.7;
  }
  .choice-card .choice-fit {
    display: inline-block;
    align-self: flex-start;
    margin: 0;
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(15, 76, 92, 0.07);
    color: var(--trust);
    font-size: 0.78rem;
    font-weight: 800;
  }
  .choice-card strong {
    color: var(--trust);
    font-size: 1.15rem;
  }
  .choice-footnote {
    margin: 0 auto;
    max-width: 680px;
    color: #777;
    font-size: 0.92rem;
  }
  .decision-guide {
    margin: 30px auto 0;
    max-width: 840px;
    padding: 24px;
    border: 1px solid var(--trust-line);
    border-radius: 20px;
    background: rgba(15, 76, 92, 0.035);
    text-align: left;
  }
  .decision-guide h3 {
    margin: 0 0 16px;
    color: #2c2c2c;
    font-size: 1.05rem;
    font-weight: 800;
  }
  .decision-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .decision-grid a {
    display: block;
    padding: 16px 18px;
    border: 1px solid var(--trust-line);
    border-radius: 14px;
    background: #fff;
    color: #333;
    text-decoration: none;
