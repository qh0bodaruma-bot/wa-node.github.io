---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Thank You for Your Inquiry | Wa-Node" description="Your inquiry has been successfully sent. We will review your message and reply as soon as possible.">
  <main class="thanks-page">
    <div class="container">
      <div class="thanks-card reveal">
        <div class="icon-wrap">
          <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        </div>
        <h1>Message Received.</h1>
        <p class="desc">
          Thank you very much for taking the step and reaching out to us.<br/>
          Our representative, Takano, will carefully read and review your message.<br/>
          We will get back to you within 2 business days. Please rest assured.
        </p>

        <div class="thanks-flow" style="margin-bottom: 50px;">
          <h3 style="font-size: 1.25rem; font-weight: 800; color: var(--accent-dark); margin-bottom: 24px; font-family: 'Shippori Mincho', serif;">✉️ Process After Submission</h3>
          <div class="flow-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; text-align: left;">
            <div class="flow-card" style="background: rgba(197, 160, 89, 0.03); border: 1px solid var(--line); border-radius: 16px; padding: 20px; position: relative;">
              <span style="font-size: 0.75rem; font-weight: 800; color: var(--accent); display: block; margin-bottom: 6px;">STEP 1</span>
              <strong style="display: block; font-size: 0.95rem; margin-bottom: 6px; color: #2c2c2c;">Scheduling</strong>
              <p style="font-size: 0.8rem; color: #666; margin: 0; line-height: 1.5;">Within 2 business days, we will send you an online consultation link (Google Meet, etc.) based on your preferred dates.</p>
            </div>
            <div class="flow-card" style="background: rgba(197, 160, 89, 0.03); border: 1px solid var(--line); border-radius: 16px; padding: 20px; position: relative;">
              <span style="font-size: 0.75rem; font-weight: 800; color: var(--accent); display: block; margin-bottom: 6px;">STEP 2</span>
              <strong style="display: block; font-size: 0.95rem; margin-bottom: 6px; color: #2c2c2c;">Free Consultation (Max 60m)</strong>
              <p style="font-size: 0.8rem; color: #666; margin: 0; line-height: 1.5;">We will listen to your challenges and wishes carefully, organizing the direction and steps for resolution together.</p>
            </div>
            <div class="flow-card" style="background: rgba(197, 160, 89, 0.03); border: 1px solid var(--line); border-radius: 16px; padding: 20px; position: relative;">
              <span style="font-size: 0.75rem; font-weight: 800; color: var(--accent); display: block; margin-bottom: 6px;">STEP 3</span>
              <strong style="display: block; font-size: 0.95rem; margin-bottom: 6px; color: #2c2c2c;">Proposal & Initial Outline</strong>
              <p style="font-size: 0.8rem; color: #666; margin: 0; line-height: 1.5;">Depending on the consultation, we will provide a brief outline and estimation. Formal works start only after you agree.</p>
            </div>
          </div>
        </div>

        <div class="next-steps">
          <div class="step-card">
            <h3>Need urgent assistance?</h3>
            <p>You can also contact us via our official LINE account.<br/>We can communicate more smoothly.</p>
            <a href="https://lin.ee/o5QFPwc" target="_blank" rel="noopener" class="line-btn">Message us on LINE</a>
          </div>

          <div class="links">
            <a href="/en/" class="btn-home">Back to Home</a>
            <a href="/en/works/" class="btn-works">View Our Works</a>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .thanks-page { min-height: 80vh; display: flex; align-items: center; padding: 100px 0; }
  .thanks-card {
    max-width: 700px; margin: 0 auto; background: #fff; border: 1px solid var(--line);
    border-radius: 48px; padding: 80px 40px; text-align: center; box-shadow: var(--shadow);
  }
  .icon-wrap { width: 100px; height: 100px; background: rgba(99, 153, 34, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 32px; color: var(--accent); }
  
  .thanks-card h1 { font-size: 2.4rem; font-weight: 900; line-height: 1.3; margin-bottom: 24px; }
  .accent-text { color: var(--accent); }
  .desc { font-size: 1.1rem; color: var(--muted); line-height: 1.8; margin-bottom: 48px; }

  .next-steps { border-top: 1px solid var(--line); padding-top: 48px; }
  .step-card { background: #fdfaf7; border-radius: 24px; padding: 32px; margin-bottom: 40px; border: 1px solid var(--line); }
  .step-card h3 { font-size: 1.2rem; font-weight: 800; margin-bottom: 12px; }
  .step-card p { font-size: 0.95rem; color: var(--muted); margin-bottom: 20px; }

  .line-btn {
    display: inline-block; background: #06C755; color: #fff; text-decoration: none;
    padding: 14px 40px; border-radius: 999px; font-weight: 800; transition: 0.3s;
  }
  .line-btn:hover { background: #05b34c; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(6, 199, 85, 0.2); }

  .links { display: flex; gap: 16px; justify-content: center; }
  .btn-home, .btn-works { padding: 16px 32px; border-radius: 999px; text-decoration: none; font-weight: 800; font-size: 0.95rem; transition: 0.3s; }
  .btn-home { background: var(--soft); color: var(--text); }
  .btn-works { border: 2px solid var(--accent); color: var(--accent); }
  
  .btn-home:hover, .btn-works:hover { transform: translateY(-2px); opacity: 0.8; }

  @media (max-width: 600px) {
    .thanks-card { padding: 60px 20px; border-radius: 32px; }
    .thanks-card h1 { font-size: 1.8rem; }
    .links { flex-direction: column; }
    .btn-home, .btn-works { width: 100%; box-sizing: border-box; }
  }
</style>
