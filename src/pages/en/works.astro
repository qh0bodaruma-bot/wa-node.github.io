---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConsultationFlow from '../../components/ConsultationFlow.astro';
---

<BaseLayout title="Works & Interactive Demos | Wa-Node" description="Explore Wa-Node's diverse portfolio: psychology-driven web design, AI assistants, interactive diagnostic tools, self-publishing, and LINE Mini Apps." lang="en">
  <!-- Background -->
  <div class="bg-decoration">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="grid-overlay"></div>
    <div class="sakura-container" id="sakura-container"></div>
  </div>

  <script is:inline>
    function initSakura() {
      const container = document.getElementById('sakura-container');
      if (!container) return;
      container.innerHTML = '';
      for (let i = 0; i < 20; i++) {
        const petal = document.createElement('div');
        petal.className = 'petal-subtle';
        petal.style.left = Math.random() * 100 + '%';
        petal.style.width = Math.random() * 8 + 4 + 'px';
        petal.style.height = petal.style.width;
        petal.style.animationDuration = Math.random() * 5 + 7 + 's';
        petal.style.animationDelay = Math.random() * 5 + 's';
        container.appendChild(petal);
      }
    }
    initSakura();
    document.addEventListener('astro:page-load', initSakura);
  </script>

  <main class="works-page">
    <section class="section works-hero">
      <div class="container narrow">
        <!-- Anniversary Banner -->
        <div class="works-anniversary-banner reveal">
          <a href="/campaign-anniversary/?lang=en">
            <span class="ann-label">1st Anniversary Campaign</span>
            <div class="ann-content">
              <strong>Celebrating Our Launch: 20% OFF Web Production!</strong>
              <span>Special rates are now available. Get the same high-end site as our portfolio. Learn more →</span>
            </div>
          </a>
        </div>

        <span class="eyebrow">Works & Demos</span>
        <h1 class="premium-heading">Portfolio, Demos & Utilities</h1>
        <p class="lead">
          Discover our real-world client cases alongside Wa-Node's original interactive tools,<br class="pc-only" />
          showcasing behavioral psychology, AI automation, and universal web accessibility.
        </p>
      </div>
    </section>

    <div class="container">
      <!-- Filter Tabs -->
      <nav class="filter-nav" id="filter-nav">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="web">Web & LP</button>
        <button class="filter-btn" data-filter="tool">Demos & Audits</button>
        <button class="filter-btn" data-filter="system">AI & System</button>
        <button class="filter-btn" data-filter="kdp">KDP Publishing</button>
      </nav>

      <div class="works-grid" id="works-grid">
        
        <!-- Category: Web (Psychology Demo) -->
        <article class="work-card reveal" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg" style="background: linear-gradient(135deg, #fdfcf9 0%, #f5eee0 100%);">
              <img src="/images/works-psy-demo.png" alt="Psychology UX Demo" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.style.display='none'" />
              <span class="category-tag demo">Proprietary Demo</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Psychology Logic</div>
            <h3>Psychology-Driven UX Demo</h3>
            <p class="card-text">Why is that button placed exactly there? Experience how behavioral psychology dictates optimal information placement, complete with detailed logic walkthroughs.</p>
            <div class="card-footer">
              <span class="tech-tag">UI/UX</span>
              <span class="tech-tag">Psychology</span>
              <a href="/psychology-demo/?lang=en" class="card-link">Try Demo Page →</a>
            </div>
          </div>
        </article>

        <!-- Category: System (AI Demo) -->
        <article class="work-card reveal" data-category="system">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg">
              <img src="/images/works-system.png" alt="AI Business Strategy Co-pilot" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo">Proprietary Demo</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">AI Solution</div>
            <h3>AI Business Strategy Co-pilot</h3>
            <p class="card-text">Our AI structure organizes your vague business or system integration concerns. Experience a practical application of the OpenAI API in real-time.</p>
            <div class="card-footer">
              <span class="tech-tag">OpenAI API</span>
              <span class="tech-tag">Astro</span>
              <a href="/ai-chat-demo/?lang=en" class="card-link">Start AI Assistant →</a>
            </div>
          </div>
        </article>

        <!-- Category: Tool (Mental) -->
        <article class="work-card reveal" data-category="tool">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg">
              <img src="/images/works-mental.png" alt="Mental Fatigue & Stress Audit" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo">Proprietary Demo</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Mental Health</div>
            <h3>Mental Fatigue & Stress Audit</h3>
            <p class="card-text">Industrial Counselor expertise converted into a system. Visualize stress triggers and encourage cognitive clarity via an empathetic interface.</p>
            <div class="card-footer">
              <span class="tech-tag">Logic</span>
              <span class="tech-tag">Empathy UI</span>
              <a href="/mental_care/?lang=en" class="card-link">Take Diagnostics →</a>
            </div>
          </div>
        </article>

        <!-- Category: Tool (Accessibility) -->
        <article class="work-card reveal" data-category="tool">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg">
              <img src="/images/works-accessibility.png" alt="Accessibility & Barrier-Free Audit" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo">Proprietary Demo</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Accessibility</div>
            <h3>Accessibility & Barrier-Free Audit</h3>
            <p class="card-text">Check your site's universal accessibility from a wheelchair user's perspective. Visualize physical/digital obstacles and map out improvement steps.</p>
            <div class="card-footer">
              <span class="tech-tag">UD Design</span>
              <span class="tech-tag">SVG Gauge</span>
              <a href="/barrier_free/?lang=en" class="card-link">Check Accessibility →</a>
            </div>
          </div>
        </article>

        <!-- Category: Tool (SEO) -->
        <article class="work-card reveal" data-category="tool">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg">
              <img src="/images/works-seo.png" alt="Technical SEO/AEO Self-Diagnostics" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo">Proprietary Demo</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">SEO / AEO Analysis</div>
            <h3>Technical SEO/AEO Self-Diagnostics</h3>
            <p class="card-text">Check your website's technical health across 30 key items, including structure that helps both search engines and AI answer engines understand your pages.</p>
            <div class="card-footer">
              <span class="tech-tag">SEO</span>
              <span class="tech-tag">AEO</span>
              <span class="tech-tag">Marketing</span>
              <a href="/seo_check/?lang=en" class="card-link">Start SEO/AEO Audit →</a>
            </div>
          </div>
        </article>

        <!-- Category: Web (Medical) -->
        <article class="work-card reveal" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/portfolio-lp/images/hero_clinic.png" alt="Medical & Clinic Landing Page" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag real">Client Work</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Medical / Clinic</div>
            <h3>Medical & Clinic Landing Page</h3>
            <p class="card-text">Designed for beauty clinics and psychosomatic medicine. Ensuring absolute compliance with strict medical advertisement laws while projecting comfort & high trust.</p>
            <div class="card-footer">
              <div class="tech-stack"><span>#UX Design</span><span>#Trust</span></div>
              <a href="/portfolio-lp/lp_clinic.html?lang=en" class="premium-link">View Showcase</a>
            </div>
          </div>
        </article>

        <!-- Category: KDP -->
        <article class="work-card reveal" data-category="kdp">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/images/works-kdp.png" alt="Amazon Kindle Self-Publishing Portfolio" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag real">Client Work</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Publishing</div>
            <h3>Amazon Kindle Self-Publishing Portfolio</h3>
            <p class="card-text">Publishing traditional Japanese visual books (Ukiyo-e and Choju-giga) tailored for global markets. Strategic branding support from cover layouts to metadata setup.</p>
            <div class="card-footer">
              <span class="tech-tag">Global</span>
              <span class="tech-tag">Design</span>
              <a href="/en/kdp_books/" class="card-link">View KDP Portfolio →</a>
            </div>
          </div>
        </article>

      </div>
    </div>

    <ConsultationFlow lang="en" />

    <!-- Standard Packages CTA -->
    <section class="packages-cta reveal">
      <div class="container glass-panel">
        <div class="cta-label">ANNIVERSARY SPECIAL</div>
        <h2>Ready to Upgrade Your Digital Conversion?</h2>
        <p>We are currently offering 20% OFF all web production services. Introduce a high-end, psychology-driven website into your business today.</p>
        <div class="cta-btns">
          <a href="/campaign-anniversary/?lang=en" class="btn-secondary-outline">Learn Campaign Details</a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

    :root {
      --accent: #c5a059;
      --accent-dark: #b18e4a;
      --accent-red: #d14d3a;
      --glass: rgba(255, 255, 255, 0.85);
      --glass-border: rgba(197, 160, 89, 0.2);
      --tag-works: #2c7c5e;
      --tag-sample: #c5a059;
      --tag-demo: #2c5e7c;
      --text-deep: #1a1a1a;
    }

    .premium-heading {
      font-family: 'Shippori Mincho', serif !important;
      font-weight: 800 !important;
      letter-spacing: 0.05em;
    }

    /* Background Decoration */
    .bg-decoration {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      z-index: -1; background: #fdfcf9; overflow: hidden;
    }
    .bg-decoration::after {
      content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3FfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3F/filter%3E%3Frect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3F/svg%3E");
      opacity: 0.05; pointer-events: none;
    }
    .sakura-container {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
    }
    .petal-subtle {
      position: absolute; background: #ffb7c5; border-radius: 150% 0 150% 0;
      opacity: 0.4; animation: fall-subtle linear infinite;
    }
    @keyframes fall-subtle {
      0% { transform: translateY(-10vh) rotate(0deg); opacity: 0; }
      10% { opacity: 0.4; }
      90% { opacity: 0.4; }
      100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
    }

    .works-page { padding-bottom: 100px; font-family: 'Shippori Mincho', serif !important; }
    .works-hero { padding: 80px 0 60px; text-align: center; }
    
    .works-anniversary-banner { margin-bottom: 40px; }
    .works-anniversary-banner a {
      display: block; background: #fff; border: 1px solid var(--accent-red);
      border-radius: 20px; padding: 20px 30px; text-decoration: none;
      transition: 0.4s; box-shadow: 0 10px 30px rgba(209, 77, 58, 0.1);
    }
    .works-anniversary-banner a:hover { transform: translateY(-3px); }
    .ann-label {
      display: inline-block; background: var(--accent-red); color: white;
      font-size: 0.75rem; font-weight: 800; padding: 4px 12px; border-radius: 4px;
      margin-bottom: 8px;
    }
    .ann-content { display: flex; align-items: center; justify-content: center; gap: 20px; color: #2c2c2c; }
    .ann-content strong { font-size: 1.2rem; color: var(--accent-red); }

    .eyebrow { font-size: 0.85rem; font-weight: 800; color: var(--accent); letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 16px; display: block; }
    .lead { font-size: 1.1rem; color: #555; line-height: 1.8; max-width: 800px; margin: 0 auto; }

    /* Filter Nav */
    .filter-nav { display: flex; justify-content: center; gap: 12px; margin-bottom: 60px; flex-wrap: wrap; }
    .filter-btn {
      padding: 12px 28px; border-radius: 999px; background: #fff;
      border: 1px solid var(--glass-border); color: #666; font-weight: 800;
      cursor: pointer; transition: 0.3s;
    }
    .filter-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }

    /* Works Grid */
    .works-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 32px; }

    .work-card {
      background: #fff; border: 1px solid var(--glass-border); border-radius: 24px;
      overflow: hidden; display: flex; flex-direction: column;
      transition: 0.4s; box-shadow: 0 10px 20px rgba(0,0,0,0.02);
    }
    .work-card:hover { transform: translateY(-10px); border-color: var(--accent); }

    .card-visual-wrap { padding: 12px; }
    .card-visual { height: 160px; border-radius: 16px; overflow: hidden; position: relative; background: #f5f5f5; }
    
    .category-tag {
      position: absolute; top: 12px; left: 12px; font-size: 0.65rem; font-weight: 800;
      padding: 4px 10px; border-radius: 999px; z-index: 2;
    }
    .category-tag.real { background: var(--accent-red); color: #fff; }
    .category-tag.demo { background: var(--tag-demo); color: #fff; }
    .category-tag.sample { background: var(--accent); color: #fff; }

    .card-body { padding: 24px; flex: 1; display: flex; flex-direction: column; }
    .expert-label { font-size: 0.75rem; font-weight: 800; color: var(--accent); letter-spacing: 0.1em; margin-bottom: 8px; }
    .card-body h3 { font-size: 1.25rem; font-weight: 800; margin-bottom: 12px; line-height: 1.4; }
    .card-text { font-size: 0.9rem; color: #666; line-height: 1.7; margin-bottom: 20px; flex: 1; }

    .card-footer { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-top: auto; }
    .tech-tag { font-size: 0.7rem; font-weight: 800; color: #888; background: #f5f5f5; padding: 4px 8px; border-radius: 4px; }
    .card-link, .premium-link {
      margin-left: auto;
      font-size: 0.8rem;
      font-weight: 800;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 22px;
      border-radius: 99px;
      color: #fff !important;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
      border: none;
    }
    .card-link:hover, .premium-link:hover {
      transform: translateY(-2px);
      filter: brightness(1.1);
    }
    .card-border-green .card-link, .card-border-green .premium-link {
      background: var(--tag-works);
      box-shadow: 0 4px 12px rgba(44, 124, 94, 0.2);
    }
    .card-border-gold .card-link, .card-border-gold .premium-link {
      background: var(--tag-sample);
      box-shadow: 0 4px 12px rgba(140, 107, 31, 0.2);
    }
    .card-border-blue .card-link, .card-border-blue .premium-link {
      background: var(--tag-demo);
      box-shadow: 0 4px 12px rgba(44, 94, 124, 0.2);
    }
    .card-border-red .card-link, .card-border-red .premium-link {
      background: var(--accent-red);
      box-shadow: 0 4px 12px rgba(199, 53, 47, 0.2);
    }

    .packages-cta { margin-top: 100px; }
    .glass-panel {
      background: #3a2e26; color: white; border-radius: 32px; padding: 60px 20px;
      text-align: center; border: 1px solid var(--accent);
    }
    .cta-label { font-size: 0.8rem; font-weight: 800; color: var(--accent); letter-spacing: 0.3em; margin-bottom: 16px; }
    .glass-panel h2 { font-size: 1.8rem; margin-bottom: 20px; font-weight: 800; }
    .glass-panel p { font-size: 1rem; opacity: 0.8; margin-bottom: 32px; }

    .btn-secondary-outline {
      display: inline-block; border: 2px solid var(--accent); color: var(--accent);
      padding: 12px 36px; border-radius: 50px; text-decoration: none; font-weight: 800; transition: 0.3s;
    }
    .btn-secondary-outline:hover { background: var(--accent); color: white; }

    .reveal { opacity: 0; transform: translateY(20px); transition: 0.6s ease-out; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 768px) {
      .works-grid { grid-template-columns: 1fr; }
    }
</style>

<script is:inline>
    function initWorks() {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const workCards = document.querySelectorAll('.work-card');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = btn.dataset.filter;
          filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          workCards.forEach(card => {
            if (filter === 'all' || card.dataset.category === filter) {
              card.style.display = 'flex';
              setTimeout(() => card.classList.add('visible'), 50);
            } else {
              card.style.display = 'none';
              card.classList.remove('visible');
            }
          });
        });
      });

      const io = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    }
    initWorks();
    document.addEventListener('astro:page-load', initWorks);
  </script>
