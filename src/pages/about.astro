---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMovie from '../components/BrandMovie.astro';
import {
  createBreadcrumbSchema,
  createWebPageSchema,
  organizationSchema,
  personSchema,
} from '../data/structuredData';

const title = "和-Nodeについて（代表プロフィール・事業所概要）｜和-Node";
const description = "和-Node代表・高野紘純のプロフィール。IT実務20年の技術力に、心理カウンセラーの知見と車いすユーザーの視点を融合。Web制作と「ビジネスの副操縦士」（戦略的パートナー）としての継続支援を通じて、ビジネスの課題を根本から整えます。";
const structuredData = [
  organizationSchema,
  personSchema,
  createWebPageSchema({ name: title, description, path: "/about/", type: "AboutPage" }),
  createBreadcrumbSchema([
    { name: "ホーム", path: "/" },
    { name: "和-Nodeについて", path: "/about/" },
  ]),
];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <main>
    <section class="section about-hero">
      <div class="section-inner">
        <span class="eyebrow">Professional Background</span>
        <h1>和-Nodeについて</h1>
        <div class="name-origin-hero">
          <h2>和-Nodeという名前に込めたもの</h2>
          <p>「和」には、人と人、考えと仕組みのあいだに調和をつくる意味を。</p>
          <p>「Node」には、情報や技術、人をつなぐ結節点という意味があります。</p>
          <p>心理学の知見をもとに、使う人の迷いや不安を見つめ、Web・AI・ICTを事業に合う形へ昇華する。</p>
          <p>人と技術、想いと行動をつなぐ役割を担いたくて、和-Nodeと名付けました。</p>
        </div>
      </div>
    </section>

    <BrandMovie
      eyebrow="Wa-Node Concept"
      title="技術と心理を、相談につながる導線へ。"
      body="和-Nodeが大切にしているのは、派手な表現ではなく、見る人の迷いを減らし、安心して次の行動へ進める設計です。"
      compact
    />

    <section class="section message">
      <div class="section-inner">
        <div class="message-content reveal">
          <div class="content-left">
            <h2>代表挨拶</h2>
            <h3 class="catch-copy">「心理的な不親切が、<br class="sp-only"/>人の心を遠ざけるから。」</h3>
            <p>IT業界で20年以上、エンジニアとして大規模システムの開発からWeb制作まで、数多くの現場を歩んできました。その中で私が辿り着いた確信は、<strong>「どんなに優れた技術も、使う人の心理に寄り添わなければ価値を届けられない」</strong>ということです。</p>
            <p>私自身、車いす生活という当事者視点を持つようになり、その想いはさらに強固になりました。誰もが迷わず、安心して操作できる導線設計。それは単なる「優しさ」ではなく、ビジネスの成果を最大化するための「技術的責務」であると考えています。</p>
            <p>和-Nodeは、心理学を応用したWeb制作を主軸に、AIやICTを活用した業務改善までを一貫してサポートします。あなたのビジネスに「和（なぎ）」をもたらし、次の一歩を確かなものにする。それが私の使命です。</p>
          </div>
          <div class="content-right">
            <div class="profile-image-wrap">
              <img src="/images/avatar.webp" alt="和-Node 代表 高野紘純" />
              <p class="name-jp">高野 紘純</p>
              <p class="name-en">Hirozumi Takano</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section profile-details">
      <div class="section-inner">
        <div class="section-title">
          <span class="eyebrow">Profile & Skills</span>
          <h2>Web制作と戦略的パートナーとしての活動</h2>
        </div>
        
        <div class="story-box reveal">
          <h3>技術と心理の融合</h3>
          <p>2002年に産業カウンセラー資格を取得し、ITエンジニアとしての実務と並行して「人と組織の心理」を学び続けてきました。技術と言葉、その両面からアプローチできることが和-Nodeの最大の強みです。</p>
          <p>身体的な困難を乗り越えてきた経験は、最新の生成AIや自動化技術を「いかに効率的に、けれど人間味を失わずに使いこなすか」という視点を与えてくれました。</p>
          <p>レガシーなシステムから、最新のAstro、React、生成AI活用まで。現場で「本当に動く」仕組みを、心理的・技術的な両面から設計・構築いたします。</p>
        </div>

        <div class="qual-grid reveal">
          <div class="qual-item highlight-border">
            <h4>Web制作・ICT技術</h4>
            <ul>
              <li>Web制作・システム開発実務 20年以上</li>
              <li>HTML5 / CSS3 / JavaScript (React, Astro)</li>
              <li>生成AI（ChatGPT, Claude）活用設計・定着支援</li>
              <li>業務自動化（LINE連携, Google App Script等）</li>
              <li>情報セキュリティマネジメント / 基本情報技術者</li>
              <li>Cisco認定資格(CCNA等) / ネットワーク設計</li>
            </ul>
          </div>
          <div class="qual-item">
            <h4>心理学・対話設計</h4>
            <ul>
              <li>産業カウンセラー (2002年〜)</li>
              <li>JADP認定 メンタル心理カウンセラー / 上級心理カウンセラー</li>
              <li>不安・迷いを減らす情報設計</li>
              <li>チームコミュニケーション支援</li>
            </ul>
          </div>
          <div class="qual-item">
            <h4>アクセシビリティ・当事者視点</h4>
            <ul>
              <li>バリアフリー住環境アドバイザー</li>
              <li>ユニバーサルデザイン・アクセシビリティ設計</li>
              <li>車いすユーザーとしての利用者視点</li>
              <li>読みやすさ・操作しやすさの改善提案</li>
            </ul>
          </div>
          <div class="qual-item">
            <h4>事業・計数管理</h4>
            <ul>
              <li>日商簿記2級 / 実務・計数管理能力</li>
              <li>業務フロー整理・優先順位設計</li>
              <li>小規模事業の費用対効果をふまえた提案</li>
              <li>公開後の改善・運用サポート</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="section business-overview">
      <div class="section-inner">
        <div class="section-title">
          <span class="eyebrow">Overview</span>
          <h2>事業所概要</h2>
        </div>
        
        <div class="overview-table-wrap reveal">
          <table class="overview-table">
            <tbody>
              <tr>
                <th>屋号</th>
                <td>和-Node（わのーど）</td>
              </tr>
              <tr>
                <th>代表者</th>
                <td>高野 紘純</td>
              </tr>
              <tr>
                <th>所在地</th>
                <td>〒509-0207 岐阜県可児市今渡2347番地1</td>
              </tr>
              <tr>
                <th>連絡先</th>
                <td>Tel: 080-3599-5388<br />Email: <a href="mailto:contacts@wa-node.com">contacts@wa-node.com</a></td>
              </tr>
              <tr>
                <th>事業内容</th>
                <td>
                  <ul>
                    <li><strong>行動心理に基づくWeb制作</strong>：LP・HPの戦略的設計・制作</li>
                    <li><strong>ビジネスの副操縦士（月額制）</strong>：戦略的パートナーとしての継続的な業務改善・保守支援</li>
                    <li><strong>ICT・アプリ連携</strong>：LINE Mini App、自動化ツールの実装</li>
                    <li><strong>組織支援・心理背景活用</strong>：コミュニケーション設計・専門窓口</li>
                    <li><strong>KDP出版支援</strong>：Amazon Kindleを活用したブランディング支援</li>
                  </ul>
                </td>
              </tr>
              <tr>
                <th>対応地域</th>
                <td>全国対応（オンライン完結可）、岐阜・愛知近郊（対面可）</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="section reliability">
      <div class="section-inner">
        <div class="reliability-box reveal">
          <h2>信頼と安全の基盤</h2>
          <div class="trust-grid">
            <div class="trust-item">
              <img src="/images/security-action-one-star.webp" alt="SECURITY ACTION" class="trust-badge" />
              <p>情報セキュリティ対策に真摯に取り組むことを宣言しています。</p>
            </div>
            <div class="trust-content">
              <ul>
                <li><strong>制作クオリティの追求</strong>：心理学的な根拠に基づいた、精度の高い導線設計を約束します。</li>
                <li><strong>プロとしての倫理観</strong>：産業カウンセラーとしての守秘義務を遵守し、情報を厳重に管理します。</li>
                <li><strong>誠実な価格提示</strong>：事前見積りのない追加料金や、不透明な請求は一切行いません。</li>
              </ul>
              <div class="policy-links">
                <a href="/privacy/">プライバシーポリシー</a>
                <a href="/security-policy/">情報セキュリティ方針</a>
                <a href="/terms/">利用規約</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section contact-teaser">
      <div class="section-inner text-center">
        <h2 class="reveal">技術と心理で、ビジネスを一本の導線に。</h2>
        <p class="reveal">初回無料相談（30分〜60分）にて、あなたの課題と「目指すべき姿」を整理します。<br />まずはお気軽にお話を聞かせてください。</p>
        <div class="btns reveal" style="justify-content: center;">
          <a href="/contact/" class="btn primary">無料で相談し、必要に応じて構成案を検討する</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .about-hero {
    background: linear-gradient(135deg, #fdfcf9 0%, #f7f1e6 100%);
    text-align: center;
    padding: 120px 0 80px;
    border-bottom: 1px solid var(--line);
  }
  .about-hero h1 { font-size: clamp(2.5rem, 6vw, 4rem); margin-bottom: 24px; color: var(--text-deep); }

  .name-origin-hero {
    max-width: 780px;
    margin: 30px auto 26px;
    padding-left: 24px;
    border-left: 4px solid var(--accent);
    text-align: left;
  }
  .name-origin-hero h2 {
    margin: 0 0 16px;
    color: var(--text-deep);
    font-size: clamp(1.35rem, 3vw, 1.8rem);
  }
  .name-origin-hero p {
    margin: 0 0 12px;
    color: #444;
    font-size: 1rem;
    line-height: 1.9;
  }
  .name-origin-hero p:last-child { margin-bottom: 0; }
  
  .message-content {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .catch-copy {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--accent);
    margin-bottom: 24px;
    font-family: 'Shippori Mincho', serif;
    font-weight: 800;
    line-height: 1.3;
  }
  .message-content p { margin-bottom: 20px; color: #444; font-size: 1.05rem; }
  
  .profile-image-wrap {
    text-align: center;
    background: #fff;
    padding: 40px;
    border-radius: 40px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    border: 1px solid var(--line);
  }
  .profile-image-wrap img {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 24px;
    background: var(--soft);
  }
  .name-jp { font-size: 1.5rem; font-weight: 800; margin-bottom: 4px; }
  .name-en { font-size: 0.9rem; color: var(--accent); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; }

  .story-box {
    background: var(--soft);
    padding: 48px;
    border-radius: 24px;
    border: 1px solid var(--line);
    margin-bottom: 40px;
  }
  .story-box h3 { margin-bottom: 24px; color: var(--accent); font-weight: 800; }
  .story-box p { margin-bottom: 16px; color: #444; line-height: 1.8; }

  .qual-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .qual-item {
    background: #fff;
    padding: 40px;
    border-radius: 24px;
    border: 1px solid var(--line);
  }
  .qual-item.highlight-border { border: 2px solid var(--accent); }
  .qual-item h4 { margin-bottom: 20px; color: var(--accent); border-bottom: 1px solid var(--line); padding-bottom: 10px; font-weight: 800; }
  .qual-item ul { list-style: none; padding: 0; }
  .qual-item li { position: relative; padding-left: 20px; margin-bottom: 12px; font-size: 0.95rem; color: #555; }
  .qual-item li::before { content: "•"; position: absolute; left: 0; color: var(--accent); font-weight: 800; }

  .overview-table-wrap {
    background: #fff;
    border-radius: 24px;
    border: 1px solid var(--line);
    overflow: hidden;
  }
  .overview-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }
  .overview-table th, .overview-table td {
    padding: 24px;
    border-bottom: 1px solid var(--line);
  }
  .overview-table th {
    background: var(--soft);
    width: 250px;
    font-weight: 800;
    color: var(--accent);
    vertical-align: top;
  }
  .overview-table td ul { padding-left: 20px; list-style: none; padding: 0; }
  .overview-table td li { margin-bottom: 8px; }
  .overview-table td li strong { color: var(--accent-dark); }
  .overview-table tr:last-child th, .overview-table tr:last-child td { border-bottom: none; }

  .reliability-box {
    background: linear-gradient(135deg, #142f3a 0%, #10222b 100%);
    color: #f8fbfc;
    padding: 80px 60px;
    border-radius: 40px;
  }
  .reliability-box h2 { color: #f6d88f; margin-bottom: 40px; font-weight: 900; }
  .trust-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 48px; align-items: center; }
  .trust-badge { width: 150px; background: #fff; border-radius: 12px; padding: 10px; box-shadow: 0 12px 28px rgba(0,0,0,0.18); }
  .trust-item p {
    margin: 18px 0 0;
    color: rgba(248, 251, 252, 0.92);
    line-height: 1.8;
    font-weight: 700;
  }
  .trust-content ul { list-style: none; padding: 0; margin-bottom: 32px; }
  .trust-content li { margin-bottom: 16px; font-size: 0.98rem; color: rgba(248, 251, 252, 0.9); line-height: 1.75; }
  .trust-content strong { color: #f6d88f; }
  
  .policy-links { display: flex; gap: 12px; flex-wrap: wrap; }
  .policy-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 9px 15px;
    border: 1px solid rgba(248, 251, 252, 0.26);
    border-radius: 999px;
    background: rgba(255,255,255,0.1);
    color: #fff8e8;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 800;
    opacity: 1;
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease, transform 0.25s ease;
  }
  .policy-links a:hover { background: #f6d88f; border-color: #f6d88f; color: #10222b; transform: translateY(-1px); }

  .text-center { text-align: center; }

  @media (max-width: 820px) {
    .message-content, .trust-grid, .qual-grid { grid-template-columns: 1fr; }
    .name-origin-hero { padding-left: 18px; }
    .content-right { order: -1; }
    .profile-image-wrap img { width: 160px; height: 160px; }
    .overview-table th { width: 120px; font-size: 0.9rem; padding: 15px; }
    .overview-table td { padding: 15px; font-size: 0.9rem; }
    .reliability-box { padding: 40px 20px; border-radius: 28px; }
    .policy-links a { width: 100%; }
  }
</style>


