---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  createBreadcrumbSchema,
  createWebPageSchema,
  organizationSchema,
} from '../data/structuredData';

const title = '地域サロン・整体向け予約導線LPデモ｜和-Node';
const description =
  '地域サロン・整体院を想定した架空LPデモ。初回来店前の不安、料金、流れ、アクセス、LINE予約導線を分かりやすく整理したサンプルです。';
const structuredData = [
  organizationSchema,
  createWebPageSchema({
    name: title,
    description,
    path: '/salon-reservation-demo/',
  }),
  createBreadcrumbSchema([
    { name: 'ホーム', path: '/' },
    { name: '制作例・デモ', path: '/works/' },
    { name: '地域サロン・整体向け予約導線LPデモ', path: '/salon-reservation-demo/' },
  ]),
];

const worries = [
  {
    label: '料金',
    title: 'いくらかかるか分からない',
    text: '初回料金、通常料金、所要時間を先に見せることで、予約前の迷いを減らします。',
  },
  {
    label: '流れ',
    title: '何をされるのか不安',
    text: '受付からカウンセリング、ケア、次回提案まで、初回の流れを短く見える化します。',
  },
  {
    label: '予約',
    title: '電話するのが少し面倒',
    text: 'LINE、フォーム、電話の入口を分け、今すぐ予約しない人も空き状況を確認しやすくします。',
  },
];

const menuItems = [
  {
    name: '初回コンディションチェック',
    price: '5,500円',
    time: '約60分',
    desc: '姿勢や生活習慣を確認し、今の状態に合わせたケア方針を一緒に整理します。',
  },
  {
    name: 'リラックス整体コース',
    price: '6,600円',
    time: '約50分',
    desc: '仕事や家事でたまりやすいこわばりに配慮し、無理のない範囲で体を整えます。',
  },
  {
    name: '産後・育児中サポート',
    price: '6,600円',
    time: '約50分',
    desc: '抱っこや授乳姿勢など、毎日の負担が出やすい方に向けたやさしいケアです。',
  },
];

const steps = [
  ['1', '空き状況を確認', 'LINEまたはフォームで希望日時を送ります。'],
  ['2', '事前メモを共有', '気になること、避けたいこと、来店目的を短く確認します。'],
  ['3', '初回カウンセリング', '料金、流れ、ケア方針を説明してから始めます。'],
  ['4', '必要な次回提案', '通い方は状態や希望に合わせて相談できます。'],
];
---

<BaseLayout title={title} description={description} image="/portfolio-lp/images/hero_sekkotsu.png" structuredData={structuredData}>
  <main class="salon-demo-page">
    <section class="salon-hero">
      <div class="hero-overlay"></div>
      <div class="sample-label">架空サンプルLP</div>
      <div class="hero-content">
        <p class="eyebrow">Local Salon Reservation LP</p>
        <h1>はじめてでも迷わず予約できる、地域サロンの導線LP。</h1>
        <p class="hero-lead">
          料金、初回の流れ、アクセス、予約方法を先に見せて、来店前の不安を減らすサンプルです。
          LINE予約・Googleマップ・フォーム相談まで、スマホで迷わない導線を想定しています。
        </p>
        <div class="hero-actions">
          <a href="#reservation" class="btn-primary">LINEで空き確認</a>
          <a href="#menu" class="btn-secondary">料金と流れを見る</a>
        </div>
        <div class="hero-trust">
          <span>初回60分</span>
          <span>女性スタッフ対応可</span>
          <span>駐車場あり</span>
        </div>
      </div>
    </section>

    <section class="section intro-band">
      <div class="container intro-grid">
        <div>
          <p class="eyebrow">Before Booking</p>
          <h2>予約前の「小さな不安」を先回りして減らす。</h2>
        </div>
        <p>
          地域サロンや整体院では、技術説明よりも先に「料金は分かるか」「初回は何をするか」
          「予約は簡単か」が見られます。このデモは、初回来店前の不安を減らす順番で情報を並べています。
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Anxiety Points</p>
          <h2>初回来店前に見られやすい3つの不安</h2>
        </div>
        <div class="worry-grid">
          {worries.map((item) => (
            <article class="worry-card">
              <span>{item.label}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section menu-section" id="menu">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Menu</p>
          <h2>料金と所要時間を先に見せる</h2>
          <p>価格と時間が分かるだけで、問い合わせ前の心理的な負担はかなり軽くなります。</p>
        </div>
        <div class="menu-grid">
          {menuItems.map((item) => (
            <article class="menu-card">
              <div>
                <span class="menu-time">{item.time}</span>
                <h3>{item.name}</h3>
                <p>{item.desc}</p>
              </div>
              <strong>{item.price}</strong>
            </article>
          ))}
        </div>
        <p class="menu-note">このページは架空サンプルです。料金や内容は実在店舗のものではありません。</p>
      </div>
    </section>

    <section class="section flow-section">
      <div class="container flow-layout">
        <div class="flow-copy">
          <p class="eyebrow">First Visit Flow</p>
          <h2>初回の流れを、短い4ステップで見える化。</h2>
          <p>
            「何をされるのか分からない」という不安を減らすため、予約前に流れを見せます。
            長い説明ではなく、スマホでざっと確認できる量に抑えるのがポイントです。
          </p>
        </div>
        <div class="flow-list">
          {steps.map(([num, title, text]) => (
            <article class="flow-item">
              <span>{num}</span>
              <div>
                <h3>{title}</h3>
                <p>{text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section ict-section" id="reservation">
      <div class="container ict-grid">
        <div class="ict-copy">
          <p class="eyebrow">Reservation Route</p>
          <h2>LINE予約、Googleマップ、フォームをひとつの流れに。</h2>
          <p>
            地域型の店舗では、検索から地図、口コミ、空き確認、予約までの導線が重要です。
            お客様が使いやすい入口を用意し、事業者側の返信負担も減らせる構成を想定しています。
          </p>
        </div>
        <div class="route-panel" aria-label="予約導線サンプル">
          <a href="#faq">よくある質問を確認</a>
          <a href="#access">Googleマップで場所を見る</a>
          <a href="/contact/">このLPの制作を相談する</a>
        </div>
      </div>
    </section>

    <section class="section access-section" id="access">
      <div class="container access-grid">
        <div class="access-photo" aria-label="サロンのイメージ写真"></div>
        <div class="access-copy">
          <p class="eyebrow">Access</p>
          <h2>来店前に知りたい情報を、ひとまとめに。</h2>
          <dl>
            <div><dt>所在地</dt><dd>福岡県内の駅近サロンを想定</dd></div>
            <div><dt>駐車場</dt><dd>店舗前に1台分あり</dd></div>
            <div><dt>支払い</dt><dd>現金・主要キャッシュレス対応</dd></div>
            <div><dt>予約</dt><dd>LINE、フォーム、電話から選択可</dd></div>
          </dl>
        </div>
      </div>
    </section>

    <section class="section faq-section" id="faq">
      <div class="container faq-layout">
        <div class="section-heading">
          <p class="eyebrow">FAQ</p>
          <h2>予約前のよくある質問</h2>
        </div>
        <div class="faq-list">
          <details>
            <summary>はじめてでも大丈夫ですか？</summary>
            <p>大丈夫です。初回は状態や希望を確認し、無理のない範囲で進める想定です。</p>
          </details>
          <details>
            <summary>強い勧誘はありますか？</summary>
            <p>このサンプルでは、必要な通い方は説明しつつ、判断を急がせない導線を想定しています。</p>
          </details>
          <details>
            <summary>どんな服装で行けばよいですか？</summary>
            <p>動きやすい服装がおすすめです。着替えの有無も事前に案内しておくと安心につながります。</p>
          </details>
          <details>
            <summary>LINE以外でも予約できますか？</summary>
            <p>フォームや電話にも対応できる構成です。お客様が使いやすい方法を選べるようにします。</p>
          </details>
        </div>
      </div>
    </section>

    <section class="final-cta">
      <div class="container final-cta-inner">
        <p class="eyebrow">Wa-Node Demo</p>
        <h2>地域店舗の予約導線を、この方向で整えませんか。</h2>
        <p>サロン、整体、教室、予約制サービスなど、初回前の不安を減らすLP制作に応用できます。</p>
        <a href="/contact/" class="btn-primary">この方向で相談する</a>
      </div>
    </section>

    <nav class="mobile-sticky" aria-label="予約導線">
      <a href="#reservation">空き確認</a>
      <a href="/contact/">制作相談</a>
    </nav>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #f6f8f3;
  }

  .salon-demo-page {
    --ink: #1d302d;
    --muted: #61706a;
    --sage: #3f7c6b;
    --sage-dark: #245c52;
    --coral: #d86f56;
    --cream: #fff7ed;
    --mist: #e6f1ed;
    --line: rgba(36, 92, 82, 0.16);
    color: var(--ink);
    font-family: 'Outfit', 'Noto Sans JP', sans-serif;
  }

  .container {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .section {
    padding: 92px 0;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--coral);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    letter-spacing: 0;
  }

  .salon-hero {
    position: relative;
    display: flex;
    min-height: 78vh;
    align-items: center;
    overflow: hidden;
    padding: 150px 0 110px;
    background:
      linear-gradient(90deg, rgba(246, 248, 243, 0.96) 0%, rgba(246, 248, 243, 0.9) 43%, rgba(246, 248, 243, 0.32) 72%),
      url('/portfolio-lp/images/hero_sekkotsu.png') center right / cover no-repeat;
  }

  .hero-overlay {
    position: absolute;
    inset: auto 0 0;
    height: 28%;
    background: linear-gradient(0deg, #f6f8f3, rgba(246, 248, 243, 0));
    pointer-events: none;
  }

  .sample-label {
    position: absolute;
    top: 100px;
    left: max(20px, calc((100vw - 1120px) / 2));
    z-index: 1;
    padding: 7px 14px;
    border: 1px solid rgba(216, 111, 86, 0.32);
    border-radius: 999px;
    background: rgba(255, 247, 237, 0.88);
    color: var(--coral);
    font-size: 0.76rem;
    font-weight: 800;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: min(650px, calc(100% - 40px));
    margin-left: max(20px, calc((100vw - 1120px) / 2));
  }

  .hero-content h1 {
    margin: 0;
    max-width: 640px;
    font-size: clamp(2.35rem, 5.4vw, 4.8rem);
    font-weight: 900;
    line-height: 1.08;
  }

  .hero-lead {
    max-width: 620px;
    margin: 26px 0 0;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.9;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 14px 24px;
    font-weight: 800;
    text-decoration: none;
    transition: 0.25s ease;
  }

  .btn-primary {
    background: var(--sage-dark);
    color: #fff;
    box-shadow: 0 16px 34px rgba(36, 92, 82, 0.22);
  }

  .btn-secondary {
    border: 1px solid rgba(36, 92, 82, 0.3);
    background: rgba(255, 255, 255, 0.74);
    color: var(--sage-dark);
  }

  .btn-primary:hover,
  .btn-secondary:hover {
    transform: translateY(-2px);
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .hero-trust span {
    padding: 8px 12px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.66);
    color: var(--sage-dark);
    font-size: 0.85rem;
    font-weight: 800;
  }

  .intro-band {
    background: linear-gradient(135deg, #ffffff, var(--mist));
    border-block: 1px solid var(--line);
  }

  .intro-grid,
  .ict-grid,
  .access-grid,
  .flow-layout {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 56px;
    align-items: center;
  }

  .intro-grid h2,
  .section-heading h2,
  .flow-copy h2,
  .ict-copy h2,
  .access-copy h2,
  .final-cta h2 {
    margin: 0;
    font-size: clamp(1.75rem, 3.2vw, 2.7rem);
    font-weight: 900;
    line-height: 1.24;
  }

  .intro-grid p,
  .section-heading p,
  .flow-copy p,
  .ict-copy p,
  .access-copy p,
  .final-cta p {
    color: var(--muted);
    line-height: 1.9;
  }

  .section-heading {
    max-width: 780px;
    margin-bottom: 34px;
  }

  .worry-grid,
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .worry-card,
  .menu-card {
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 16px 36px rgba(29, 48, 45, 0.055);
  }

  .worry-card {
    padding: 26px;
  }

  .worry-card span,
  .menu-time {
    display: inline-flex;
    margin-bottom: 16px;
    padding: 5px 10px;
    border-radius: 999px;
    background: rgba(216, 111, 86, 0.12);
    color: var(--coral);
    font-size: 0.76rem;
    font-weight: 800;
  }

  .worry-card h3,
  .menu-card h3,
  .flow-item h3 {
    margin: 0 0 10px;
    font-size: 1.18rem;
    line-height: 1.45;
  }

  .worry-card p,
  .menu-card p,
  .flow-item p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .menu-section {
    background: #fffaf2;
  }

  .menu-card {
    display: flex;
    min-height: 280px;
    flex-direction: column;
    justify-content: space-between;
    padding: 28px;
  }

  .menu-card strong {
    display: block;
    margin-top: 24px;
    color: var(--sage-dark);
    font-size: 1.75rem;
  }

  .menu-note {
    margin: 22px 0 0;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .flow-section {
    background: linear-gradient(135deg, var(--mist), #f8fbf8);
  }

  .flow-list {
    display: grid;
    gap: 14px;
  }

  .flow-item {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 16px;
    align-items: start;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.76);
  }

  .flow-item > span {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border-radius: 50%;
    background: var(--sage-dark);
    color: #fff;
    font-weight: 900;
  }

  .ict-section {
    background: #f6f8f3;
  }

  .route-panel {
    display: grid;
    gap: 14px;
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: linear-gradient(180deg, #fff, #f0f7f3);
    box-shadow: 0 18px 42px rgba(36, 92, 82, 0.08);
  }

  .route-panel a {
    display: flex;
    min-height: 58px;
    align-items: center;
    justify-content: space-between;
    border-radius: 16px;
    padding: 16px 18px;
    background: #fff;
    color: var(--sage-dark);
    font-weight: 800;
    text-decoration: none;
    box-shadow: inset 0 0 0 1px var(--line);
  }

  .route-panel a::after {
    content: "→";
    color: var(--coral);
    font-size: 1.2rem;
  }

  .access-section {
    background: #fff;
  }

  .access-photo {
    min-height: 420px;
    border-radius: 30px;
    background:
      linear-gradient(0deg, rgba(36, 92, 82, 0.22), rgba(36, 92, 82, 0.02)),
      url('/portfolio-lp/images/hero_beauty.png') center / cover no-repeat;
    box-shadow: 0 24px 50px rgba(29, 48, 45, 0.14);
  }

  .access-copy dl {
    display: grid;
    gap: 12px;
    margin: 28px 0 0;
  }

  .access-copy dl div {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
  }

  .access-copy dt {
    color: var(--sage-dark);
    font-weight: 900;
  }

  .access-copy dd {
    margin: 0;
    color: var(--muted);
  }

  .faq-section {
    background: #f6f8f3;
  }

  .faq-layout {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 44px;
    align-items: start;
  }

  .faq-list {
    display: grid;
    gap: 12px;
  }

  .faq-list details {
    border: 1px solid var(--line);
    border-radius: 16px;
    background: #fff;
    overflow: hidden;
  }

  .faq-list summary {
    cursor: pointer;
    padding: 18px 20px;
    color: var(--ink);
    font-weight: 900;
  }

  .faq-list p {
    margin: 0;
    padding: 0 20px 18px;
    color: var(--muted);
    line-height: 1.8;
  }

  .final-cta {
    padding: 98px 0;
    background:
      linear-gradient(135deg, rgba(36, 92, 82, 0.94), rgba(63, 124, 107, 0.9)),
      url('/portfolio-lp/images/hero_sekkotsu.png') center / cover no-repeat;
    color: #fff;
  }

  .final-cta-inner {
    max-width: 760px;
    text-align: center;
  }

  .final-cta .eyebrow,
  .final-cta p {
    color: rgba(255, 255, 255, 0.84);
  }

  .final-cta .btn-primary {
    margin-top: 22px;
    background: #fff;
    color: var(--sage-dark);
  }

  .mobile-sticky {
    display: none;
  }

  @media (max-width: 900px) {
    .salon-hero {
      min-height: auto;
      padding: 132px 0 88px;
      background:
        linear-gradient(180deg, rgba(246, 248, 243, 0.98) 0%, rgba(246, 248, 243, 0.9) 55%, rgba(246, 248, 243, 0.55) 100%),
        url('/portfolio-lp/images/hero_sekkotsu.png') center / cover no-repeat;
    }

    .sample-label {
      top: 88px;
      left: 20px;
    }

    .hero-content {
      margin-inline: auto;
      width: min(100% - 40px, 640px);
    }

    .intro-grid,
    .ict-grid,
    .access-grid,
    .flow-layout,
    .faq-layout {
      grid-template-columns: 1fr;
      gap: 34px;
    }

    .worry-grid,
    .menu-grid {
      grid-template-columns: 1fr;
    }

    .section {
      padding: 70px 0;
    }

    .access-photo {
      min-height: 300px;
    }
  }

  @media (max-width: 640px) {
    .container {
      width: min(100% - 28px, 1120px);
    }

    .hero-content h1 {
      font-size: clamp(2.15rem, 13vw, 3.25rem);
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
    }

    .access-copy dl div {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .mobile-sticky {
      position: sticky;
      bottom: 0;
      z-index: 20;
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-top: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.94);
      backdrop-filter: blur(10px);
    }

    .mobile-sticky a {
      display: grid;
      min-height: 56px;
      place-items: center;
      color: var(--sage-dark);
      font-weight: 900;
      text-decoration: none;
