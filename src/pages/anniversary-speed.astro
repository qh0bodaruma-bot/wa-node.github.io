---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "【起業記念Plan A】選ばれる導線・速戦LP案 | 和-Node",
  "description": "心理学の知見で「安心して選ばれる」サイトへ。和-Node起業記念キャンペーン限定の速戦LPパッケージ。",
};
---
<BaseLayout 
  title="【起業記念Plan A】選ばれる導線・速戦LP制作｜和-Node" 
  description="心理学の知見で「安心して選ばれる」サイトへ。和-Node起業記念キャンペーン限定の速戦LPパッケージ。"
>
  <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap" rel="stylesheet">

  <div class="campaign-page">
    <!-- Sakura Container -->
    <div class="sakura-container" id="sakura-container"></div>
    <script is:inline>
      function initPremiumEffects() {
        const container = document.getElementById('sakura-container');
        if (!container) return;
        container.innerHTML = '';
        for (let i = 0; i < 40; i++) {
          const petal = document.createElement('div');
          petal.className = 'petal';
          petal.style.left = Math.random() * 100 + '%';
          petal.style.width = Math.random() * 10 + 5 + 'px';
          petal.style.height = petal.style.width;
          petal.style.animationDuration = Math.random() * 5 + 5 + 's';
          petal.style.animationDelay = Math.random() * 5 + 's';
          container.appendChild(petal);
        }
      }
      initPremiumEffects();
      document.addEventListener('astro:page-load', initPremiumEffects);
    </script>

    <main class="plan-a-page">
      <!-- Back Link -->
      <nav class="back-nav container reveal">
        <a href="/campaign-anniversary/" class="back-link">← キャンペーンポータルに戻る</a>
      </nav>

      <!-- Mini Hero -->
      <section class="plan-hero">
        <div class="container">
          <span class="plan-label">Plan A: Standard</span>
          <h1 class="premium-heading">行動心理に基づくWeb制作・LP制作<br/>（速戦プラン）</h1>
          <p class="plan-subtitle">「伝わらない」を、心理学で「選ばれる」に変える。</p>
          <div class="campaign-price-tag reveal">
            <span class="label">起業記念 20% OFF</span>
            <span class="price">52,800円<small>(税込)</small></span>
            <span class="old">通常 66,000円(税込)</span>
          </div>
        </div>
      </section>

      <!-- Psychology Focus -->
      <section class="psychology-demo">
        <div class="container">
          <div class="demo-box reveal">
            <h2>このLP自体が「選ばれる導線設計」のデモです</h2>
            <p>人は「不安」があるとき、行動を止めてしまいます。Plan Aでは、以下の3つの心理的アプローチを標準装備しています。</p>
            
            <div class="logic-grid">
              <div class="logic-item">
                <span class="num">01</span>
                <h4>社会的証明の最適化</h4>
                <p>実績や声を「ただ載せる」のではなく、信頼が最大化されるタイミングで配置します。</p>
              </div>
              <div class="logic-item">
                <span class="num">02</span>
                <h4>認知負荷の軽減</h4>
                <p>情報を整理し、迷いをなくすことで、最後までストレスなく読み進められる設計を行います。</p>
              </div>
              <div class="logic-item">
                <span class="num">03</span>
                <h4>一貫性の原理</h4>
                <p>ユーザーの小さな「Yes」を積み重ね、自然にお問い合わせへと導きます。</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Options Included -->
      <section class="options-list">
        <div class="container">
          <h2 class="reveal premium-heading">速戦プランに含まれる標準的な制作内容</h2>
          <div class="option-cards">
            <div class="o-card reveal">
              <h3>心理分析・構成作成</h3>
              <p>ターゲットの悩みを深掘りし、刺さるキャッチコピーと構成をゼロから提案します。</p>
            </div>
            <div class="o-card reveal">
              <h3>マイクロアニメーション</h3>
              <p>ボタンや文字に命を吹き込み、「動いている＝生きているサイト」という安心感を与えます。</p>
            </div>
            <div class="o-card reveal">
              <h3>レスポンシブ・スピード改善</h3>
              <p>スマホでの読み心地を徹底追及。1秒の遅れによる離脱を最小限に抑えます。</p>
            </div>
            <div class="o-card reveal">
              <h3>Googleアナリティクス設定</h3>
              <p>公開して終わりではなく、どこまで読まれたか「次の一歩」のための計測基盤も構築します。</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Why Wait? -->
      <section class="cta-section">
        <div class="container reveal">
          <div class="cta-inner">
            <h2>まずは「たたき台」を見てから判断しませんか？</h2>
            <p>和-Nodeは、ご相談後に1ページのたたき台を無料作成します。実物を見て、納得してから進める。それも一つの「安心」です。</p>
            <a href="/contact/?plan=A" class="btn-primary">キャンペーン価格で無料相談する</a>
            <p class="limit">※月3名様まで丁寧に対応</p>
          </div>
        </div>
      </section>

      <div class="footer-nav container reveal">
        <a href="/campaign-anniversary/" class="btn-secondary-outline">他の限定プランも見る</a>
      </div>
    </main>
  </div>
</BaseLayout>

<style is:global>
  .campaign-page {
    background: #fdfcf9 !important;
    color: #2c2c2c !important;
    overflow-x: hidden;
    position: relative;
    font-family: 'Shippori Mincho', serif !important;
  }
  .campaign-page::before {
    content: "" !important;
    position: fixed !important;
    top: 0; left: 0; width: 100%; height: 100%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3FfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3F/filter%3E%3Frect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3F/svg%3E") !important;
    opacity: 0.1 !important;
    pointer-events: none !important;
    z-index: 1000 !important;
  }
  .sakura-container {
    position: fixed !important;
    top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none !important;
    z-index: 900 !important;
  }
  .petal {
    position: absolute !important;
    background: #ffb7c5 !important;
    border-radius: 150% 0 150% 0 !important;
    opacity: 0.7 !important;
    animation: fall linear infinite;
  }
  @keyframes fall {
    0% { transform: translateY(-10vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.7; }
    90% { opacity: 0.7; }
    100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
  }

  .premium-heading {
    font-family: 'Shippori Mincho', serif !important;
    font-weight: 800 !important;
    letter-spacing: 0.05em;
  }

  .back-nav { padding-top: 40px; }
  .back-link {
    color: #c5a059;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: 0.3s;
  }
  .back-link:hover { color: #d14d3a; transform: translateX(-5px); display: inline-block; }

  .plan-hero { padding: 80px 0 60px; text-align: center; }
  .plan-label {
    display: inline-block; background: #c5a059; color: white;
    padding: 5px 15px; border-radius: 4px; font-weight: 800; margin-bottom: 20px;
  }
  .plan-subtitle { font-size: 1.1rem; opacity: 0.8; margin-top: 10px; }
  
  .campaign-price-tag {
    display: inline-flex; flex-direction: column; align-items: center;
    padding: 20px 40px; background: white; border: 2px solid #d14d3a;
    border-radius: 12px; margin-top: 30px;
    box-shadow: 0 10px 30px rgba(209, 77, 58, 0.1);
  }
  .campaign-price-tag .label { color: #d14d3a; font-weight: 800; margin-bottom: 5px; }
  .campaign-price-tag .price { font-size: 2.8rem; font-weight: 900; color: #d14d3a; }
  .campaign-price-tag .old { font-size: 1.1rem; color: #999; text-decoration: line-through; }

  .psychology-demo { padding: 100px 0; }
  .demo-box {
    background: white; padding: 60px; border-radius: 30px;
    border: 1px solid rgba(197, 160, 89, 0.3);
    box-shadow: 0 15px 50px rgba(197, 160, 89, 0.08);
  }
  .logic-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 40px; margin-top: 50px;
  }
  .logic-item .num { font-size: 1.8rem; font-weight: 800; color: #c5a059; opacity: 0.3; }
  .logic-item h4 { margin: 15px 0; font-size: 1.3rem; border-bottom: 1px solid #f0e6d2; padding-bottom: 10px; }

  .options-list { padding: 100px 0; background: rgba(197, 160, 89, 0.03); }
  .option-cards {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 30px; margin-top: 50px;
  }
  .o-card {
    background: white; padding: 40px; border-radius: 20px;
    border: 1px solid #f0f0f0; transition: 0.4s;
  }
  .o-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.05); border-color: #c5a059; }
  .o-card h3 { font-size: 1.2rem; margin-bottom: 15px; color: #c5a059; }

  .cta-section { padding: 120px 0; }
  .cta-inner {
    background: #c5a059; color: white; padding: 80px 40px;
    border-radius: 40px; text-align: center;
    box-shadow: 0 20px 50px rgba(197, 160, 89, 0.3);
  }
  .btn-primary {
    display: inline-block; background: white; color: #c5a059;
    padding: 22px 60px; border-radius: 100px; font-weight: 900;
    text-decoration: none; margin-top: 40px; font-size: 1.4rem;
    transition: 0.3s;
  }
  .btn-primary:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.2); }

  .footer-nav { padding-bottom: 80px; text-align: center; }
  .btn-secondary-outline {
    display: inline-block; border: 2px solid #c5a059; color: #c5a059;
    padding: 15px 40px; border-radius: 50px; text-decoration: none;
    font-weight: 800; transition: 0.3s;
  }
  .btn-secondary-outline:hover { background: #c5a059; color: white; }

  @media (max-width: 768px) {
    .cta-inner { padding: 40px 20px; }
    .demo-box { padding: 30px 20px; }
  }
</style>
