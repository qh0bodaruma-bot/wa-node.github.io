    .lp-choice-guide h2 { font-size: 1.55rem; }
    .lp-choice-grid { grid-template-columns: 1fr; }
    .lp-choice-card { min-height: auto; }
    .section-head { text-align: left; }
    .lp-value-grid,
    .lp-scope-grid,
    .lp-build-steps,
    .lp-customize-section,
    .lp-customize-list ul {
      grid-template-columns: 1fr;
    }
    .lp-scope-section,
    .lp-build-flow,
    .lp-customize-section {
      padding: 28px 20px;
    }
