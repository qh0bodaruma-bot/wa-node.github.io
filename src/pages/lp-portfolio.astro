---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConsultationFlow from '../components/ConsultationFlow.astro';
import {
  createBreadcrumbSchema,
  createWebPageSchema,
  organizationSchema,
} from '../data/structuredData';

const title = "LP制作サンプルギャラリー｜和-Node";
const description = "和-Nodeが業種別に用意した全14種類のランディングページ（LP）制作サンプルです。業種ごとの不安・比較・申込心理に合わせた設計意図と工夫を確認できます。";
const structuredData = [
  organizationSchema,
  createWebPageSchema({ name: title, description, path: "/lp-portfolio/", type: "CollectionPage" }),
  createBreadcrumbSchema([
    { name: "ホーム", path: "/" },
    { name: "LP制作サンプルギャラリー", path: "/lp-portfolio/" },
  ]),
];

const valueBlocks = [
  {
    label: "Research",
    title: "初見の不安を先回りする構成",
    text: "業種ごとに、ユーザーが迷いやすい料金、信頼材料、申込前の不安を洗い出し、見せる順番を調整します。",
  },
  {
    label: "Writing",
    title: "原稿をそのまま並べない文章整理",
    text: "強み、対象者、選ばれる理由を読み手の判断順に合わせて整理。見出し、補足文、CTA文言まで整えます。",
  },
  {
    label: "Design",
    title: "業種に合わせた第一印象づくり",
    text: "信頼感、高級感、親しみ、専門性など、目的に合う印象へ寄せながら、スマホで読める余白と文字量に調整します。",
  },
  {
    label: "Conversion",
    title: "相談・予約・購入への導線",
    text: "ボタンの位置、フォーム前の安心材料、よくある質問、料金表示を整え、次の行動に進みやすくします。",
  },
];

const scopeTiers = [
  {
    name: "シンプルLP",
    price: "24,000円〜",
    target: "まず1ページを用意したい",
    detail: "短めの縦幅、既存原稿中心、最低限のCTA。名刺代わりや小さなキャンペーン向け。",
  },
  {
    name: "推奨LP",
    price: "64,000円〜",
    target: "相談・予約につなげたい",
    detail: "構成整理、見出し設計、心理導線、FAQ、料金・流れの見せ方まで含めた標準制作。",
  },
  {
    name: "連携つきLP",
    price: "120,000円〜",
    target: "公開後の対応も整えたい",
    detail: "フォーム、LINE、メール自動送信、予約導線、計測改善などを必要範囲に合わせて追加。",
  },
];

const buildSteps = [
  "目的とゴールを整理",
  "誰に何を伝えるかを決める",
  "情報の順番とCTAを設計",
  "文章・デザイン・スマホ表示を制作",
  "公開後の改善ポイントを確認",
];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <!-- Background Decor -->
  <div class="bg-decoration">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="grid-overlay"></div>
  </div>

  <main class="lp-portfolio-page" data-glossary-skip>
    <header class="page-header reveal">
      <div class="container">
        <span class="eyebrow">LP Production Gallery</span>
        <h1 class="page-title">和-Nodeが贈る、<br/><span class="accent-text">業種別LP制作<br class="mobile-title-break" />サンプル集</span></h1>
        <p class="page-desc">
          見た目だけで終わらせず、相談・予約・申込みにつながる理由まで見えるLPサンプル集です。<br />
          医療、美容、IT、不動産、教育、アートなど、全14種類の制作サンプルと、それぞれの設計意図を比較できます。
        </p>
        <p class="sample-disclaimer">
          ※掲載LPはすべて架空の業種・商品・団体を題材にした自主制作サンプルです。実在の実績・企業・成果を示すものではなく、業種別の表現例としてご覧ください。
        </p>
        <div class="lp-price-summary">
          <span>参考価格の目安</span>
          <strong>シンプルLP 24,000円〜 / 推奨LP 64,000円〜 / 連携つき 120,000円〜</strong>
          <small>業種別サンプルの多くは、構成・文章・導線設計を含む「推奨LP」以上を想定しています。</small>
        </div>
        <ol class="lp-reading-guide" aria-label="LPサンプルの見方">
          <li>
            <span>Purpose</span>
            <strong>業種より目的で選ぶ</strong>
            <p>予約、販売、採用、相談など、近い目的から見ると判断しやすくなります。</p>
          </li>
          <li>
            <span>Reason</span>
            <strong>設計意図を見る</strong>
            <p>なぜその構成なのかを確認すると、自社LPに必要な要素が見えてきます。</p>
          </li>
          <li>
            <span>Budget</span>
            <strong>参考価格を合わせる</strong>
            <p>近いサンプルと予算感をもとに、制作範囲を絞って相談できます。</p>
          </li>
        </ol>
      </div>
    </header>

    <div class="container">
      <section class="lp-choice-guide reveal" aria-labelledby="lp-choice-title">
        <span class="eyebrow">Choose by Purpose</span>
        <h2 id="lp-choice-title">目的が近いサンプルから選べます</h2>
        <p>業種が完全に一致していなくても大丈夫です。まずは近い目的のLPを見ると、必要な構成や相談時の優先順位が掴みやすくなります。</p>
        <div class="lp-choice-grid">
          <a href="/portfolio-lp/lp_clinic.html" class="lp-choice-card main">
            <span>予約・相談を増やしたい</span>
            <h3>信頼形成型LP</h3>
            <p>医療・美容・士業など、安心感が成果に直結する事業に向いた構成です。</p>
          </a>
          <a href="/portfolio-lp/lp_ec.html" class="lp-choice-card">
            <span>商品・サービスを売りたい</span>
            <h3>販売促進型LP</h3>
            <p>EC、SaaS、セミナーなど、魅力とベネフィットを素早く伝える構成です。</p>
          </a>
          <a href="/portfolio-lp/lp_corporate.html" class="lp-choice-card">
            <span>ブランドの土台を整えたい</span>
            <h3>信頼・採用型LP</h3>
            <p>企業紹介、採用、地域事業など、想いや実績を丁寧に届ける構成です。</p>
          </a>
        </div>
        <div class="lp-choice-cta">
          <a href="/contact/?source=lp_portfolio">近い目的で相談する</a>
        </div>
      </section>

      <section class="lp-value-section reveal" aria-labelledby="lp-value-title">
        <div class="section-head">
          <span class="eyebrow">Why This Price</span>
          <h2 id="lp-value-title">金額に含まれるのは、見た目だけではありません。</h2>
          <p>
            LPは1枚の長いページですが、実際には「誰に、どの順番で、何を見せるか」を設計する仕事です。
            和-Nodeでは、心理学を用いた情報整理とWeb制作を組み合わせ、相談や予約につながる形まで整えます。
          </p>
        </div>
        <div class="lp-value-grid">
          {valueBlocks.map((item) => (
            <article class="lp-value-card">
              <span>{item.label}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="lp-scope-section reveal" aria-labelledby="lp-scope-title">
        <div class="section-head compact">
          <span class="eyebrow">Scope</span>
          <h2 id="lp-scope-title">同じLPでも、制作範囲で価格が変わります。</h2>
          <p>サンプルを見るときは、デザインの好みだけでなく「どこまで作る必要があるか」も一緒に見ると、相談内容が整理しやすくなります。</p>
        </div>
        <div class="lp-scope-grid">
          {scopeTiers.map((tier) => (
            <article class="lp-scope-card">
              <span>{tier.name}</span>
              <strong>{tier.price}</strong>
              <h3>{tier.target}</h3>
              <p>{tier.detail}</p>
            </article>
          ))}
        </div>
      </section>

      <!-- Category Filter -->
      <nav class="filter-nav">
        <button class="filter-btn active" data-filter="all">すべて</button>
        <button class="filter-btn" data-filter="medical">医療・美容</button>
        <button class="filter-btn" data-filter="business">ビジネス・IT</button>
        <button class="filter-btn" data-filter="lifestyle">ライフスタイル</button>
        <button class="filter-btn" data-filter="creative">アート・クリエイティブ</button>
      </nav>

      <div class="lp-grid">
        <!-- 1. Medical -->
        <article class="lp-card reveal" data-category="medical">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_clinic.png" alt="美容クリニック・歯科LP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">Medical</span>
          </div>
          <div class="lp-info">
            <h3>美容クリニック・歯科LP</h3>
            <p>清潔感と信頼感を両立。行動心理に基づいた予約率向上のための設計。</p>
            <p class="lp-rationale"><span>設計意図</span>不安や比較が強い業種のため、料金・流れ・根拠を早めに見せて、納得して予約できる構成にしています。</p>
            <p class="lp-price-hint"><span>参考価格</span>64,000円〜120,000円前後</p>
            <a href="/portfolio-lp/lp_clinic.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 2. Beauty -->
        <article class="lp-card reveal" data-category="medical">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_beauty.png" alt="エステ・脱毛・サロン系LP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">Beauty</span>
          </div>
          <div class="lp-info">
            <h3>エステ・脱毛・サロン系LP</h3>
            <p>高級感溢れるビジュアル。ユーザーの憧れを刺激し、来店意欲を高めます。</p>
            <p class="lp-rationale"><span>設計意図</span>価格だけで比較されやすいため、施術後のイメージ・空間の安心感・初回導線をセットで見せています。</p>
            <p class="lp-price-hint"><span>参考価格</span>64,000円〜120,000円前後</p>
            <a href="/portfolio-lp/lp_beauty.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 3. Gym -->
        <article class="lp-card reveal" data-category="lifestyle">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_gym.png" alt="パーソナルジム・フィットネスLP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">Fitness</span>
          </div>
          <div class="lp-info">
            <h3>パーソナルジム・フィットネスLP</h3>
            <p>力強さとモチベーション。ビフォーアフターを効果的に見せる導線。</p>
            <p class="lp-rationale"><span>設計意図</span>継続の不安が出やすい業種なので、成果イメージだけでなく通い方・サポート体制も伝える設計です。</p>
            <p class="lp-price-hint"><span>参考価格</span>64,000円〜120,000円前後</p>
            <a href="/portfolio-lp/lp_gym.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 4. EC -->
        <article class="lp-card reveal" data-category="lifestyle">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_ec.png" alt="商品販売・EC特化LP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">E-Commerce</span>
          </div>
          <div class="lp-info">
            <h3>商品販売・EC特化LP</h3>
            <p>購買心理を徹底追求。商品の魅力を引き出し、即座の注文へ繋げます。</p>
            <p class="lp-rationale"><span>設計意図</span>短時間で判断されるため、ベネフィット、使用場面、購入ボタンまでの距離を短くしています。</p>
            <p class="lp-price-hint"><span>参考価格</span>64,000円〜120,000円前後</p>
            <a href="/portfolio-lp/lp_ec.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 5. SaaS -->
        <article class="lp-card reveal" data-category="business">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_saas.png" alt="ITツール・SaaSサービスLP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">IT / SaaS</span>
          </div>
          <div class="lp-info">
            <h3>ITツール・SaaSサービスLP</h3>
            <p>先進性と機能性。複雑なサービス内容をチャートとアニメーションで簡潔に。</p>
            <p class="lp-rationale"><span>設計意図</span>機能説明が難しくなりやすいため、課題、導入後の変化、主要機能の順で理解負荷を下げています。</p>
            <p class="lp-price-hint"><span>参考価格</span>64,000円〜144,000円前後</p>
            <a href="/portfolio-lp/lp_saas.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 6. Real Estate -->
        <article class="lp-card reveal" data-category="business">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_realestate.png" alt="不動産・戸建・マンションLP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">Real Estate</span>
          </div>
          <div class="lp-info">
            <h3>不動産・戸建・マンションLP</h3>
            <p>一生の買い物を支える安心感。物件の魅力を高精細なレイアウトで表現。</p>
            <p class="lp-rationale"><span>設計意図</span>検討期間が長い商材のため、写真、周辺情報、相談導線を分けて保存・比較しやすくしています。</p>
            <p class="lp-price-hint"><span>参考価格</span>64,000円〜144,000円前後</p>
            <a href="/portfolio-lp/lp_realestate.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 7. Professional -->
        <article class="lp-card reveal" data-category="business">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_lawyer.png" alt="士業・コンサルティング・スクールLP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">Consulting</span>
          </div>
          <div class="lp-info">
            <h3>士業・コンサルティング・スクールLP</h3>
            <p>権威性と専門性。読み手の信頼を勝ち取る情報の整理とライティング支援。</p>
            <p class="lp-rationale"><span>設計意図</span>専門性が伝わらないと相談されにくいため、実績、対応範囲、初回相談の流れを丁寧に整理します。</p>
            <p class="lp-price-hint"><span>参考価格</span>64,000円〜120,000円前後</p>
            <a href="/portfolio-lp/lp_lawyer.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 8. Seminar -->
        <article class="lp-card reveal" data-category="lifestyle">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_seminar.png" alt="投資・教育セミナーLP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">Education</span>
          </div>
          <div class="lp-info">
            <h3>投資・教育セミナーLP</h3>
            <p>期待感を最大化。成功イメージを共有し、申込へのステップを最適化。</p>
            <p class="lp-rationale"><span>設計意図</span>誇張に見えやすい分野のため、学べる内容、対象者、申込前の確認事項を明確にしています。</p>
            <p class="lp-price-hint"><span>参考価格</span>64,000円〜120,000円前後</p>
            <a href="/portfolio-lp/lp_seminar.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 9. Recruit -->
        <article class="lp-card reveal" data-category="business">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_recruit.png" alt="採用・リクルーティングLP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">Recruit</span>
          </div>
          <div class="lp-info">
            <h3>採用・リクルーティングLP</h3>
            <p>企業の想いを届ける。未来の仲間へ、共感と憧れを生むブランディング。</p>
            <p class="lp-rationale"><span>設計意図</span>応募前に職場の空気を知りたい人が多いため、価値観、働き方、選考ステップを先に見せています。</p>
            <p class="lp-price-hint"><span>参考価格</span>64,000円〜144,000円前後</p>
            <a href="/portfolio-lp/lp_recruit.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 10. Local -->
        <article class="lp-card reveal" data-category="lifestyle">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_cafe.png" alt="地域振興・カフェ・店舗LP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">Regional</span>
          </div>
          <div class="lp-info">
            <h3>地域振興・カフェ・店舗LP</h3>
            <p>温かみと独自性。その場所、その店にしかない空気感をデジタルで再現。</p>
            <p class="lp-rationale"><span>設計意図</span>来店理由が感情に左右されやすいため、雰囲気、場所、メニュー、アクセスを近い距離で見せています。</p>
            <p class="lp-price-hint"><span>参考価格</span>24,000円〜64,000円前後</p>
            <a href="/portfolio-lp/lp_local.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 11. Event -->
        <article class="lp-card reveal" data-category="lifestyle">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_event.png" alt="イベント・フェス・期間限定LP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">Event</span>
          </div>
          <div class="lp-info">
            <h3>イベント・フェス・期間限定LP</h3>
            <p>ワクワク感と勢い。開催への期待を高めるエネルギッシュなデザイン。</p>
            <p class="lp-rationale"><span>設計意図</span>開催日が決まっているため、日時、場所、参加メリット、申込ボタンを迷わず追える順番にしています。</p>
            <p class="lp-price-hint"><span>参考価格</span>24,000円〜64,000円前後</p>
            <a href="/portfolio-lp/lp_event.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 12. Art -->
        <article class="lp-card reveal" data-category="creative">
          <div class="lp-visual art-card-visual" aria-label="アート・ギャラリーLP">
            <span class="lp-tag">Art / Gallery</span>
            <div class="art-orbit art-orbit-1"></div>
            <div class="art-orbit art-orbit-2"></div>
            <div class="art-frame-shape"></div>
            <div class="art-caption-line"></div>
          </div>
          <div class="lp-info">
            <h3>アート・ギャラリーLP</h3>
            <p>作品の世界観と来場・購入導線を両立。余白、光、言葉の温度で記憶に残す構成。</p>
            <p class="lp-rationale"><span>設計意図</span>作品の魅力を邪魔しないよう余白を広く取り、作家の想い、展示情報、購入・来場導線を静かに追える順番にしています。</p>
            <p class="lp-price-hint"><span>参考価格</span>64,000円〜144,000円前後</p>
            <a href="/portfolio-lp/lp_art.html" class="lp-link">デモを見る →</a>
          </div>
        </article>

        <!-- 13. Corporate -->
        <article class="lp-card reveal" data-category="business">
          <div class="lp-visual">
            <img src="/portfolio-lp/images/hero_corporate.png" alt="企業紹介・ブランドLP" style="width: 100%; height: 100%; object-fit: cover;" />
            <span class="lp-tag">Corporate</span>
          </div>
          <div class="lp-info">
            <h3>企業紹介・ブランドLP</h3>
            <p>揺るぎない信頼。コーポレートアイデンティティを尊重した誠実な設計。</p>
            <p class="lp-rationale"><span>設計意図</span>初見での信用が重要なため、事業内容、姿勢、実績、問い合わせ導線を落ち着いた順番で配置します。</p>
            <p class="lp-price-hint"><span>参考価格</span>64,000円〜144,000円前後</p>
