---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomepageContent from '../components/HomepageContent.astro';
import {
  createServiceSchema,
  createWebPageSchema,
  organizationSchema,
  websiteSchema,
} from '../data/structuredData';

const title = "心理学に強いWeb制作・LP改善｜ホームページ制作とICT活用｜和-Node";
const description = "和-Nodeは、心理学の知見を活かしたホームページ制作・LP制作・Web改善の専門窓口です。伝わる情報設計、相談しやすい導線、アクセス解析を使った公開後の改善まで支援します。";
const structuredData = [
  organizationSchema,
  websiteSchema,
  createWebPageSchema({ name: title, description, path: "/" }),
  createServiceSchema({
    name: "心理学に強いWeb制作・LP改善",
    description:
      "行動心理に基づく情報設計、ホームページ制作、LP制作、公開後の計測改善を支援します。",
    path: "/pricing/",
    serviceType: "Web design and conversion improvement",
    priceFrom: "64000",
  }),
];
---
<BaseLayout lang="ja" title={title} description={description} structuredData={structuredData}>
  <HomepageContent lang="ja" />
</BaseLayout>
