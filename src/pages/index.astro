---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "和-Node (wa-node)",
  "url": "https://www.wa-node.com/",
  "image": "https://www.wa-node.com/images/ogp.png",
  "description": "心理学を応用したWeb制作・導線設計の専門家。LP・HP制作からAI・ICT活用、月額制の伴走コンサルティングまで提供します。",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "JP"
  }
};
---

<BaseLayout title="心理学×Web制作・ホームページ制作｜LP制作とAI・ICT伴走｜和-Node" description="心理学の知見をWeb導線設計に応用。20年のエンジニア経験を活かしたWeb制作・ホームページ制作・LP制作、AI・ICT活用、そして月額制の継続伴走コンサルティング。">
  <!-- JSON-LD for SEO -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <main>
    <!-- 1. Hero Section -->
    <section class="section hero">
      <div class="hero-inner">
        <div class="hero-content reveal">
          <div class="hero-badge">月3名まで丁寧に対応</div>
          <p class="tagline-top">技術（ICT×統計）のその先へ。</p>
          <h1>「選ばれる」には、<br /><span class="highlight-text">心理学</span>的な根拠がある。</h1>
          <p class="lead">和-Nodeは、<strong>「ICT・統計技術」に「行動心理学」を融合</strong>させたWeb制作で、訪問者の「なんとなく離脱」を防ぎ、澱みのない購入・成約導線をデザインする伴走パートナーです。</p>
          <div class="btns">
            <a class="btn primary" href="/contact">無料で相談する</a>
            <a class="btn secondary" href="/psychology-demo/">心理導線デモ</a>
            <a class="btn secondary" href="/pricing">料金を確認</a>
          </div>
        </div>
      </div>
    </section>

    <!-- 1.5. Agitation Section (For frustrated/skeptical users) -->
    <section class="section why-psy">
      <div class="section-inner why-psy-inner">
        <div class="question-box">
          <span class="q-eyebrow">こんなお悩みはありませんか？</span>
          <h2>「デザイン会社に頼んだのに、なぜ成果が出ないのか？」</h2>
          <p class="q-lead">その答えは、見た目の良さの中に潜む「1pxの心理的不親切（ユーザーの迷い）」にあります。</p>
        </div>
        <div class="concept-intro-grid">
          <div class="concept-intro-card highlight-card">
            <div class="card-num">💡</div>
            <h3>「綺麗」だけでは、人は動きません</h3>
            <p>優れたグラフィックデザインも、ユーザーの「次の行動への心理ステップ」が設計されていなければ、ただの自己満足で終わり、離脱の原因になります。</p>
          </div>
          <div class="concept-intro-card">
            <div class="card-num">📈</div>
            <h3>ICT × 統計 × 行動心理学</h3>
            <p>和-Nodeは、20年のシステム構築力とデータ分析（統計）に加え、カウンセラーの心理学知見を融合。ロジカルかつ直感的に「迷わない」導線を作ります。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. Services (Minimal) -->
    <section class="section" id="services">
      <div class="section-inner">
        <div class="section-title">
          <span class="eyebrow">Service Pillars</span>
          <h2>ビジネスの「出口」を整える3つの柱</h2>
        </div>
        <div class="consult-grid">
          <article class="consult-card highlight">
            <span class="card-tag">Web Design</span>
            <h3>心理導線のWeb制作</h3>
            <p>行動心理に基づいた導線設計。LPから多機能HPまで20年の技術力で形にします。</p>
            <a href="/pricing" class="card-link">30,000円〜 →</a>
          </article>
          <article class="consult-card">
            <span class="card-tag">Ongoing Support</span>
            <h3>月額ICT・AI伴走</h3>
            <p>AI活用から業務改善まで。月額制であなたのビジネスに継続的に寄り添います。</p>
            <a href="/pricing" class="card-link">15,000円/月〜 →</a>
          </article>
          <article class="consult-card">
            <span class="card-tag">ICT & System</span>
            <h3>ICT・アプリ連携</h3>
            <p>LINE Mini App連携や自動化。複雑な仕組みを「人に優しく」実装します。</p>
            <a href="/pricing" class="card-link">スポット相談 5,000円〜 →</a>
          </article>
        </div>
      </div>
    </section>

    <!-- 3. Experience (Psychology & AI) -->
    <section class="section" id="experience" style="background: var(--soft);">
      <div class="section-inner">
        <div class="section-title" style="text-align: center;">
          <span class="eyebrow">Experience Demo</span>
          <h2>「伝わる」と「動く」を体験する</h2>
        </div>
        <div class="action-buttons-grid reveal">
          <a href="/psychology-demo/" class="action-card highlight-border">
            <div class="action-icon">💡</div>
            <h3>心理導線デモ</h3>
            <p>心理学的根拠を可視化したデモページ</p>
          </a>
          <a href="/ai-chat-demo" class="action-card">
            <div class="action-icon">🤖</div>
            <h3>AI相談ナビ</h3>
            <p>AIがあなたの課題を整理。技術力を体験</p>
          </a>
          <a href="/simulator" class="action-card">
            <div class="action-icon">💰</div>
            <h3>料金シミュレーター</h3>
            <p>概算費用と納期をリアルタイム確認</p>
          </a>
        </div>
        <div style="text-align: center; margin-top: 40px;">
          <a href="/works" style="color: var(--accent); font-weight: 800; text-decoration: underline;">すべての制作実績・診断ツールを見る →</a>
        </div>
      </div>
    </section>

    <!-- 5. Visual Proof (Offer) -->
    <section class="section visual-proof" style="background: var(--white); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);">
      <div class="section-inner" style="max-width: 800px; text-align: center;">
        <span class="eyebrow" style="color: var(--accent2);">Step toward Quality</span>
        <h2>「実物を見てから、決めてください」</h2>
        <p style="font-size: 1.1rem; color: var(--text); line-height: 1.8; margin-bottom: 32px;">
          初回相談後、必要に応じて<strong>「簡易的な構成案（たたき台）」</strong>を無料で作成します。まずは「和-Nodeと組む価値」を肌で感じていただいた上で、進めるかどうかをご判断いただけます。
        </p>
      </div>
    </section>

    <!-- 6. Consultation Flow (Simplified) -->
    <section class="section flow" id="flow">
      <div class="section-inner">
        <div class="section-title" style="text-align: center;">
          <span class="eyebrow">Flow</span>
          <h2>ご相談の流れ</h2>
        </div>
        <div class="simple-flow-grid">
          <div class="flow-item">
            <span class="flow-num">1</span>
            <h4>無料相談（30-60分）</h4>
            <p>フォームまたはLINEより。現状の課題を丁寧に整理します。</p>
          </div>
          <div class="flow-item">
            <span class="flow-num">2</span>
            <h4>構成案・お見積り</h4>
            <p>必要に応じて「たたき台」を作成し、最適なプランをご提示します。</p>
          </div>
          <div class="flow-item">
            <span class="flow-num">3</span>
            <h4>ご契約・着手</h4>
            <p>内容にご納得いただいた上で、制作・伴走をスタートします。</p>
          </div>
        </div>
        <div class="btns" style="justify-content: center; margin-top: 60px;">
          <a class="btn primary" href="/contact">無料で相談し、必要に応じて構成案を検討する</a>
        </div>
      </div>
    </section>

    <!-- 6. Profile Summary (Avatar relocated here) -->
    <section class="section profile-summary">
      <div class="section-inner profile-summary-inner">
        <div class="profile-avatar-wrap">
          <img src="/images/avatar.png" alt="和-Node 代表 高野紘純" class="profile-avatar-img" />
        </div>
        <div class="profile-text-wrap">
          <span class="eyebrow">Professional Partner</span>
          <h2>代表：高野 紘純</h2>
          <p class="profile-desc">
            IT業界20年のエンジニア経験、産業カウンセラーとしての行動心理学の知見、そして車いす当事者としてのユニバーサル（バリアフリー）視点。これらすべての強みを掛け合わせ、「1pxの不親切も見逃さない、澱みのない導線」を作ります。
          </p>
          <a href="/about" class="profile-link">詳しいプロフィール・活動実績はこちら →</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

  :root {
    --accent: #c5a059;
    --accent-dark: #b18e4a;
    --accent2: #d14d3a;
    --text: #333;
    --text-deep: #1a1a1a;
    --muted: #666;
    --line: rgba(197, 160, 89, 0.2);
    --soft: #fdfaf5;
    --white: #ffffff;
    --paper: #fdfcf9;
    --radius: 24px;
  }

  body { font-family: 'Shippori Mincho', serif; color: var(--text); line-height: 1.8; background: var(--paper); }
  .section { padding: 80px 0; }
  .section-inner { max-width: 1000px; margin: 0 auto; padding: 0 20px; }

  h1, h2, h3, h4 { font-family: 'Shippori Mincho', serif; font-weight: 800; color: var(--text-deep); }
  h1 { font-size: clamp(2.2rem, 5vw, 4rem); line-height: 1.2; margin-bottom: 24px; }
  h2 { font-size: clamp(1.8rem, 4vw, 2.5rem); margin-bottom: 32px; }

  .tagline-top { font-size: 1.1rem; color: var(--accent); font-weight: 800; letter-spacing: 0.1em; margin-bottom: 8px; }
  .lead { font-size: 1.2rem; color: var(--muted); margin-bottom: 40px; max-width: 700px; }
  .lead strong { color: var(--accent); }

  .btns { display: flex; gap: 16px; margin-top: 40px; }
  .btn { padding: 18px 36px; border-radius: 50px; font-weight: 800; text-decoration: none; transition: 0.3s; text-align: center; }
  .btn.primary { background: var(--accent); color: white; box-shadow: 0 10px 20px rgba(197, 160, 89, 0.2); }
  .btn.primary:hover { background: var(--accent-dark); transform: translateY(-2px); }
  .btn.secondary { border: 1px solid var(--accent); color: var(--accent); }

  /* Hero */
  .hero { 
    padding: 160px 0 120px; 
    background: 
      linear-gradient(to right, rgba(253, 250, 245, 1) 40%, rgba(253, 250, 245, 0.9) 55%, rgba(253, 250, 245, 0.2) 80%, rgba(253, 250, 245, 0) 100%), 
      url('/images/hero.png') no-repeat right center/cover;
    min-height: 520px;
    display: flex;
    align-items: center;
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; padding: 0 40px; width: 100%; }
  .hero-content { max-width: 650px; }
  .hero-badge { display: inline-block; background: var(--accent2); color: white; padding: 6px 16px; border-radius: 4px; font-size: 0.85rem; font-weight: 800; margin-bottom: 24px; }
  .highlight-text { border-bottom: 3px double var(--accent); padding-bottom: 2px; color: var(--accent2); font-weight: 800; }

  /* Agitation / Hook Section */
  .why-psy { background: var(--white); border-bottom: 1px solid var(--line); }
  .why-psy-inner { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  .question-box { text-align: center; margin-bottom: 48px; }
  .q-eyebrow { font-size: 0.9rem; color: var(--accent2); font-weight: 800; letter-spacing: 0.1em; display: block; margin-bottom: 12px; }
  .q-lead { font-size: 1.2rem; color: var(--text-deep); margin-top: 16px; font-weight: 700; }
  
  .concept-intro-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 32px; }
  .concept-intro-card { background: var(--paper); padding: 40px; border-radius: var(--radius); border: 1px solid var(--line); transition: 0.3s; }
  .concept-intro-card:hover { transform: translateY(-5px); border-color: var(--accent); }
  .concept-intro-card.highlight-card { background: var(--soft); border-color: var(--accent); box-shadow: 0 15px 30px rgba(197, 160, 89, 0.08); }
  .card-num { font-size: 2.2rem; margin-bottom: 16px; }

  /* Profile Summary Section */
  .profile-summary { background: var(--soft); border-top: 1px solid var(--line); }
  .profile-summary-inner { max-width: 850px; display: flex; align-items: center; gap: 48px; margin: 0 auto; padding: 0 20px; }
  .profile-avatar-wrap { flex: 0 0 200px; width: 200px; height: 200px; border-radius: 30px; overflow: hidden; box-shadow: 0 15px 30px rgba(0,0,0,0.08); border: 3px solid var(--white); }
  .profile-avatar-img { width: 100%; height: 100%; object-fit: cover; }
  .profile-text-wrap { flex: 1; }
  .profile-desc { font-size: 1rem; color: var(--muted); margin: 16px 0 24px; line-height: 1.8; }
  .profile-link { font-weight: 800; color: var(--accent); text-decoration: underline; transition: 0.3s; }
  .profile-link:hover { color: var(--accent-dark); }

  /* Cards */
  .consult-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; margin-top: 40px; }
  .consult-card { background: var(--white); padding: 40px; border-radius: var(--radius); border: 1px solid var(--line); transition: 0.3s; }
  .consult-card:hover { transform: translateY(-5px); border-color: var(--accent); }
  .consult-card.highlight { background: var(--soft); border-color: var(--accent); }
  .card-tag { font-size: 0.75rem; font-weight: 800; color: var(--accent); letter-spacing: 0.1em; margin-bottom: 12px; display: block; }
  .card-link { display: inline-block; margin-top: 16px; font-weight: 800; color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); }

  /* Experience Grid */
  .action-buttons-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px; }
  .action-card { background: #fff; border: 1px solid var(--line); border-radius: 20px; padding: 30px 20px; text-decoration: none; text-align: center; transition: 0.3s; color: inherit; }
  .action-card:hover { transform: translateY(-5px); border-color: var(--accent); }
  .action-card.highlight-border { border: 2px solid var(--accent); }
  .action-icon { font-size: 2.5rem; margin-bottom: 16px; display: block; }

  /* Flow */
  .simple-flow-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; margin-top: 40px; }
  .flow-item { text-align: center; position: relative; }
  .flow-num { width: 40px; height: 40px; background: var(--accent); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-weight: 800; }
  .flow-item h4 { margin-bottom: 12px; }
  .flow-item p { font-size: 0.9rem; color: var(--muted); }

  .eyebrow { font-size: 0.85rem; font-weight: 800; color: var(--accent); text-transform: uppercase; letter-spacing: 0.2em; margin-bottom: 12px; display: block; }

  @media (max-width: 768px) {
    .hero {
      padding: 80px 0;
      background: 
        linear-gradient(to bottom, rgba(253, 250, 245, 0.98) 50%, rgba(253, 250, 245, 0.8) 80%, rgba(253, 250, 245, 0.4) 100%), 
        url('/images/hero.png') no-repeat center center/cover;
      text-align: center;
      min-height: auto;
    }
    .hero-inner { padding: 0 20px; }
    .hero-content { max-width: 100%; }
    .action-buttons-grid, .simple-flow-grid, .concept-intro-grid { grid-template-columns: 1fr; }
    .flow-item:not(:last-child)::after { display: none; }
    .profile-summary-inner { flex-direction: column; text-align: center; gap: 24px; }
    .profile-avatar-wrap { flex: 0 0 160px; width: 160px; height: 160px; }
  }
</style>
