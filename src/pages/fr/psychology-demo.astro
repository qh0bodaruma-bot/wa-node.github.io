---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MaterialIcon from '../../components/MaterialIcon.astro';

const title = "Démo Design UX & Parcours Cognitif | Wa-Node";
const description = "Pourquoi les pages de destination à fort taux de conversion réussissent-elles ? Le secret réside dans la psychologie comportementale du design. Comparez les mises en page héritées standards à l'architecture cognitive moderne de Wa-Node.";
---

<BaseLayout title={title} description={description} lang="fr">
  <main class="demo-page">
    <!-- Hero Section -->
    <section class="hero-demo section">
      <div class="container narrow reveal">
        <div class="eyebrow">Visualiser la Psychologie</div>
        <h1>Votre page de destination<br/><span class="text-accent">a-t-elle une « Âme » ?</span></h1>
        <p class="lead">
          La beauté visuelle seule ne peut pas toucher le cœur d'un utilisateur. Anticipez et résolvez les angoisses subconscientes de vos visiteurs pour bâtir un flux constant de confiance. C'est l'essence du « Parcours Cognitif Intuitif » de Wa-Node.
        </p>
      </div>
    </section>

    <!-- Comparison Intro -->
    <section class="comparison-intro container">
      <div class="comparison-header reveal">
        <h2>Un seul mot modifie<br class="mobile-only"/> la distance émotionnelle.</h2>
        <p>Comparez une page de destination héritée standard (Before) à une version optimisée par Wa-Node (After) et explorez les sciences cognitives derrière ce changement.</p>
      </div>
    </section>

    <!-- Comparison Items -->
    <div class="comparison-list container">
      
      <!-- Case 1: CTA -->
      <section class="comp-item reveal">
        <div class="comp-label">CASE 01 : Susciter l'Action (CTA)</div>
        <div class="comp-grid">
          <div class="comp-card before">
            <div class="status-badge before">BEFORE</div>
            <div class="preview-area">
              <button class="btn-legacy">Nous Contacter</button>
            </div>
            <p class="card-note">"Je ne fais que regarder, soumettre une demande directe me semble être un trop grand engagement..."</p>
          </div>
          <div class="comp-arrow-wrapper">
            <div class="comp-arrow-svg">
              <MaterialIcon name="arrow_forward" />
            </div>
            <span class="arrow-text">Améliorer</span>
          </div>
          <div class="comp-card after">
            <div class="status-badge after">AFTER (Wa-Node)</div>
            <div class="preview-area">
              <button class="btn-modern">Clarifions Ensemble Vos Besoins</button>
            </div>
            <div class="logic-card">
              <span class="logic-tag">Psychologie : Obstacle Faible</span>
              <p>En éliminant la pression de « contact = décision immédiate » et en proposant la « clarification » comme première étape collaborative, nous abaissons la barrière psychologique et encourageons un dialogue naturel.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Case 2: Pricing -->
      <section class="comp-item reveal">
        <div class="comp-label">CASE 02 : Naviguer vers les Tarifs</div>
        <div class="comp-grid">
          <div class="comp-card before">
            <div class="status-badge before">BEFORE</div>
            <div class="preview-area">
              <div class="link-legacy">Consulter les Tarifs</div>
            </div>
            <p class="card-note">"Combien cela va-t-il me coûter réellement ? J'ai peur que ce soit hors de mon budget..."</p>
          </div>
          <div class="comp-arrow-wrapper">
            <div class="comp-arrow-svg">
              <MaterialIcon name="arrow_forward" />
            </div>
            <span class="arrow-text">Améliorer</span>
          </div>
          <div class="comp-card after">
            <div class="status-badge after">AFTER (Wa-Node)</div>
            <div class="preview-area">
              <div class="link-modern">Résoudre Vos Doutes Avant de Choisir</div>
            </div>
            <div class="logic-card">
              <span class="logic-tag">Psychologie : La Sécurité D'abord</span>
              <p>Instaurer la sérénité avant de présenter des chiffres bruts. En montrant une attitude d'écoute vis-à-vis des préoccupations individuelles, nous aidons les utilisateurs à prendre des décisions positives et éclairées.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Case 3: Hero Message -->
      <section class="comp-item reveal">
        <div class="comp-label">CASE 03 : Le Message Principal</div>
        <div class="comp-grid">
          <div class="comp-card before">
            <div class="status-badge before">BEFORE</div>
            <div class="preview-area">
              <h3 class="h-legacy">Solution Leader de l'Industrie &<br/>Résultats Exceptionnels</h3>
            </div>
            <p class="card-note">"Cela semble impressionnant, mais quel est le rapport avec mon quotidien ?"</p>
          </div>
          <div class="comp-arrow-wrapper">
            <div class="comp-arrow-svg">
              <MaterialIcon name="arrow_forward" />
            </div>
            <span class="arrow-text">Améliorer</span>
          </div>
          <div class="comp-card after">
            <div class="status-badge after">AFTER (Wa-Node)</div>
            <div class="preview-area">
              <h3 class="h-modern">Retrouvez l'Harmonie et la Sérénité<br/>dans Votre Quotidien.</h3>
            </div>
            <div class="logic-card">
              <span class="logic-tag">Psychologie : Bénéfice avant Fonctionnalité</span>
              <p>Se concentrer sur « la transformation future » plutôt que sur les caractéristiques techniques. Le cerveau humain privilégie les informations liées à son bénéfice personnel ; ainsi, présenter les résultats concrets suscite rapidement la confiance.</p>
            </div>
          </div>
        </div>
      </section>

    </div>

    <!-- Methodology -->
    <section class="methodology section">
      <div class="container narrow reveal">
        <h2 class="section-title">Le Flux de l'Architecture Psychologique de Wa-Node</h2>
        <div class="method-steps">
          <div class="step">
            <div class="step-num">01</div>
            <h3>Écouter (Empathie)</h3>
            <p>Démêler la source subconsciente d'anxiété que le client lui-même n'a pas encore remarquée.</p>
          </div>
          <div class="step">
            <div class="step-num">02</div>
            <h3>Aligner (Design)</h3>
            <p>Relier les parcours de conversion optimaux en un seul voyage cohérent, tant du point de vue logique qu'émotionnel.</p>
          </div>
          <div class="step">
            <div class="step-num">03</div>
            <h3>Connecter (Implémenter)</h3>
            <p>Exploiter l'IA de pointe et les technologies modernes pour matérialiser ces parcours dans une réalité élégante et performante.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Designer Profile -->
    <section class="designer-profile section">
      <div class="container narrow reveal">
        <div class="profile-card">
          <div class="profile-header">
            <div class="profile-title">
              <span class="eyebrow">Profil du Designer</span>
              <h2>À propos du Designer</h2>
            </div>
          </div>
          <div class="profile-content">
            <div class="profile-text">
              <h3>Hirozumi Takano <small>Hirozumi Takano</small></h3>
              <p class="profile-qual">Conseiller Industriel / Consultant TIC</p>
              
              <div class="profile-history">
                <p>
                  Actif dans l'industrie de la restauration et de l'hôtellerie depuis 2001. Qualifié comme Conseiller Industriel en 2002, consacrant plus de 20 ans à l'accompagnement psychologique des employés et à la gestion des risques relationnels en entreprise.
                  Parallèlement, il a mené sa carrière dans l'ingénierie informatique et les systèmes d'information : surveillance système UNIX, maintenance de POS et modernisation de bases de données (Access, etc.). Il a notamment divisé par deux le temps de travail administratif en développant des terminaux sur mesure.
                </p>
                <p>
                  Après avoir quitté son poste précédent, il a traversé une période de rééducation physique en raison de limitations de mobilité et de douleurs chroniques. Durant cette période, il a poursuivi ses recherches sur les technologies web modernes et l'intégration de l'IA générative. De retour à la pratique active, il fonde Wa-Node en avril 2026. Il accompagne les entreprises à structurer leur présence numérique grâce à une vision multidimensionnelle unissant matériel, logiciel et psychologie humaine.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta section">
      <div class="container narrow reveal">
        <div class="cta-box">
          <h2>Alignons Votre Parcours Ensemble.</h2>
          <p>
            Votre page de destination manque de conversion ? Vous souhaitez que votre véritable message résonne ?<br/>
            Commencez par un entretien stratégique gratuit pour définir votre parcours optimal.
          </p>
          <div class="btns">
            <a href="/fr/contact/" class="btn">Commencer l'Entretien Gratuit</a>
            <a href="/fr/works/" class="btn secondary">Consulter le Portefeuille</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .demo-page {
    background-color: var(--bg);
    overflow-x: hidden;
  }

  .text-accent { color: var(--accent); }

  .hero-demo {
    text-align: center;
    padding: 120px 0 80px;
  }
  .hero-demo h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.2;
    margin-bottom: 32px;
    font-weight: 800;
  }
  .hero-demo .lead {
    font-size: 1.2rem;
    color: var(--muted);
    max-width: 800px;
    margin: 0 auto;
  }

  .comparison-header {
    text-align: center;
    margin-bottom: 80px;
  }
  .comparison-header h2 {
    font-size: 2.2rem;
    margin-bottom: 20px;
    font-weight: 800;
  }

  .comp-item {
    margin-bottom: 120px;
  }
  .comp-label {
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 40px;
    text-align: center;
  }

  .comp-grid {
    display: grid;
    grid-template-columns: 1fr 120px 1.2fr;
    gap: 20px;
    align-items: center;
  }

  .comp-card {
    border-radius: var(--radius);
    padding: 50px 40px;
    position: relative;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 340px;
    transition: 0.3s;
  }
  .comp-card.before {
    background: #ececec;
    border: 1px solid #ddd;
  }
  .comp-card.after {
    background: var(--paper);
    border: 2px solid var(--accent2);
  }

  .status-badge {
    position: absolute;
    top: 24px;
    left: 24px;
    font-size: 0.75rem;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 4px;
    letter-spacing: 0.1em;
  }
  .status-badge.before {
    background: #999;
    color: #fff;
  }
  .status-badge.after {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 4px 10px rgba(138, 90, 50, 0.2);
  }

  .preview-area {
    margin: 40px 0 24px;
    text-align: center;
  }

  /* Legacy Elements */
  .btn-legacy {
    background: #e74c3c;
    color: #fff;
    border: none;
    padding: 18px 36px;
    font-weight: 700;
    border-radius: 4px;
    font-size: 1rem;
    cursor: default;
    opacity: 0.7;
  }
  .link-legacy {
    color: #2980b9;
    text-decoration: underline;
    font-weight: 700;
    font-size: 1.1rem;
    opacity: 0.7;
  }
  .h-legacy {
    font-size: 1.8rem;
    color: #2c3e50;
    line-height: 1.3;
    font-weight: 900;
    opacity: 0.6;
  }

  /* Wa-Node Elements */
  .btn-modern {
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 20px 56px;
    font-weight: 800;
    border-radius: 999px;
    font-size: 1.2rem;
    box-shadow: 0 10px 30px rgba(138, 90, 50, 0.2);
    cursor: default;
    position: relative;
    overflow: hidden;
  }
  .btn-modern::after {
    content: "";
    position: absolute;
    top: -50%; left: -100%;
    width: 30%; height: 200%;
    background: rgba(255, 255, 255, 0.3);
    transform: rotate(30deg);
    animation: shine-demo 6s infinite;
  }
  @keyframes shine-demo {
    0% { left: -100%; }
    20% { left: 150%; }
    100% { left: 150%; }
  }

  .link-modern {
    display: inline-block;
    color: var(--accent);
    font-weight: 800;
    font-size: 1.3rem;
    border-bottom: 3px solid var(--accent2);
    padding-bottom: 6px;
  }
  .h-modern {
    font-size: 2.2rem;
    color: var(--text);
    line-height: 1.4;
    font-weight: 800;
  }

  .card-note {
    font-size: 0.85rem;
    color: #777;
    text-align: center;
    font-style: italic;
    line-height: 1.6;
  }

  .comp-arrow-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: var(--accent);
  }
  .comp-arrow-svg {
    width: 60px;
    height: 60px;
    background: var(--soft);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(138, 90, 50, 0.1);
  }
  .comp-arrow-svg svg,
  .comp-arrow-svg :global(.material-symbols-rounded) {
    width: 32px;
    height: 32px;
  }
  .arrow-text {
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    color: var(--accent);
  }

  .logic-card {
    margin-top: 30px;
    padding: 24px;
    background: var(--soft);
    border-radius: 16px;
    text-align: left;
    border-left: 4px solid var(--accent);
  }
  .logic-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 800;
    color: #fff;
    background: var(--accent);
    padding: 4px 10px;
    border-radius: 4px;
    margin-bottom: 12px;
    letter-spacing: 0.05em;
  }
  .logic-card p {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.7;
  }

  /* Steps */
  .methodology {
    background-color: var(--paper);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .method-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    margin-top: 60px;
  }
  .step {
    text-align: center;
  }
  .step-num {
    font-size: 3rem;
    font-weight: 800;
    color: var(--accent2);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 20px;
  }
  .step h3 {
    font-size: 1.4rem;
    margin-bottom: 15px;
    font-weight: 800;
  }

  /* Designer Profile */
  .designer-profile {
    background: #fdfaf5;
    border-top: 1px solid var(--line);
  }
  .profile-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 60px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .profile-header h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-top: 10px;
  }
  .profile-text h3 {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 5px;
  }
  .profile-text h3 small {
    font-size: 0.9rem;
    color: var(--muted);
    font-weight: 400;
    margin-left: 10px;
  }
  .profile-qual {
    color: var(--accent);
    font-weight: 800;
    font-size: 1.1rem;
    margin-bottom: 24px;
  }
  .profile-history p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--muted);
    margin-bottom: 20px;
  }

  /* CTA Box */
  .cta-box {
    background: var(--paper);
    border: 2px solid var(--accent2);
    border-radius: 40px;
    padding: 80px 40px;
    text-align: center;
    box-shadow: 0 20px 60px rgba(138, 90, 50, 0.1);
  }
  .cta-box h2 {
    font-size: 2.8rem;
    margin-bottom: 24px;
    font-weight: 800;
  }
  .cta-box p {
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 40px;
  }

  @media (max-width: 1024px) {
    .comp-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .comp-arrow-wrapper {
      flex-direction: row;
      justify-content: center;
      gap: 20px;
    }
    .comp-arrow-wrapper svg,
    .comp-arrow-wrapper :global(.material-symbols-rounded) {
      transform: rotate(90deg);
    }
    .method-steps {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero-demo h1 { font-size: 2.2rem; }
    .cta-box h2 { font-size: 2rem; }
    .cta-box { padding: 60px 20px; }
    .mobile-only { display: block; }
    .comp-card { padding: 40px 24px; }
  }
</style>

<script is:inline>
  function initReveal() {
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  }
  initReveal();
  document.addEventListener('astro:page-load', initReveal);
</script>
