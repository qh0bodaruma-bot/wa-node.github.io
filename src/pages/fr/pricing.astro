</BaseLayout>

<script>
  function initPlanTabs() {
    const tabButtons = document.querySelectorAll('.plan-tab-btn');
    const planContents = document.querySelectorAll('.plan-content');

    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        const targetTab = button.getAttribute('data-plan-tab');

        // Deactivate all buttons
        tabButtons.forEach(btn => {
          btn.classList.remove('active');
          btn.setAttribute('aria-selected', 'false');
        });

        // Hide all contents
        planContents.forEach(content => {
          content.classList.remove('active-plan');
        });

        // Activate selected button & content
        button.classList.add('active');
        button.setAttribute('aria-selected', 'true');
        
        const targetContent = document.getElementById(`plan-content-${targetTab}`);
        if (targetContent) {
          targetContent.classList.add('active-plan');
        }
      });
    });
  }

  // Support page transition in Astro (swup/barba/native)
  document.addEventListener('astro:page-load', initPlanTabs);
  document.addEventListener('DOMContentLoaded', initPlanTabs);
  initPlanTabs();
</script>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

  :root {
    --accent: #c5a059;
    --accent-dark: #b18e4a;
    --accent-red: #d14d3a;
    --trust: #0f4c5c;
    --trust-mid: #1f6f78;
    --trust-line: rgba(15, 76, 92, 0.18);
    --line: rgba(197, 160, 89, 0.2);
  }

  .premium-heading {
    font-family: 'Shippori Mincho', serif !important;
    font-weight: 800 !important;
    letter-spacing: 0.05em;
  }

  .pricing-container {
    background: #fdfcf9;
    font-family: 'Shippori Mincho', serif !important;
  }

  .hero { padding: 80px 0 60px; border-bottom: 1px solid var(--line); text-align: center; }
  .hero-inner, .section { max-width: 1000px; margin: 0 auto; padding: 0 20px; }
  
  .premium-ann-banner { margin-bottom: 50px; }
  .banner-inner {
    background: #fff; border: 1px solid var(--accent-red); border-radius: 24px;
    padding: 24px 32px; display: flex; align-items: center; gap: 30px;
    box-shadow: 0 15px 40px rgba(209, 77, 58, 0.08); position: relative;
  }
  .banner-badge {
    background: var(--accent-red); color: #fff; font-size: 0.7rem; font-weight: 800;
    padding: 4px 12px; border-radius: 4px; white-space: nowrap;
  }
  .banner-main { flex: 1; text-align: left; }
  .banner-main strong { display: block; font-size: 1.3rem; color: var(--accent-red); margin-bottom: 4px; }
  .banner-link {
    font-size: 0.95rem; font-weight: 800; color: var(--accent-red); text-decoration: none;
    padding: 12px 24px; border: 1px solid var(--accent-red); border-radius: 50px;
    transition: 0.3s; white-space: nowrap;
  }
  .banner-link:hover { background: var(--accent-red); color: #fff; }

  .lead { font-size: 1.1rem; color: #555; margin-bottom: 30px; }
  .note { background: #fff; border: 1px solid var(--line); padding: 20px; border-radius: 15px; color: #666; font-size: 0.95rem; }

  .section { padding: 80px 20px; }
  .eyebrow { font-size: 0.8rem; font-weight: 800; color: var(--accent); letter-spacing: 0.2em; margin-bottom: 10px; display: block; }
  h2 { font-size: 2.2rem; margin-bottom: 20px; color: #2c2c2c; }

  .choice-guide {
    padding-top: 70px;
    padding-bottom: 70px;
    text-align: center;
    border-bottom: 1px solid var(--line);
  }
  .choice-lead {
    max-width: 720px;
    margin: 0 auto 34px;
    color: #555;
    line-height: 1.8;
  }
  .choice-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin: 34px 0 20px;
  }
  .choice-card {
    display: flex;
    min-height: 260px;
    flex-direction: column;
    justify-content: space-between;
    gap: 14px;
    padding: 28px 24px;
    border: 1px solid var(--line);
    border-radius: 20px;
    background: #fff;
    color: #333;
    text-decoration: none;
    text-align: left;
    box-shadow: 0 16px 34px rgba(44, 44, 44, 0.04);
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }
  .choice-card:hover {
    border-color: var(--trust-mid);
    box-shadow: 0 20px 44px rgba(44, 44, 44, 0.08);
    transform: translateY(-3px);
  }
  .choice-card.primary-choice {
    border: 2px solid var(--trust-line);
    background: linear-gradient(135deg, rgba(15, 76, 92, 0.06), rgba(197, 160, 89, 0.06)), #fff;
  }
  .choice-label {
    align-self: flex-start;
    border-radius: 999px;
    background: rgba(15, 76, 92, 0.08);
    color: var(--trust);
    font-size: 0.75rem;
    font-weight: 800;
    padding: 5px 12px;
  }
  .choice-card h3 {
    margin: 0;
    color: #2c2c2c;
    font-size: 1.25rem;
    line-height: 1.45;
  }
  .choice-card p {
    margin: 0;
    color: #666;
    font-size: 0.92rem;
    line-height: 1.7;
  }
  .choice-card .choice-fit {
    display: inline-block;
