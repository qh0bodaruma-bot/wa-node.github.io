          <button class="plan-tab-btn active" data-plan-tab="hp" role="tab" aria-selected="true">
            <MaterialIcon name="language" /> Site Web (HP)
          </button>
          <button class="plan-tab-btn" data-plan-tab="lp" role="tab" aria-selected="false">
            <MaterialIcon name="ads_click" /> Landing Page (LP)
          </button>
        </div>
      </div>

      <!-- Plans de Création HP -->
