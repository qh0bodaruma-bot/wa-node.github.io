              <tr><td>Site Web Simple</td><td>50 000 JPY〜</td><td class="price-campaign">40 000 JPY〜</td><td>Site professionnel vitrine (3 à 5 pages)</td></tr>
              <tr><td>LP Psychologie</td><td>80 000 JPY〜</td><td class="price-campaign">64 000 JPY〜</td><td>LP optimisée pour la conversion (structure stratégique incluse)</td></tr>
              <tr><td>LP Psychologie Premium</td><td>150 000 JPY〜</td><td class="price-campaign">120 000 JPY〜</td><td>LP haut de gamme avec automatisation post-demande, e-mails GAS et intégration LINE</td></tr>
              <tr><td>Site Web Psychologie</td><td>180 000 JPY〜</td><td class="price-campaign">144 000 JPY〜</td><td>Site standard haut de gamme (environ 5 pages)</td></tr>
