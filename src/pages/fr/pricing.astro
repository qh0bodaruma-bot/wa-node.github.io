---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConsultationFlow from '../../components/ConsultationFlow.astro';
---

<BaseLayout title="Tarifs & Offres de Services | Wa-Node" description="Découvrez les tarifs transparents de Wa-Node. Nous proposons une conception de sites web et LP optimisée pour la conversion grâce à la psychologie comportementale, un co-pilotage stratégique mensuel et l'intégration de solutions IA." lang="fr">
  <main class="pricing-container">
    <section class="hero">
      <div class="hero-inner">
        <!-- Premium Anniversary Banner -->
        <div class="premium-ann-banner reveal">
          <div class="banner-inner">
            <span class="banner-badge">1er ANNIVERSAIRE</span>
            <div class="banner-main">
              <strong>Offre Spéciale Anniversaire : 20% de réduction sur toutes nos formules !</strong>
              <p>Limité à 3 clients par mois. Design de conversion haut de gamme à prix d'anniversaire. <span class="period">Jusqu'au 31 juillet 2026</span></p>
            </div>
            <a href="/campaign-anniversary/?lang=fr" class="banner-link">Consulter la Page Spéciale →</a>
          </div>
        </div>

        <p class="eyebrow">Tarifs</p>
        <h1 class="premium-heading">Formules & Tarification</h1>
        <p class="lead">Des tarifs transparents adaptés à votre conversion. Des solutions sur mesure ajustées à votre budget sont également envisageables.</p>
        <p class="note">Chez Wa-Node, nous exploitons la psychologie comportementale non pas pour "susciter de l'anxiété," mais pour "bâtir un parcours de haute confiance où l'utilisateur se sent pleinement en sécurité."</p>
      </div>
    </section>

    <section class="section">
      <p class="eyebrow">01. Web & Lead Design</p>
      <h2 class="premium-heading">Design Web & LP Orienté Psychologie</h2>
      <p>Élimination des frictions numériques et optimisation de la conversion. Des sites d'exception conçus selon les analyses cognitives.</p>
      <div class="campaign-notice-box">
        <strong>【Campagne du 1er Anniversaire】 -20% sur la Création Web !</strong>
        <p>Bénéficiez d'une réduction de 20% sur nos tarifs standards ci-dessous (Limité à 3 clients par mois).</p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Service</th><th>Tarif Standard</th><th>Tarif de Campagne</th><th>Détails</th></tr>
          </thead>
          <tbody>
            <tr><td>LP Simple</td><td>30 000 JPY〜</td><td class="price-campaign">24 000 JPY〜</td><td>Page d'atterrissage épurée et efficace pour une présentation claire</td></tr>
            <tr><td>Site Web Simple</td><td>50 000 JPY〜</td><td class="price-campaign">40 000 JPY〜</td><td>Site professionnel vitrine (3 à 5 pages)</td></tr>
            <tr><td>LP Psychologie</td><td>60 000 JPY〜</td><td class="price-campaign">48 000 JPY〜</td><td>LP optimisée pour la conversion (structure stratégique incluse)</td></tr>
            <tr><td>Site Web Psychologie</td><td>120 000 JPY〜</td><td class="price-campaign">96 000 JPY〜</td><td>Site standard haut de gamme (environ 5 pages)</td></tr>
            <tr><td>Formule "Business 7"</td><td>150 000 JPY〜</td><td class="price-campaign">120 000 JPY〜</td><td>Structure à 7 pages, SEO de base optimisé, finitions premium</td></tr>
            <tr><td>Options Personnalisées</td><td>5 000 JPY〜</td><td class="price-campaign">4 000 JPY〜</td><td>Création d'infographies, configuration de blog, quiz sur mesure, etc.</td></tr>
            <tr><td>Maintenance & Support</td><td>10 000 JPY〜 / mois</td><td>-</td><td>Audits de sécurité réguliers, mises à jour techniques, retouches mineures</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="section">
      <p class="eyebrow">02. Support Continu & IA</p>
      <h2 class="premium-heading">Co-pilote d'Affaires (Partenariat Stratégique Mensuel)</h2>
      <p>Nous ne nous limitons pas à "bâtir et partir." Nous résolvons vos défis système continus et vous guidons dans l'intégration de l'IA pour automatiser vos tâches.</p>
      
      <div class="pricing-grid-simple">
        <div class="p-card-simple highlight">
          <span class="p-tag">Recommandée</span>
          <h3>Co-pilote (Formule Light)</h3>
          <p class="p-price">15 000 JPY〜 <small>/ mois</small></p>
          <p class="p-desc">1 entretien mensuel + assistance continue par messagerie. Idéal pour vos retouches web et conseils en IA.</p>
        </div>
        <div class="p-card-simple">
          <h3>Consultation TIC Ponctuelle</h3>
          <p class="p-price">5 000 JPY <small>/ 60 min</small></p>
          <p class="p-desc">Résolution ciblée pour ChatGPT, APIs LINE, outils internes ou questions web.</p>
        </div>
        <div class="p-card-simple">
          <h3>Pack d'Intégration IA</h3>
          <p class="p-price">30 000 JPY</p>
          <p class="p-desc">Paramétrages initiaux de ChatGPT, création de modèles de prompts personnalisés et plan d'intégration.</p>
        </div>
      </div>

      <details class="addon-details">
        <summary>Afficher les Services Additionnels & Options sur Mesure</summary>
        <div class="table-wrap mini">
          <table>
            <thead>
              <tr><th>Nom de l'Offre</th><th>Tarif</th><th>Détails</th></tr>
            </thead>
            <tbody>
              <tr><td>Co-pilote (Formule Standard)</td><td>30 000 JPY / mois</td><td>2 entretiens par mois + propositions d'amélioration + manuels de prompts personnalisés</td></tr>
              <tr><td>Audit de Flux & Diagnostic</td><td>15 000 JPY</td><td>90 min de cadrage + cartographie des processus pour prioriser vos automatisations</td></tr>
              <tr><td>Pack DX Petite Entreprise</td><td>50 000 JPY</td><td>Visualisation complète des flux, sélection d'outils et feuille de route sur mesure</td></tr>
              <tr><td>Formation IA pour Entreprises</td><td>80 000 JPY〜</td><td>Conférences sur site, règles de sécurité des données et onboarding personnalisé</td></tr>
              <tr><td>Tunnel LINE Officiel</td><td>20 000 JPY〜</td><td>Conception de parcours orienté conversion, du message d'accueil à l'action</td></tr>
            </tbody>
          </table>
        </div>
      </details>
    </section>

    <section class="section">
      <p class="eyebrow">03. Soutien Organisationnel & Alignement Psychologique</p>
      <h2 class="premium-heading">Soutien Organisationnel & Alignement Psychologique</h2>
      <p>Application d'expertises en psychologie aux processus de communication interne, cohésion d'équipe et soutien au bien-être.</p>
      <div class="table-wrap">
        <table>
          <tbody>
            <tr>
              <td>Support de Com' Psychologique</td>
              <td>15 000 JPY〜 / mois</td>
              <td>Pour petites entreprises. Conception d'espaces d'écoute et formation à la sécurité psychologique.</td>
            </tr>
            <tr>
              <td>Séance Conseiller Exécutif</td>
              <td>5 000 JPY / 60 min</td>
              <td>Clarté cognitive et prise de décision pour dirigeants et leaders. 30 min offertes au premier rendez-vous.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <ConsultationFlow lang="fr" />
  </main>
</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

  :root {
    --accent: #c5a059;
    --accent-dark: #b18e4a;
    --accent-red: #d14d3a;
    --line: rgba(197, 160, 89, 0.2);
  }

  .premium-heading {
    font-family: 'Shippori Mincho', serif !important;
    font-weight: 800 !important;
    letter-spacing: 0.05em;
  }

  .pricing-container {
    background: #fdfcf9;
    font-family: 'Shippori Mincho', serif !important;
  }

  .hero { padding: 80px 0 60px; border-bottom: 1px solid var(--line); text-align: center; }
  .hero-inner, .section { max-width: 1000px; margin: 0 auto; padding: 0 20px; }
  
  .premium-ann-banner { margin-bottom: 50px; }
  .banner-inner {
    background: #fff; border: 1px solid var(--accent-red); border-radius: 24px;
    padding: 24px 32px; display: flex; align-items: center; gap: 30px;
    box-shadow: 0 15px 40px rgba(209, 77, 58, 0.08); position: relative;
  }
  .banner-badge {
    background: var(--accent-red); color: #fff; font-size: 0.7rem; font-weight: 800;
    padding: 4px 12px; border-radius: 4px; white-space: nowrap;
  }
  .banner-main { flex: 1; text-align: left; }
  .banner-main strong { display: block; font-size: 1.3rem; color: var(--accent-red); margin-bottom: 4px; }
  .banner-link {
    font-size: 0.95rem; font-weight: 800; color: var(--accent-red); text-decoration: none;
    padding: 12px 24px; border: 1px solid var(--accent-red); border-radius: 50px;
    transition: 0.3s; white-space: nowrap;
  }
  .banner-link:hover { background: var(--accent-red); color: #fff; }

  .lead { font-size: 1.1rem; color: #555; margin-bottom: 30px; }
  .note { background: #fff; border: 1px solid var(--line); padding: 20px; border-radius: 15px; color: #666; font-size: 0.95rem; }

  .section { padding: 80px 20px; }
  .eyebrow { font-size: 0.8rem; font-weight: 800; color: var(--accent); letter-spacing: 0.2em; margin-bottom: 10px; display: block; }
  h2 { font-size: 2.2rem; margin-bottom: 20px; color: #2c2c2c; }

  .campaign-notice-box {
    background: rgba(209, 77, 58, 0.03); border-left: 4px solid var(--accent-red);
    padding: 20px; border-radius: 0 15px 15px 0; margin-bottom: 30px;
  }
  .campaign-notice-box strong { color: var(--accent-red); font-size: 1.1rem; }

  .table-wrap { border: 1px solid var(--line); border-radius: 20px; overflow: hidden; background: #fff; margin-bottom: 40px; }
  table { width: 100%; border-collapse: collapse; }
  th, td { padding: 20px; text-align: left; border-bottom: 1px solid var(--line); }
  th { background: #fdfaf5; color: var(--accent-dark); font-weight: 800; font-size: 0.85rem; }
  .price-campaign { color: var(--accent-red); font-weight: 800; }

  .pricing-grid-simple {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin: 40px 0;
  }
  .p-card-simple {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 30px 20px;
    text-align: center;
    position: relative;
    transition: 0.3s;
  }
  .p-card-simple.highlight {
    border: 2px solid var(--accent);
    background: #fffdf9;
    transform: scale(1.05);
    z-index: 1;
  }
  .p-tag {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    padding: 2px 12px;
    border-radius: 4px;
  }
  .p-card-simple h3 { font-size: 1.1rem; margin-bottom: 15px; font-weight: 800; }
  .p-price { font-size: 1.6rem; font-weight: 800; color: var(--accent-dark); margin-bottom: 15px; }
  .p-price small { font-size: 0.8rem; font-weight: 400; color: #999; }
  .p-desc { font-size: 0.85rem; color: #666; line-height: 1.5; }

  .addon-details { margin-top: 20px; }
  .addon-details summary {
    cursor: pointer;
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 800;
    text-align: center;
    list-style: none;
  }
  .addon-details summary:hover { text-decoration: underline; }
  .table-wrap.mini { margin-top: 20px; }
  .table-wrap.mini th, .table-wrap.mini td { padding: 12px 15px; font-size: 0.85rem; }

  @media (max-width: 768px) {
    .banner-inner { flex-direction: column; text-align: center; padding: 30px 20px; gap: 15px; }
    .banner-main { text-align: center; }
    .banner-main strong { font-size: 1.1rem; }
    h2 { font-size: 1.8rem; }
    th, td { padding: 15px 10px; font-size: 0.9rem; }
    .pricing-grid-simple { grid-template-columns: 1fr; }
  }
</style>
