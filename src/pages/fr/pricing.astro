---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConsultationFlow from '../../components/ConsultationFlow.astro';
import ProjectExecutionFlow from '../../components/ProjectExecutionFlow.astro';
import MaterialIcon from '../../components/MaterialIcon.astro';
---

<BaseLayout title="Tarifs & Offres de Services | Wa-Node" description="Découvrez les tarifs transparents de Wa-Node. Nous proposons une conception de sites web et LP optimisée pour la conversion grâce à la psychologie comportementale, un co-pilotage stratégique mensuel et l'intégration de solutions IA." lang="fr">
  <main class="pricing-container">
    <section class="hero">
      <div class="hero-inner">
        <!-- Premium Anniversary Banner -->
        <div class="premium-ann-banner reveal">
          <div class="banner-inner">
            <span class="banner-badge">1er ANNIVERSAIRE</span>
            <div class="banner-main">
              <strong>Offre Spéciale Anniversaire : 20% de réduction sur toutes nos formules !</strong>
              <p>Limité à 3 clients par mois. Design de conversion haut de gamme à prix d'anniversaire. <span class="period">Jusqu'au 31 juillet 2026</span></p>
            </div>
            <a href="/campaign-anniversary/?lang=fr" class="banner-link">Consulter la Page Spéciale →</a>
          </div>
        </div>

        <p class="eyebrow">Tarifs</p>
        <h1 class="premium-heading">Formules & Tarification</h1>
        <p class="lead">Des tarifs transparents adaptés à votre conversion. Des solutions sur mesure ajustées à votre budget sont également envisageables.</p>
        <p class="note">Chez Wa-Node, nous exploitons la psychologie comportementale non pas pour "susciter de l'anxiété," mais pour "bâtir un parcours de haute confiance où l'utilisateur se sent pleinement en sécurité."</p>
      </div>
    </section>

    <section class="section choice-guide">
      <p class="eyebrow">Commencez Ici</p>
      <h2 class="premium-heading">Un doute ? Choisissez parmi ces 4 points d'entrée</h2>
      <p class="choice-lead">Pas besoin de choisir une formule détaillée d'emblée. Exprimez simplement vos objectifs depuis l'un de ces points d'entrée, et nous concevrons l'offre idéale.</p>
      <div class="choice-grid">
        <a class="choice-card primary-choice" href="#web-production">
          <span class="choice-label">Le Plus Populaire</span>
          <h3>Je souhaite créer un Site Web ou une LP</h3>
          <p class="choice-fit">Pour établir une présence de confiance</p>
          <p>Nous structurons et concevons des LPs et sites web optimisés pour la conversion et la confiance.</p>
          <strong>Recommandé dès 64 000 JPY</strong>
        </a>
        <a class="choice-card" href="#copilot">
          <span class="choice-label">Audit du parcours</span>
          <h3>Je souhaite améliorer un site ou une LP existante</h3>
          <p class="choice-fit">Pour réduire les hésitations avant la demande</p>
          <p>Nous vérifions CTA, tarifs, formulaires, structure lisible par l'IA, couleurs, mouvements et lisibilité.</p>
          <strong>Dès 15 000 JPY</strong>
        </a>
        <a class="choice-card" href="#copilot">
          <span class="choice-label">Support Continu</span>
          <h3>Je souhaite un accompagnement après le lancement</h3>
          <p class="choice-fit">Pour l'optimisation continue</p>
          <p>Votre « Co-pilote d'Affaires » mensuel pour l'optimisation, l'intégration de l'IA et la simplification des flux.</p>
          <strong>Dès 15 000 JPY / mois</strong>
        </a>
        <a class="choice-card" href="#ict-ai">
          <span class="choice-label">Consultation Ponctuelle</span>
          <h3>Je souhaite optimiser mes flux avec l'IA & les TIC</h3>
          <p class="choice-fit">Pour débuter avec un audit de flux</p>
          <p>Nous résolvons vos questions sur ChatGPT, LINE, outils internes et automatisations simples lors d'une session unique.</p>
          <strong>Dès 5 000 JPY</strong>
        </a>
      </div>
      <p class="choice-footnote">En cas de doute, nous vous recommandons de commencer par « Je souhaite créer un Site Web ou une LP » ou « Je souhaite améliorer un site ou une LP existante ».</p>
      <div class="decision-guide" aria-label="Recommandé par Objectif">
        <h3>Recommandé par Objectif</h3>
        <div class="decision-grid">
          <a href="#web-production">
            <span>Augmenter les demandes de contact</span>
            <strong>LP Optimisée Psychologie</strong>
          </a>
          <a href="#web-production">
            <span>Bâtir des bases commerciales solides</span>
            <strong>Site Web Optimisé Psychologie</strong>
          </a>
          <a href="#copilot">
            <span>Optimiser en continu</span>
            <strong>Co-pilote d'Affaires</strong>
          </a>
        </div>
      </div>
    </section>

    <section class="section" id="web-production">
      <p class="eyebrow">01. Web & Lead Design</p>
