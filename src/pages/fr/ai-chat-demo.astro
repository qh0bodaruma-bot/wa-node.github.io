---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Navigateur de Consultation Stratégique IA (Démo) | Wa-Node";
const description = "Démo interactive des compétences de développement d'IA de Wa-Node. Clarifiez vos obstacles d'affaires (production web, automatisation de flux de travail, DX) en moins de 3 minutes grâce à notre assistant stratégique IA.";
---

<BaseLayout title={title} description={description} lang="fr">
  <main class="demo-page">
    <section class="section demo-hero">
      <div class="section-inner">
        <span class="eyebrow">Démo des Solutions IA & TIC</span>
        <h1>Navigateur de Consultation IA</h1>
        <h2 class="demo-subheading">Clarifier Vos Besoins en Moins de 3 Minutes</h2>
        <p class="lead">Design web, automatisation IA ou optimisation de la conversion. Notre assistant stratégique IA vous guide vers la meilleure prochaine étape, adaptée à votre situation.</p>
        <div class="demo-notice">
          <p>*Cette page est une démonstration interactive des capacités de développement d'IA de Wa-Node. Bien que l'IA génère les réponses, elle ne représente pas un devis contractuel, un accord juridique ou une consultation clinique.</p>
        </div>
      </div>
    </section>

    <section class="section chat-demo-section">
      <div class="section-inner">
        <div class="chat-container glass-card">
          <div class="chat-header">
            <div class="header-info">
              <span class="status-dot"></span>
              <strong>Navigateur de Consultation IA (Bêta)</strong>
            </div>
            <p class="header-sub">IA Spécialisée en Architecture Web & Solutions TIC</p>
          </div>
          
          <div class="chat-messages" id="chat-messages">
            <div class="message ai">
              <div class="message-inner">
                Bienvenue sur le Navigateur de Consultation IA de Wa-Node. Je suis ici pour vous aider à structurer vos défis commerciaux selon trois piliers essentiels : « Tunnels de Conversion Web », « Solutions TIC & Automatisation » et « Approches Psychologiques Comportementales ».<br/><br/>
                Quels sont les sujets ou difficultés que vous explorez actuellement ? (Par exemple : améliorer le taux de conversion d'une page de destination, automatiser des tâches répétitives avec ChatGPT, fluidifier votre service client...)
              </div>
            </div>
          </div>

          <div class="chat-input-area">
            <div class="input-wrap">
              <textarea id="chat-input" placeholder="Ex : Je souhaite optimiser ma page de destination, je veux intégrer ChatGPT dans mes tâches..." rows="1"></textarea>
              <button id="send-btn" type="button" aria-label="Envoyer la demande" disabled>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
              </button>
            </div>
          </div>
        </div>

        <div class="demo-footer-info">
          <h3>Ce que vous pouvez accomplir avec cette démo</h3>
          <ul>
            <li>Formuler des idées ou défis vagues en objectifs professionnels clairs.</li>
            <li>Vérifier la compatibilité et la synergie avec les services clés de Wa-Node.</li>
            <li>Organiser vos pensées efficacement avant un entretien en direct.</li>
          </ul>
          <div class="final-cta">
            <p>Une fois vos pensées structurées, construisons ensemble votre feuille de route personnalisée lors d'un entretien stratégique gratuit.</p>
            <a href="/fr/contact/" class="btn primary">Prendre Rendez-vous pour un Entretien Gratuit (30-60 min)</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  .demo-page { background: #fdfcf9; }
  .demo-hero { text-align: center; padding: 80px 0 40px; border-bottom: 1px solid var(--line); }
  .demo-notice {
    max-width: 700px; margin: 30px auto 0; padding: 20px;
    background: rgba(197, 160, 89, 0.05); border-radius: 12px;
    font-size: 0.85rem; color: var(--muted); line-height: 1.6;
  }

  .chat-demo-section { padding: 60px 0; }
  .chat-container {
    max-width: 800px; margin: 0 auto 40px;
    height: 600px; display: flex; flex-direction: column;
    border: 1px solid var(--line); overflow: hidden;
    background: #fff; box-shadow: 0 30px 60px rgba(0,0,0,0.05);
  }

  .chat-header { padding: 24px; background: var(--soft); border-bottom: 1px solid var(--line); }
  .header-info { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
  .status-dot { width: 8px; height: 8px; background: #639922; border-radius: 50%; }
  .header-sub { font-size: 0.8rem; color: var(--muted); margin: 0; }

  .chat-messages { flex: 1; overflow-y: auto; padding: 30px; display: flex; flex-direction: column; gap: 20px; }
  .message { max-width: 85%; line-height: 1.7; }
  .message.ai { align-self: flex-start; }
  .message.user { align-self: flex-end; }
  .message-inner { padding: 16px 20px; border-radius: 20px; font-size: 0.95rem; }
  .message.ai .message-inner { background: #f0f0f0; border-bottom-left-radius: 4px; color: #333; }
  .message.user .message-inner { background: var(--accent); border-bottom-right-radius: 4px; color: #fff; }

  .chat-input-area { padding: 24px; border-top: 1px solid var(--line); background: #fff; }
  .input-wrap { display: flex; gap: 12px; align-items: flex-end; }
  #chat-input {
    flex: 1; border: 1px solid #ddd; border-radius: 12px; padding: 12px 16px;
    font-family: inherit; font-size: 1rem; resize: none; min-height: 48px; max-height: 120px;
    transition: 0.3s;
  }
  #chat-input:focus { border-color: var(--accent); outline: none; }
  #send-btn {
    width: 48px; height: 48px; border-radius: 12px; background: var(--accent); color: #fff;
    border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: 0.3s;
  }
  #send-btn:disabled { opacity: 0.3; cursor: not-allowed; }

  .demo-footer-info { max-width: 800px; margin: 0 auto; text-align: center; }
  .demo-hero h1 { font-size: clamp(2.5rem, 6vw, 4rem); margin-bottom: 12px; }
  .demo-subheading { font-size: 1.5rem; color: var(--accent); margin-bottom: 24px; font-weight: 800; }
  .demo-footer-info ul { list-style: none; padding: 0; display: inline-block; text-align: left; margin-bottom: 40px; }
  .demo-footer-info li { margin-bottom: 12px; font-size: 0.95rem; display: flex; gap: 10px; }
  .demo-footer-info li::before { content: "✔"; color: var(--accent); font-weight: 800; }
  .final-cta { padding: 40px; background: var(--soft); border-radius: 24px; border: 1px solid var(--line); }
  .final-cta p { margin-bottom: 20px; font-weight: 800; }
</style>

<script is:inline>
  function initDemoChat() {
    const messages = document.getElementById('chat-messages');
    const input = document.getElementById('chat-input');
    const sendBtn = document.getElementById('send-btn');
    
    // Add dynamic system instructions to prioritize French replies
    let chatHistory = [
      { role: "system", content: "You are the AI Consult Navigator for Wa-Node. Reply strictly in French. Guide the user regarding their web conversion, ICT/automation, or counseling questions." }
    ];

    input.addEventListener('input', () => {
      sendBtn.disabled = !input.value.trim();
      input.style.height = 'auto';
      input.style.height = input.scrollHeight + 'px';
    });

    async function sendMessage() {
      const text = input.value.trim();
      if (!text) return;

      // Add User Message
      appendMessage('user', text);
      input.value = '';
      input.style.height = 'auto';
      sendBtn.disabled = true;

      const aiMsgDiv = appendMessage('ai', 'Analyse en cours...');
      const inner = aiMsgDiv.querySelector('.message-inner');

      try {
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            messages: [...chatHistory, { role: 'user', content: text }] 
          })
        });

        if (!response.ok) throw new Error();

        inner.innerHTML = '';
        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        let fullContent = '';

        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          const chunk = decoder.decode(value);
          const lines = chunk.split('\n');
          
          for (const line of lines) {
            if (line.startsWith('data: ')) {
              const data = line.slice(6);
              if (data === '[DONE]') continue;
              try {
                const parsed = JSON.parse(data);
                const content = parsed.choices[0].delta.content || '';
                fullContent += content;
                inner.innerText = fullContent;
                messages.scrollTop = messages.scrollHeight;
              } catch (e) {}
            }
          }
        }
        chatHistory.push({ role: 'user', content: text });
        chatHistory.push({ role: 'assistant', content: fullContent });

      } catch (e) {
        inner.innerText = 'Une erreur est survenue. Veuillez réessayer dans quelques instants.';
      }
    }

    function appendMessage(role, text) {
      const div = document.createElement('div');
      div.className = `message ${role}`;
      div.innerHTML = `<div class="message-inner">${text}</div>`;
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
      return div;
    }

    sendBtn.addEventListener('click', sendMessage);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });
  }

  document.addEventListener('astro:page-load', initDemoChat);
</script>
