---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="デモHPパッケージ一覧 | 和-Node">
  <main>
    <!-- Hero Section -->
    <section class="demo-hero">
      <div class="container">
        <div class="hero-label">Standard Website Packages</div>
        <h1>理想のウェブサイトを、<br/><span>パッケージ</span>から選ぶ。</h1>
        <p>事業の規模や目的に合わせ、厳選されたページ構成と最高級のデザインをパッケージ化しました。<br/>あなたのビジョンに最適な「器」をお選びください。</p>
      </div>
    </section>

    <!-- Package Grid -->
    <section class="package-selection">
      <div class="container">
        <div class="grid">
          
          <!-- Standard / Business 7 -->
          <article class="package-card reveal">
            <div class="card-header">
              <span class="plan-tag">Standard</span>
              <h3>Business 7</h3>
              <div class="page-count">7 Pages</div>
            </div>
            <div class="card-body">
              <p class="description">あああああああああああああああああああああああああああああああああああああああああああああ。</p>
              <ul class="features">
                <li>✅ 構成設計（あああああ）</li>
                <li>✅ レスポンシブ対応（いいいいい）</li>
                <li>✅ 基本7ページ構成（ううううう）</li>
                <li>✅ プレミアム・フィニッシュ適用</li>
              </ul>
              <a href="/portfolio-lp/demo_business_7.html" class="demo-btn">デモを体験する</a>
            </div>
          </article>

          <!-- Premium / Premium 10 -->
          <article class="package-card premium reveal">
            <div class="best-value">MOST POPULAR</div>
            <div class="card-header">
              <span class="plan-tag">High-End</span>
              <h3>Premium 10</h3>
              <div class="page-count">10 Pages</div>
            </div>
            <div class="card-body">
              <p class="description">いいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいいい。</p>
              <ul class="features">
                <li>✅ Business 7 の全機能</li>
                <li>✅ リッチアニメーション（あああああ）</li>
                <li>✅ SEO強化5セクション追加</li>
                <li>✅ 心理導線10ページ構成</li>
              </ul>
              <a href="/portfolio-lp/demo_premium_10.html" class="demo-btn">デモを体験する</a>
            </div>
          </article>

          <!-- Elite / Enterprise 15+ -->
          <article class="package-card elite reveal">
            <div class="card-header">
              <span class="plan-tag">Ultimate</span>
              <h3>Enterprise 15+</h3>
              <div class="page-count">15+ Pages</div>
            </div>
            <div class="card-body">
              <p class="description">うううううううううううううううううううううううううううううううううううううううううううう。</p>
              <ul class="features">
                <li>✅ Premium 10 の全機能</li>
                <li>✅ カスタムシステム連携（あああああ）</li>
                <li>✅ 採用・実績・ブログ全網羅</li>
                <li>✅ 権威性を極める15ページ超構成</li>
              </ul>
              <a href="/portfolio-lp/demo_enterprise_15.html" class="demo-btn">デモを体験する</a>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="comparison-section">
      <div class="container glass-panel">
        <h2 class="sec-title">グレード別機能比較</h2>
        <table class="comparison-table">
          <thead>
            <tr>
              <th>機能 / プラン</th>
              <th>Business 7</th>
              <th>Premium 10</th>
              <th>Enterprise 15+</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>ページ数</td>
              <td>7枚</td>
              <td>10枚</td>
              <td>15枚〜</td>
            </tr>
            <tr>
              <td>デザイン品質</td>
              <td>Standard</td>
              <td>High-End</td>
              <td>Ultimate</td>
            </tr>
            <tr>
              <td>アニメーション</td>
              <td>基本のみ</td>
              <td>リッチ演出</td>
              <td>フルカスタム</td>
            </tr>
            <tr>
              <td>心理導線設計</td>
              <td>✅</td>
              <td>✅ (強化版)</td>
              <td>✅ (戦略網羅)</td>
            </tr>
            <tr>
              <td>システム連携</td>
              <td>ー</td>
              <td>基本フォーム</td>
              <td>カスタムDB/API</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- CTA -->
    <section class="demo-cta">
      <div class="container">
        <h2>あなたのビジョンに、<br/>最適なプランを。</h2>
        <p>どのパッケージが最適か、専門のコンサルタントがアドバイスいたします。</p>
        <a href="https://docs.google.com/forms/d/e/1FAIpQLScUbeK9em6cjegU5ha5Sh2fWamrIbxDuhmHDJPIN_no5Sj8-w/viewform?usp=publish-editor" class="cta-btn">無料相談を予約する</a>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  main {
    background: #0a0a0c;
    color: #e2e2e7;
    min-height: 100vh;
    padding-bottom: 100px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero */
  .demo-hero {
    padding: 160px 0 100px;
    text-align: center;
  }
  .hero-label {
    color: #c0a060;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-size: 14px;
    margin-bottom: 24px;
  }
  .demo-hero h1 {
    font-size: clamp(40px, 8vw, 72px);
    line-height: 1.1;
    margin-bottom: 32px;
    background: linear-gradient(135deg, #fff 0%, #a0a0a0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .demo-hero h1 span {
    color: #c0a060;
    -webkit-text-fill-color: #c0a060;
  }
  .demo-hero p {
    font-size: 18px;
    color: #8e8e93;
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.8;
  }

  /* Package Grid */
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 40px;
  }
  .package-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 32px;
    padding: 48px 32px;
    position: relative;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    overflow: hidden;
  }
  .package-card:hover {
    transform: translateY(-16px);
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(192, 160, 96, 0.4);
    box-shadow: 0 40px 80px rgba(0,0,0,0.5);
  }
  .package-card.premium {
    background: linear-gradient(180deg, rgba(192, 160, 96, 0.1) 0%, rgba(255, 255, 255, 0.03) 100%);
    border-color: rgba(192, 160, 96, 0.3);
  }
  .best-value {
    position: absolute;
    top: 0;
    right: 0;
    background: #c0a060;
    color: #000;
    padding: 8px 24px;
    font-size: 12px;
    font-weight: 900;
    border-bottom-left-radius: 16px;
  }

  .plan-tag {
    font-size: 12px;
    color: #c0a060;
    font-weight: 700;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 16px;
  }
  .package-card h3 {
    font-size: 32px;
    margin-bottom: 8px;
    color: #fff;
  }
  .page-count {
    font-size: 14px;
    color: #8e8e93;
    margin-bottom: 32px;
  }
  .description {
    font-size: 15px;
    color: #aeaeb2;
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .features {
    list-style: none;
    padding: 0;
    margin-bottom: 48px;
  }
  .features li {
    margin-bottom: 16px;
    font-size: 14px;
    color: #d1d1d6;
  }

  .demo-btn {
    display: block;
    width: 100%;
    padding: 16px;
    text-align: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    text-decoration: none;
    border-radius: 12px;
    font-weight: 700;
    transition: all 0.3s;
  }
  .package-card.premium .demo-btn {
    background: #c0a060;
    color: #000;
    border: none;
  }
  .demo-btn:hover {
    background: #fff;
    color: #000;
  }

  /* Comparison */
  .comparison-section {
    padding: 100px 0;
  }
  .glass-panel {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 40px;
    padding: 60px;
  }
  .sec-title {
    text-align: center;
    font-size: 32px;
    margin-bottom: 60px;
    color: #fff;
  }
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
  }
  .comparison-table th, .comparison-table td {
    padding: 24px;
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .comparison-table th {
    font-size: 18px;
    color: #c0a060;
  }
  .comparison-table td:first-child {
    text-align: left;
    color: #8e8e93;
    font-weight: 500;
  }

  /* CTA */
  .demo-cta {
    text-align: center;
    padding: 100px 0;
  }
  .demo-cta h2 {
    font-size: 48px;
    margin-bottom: 24px;
    color: #fff;
  }
  .demo-cta p {
    font-size: 18px;
    color: #8e8e93;
    margin-bottom: 48px;
  }
  .cta-btn {
    background: #fff;
    color: #000;
    padding: 20px 60px;
    border-radius: 50px;
    font-weight: 900;
    text-decoration: none;
    transition: 0.3s;
  }
  .cta-btn:hover {
    background: #c0a060;
    transform: scale(1.05);
  }

  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr; }
    .glass-panel { padding: 30px; }
    .comparison-table { font-size: 12px; }
  }

  /* Reveal Animation */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: 1s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
