---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMovie from '../components/BrandMovie.astro';
import {
  absoluteUrl,
  createBreadcrumbSchema,
  createWebPageSchema,
  organizationSchema,
} from '../data/structuredData';

const title = "和-Nodeを支えるテクノロジー（Tech Stack）｜和-Node";
const description = "和-NodeのWeb制作を支える技術基盤。Astro、Cloudflare Pages、Vanilla CSSを用いた、高速・安全性・柔軟性を重視するWebサイト構築と、静的サイト・動的サイトの選び方を解説します。";
const image = "/images/ogp-tech-stack.png";
const structuredData = [
  organizationSchema,
  createWebPageSchema({ name: title, description, path: "/tech-stack/" }),
  createBreadcrumbSchema([
    { name: "ホーム", path: "/" },
    { name: "当サイトの技術", path: "/tech-stack/" },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "@id": absoluteUrl("/tech-stack/#article"),
    headline: "和-Nodeを支えるテクノロジー",
    description,
    url: absoluteUrl("/tech-stack/"),
    image: absoluteUrl(image),
    inLanguage: "ja",
    publisher: { "@id": "https://www.wa-node.com/#organization" },
    about: ["Astro", "Cloudflare Pages", "Vanilla CSS", "AI Driven Development", "Static Site", "Dynamic Site"],
  },
];
---

<BaseLayout title={title} description={description} image={image} structuredData={structuredData}>
  <main class="tech-page">
    <!-- Hero Section -->
    <section class="tech-hero section">
      <div class="container narrow reveal">
        <div class="eyebrow">Technology & Architecture</div>
        <h1>和-Nodeを支える<br/><span class="text-accent">テクノロジー</span></h1>
        <p class="lead">
          ただ見た目が綺麗なだけでなく、軽さ、安全性、ユーザーの心理に寄り添うことを重視する。<br/>
          それを実現するための、私たちの技術スタックとその理由を公開します。
        </p>
      </div>
    </section>

    <BrandMovie
      eyebrow="Brand Movie"
      title="伝わるサイトは、見た目だけでは決まらない。"
      body="心理学・Web制作・ICTの視点から、表示速度、導線、相談しやすさまで一つの流れとして整える。和-Nodeの制作思想を短い動画で紹介します。"
    />
    <!-- Tech Stack Grid -->
    <section class="tech-stack-section section">
      <div class="container">
        
        <div class="tech-card reveal card-border-gold">
          <div class="tech-header">
            <h2 class="tech-title"><span class="card-icon-window window-gold"><svg viewBox="0 0 24 24"><path d="M12 2S8 7 8 12c0 3 2 5 4 5s4-2 4-5c0-5-4-10-4-10z" stroke="currentColor" stroke-width="2" fill="none"/><path d="M9 15l-3 6M15 15l3 6M12 17v4" stroke="currentColor" stroke-width="2"/></svg></span>Astro</h2>
            <span class="tech-badge">Framework</span>
          </div>
          <div class="tech-body">
            <h3>「Zero JS」による圧倒的な表示速度</h3>
            <p>
              現代のWebフレームワークの多くは、ユーザーのブラウザに大量のJavaScriptを送信します。
              Astroは「デフォルトでJavaScriptを送信しない（Zero JS）」という設計思想を持ち、
              必要な部分だけを動的にする「Islands Architecture」を採用しています。
            </p>
            <p>
              これにより、ページ表示の待ち時間を極限まで削り、離脱率の低下とSEO評価の向上を同時に実現します。
            </p>
            <div class="tech-psych-note">
              <strong>🧠 心理学エビデンス：0.05秒の第一印象（Lindgaard et al., 2006）</strong><br/>
              ユーザーはWebページの第一印象を非常に短い時間で判断するとされています。表示の遅れは、無意識の不安やストレスにつながり、離脱の一因になり得ます。
            </div>
          </div>
        </div>

        <div class="tech-card reveal card-border-blue">
          <div class="tech-header">
            <h2 class="tech-title"><span class="card-icon-window window-blue"><svg viewBox="0 0 24 24"><path d="M18 10h-1.26A8 8 0 109 15h9a5 5 0 000-10z" stroke="currentColor" stroke-width="2" fill="none"/></svg></span>Cloudflare Pages</h2>
            <span class="tech-badge">Infrastructure</span>
          </div>
          <div class="tech-body">
            <h3>エッジ・コンピューティングと強固なセキュリティ</h3>
            <p>
              従来の「一つのサーバーから世界中に配信する」方式ではなく、世界中に分散されたCloudflareのエッジサーバー（CDN）を利用します。
              ユーザーの最も近くにあるサーバーからデータが爆速で配信されるため、どの地域からアクセスしても高速です。
            </p>
            <p>
              また、強力なDDoS対策や常時SSL化など、エンタープライズ水準のセキュリティが標準で備わっています。
            </p>
          </div>
        </div>

        <div class="tech-card reveal card-border-green">
          <div class="tech-header">
            <h2 class="tech-title"><span class="card-icon-window window-green"><svg viewBox="0 0 24 24"><path d="M12 22C17.522 22 22 17.522 22 12C22 6.478 17.522 2 12 2C6.478 2 2 6.478 2 12C2 14.721 3.09 17.189 4.858 19C4.858 19.5 5 20 5.5 20.5C6 21 6.5 21.142 7 21.142C7 21.6 7.5 22 8 22H12Z" stroke="currentColor" stroke-width="2" fill="none"/><circle cx="7.5" cy="10.5" r="1.5" fill="currentColor"/><circle cx="11.5" cy="7.5" r="1.5" fill="currentColor"/><circle cx="16.5" cy="9.5" r="1.5" fill="currentColor"/><circle cx="15.5" cy="14.5" r="1.5" fill="currentColor"/></svg></span>Vanilla CSS</h2>
            <span class="tech-badge">Styling</span>
          </div>
          <div class="tech-body">
            <h3>ピクセル単位の「選ばれる導線設計」を描くために</h3>
            <p>
              流行のCSSフレームワーク（Tailwind CSSなど）に依存せず、あえてピュアな「Vanilla CSS」を中心に構築しています。
              これは、フレームワークの制約に縛られすぎず、ユーザーの視線誘導や「繊細な余白」が与える心理的影響を丁寧に調整するためです。
            </p>
            <p>
              不要なCSSクラスが読み込まれないため、ファイルサイズも最小限に抑えられます。
            </p>
            <div class="tech-psych-note">
              <strong>🧠 心理学エビデンス：視覚的シンプルさと信頼性（Google共同研究, 2012）</strong><br/>
              ユーザーは「視覚的複雑さが低く（シンプル）」、かつ「そのジャンルで標準的なレイアウト（プロトタイプ性）」を持つサイトを理解しやすいと感じやすいとされています。不要な装飾を削ぎ落とし、余白を整えることは、脳の処理負荷（認知摩擦）を下げる助けになります。
            </div>
          </div>
        </div>

        <div class="tech-card reveal card-border-gold">
          <div class="tech-header">
            <h2 class="tech-title"><span class="card-icon-window window-gold"><svg viewBox="0 0 24 24"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m11.314 11.314l.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" stroke="currentColor" stroke-width="2" fill="none"/></svg></span>AI Driven Development</h2>
            <span class="tech-badge">Workflow</span>
          </div>
          <div class="tech-body">
            <h3>生成AIを活用した高品質な高速開発</h3>
            <p>
              最新の生成AIをコードのレビューやリファクタリング、反復タスクの自動化に組み込んでいます。
              これにより、ヒューマンエラーを減らしながら開発スピードを飛躍的に向上させ、
              私たちは「デザインとユーザー心理の設計」という人間にしかできないクリエイティブな領域に集中しています。
            </p>
          </div>
        </div>

      </div>
    </section>

    <section class="tech-demo-section section" aria-labelledby="tech-demo-title">
      <div class="container narrow reveal">
        <div class="tech-demo-shell">
          <div class="tech-demo-copy">
            <span class="custom-tech-eyebrow">HTML5 Canvas Demo</span>
            <h2 id="tech-demo-title">必要な技術を、<br /><span class="tech-demo-nowrap">目的に合わせてつなぐ。</span></h2>
            <p>
              表示の速さ、問い合わせ導線、AI活用、アクセス解析。和-Nodeでは、技術単体ではなく、
              事業の目的に合わせた組み合わせとして設計します。
            </p>
          </div>
          <div class="tech-demo-visual" aria-label="Web制作で連携する技術領域">
            <canvas id="techNodeCanvas" class="tech-node-canvas" width="760" height="360" aria-hidden="true"></canvas>
            <ol class="tech-node-labels" data-glossary-skip>
              <li style="--x: 18%; --y: 28%;">
                <strong>静的サイト</strong>
                <span>高速表示</span>
              </li>
              <li style="--x: 45%; --y: 18%;">
                <strong>心理導線</strong>
                <span>相談設計</span>
              </li>
              <li style="--x: 75%; --y: 32%;">
                <strong>動的機能</strong>
                <span>予約・管理</span>
              </li>
              <li style="--x: 31%; --y: 72%;">
                <strong>AI・ICT</strong>
                <span>業務支援</span>
              </li>
              <li style="--x: 66%; --y: 72%;">
                <strong>計測改善</strong>
                <span>公開後</span>
              </li>
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="site-type-section section" aria-labelledby="site-type-title">
      <div class="container narrow reveal">
        <div class="site-type-intro">
          <span class="custom-tech-eyebrow">Static / Dynamic</span>
          <h2 id="site-type-title">静的サイトと動的サイト、<br /><span class="site-type-nowrap">どちらが向いているか</span></h2>
          <p>
            Webサイトは、大きく分けると「表示が速く管理しやすい静的サイト」と、
            「データ保存・認証・管理画面などを扱う動的な仕組み」があります。
            予約フォームや管理画面の入口は静的サイトにも置けますが、保存・認証・編集などは外部サービスやサーバーレス機能、データベース連携と組み合わせて設計します。
          </p>
        </div>

        <div class="site-type-grid">
          <article class="site-type-card">
            <span class="site-type-label">Static Site</span>
            <h3>表示が速く、保守しやすい静的サイト</h3>
            <p>
              会社案内、サービス紹介、料金、制作例、問い合わせ導線など、内容を安定して伝えるページに向いています。
              余計な処理が少ないため表示が速く、セキュリティ面でも管理しやすいのが特徴です。
              予約ボタンやフォームの入口を置き、外部サービスへつなぐこともできます。
            </p>
            <ul>
              <li>ホームページ・LP・キャンペーンページ</li>
              <li>ブログ更新が少ない事業サイト</li>
              <li>まず信頼されるWeb上の拠点を作りたい場合</li>
            </ul>
          </article>

          <article class="site-type-card highlighted">
            <span class="site-type-label">Dynamic Site</span>
            <h3>保存・認証・管理が必要な動的な仕組み</h3>
            <p>
              予約データの保存、会員ログイン、管理画面からの登録・編集、在庫や顧客情報との連携など、
              操作によってデータを扱う部分は、外部サービス、サーバーレス機能、データベース連携、または動的アプリとして設計します。
              便利な一方で、設計・保守・セキュリティ確認の範囲が広がります。
            </p>
            <ul>
              <li>予約データの保存・確認</li>
              <li>会員認証・会員別の表示</li>
              <li>管理画面、CMS、外部DB/API連携</li>
            </ul>
          </article>
        </div>

        <div class="site-type-note">
          <strong>迷った場合は、目的から決めれば大丈夫です。</strong>
          <p>
            「まず見つけてもらい、安心して相談してもらう」ことが目的なら静的構成で十分なことも多く、
            予約や管理画面などの業務機能が必要になった段階で、外部サービスやサーバーレス機能を追加する選び方もできます。
          </p>
        </div>
      </div>
    </section>

    <section class="custom-tech-section section">
      <div class="container narrow reveal">
        <div class="custom-tech-box">
          <span class="custom-tech-eyebrow">Custom Development</span>
          <h2>掲載している技術以外も、ご注文内容に応じて柔軟に対応します。</h2>
          <p>
            このページで紹介している4つは、和-Nodeが基本方針として大切にしている技術基盤です。
            実際の制作では、既存サイトの環境、必要な機能、運用体制、ご予算に合わせて、
            WordPress、フォーム連携、予約導線、LINE・Googleツール連携、業務自動化なども含めて最適な構成をご提案します。
          </p>
          <p>
            「この仕組みも作れる？」「今使っているサービスとつなげたい」といった段階でも大丈夫です。
            技術を先に決めるのではなく、目的と運用に合う形から一緒に整理します。
          </p>
          <div class="custom-tech-actions">
            <a href="/contact/" class="custom-tech-link">実現したいことを相談する</a>
            <a href="/wasm-diagnosis/" class="custom-tech-link secondary">診断ツールのデモを見る</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Philosophy -->
    <section class="philosophy section">
      <div class="container narrow reveal">
        <div class="philosophy-box">
          <h2>技術は、心を動かすための「裏方」である。</h2>
          <p>
            私たちが最新技術を追い求めるのは、スペックを誇示するためではありません。<br/>
            ページが1秒早く表示されることで、訪問者のイライラを防ぐ。<br/>
            セキュアな通信環境があるからこそ、安心して問い合わせができる。<br/>
            すべては、<strong>ユーザーの心理的負担を減らし、本来の「和」を届けるため</strong>の裏方なのです。
          </p>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<script is:inline>
  function initTechCanvas() {
    const canvas = document.getElementById('techNodeCanvas');
    if (!canvas || canvas.dataset.ready === 'true') return;
    canvas.dataset.ready = 'true';

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const nodes = [
      { x: 0.18, y: 0.28, r: 13, color: '#0f4c5c' },
      { x: 0.45, y: 0.18, r: 15, color: '#8c6b1f' },
      { x: 0.75, y: 0.32, r: 13, color: '#c7352f' },
      { x: 0.31, y: 0.72, r: 12, color: '#1f6f78' },
      { x: 0.66, y: 0.72, r: 12, color: '#8c6b1f' },
    ];
    const links = [
      [0, 1],
      [1, 2],
      [0, 3],
      [1, 3],
      [1, 4],
      [2, 4],
      [3, 4],
    ];

    let width = 0;
    let height = 0;
    let frame = 0;
    let rafId = 0;

    function resize() {
      const rect = canvas.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = rect.width || 760;
      height = rect.height || 360;
      canvas.width = Math.round(width * dpr);
      canvas.height = Math.round(height * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function draw() {
      frame += reduceMotion ? 0 : 1;
      ctx.clearRect(0, 0, width, height);

      const bg = ctx.createRadialGradient(width * 0.5, height * 0.5, 20, width * 0.5, height * 0.5, width * 0.7);
      bg.addColorStop(0, 'rgba(238, 245, 242, 0.86)');
      bg.addColorStop(1, 'rgba(255, 255, 255, 0)');
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, width, height);

      links.forEach(([from, to], index) => {
        const a = nodes[from];
        const b = nodes[to];
        const ax = a.x * width;
        const ay = a.y * height;
        const bx = b.x * width;
        const by = b.y * height;
        const pulse = reduceMotion ? 0.36 : 0.22 + 0.16 * Math.sin(frame * 0.035 + index);

        ctx.beginPath();
        ctx.moveTo(ax, ay);
        ctx.lineTo(bx, by);
        ctx.strokeStyle = `rgba(15, 76, 92, ${pulse})`;
        ctx.lineWidth = 1.4;
        ctx.stroke();

        if (!reduceMotion) {
          const t = (frame * 0.006 + index * 0.18) % 1;
          const px = ax + (bx - ax) * t;
          const py = ay + (by - ay) * t;
          ctx.beginPath();
          ctx.arc(px, py, 3.2, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(199, 53, 47, 0.46)';
          ctx.fill();
        }
      });

      nodes.forEach((node, index) => {
        const x = node.x * width;
        const y = node.y * height;
        const breath = reduceMotion ? 0 : Math.sin(frame * 0.035 + index) * 1.5;

        ctx.beginPath();
        ctx.arc(x, y, node.r + 14 + breath, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(15, 76, 92, 0.055)';
        ctx.fill();

        ctx.beginPath();
        ctx.arc(x, y, node.r + breath, 0, Math.PI * 2);
        ctx.fillStyle = node.color;
        ctx.fill();

        ctx.beginPath();
        ctx.arc(x - node.r * 0.28, y - node.r * 0.28, Math.max(2, node.r * 0.22), 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255, 255, 255, 0.72)';
        ctx.fill();
      });

      if (!reduceMotion) rafId = window.requestAnimationFrame(draw);
    }

    function start() {
      resize();
      window.cancelAnimationFrame(rafId);
      draw();
    }

    if ('ResizeObserver' in window) {
      const observer = new ResizeObserver(start);
      observer.observe(canvas);
    } else {
      window.addEventListener('resize', start);
    }

    start();
  }

  document.addEventListener('astro:page-load', initTechCanvas);
  initTechCanvas();
</script>

<style>
  .tech-page { background-color: var(--bg); overflow-x: hidden; }
  .text-accent { color: var(--accent); }

  .tech-hero {
    text-align: center;
    padding: 120px 0 80px;
    border-bottom: 1px solid var(--line);
  }
  .tech-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.2;
    margin-bottom: 32px;
    font-weight: 800;
  }
  .tech-hero .lead {
    font-size: 1.15rem;
    color: var(--muted);
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.8;
  }

  .tech-stack-section { padding: 80px 0; }
  .tech-stack-section .container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }

  .tech-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 10px 30px rgba(138, 90, 50, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .tech-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(138, 90, 50, 0.1);
    border-color: rgba(138, 90, 50, 0.2);
  }

  .tech-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 16px;
  }
  .tech-title {
    font-size: 1.8rem;
    font-weight: 900;
    margin: 0;
    color: #2b241f;
  }
  .tech-badge {
    background: var(--soft);
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 800;
    padding: 6px 12px;
    border-radius: 999px;
    letter-spacing: 0.05em;
  }

  .tech-body h3 {
    font-size: 1.2rem;
    font-weight: 800;
    margin-bottom: 16px;
    color: var(--text);
  }
  .tech-body p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .tech-body p:last-child { margin-bottom: 0; }

  .tech-demo-section {
    padding: 20px 0 76px;
    border-top: 1px solid rgba(15, 76, 92, 0.08);
  }
  .tech-demo-shell {
    display: grid;
    grid-template-columns: minmax(300px, 0.95fr) minmax(0, 1.05fr);
    gap: 34px;
    align-items: center;
    padding: 34px;
    border: 1px solid rgba(15, 76, 92, 0.15);
    border-radius: 28px;
    background:
      linear-gradient(135deg, rgba(238, 245, 242, 0.92), rgba(255, 255, 255, 0.98)),
      radial-gradient(circle at 88% 16%, rgba(199, 53, 47, 0.06), transparent 28%);
    box-shadow: 0 18px 42px rgba(15, 76, 92, 0.08), 0 6px 18px rgba(70, 52, 32, 0.05);
  }
  .tech-demo-copy h2 {
    margin: 0 0 16px;
    color: var(--text);
    font-size: clamp(1.45rem, 3.2vw, 2.15rem);
    line-height: 1.45;
    font-weight: 900;
  }
  .tech-demo-copy p {
    margin: 0;
    color: var(--muted);
    line-height: 1.9;
  }
  .tech-demo-nowrap {
    white-space: nowrap;
  }
  .tech-demo-visual {
    position: relative;
