---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "【起業記念Plan B】ICT・自動化フル強化案 | 和-Node",
  "description": "24時間働く営業マンを、あなたのWebサイトに。LINE連携・AI要約・自動予約をパッケージした最強のICT強化プラン。",
};
---

  <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap" rel="stylesheet">

  <div class="campaign-page">
    <!-- Sakura Container -->
    <div class="sakura-container" id="sakura-container"></div>
    <script is:inline>
      function initPremiumEffects() {
        const container = document.getElementById('sakura-container');
        if (!container) return;
        container.innerHTML = '';
        for (let i = 0; i < 40; i++) {
          const petal = document.createElement('div');
          petal.className = 'petal';
          petal.style.left = Math.random() * 100 + '%';
          petal.style.width = Math.random() * 10 + 5 + 'px';
          petal.style.height = petal.style.width;
          petal.style.animationDuration = Math.random() * 5 + 5 + 's';
          petal.style.animationDelay = Math.random() * 5 + 's';
          container.appendChild(petal);
        }
      }
      initPremiumEffects();
      document.addEventListener('astro:page-load', initPremiumEffects);
    </script>

    <main class="plan-b-page">
      <!-- Back Link -->
      <nav class="back-nav container reveal">
        <a href="/campaign-anniversary/" class="back-link">← キャンペーンポータルに戻る</a>
      </nav>

      <!-- Tech Hero -->
      <section class="plan-hero dark">
        <div class="tech-grid-bg"></div>
        <div class="container">
          <span class="plan-label blue">Plan B: Automation</span>
          <h1 class="premium-heading">ICT活用・AI導入・LINE連携<br/>（自動化プラン）</h1>
          <p class="plan-subtitle">Webサイトを、24時間働く最強の営業マンへ。</p>
          <div class="campaign-price-tag blue reveal">
            <span class="label">起業記念 20% OFF</span>
            <span class="price">¥120,000<small>(税別)</small></span>
            <span class="old">通常 ¥150,000</span>
          </div>
        </div>
      </section>

      <!-- Automation Showcase -->
      <section class="automation-showcase">
        <div class="container">
          <div class="showcase-header reveal">
            <h2 class="premium-heading">「手作業」を「仕組み」に変える盛り盛りオプション</h2>
            <p>Plan Bでは、WebサイトにICTとAIの力を注入し、あなたの自由な時間を創り出します。</p>
          </div>

          <div class="feature-rows">
            <!-- LINE -->
            <div class="f-row reveal">
              <div class="f-text">
                <span class="f-icon">💬</span>
                <h3>LINE公式アカウント連携</h3>
                <p>サイトからLINEへシームレスに誘導。予約、自動応答、プッシュ通知を組み合わせ、取りこぼしのない顧客体験を実現します。</p>
              </div>
              <div class="f-visual">
                <div class="mockup-line">
                  <div class="msg">「予約ありがとうございます！」</div>
                  <div class="msg ai">AIが最適な日時を提案中...</div>
                </div>
              </div>
            </div>

            <!-- AI -->
            <div class="f-row reverse reveal">
              <div class="f-text">
                <span class="f-icon">🤖</span>
                <h3>AIによる問い合わせ要約・返信支援</h3>
                <p>ChatGPTを裏側で連携。届いたメールをAIが要約し、あなたのトーンに合わせた返信案を自動生成。管理の手間を激減させます。</p>
              </div>
              <div class="f-visual">
                <div class="mockup-ai">
                  <div class="code-block">Input: 長いメール...</div>
                  <div class="code-block success">Summary: 3行で要約完了</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Technical Specs -->
      <section class="tech-specs">
        <div class="container">
          <h2 class="reveal premium-heading">プロフェッショナルな技術スタック</h2>
          <div class="spec-grid">
            <div class="spec-card reveal">
              <h4>高性能な基盤</h4>
              <p>Astro / Next.js を採用。爆速の読み込み速度で、離脱率を極限まで下げます。</p>
            </div>
            <div class="spec-card reveal">
              <h4>安心のセキュリティ</h4>
              <p>SSL・WAF・最新の暗号化。個人情報や機密情報を守る、堅牢な設計です。</p>
            </div>
            <div class="spec-card reveal">
              <h4>拡張性</h4>
              <p>API連携が容易な設計。将来的に予約システムやEC機能を追加することも可能です。</p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="cta-section">
        <div class="container reveal">
          <div class="cta-inner blue">
            <h2>「技術」をあなたの味方にしませんか？</h2>
            <p>難しい設定はすべてお任せください。あなたのビジネスに最適な「自動化の型」を提案します。</p>
            <a href="/contact?plan=B" class="btn-primary-blue">ICT活用を相談する</a>
            <p class="limit">※今月の無料相談枠 残り2名</p>
          </div>
        </div>
      </section>

      <div class="footer-nav container reveal">
        <a href="/campaign-anniversary/" class="btn-secondary-outline">他の限定プランも見る</a>
      </div>
    </main>
  </div>
</BaseLayout>

<style is:global>
  .campaign-page {
    background: #fdfcf9 !important;
    color: #2c2c2c !important;
    overflow-x: hidden;
    position: relative;
    font-family: 'Shippori Mincho', serif !important;
  }
  .campaign-page::before {
    content: "" !important;
    position: fixed !important;
    top: 0; left: 0; width: 100%; height: 100%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3FfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3F/filter%3E%3Frect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3F/svg%3E") !important;
    opacity: 0.1 !important;
    pointer-events: none !important;
    z-index: 1000 !important;
  }
  .sakura-container {
    position: fixed !important;
    top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none !important;
    z-index: 900 !important;
  }
  .petal {
    position: absolute !important;
    background: #ffb7c5 !important;
    border-radius: 150% 0 150% 0 !important;
    opacity: 0.7 !important;
    animation: fall linear infinite;
  }
  @keyframes fall {
    0% { transform: translateY(-10vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.7; }
    90% { opacity: 0.7; }
    100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
  }

  .premium-heading {
    font-family: 'Shippori Mincho', serif !important;
    font-weight: 800 !important;
    letter-spacing: 0.05em;
  }

  .back-nav { padding-top: 40px; position: relative; z-index: 10; }
  .back-link {
    color: #3b82f6; text-decoration: none; font-weight: 700;
    font-size: 0.9rem; transition: 0.3s;
  }
  .back-link:hover { color: #d14d3a; transform: translateX(-5px); display: inline-block; }

  /* Hero */
  .plan-hero.dark {
    background: #0f172a; color: white; padding: 120px 0 80px;
    position: relative; overflow: hidden; text-align: center; margin-top: -60px;
  }
  .tech-grid-bg {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background-image: radial-gradient(circle at 2px 2px, rgba(59, 130, 246, 0.1) 1px, transparent 0);
    background-size: 40px 40px; opacity: 0.5;
  }
  .plan-label.blue { background: #3b82f6; color: white; padding: 5px 15px; border-radius: 4px; font-weight: 800; margin-bottom: 20px; display: inline-block; position: relative; z-index: 2; }
  .plan-subtitle { font-size: 1.1rem; opacity: 0.8; margin-top: 10px; position: relative; z-index: 2; }

  .campaign-price-tag.blue {
    display: inline-flex; flex-direction: column; align-items: center;
    padding: 20px 40px; background: rgba(15, 23, 42, 0.8); border: 2px solid #3b82f6;
    border-radius: 12px; margin-top: 30px; position: relative; z-index: 2;
    box-shadow: 0 10px 40px rgba(59, 130, 246, 0.2);
  }
  .campaign-price-tag.blue .price { font-size: 2.8rem; font-weight: 900; color: #60a5fa; }
  .campaign-price-tag.blue .label { color: #60a5fa; font-weight: 800; }
  .campaign-price-tag.blue .old { font-size: 1.1rem; color: #94a3b8; text-decoration: line-through; }

  /* Showcase */
  .automation-showcase { padding: 100px 0; }
  .showcase-header { text-align: center; margin-bottom: 80px; }
  .f-row { display: flex; align-items: center; gap: 60px; margin-bottom: 80px; }
  .f-row.reverse { flex-direction: column-reverse; }
  .f-text { flex: 1; }
  .f-visual { flex: 1; background: #eef2f7; border-radius: 30px; padding: 40px; display: flex; align-items: center; justify-content: center; }
  .f-text h3 { font-size: 1.8rem; margin-bottom: 15px; color: #1e3a8a; }

  /* Mockups */
  .mockup-line { background: #fff; width: 100%; max-width: 300px; border-radius: 15px; padding: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
  .msg { background: #74eb74; padding: 10px; border-radius: 10px; margin-bottom: 10px; font-size: 0.8rem; width: fit-content; }
  .msg.ai { background: #f0f4f8; margin-left: auto; border: 1px dashed #3b82f6; }

  /* Tech Specs */
  .tech-specs { padding: 100px 0; background: white; }
  .spec-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; margin-top: 50px; }
  .spec-card { padding: 40px; border: 1px solid #eef2f7; border-radius: 20px; transition: 0.3s; }
  .spec-card:hover { border-color: #3b82f6; transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.05); }
  .spec-card h4 { color: #3b82f6; margin-bottom: 15px; font-size: 1.3rem; }

  /* CTA */
  .cta-section { padding: 120px 0; }
  .cta-inner.blue { background: #1e3a8a; color: white; padding: 80px 40px; border-radius: 40px; text-align: center; }
  .btn-primary-blue {
    display: inline-block; background: #3b82f6; color: white;
    padding: 22px 60px; border-radius: 100px; font-weight: 900;
    text-decoration: none; margin-top: 40px; font-size: 1.4rem; transition: 0.3s;
  }
  .btn-primary-blue:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(59, 130, 246, 0.4); }

  .footer-nav { padding-bottom: 80px; text-align: center; }
  .btn-secondary-outline {
    display: inline-block; border: 2px solid #3b82f6; color: #3b82f6;
    padding: 15px 40px; border-radius: 50px; text-decoration: none;
    font-weight: 800; transition: 0.3s;
  }
  .btn-secondary-outline:hover { background: #3b82f6; color: white; }

  @media (max-width: 768px) {
    .f-row, .f-row.reverse { flex-direction: column; text-align: center; gap: 40px; }
  }
</style>
