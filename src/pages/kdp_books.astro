---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="KDP出版実績｜和-Node" description="和-Node代表「マルだ←」によるAmazon Kindle (KDP) の出版実績一覧。オリジナル鳥獣戯画や浮世絵風デザインの書籍など。">
