                <div class="book-spine"></div>
              </div>
            </div>
            <div class="book-meta">
              <h3 class="title">江戸旅行記 フレンチブルドッグ</h3>
              <p class="price">$12.99 / €12.99</p>
              <div class="links">
                <a href="https://www.amazon.com/dp/B0GWQ5VTWC" target="_blank" class="store-link us">🇺🇸 Amazon US</a>
