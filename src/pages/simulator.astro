---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="心理導線Web制作 料金シミュレーター｜和-Node" description="心理導線Web制作の概算費用を確認できる自動お見積りシミュレーター。LP、ホームページ、機能追加、心理導線コピーなどの目安を確認できます。">
  <div class="sample-banner">
    【制作例デモ】このような診断・見積ツールを、あなたのサイトに導入できます。 
    <a href="https://docs.google.com/forms/d/e/1FAIpQLScUbeK9em6cjegU5ha5Sh2fWamrIbxDuhmHDJPIN_no5Sj8-w/viewform?usp=publish-editor" target="_blank">無料相談はこちら</a>
  </div>

  <main>
    <section class="hero">
      <div class="wrap">
        <span class="eyebrow">Psychology Driven Web Estimate</span>
        <h1>料金シミュレーター</h1>
        <p class="lead">
          見た目だけでなく、訪問者の心理導線まで考えたWeb制作を。<br />
          プランやオプションを選ぶだけで、概算の費用と納期をリアルタイムで確認できます。
        </p>
      </div>
    </section>

    <div class="wrap main-layout">
      <section class="form-section">
        <div class="card-panel">
          <h2>1. 制作プランを選択</h2>
          <div class="choices">
            <label class="choice-item">
              <input type="radio" name="type" value="30000" data-days="2" data-label="シンプルLP" />
              <div class="choice-content">
                <strong>シンプルLP制作</strong>
                <p>1ページ構成。まずは低コストでWeb広告やSNSの受け皿を作りたい方に。</p>
              </div>
              <div class="choice-price">¥30,000〜</div>
            </label>
            <label class="choice-item selected">
              <input type="radio" name="type" value="50000" data-days="3" data-label="シンプルHP" checked />
              <div class="choice-content">
                <strong>名刺代わりのシンプルHP</strong>
                <p>必要最低限の情報を美しくまとめたい方向け。</p>
              </div>
              <div class="choice-price">¥50,000〜</div>
            </label>
            <label class="choice-item">
              <input type="radio" name="type" value="60000" data-days="5" data-label="心理導線LP" />
              <div class="choice-content">
                <strong>心理導線LP制作</strong>
                <p>1つの商品・サービスを、行動心理に基づいて訴求し獲得を最大化します。</p>
              </div>
              <div class="choice-price">¥60,000〜</div>
            </label>
            <label class="choice-item">
              <input type="radio" name="type" value="120000" data-days="8" data-label="心理導線HP" />
              <div class="choice-content">
                <strong>心理導線ホームページ制作</strong>
                <p>複数ページ構成。事業の全体像と信頼をしっかり伝える標準的なサイトです。</p>
              </div>
              <div class="choice-price">¥120,000〜</div>
            </label>
          </div>
        </div>

        <div class="card-panel">
          <h2>2. ページ構成の規模</h2>
          <div class="choices">
            <label class="choice-item selected">
              <input type="radio" name="pages" value="0" data-days="0" data-label="1ページ構成" checked />
              <div class="choice-content">
                <strong>1ページ構成（LP・ペライチ）</strong>
                <p>まずは特定の目的に絞って公開したい場合に。</p>
              </div>
              <div class="choice-price">+¥0</div>
            </label>
            <label class="choice-item">
              <input type="radio" name="pages" value="30000" data-days="3" data-label="2〜5ページ" />
              <div class="choice-content">
                <strong>2〜5ページ（標準的）</strong>
                <p>トップ、サービス、料金、プロフィール、問い合わせ等。</p>
              </div>
              <div class="choice-price">+¥30,000</div>
            </label>
            <label class="choice-item">
              <input type="radio" name="pages" value="80000" data-days="6" data-label="6ページ以上" />
              <div class="choice-content">
                <strong>6ページ以上（多め）</strong>
                <p>実績紹介、採用、複数事業などボリュームがある場合。</p>
              </div>
              <div class="choice-price">+¥80,000</div>
            </label>
          </div>
        </div>

        <div class="card-panel">
          <h2>3. 追加機能・オプション</h2>
          <div class="choices">
            <label class="choice-item">
              <input type="checkbox" name="feature" value="10000" data-days="1" data-label="フォーム設置" />
              <div class="choice-content">
                <strong>お問い合わせフォームの設置</strong>
                <p>基本のコンタクト導線を作成します。</p>
              </div>
              <div class="choice-price">+¥10,000</div>
            </label>
            <label class="choice-item">
              <input type="checkbox" name="feature" value="30000" data-days="3" data-label="ブログ機能" />
              <div class="choice-content">
                <strong>お知らせ・ブログ機能（WordPress等）</strong>
                <p>お客様自身で簡単に更新できる環境を構築します。</p>
              </div>
              <div class="choice-price">+¥30,000</div>
            </label>
            <label class="choice-item">
              <input type="checkbox" name="feature" value="30000" data-days="3" data-label="予約システム" />
              <div class="choice-content">
                <strong>予約システムの導入</strong>
                <p>来店や面談の予約導線をスムーズにします。</p>
              </div>
              <div class="choice-price">+¥30,000</div>
            </label>
            <label class="choice-item">
              <input type="checkbox" name="feature" value="10000" data-days="1" data-label="代行サポート" />
              <div class="choice-content">
                <strong>サーバー・ドメイン取得の代行</strong>
                <p>複雑な初期設定をすべてお任せいただけます。</p>
              </div>
              <div class="choice-price">+¥10,000</div>
            </label>
            <label class="choice-item">
              <input type="checkbox" id="rushCheck" name="rush" value="1.5" data-days="-2" data-label="特急対応" />
              <div class="choice-content">
                <strong>【特急対応】なるべく早く納品</strong>
                <p>費用1.5倍 / 期間を約30%短縮（内容により要相談）。</p>
              </div>
              <div class="choice-price">×1.5</div>
            </label>
          </div>
        </div>
      </section>

      <aside class="sticky-sidebar">
        <div class="result-card" id="resultCard">
          <h2>ESTIMATED TOTAL</h2>
          <div class="total-price" id="totalPrice">¥0<span>〜</span></div>
          <div class="delivery-days" id="deliveryDays">目安納期：約0営業日</div>
          
          <div class="breakdown" id="breakdownList">
            <!-- Dynamic list -->
          </div>

          <div class="action-btns">
            <a class="btn-main btn-primary" href="https://docs.google.com/forms/d/e/1FAIpQLScUbeK9em6cjegU5ha5Sh2fWamrIbxDuhmHDJPIN_no5Sj8-w/viewform?usp=publish-editor" target="_blank">この内容で無料相談する</a>
            <a class="btn-main btn-secondary" href="/lp_wizard">もっと詳しくヒアリングする</a>
          </div>

          <p class="disclaimer">
            ※表示価格は税込の概算です。正確なお見積りは、詳細要件を確認後にご提示いたします。
          </p>
        </div>
      </aside>
    </div>
  </main>
</BaseLayout>

<style>
    .sample-banner { background: var(--accent2); color: #fff; padding: 10px 20px; text-align: center; font-size: 0.88rem; font-weight: 700; }
    .sample-banner a { color: #fff; text-decoration: underline; }

    .wrap { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    .hero { padding: 60px 0 40px; text-align: center; }
    .eyebrow {
      display: inline-block; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--accent); font-size: 0.82rem; font-weight: 800; background: var(--accent-soft);
      padding: 4px 12px; border-radius: 999px; margin-bottom: 16px;
    }
    .hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.2; margin: 0 0 20px; font-weight: 800; }
    .lead { font-size: 1.1rem; max-width: 800px; margin: 0 auto; color: var(--muted); }

    .main-layout { display: grid; grid-template-columns: 1fr 380px; gap: 32px; padding-bottom: 80px; }

    .form-section { display: flex; flex-direction: column; gap: 32px; }
    .card-panel { background: var(--paper); border: 1px solid var(--line); border-radius: 24px; padding: 32px; box-shadow: var(--shadow); }
    .card-panel h2 { font-size: 1.5rem; margin: 0 0 24px; display: flex; align-items: center; gap: 12px; font-weight: 800; }
    .card-panel h2::before { content: ""; width: 4px; height: 24px; background: var(--accent); border-radius: 2px; }

    .choices { display: grid; gap: 16px; }
    .choice-item {
      position: relative; display: flex; align-items: flex-start; gap: 16px; padding: 20px;
      border: 1px solid var(--line); border-radius: 20px; background: #fff; cursor: pointer; transition: 0.3s;
    }
    .choice-item:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(138, 90, 50, 0.08); }
    .choice-item input { margin-top: 6px; width: 20px; height: 20px; accent-color: var(--accent); }
    .choice-item.selected { border-color: var(--accent); background: var(--accent-soft); }
    .choice-content { flex: 1; }
    .choice-content strong { display: block; font-size: 1.1rem; margin-bottom: 4px; font-weight: 800; }
    .choice-content p { margin: 0; font-size: 0.92rem; color: var(--muted); line-height: 1.6; }
    .choice-price { font-weight: 800; color: var(--accent); font-size: 1rem; white-space: nowrap; margin-top: 2px; }

    .sticky-sidebar { position: sticky; top: 100px; align-self: start; }
    .result-card { background: #1a1c1e; color: #fff; border-radius: 24px; padding: 32px; box-shadow: 0 24px 60px rgba(0, 0, 0, 0.2); }
    .result-card h2 { margin: 0 0 8px; font-size: 0.8rem; color: var(--accent2); opacity: 0.9; letter-spacing: 0.1em; font-weight: 800; }
    .total-price { font-size: 3.5rem; font-weight: 900; line-height: 1; margin-bottom: 8px; }
    .total-price span { font-size: 1.2rem; font-weight: 700; margin-left: 4px; }
    .delivery-days { font-size: 1rem; font-weight: 700; color: #d8b98c; margin-bottom: 24px; }
    
    .breakdown { border-top: 1px solid rgba(255, 255, 255, 0.1); margin-top: 24px; padding-top: 24px; }
    .breakdown-row { display: flex; justify-content: space-between; font-size: 0.9rem; margin-bottom: 10px; opacity: 0.85; }
    .breakdown-row span:last-child { font-weight: 800; color: #fff; }

    .action-btns { display: flex; flex-direction: column; gap: 12px; margin-top: 32px; }
    .btn-main {
      display: flex; align-items: center; justify-content: center; padding: 16px 24px;
      border-radius: 999px; font-weight: 800; font-size: 1rem; text-align: center;
      transition: 0.3s; cursor: pointer; text-decoration: none; border: none;
    }
    .btn-primary { background: var(--accent); color: #fff; box-shadow: 0 8px 20px rgba(138, 90, 50, 0.3); }
    .btn-secondary { background: rgba(255, 255, 255, 0.1); color: #fff; border: 1px solid rgba(255, 255, 255, 0.2); }

    .disclaimer { font-size: 0.82rem; color: #b7a99c; margin-top: 20px; line-height: 1.6; }

    @media (max-width: 960px) {
      .main-layout { grid-template-columns: 1fr; }
      .sticky-sidebar { position: static; margin-top: 32px; }
    }
</style>

<script is:inline>
    const yen = (n) => '¥' + Math.round(n).toLocaleString('ja-JP');
    let currentDisplayPrice = 0;

    function animateValue(obj, start, end, duration) {
      let startTimestamp = null;
      const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        const value = Math.floor(progress * (end - start) + start);
        obj.innerHTML = yen(value) + '<span>〜</span>';
        if (progress < 1) {
          window.requestAnimationFrame(step);
        }
      };
      window.requestAnimationFrame(step);
    }

    function update() {
      let total = 0;
      let days = 0;
      let rows = [];

      // Type
      const type = document.querySelector('input[name="type"]:checked');
      if (type) {
          total += parseInt(type.value);
          days += parseInt(type.dataset.days);
          rows.push({ label: type.dataset.label, price: parseInt(type.value) });
      }

      // Pages
      const pages = document.querySelector('input[name="pages"]:checked');
      if (pages) {
          total += parseInt(pages.value);
          days += parseInt(pages.dataset.days);
          if (parseInt(pages.value) > 0) rows.push({ label: pages.dataset.label, price: parseInt(pages.value) });
      }

      // Features
      document.querySelectorAll('input[name="feature"]:checked').forEach(f => {
        total += parseInt(f.value);
        days += parseInt(f.dataset.days);
        rows.push({ label: f.dataset.label, price: parseInt(f.value) });
      });

      // Rush
      const rush = document.getElementById('rushCheck');
      if (rush && rush.checked) {
        total *= 1.5;
        days = Math.max(2, Math.ceil(days * 0.7));
        rows.push({ label: '特急対応', price: '×1.5' });
      }

      // Selection Visuals
      document.querySelectorAll('.choice-item').forEach(item => {
        const input = item.querySelector('input');
        item.classList.toggle('selected', input.checked);
      });

      // Update UI
      const priceEl = document.getElementById('totalPrice');
      if (priceEl) {
          animateValue(priceEl, currentDisplayPrice, total, 400);
          currentDisplayPrice = total;
      }

      const daysEl = document.getElementById('deliveryDays');
      if (daysEl) daysEl.textContent = `目安納期：約${days}営業日`;

      const breakdownEl = document.getElementById('breakdownList');
      if (breakdownEl) {
          breakdownEl.innerHTML = rows.map(r => `
            <div class="breakdown-row">
              <span>${r.label}</span>
              <span>${typeof r.price === 'number' ? yen(r.price) : r.price}</span>
            </div>
          `).join('');
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('input').forEach(i => i.addEventListener('change', update));
        update();
    });
</script>
