  }

  .docx-app :global(.empty-state) {
    display: grid;
    place-items: center;
    min-height: 280px;
    padding: 32px;
    text-align: center;
  }

  .docx-app :global(.empty-state svg) {
    width: 46px;
    height: 46px;
    color: var(--tool-teal-2);
  }

  .docx-app :global(.empty-state strong) {
    margin-top: 12px;
    color: var(--tool-ink);
  }

  .docx-app :global(.empty-state p) {
    max-width: 360px;
    margin: 8px auto 0;
    color: var(--tool-muted);
    line-height: 1.75;
  }

  .preview-surface :global(p) {
    margin: 0 0 1em;
  }

  .preview-surface :global(ruby) {
    ruby-position: over;
  }

  .preview-surface :global(rt) {
    color: var(--tool-teal-2);
