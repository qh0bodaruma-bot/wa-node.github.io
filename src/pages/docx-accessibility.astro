  .docx-app :global(.file-row) {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    padding: 14px;
  }

  .docx-app :global(.file-row.is-selected) {
    border-color: var(--tool-teal);
    box-shadow: inset 4px 0 0 var(--tool-teal);
  }

  .docx-app :global(.file-row.is-targeted) {
    background: color-mix(in srgb, var(--tool-panel-strong) 92%, #eaf6f3);
  }

  .docx-app :global(.file-check) {
    position: relative;
    display: grid;
    width: 38px;
