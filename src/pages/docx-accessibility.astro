---
import BaseLayout from '../layouts/BaseLayout.astro';
import MaterialIcon from '../components/MaterialIcon.astro';

const title = 'DOCXアクセシブル変換アプリ｜和-Node';
const description = 'DOCXファイルをブラウザ内で読み込み、フォントサイズ拡大、複数の高コントラスト表示、読み仮名プレビュー、変換済みDOCXのダウンロードを行うアクセシビリティ支援デモアプリです。';
---

<BaseLayout title={title} description={description} noindex={true}>
  <main class="docx-app" data-docx-app>
    <div class="drop-overlay" id="dropOverlay" aria-live="polite" hidden>
      <MaterialIcon name="upload_file" />
      <strong>ここにDOCXをドロップ</strong>
      <span>画面内のどこに離しても読み込めます</span>
    </div>

    <section class="docx-hero">
      <div class="docx-shell hero-grid">
        <div class="hero-copy">
          <p class="tool-label">Wa-Node Accessibility Tool</p>
          <h1>DOCX<wbr />アクセシブル<wbr />変換</h1>
          <p>
            Word文書をブラウザ内で読み込み、文字サイズの拡大、複数の高コントラスト表示、読み仮名プレビューをまとめて確認できます。
            文書データはサーバーへ送信されません。
          </p>
        </div>
        <div class="hero-badges" aria-label="このアプリの前提">
          <span>DOCX専用</span>
          <span>端末内処理</span>
          <span>初期デモ</span>
        </div>
      </div>
    </section>

    <section class="docx-workspace" aria-labelledby="workspace-title">
      <div class="docx-shell workspace-grid">
        <aside class="control-panel" aria-label="ファイル読み込みと変換設定">
          <div class="panel-heading">
            <div class="panel-heading-row">
              <p class="tool-label">Input</p>
              <button class="icon-only help-button" id="helpBtn" type="button" aria-label="使い方を開く" title="ヘルプ">
                <MaterialIcon name="help" />
              </button>
            </div>
            <h2 class="sr-only" id="workspace-title">文書を読み込む</h2>
          </div>

          <div class="input-actions">
            <label class="icon-button primary icon-symbol-button" for="docxFiles" aria-label="DOCXファイルを選ぶ" title="ファイル">
              <MaterialIcon name="upload_file" />
              <span class="sr-only">ファイル</span>
              <input id="docxFiles" type="file" accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document" multiple />
            </label>

            <label class="icon-button icon-symbol-button" for="docxFolder" aria-label="フォルダを選ぶ" title="フォルダ">
              <MaterialIcon name="drive_folder_upload" />
              <span class="sr-only">フォルダ</span>
              <input id="docxFolder" type="file" accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document" multiple webkitdirectory directory />
            </label>
          </div>

          <section class="file-panel" id="fileDropZone" aria-labelledby="file-list-title">
            <div class="section-title-row file-panel-heading">
              <div>
                <p class="tool-label">Files</p>
                <h2 id="file-list-title">読み込んだ文書</h2>
              </div>
              <p class="loaded-state" id="fileCount" aria-label="変換対象 0件、読み込み 0件">0/0</p>
            </div>
            <div class="file-list" id="fileList">
              <article class="empty-state">
                <MaterialIcon name="description" />
                <strong>.docxファイルをドラッグ＆ドロップで追加</strong>
              </article>
            </div>
          </section>

          <div class="mode-panel" aria-labelledby="mode-title">
            <div class="section-title-row compact">
              <div>
                <p class="tool-label">Font Size</p>
                <h2 class="sr-only" id="mode-title">文字サイズ</h2>
              </div>
              <button class="icon-only" id="settingsBtn" type="button" aria-label="設定を開く" title="設定">
                <MaterialIcon name="settings" />
              </button>
            </div>
            <div class="font-modes" role="group" aria-label="文字サイズモード">
              <button type="button" class="mode-button" data-mode="standard">
                <span class="mode-icon">A</span>
                <strong>標準</strong>
                <small class="sr-only">+0pt</small>
              </button>
              <button type="button" class="mode-button" data-mode="large">
                <span class="mode-icon">A+</span>
                <strong>大</strong>
                <small class="sr-only" id="largeDeltaLabel">+6pt</small>
              </button>
              <button type="button" class="mode-button" data-mode="xlarge">
                <span class="mode-icon">A++</span>
                <strong>特大</strong>
                <small class="sr-only" id="xlargeDeltaLabel">+10pt</small>
              </button>
            </div>
          </div>

          <div class="assist-panel" aria-label="補助表示設定">
            <div class="assist-heading">
              <MaterialIcon name="contrast" />
              <strong>表示色</strong>
            </div>
            <div class="contrast-modes" role="group" aria-label="表示色を選ぶ">
              <button type="button" class="contrast-mode-button" data-contrast-mode="standard" aria-pressed="true">
                <span class="contrast-swatch standard" aria-hidden="true"></span>
                <strong>標準</strong>
                <small>元の色</small>
              </button>
              <button type="button" class="contrast-mode-button" data-contrast-mode="light-high" aria-pressed="false">
                <span class="contrast-swatch light-high" aria-hidden="true"></span>
                <strong>白地</strong>
                <small>AAA</small>
              </button>
              <button type="button" class="contrast-mode-button" data-contrast-mode="dark-high" aria-pressed="false">
                <span class="contrast-swatch dark-high" aria-hidden="true"></span>
                <strong>黒地</strong>
                <small>AAA</small>
              </button>
              <button type="button" class="contrast-mode-button" data-contrast-mode="low-glare" aria-pressed="false">
                <span class="contrast-swatch low-glare" aria-hidden="true"></span>
                <strong>低輝度</strong>
                <small>AAA</small>
              </button>
            </div>
            <button type="button" class="assist-button" id="rubyPreviewBtn" aria-pressed="false">
              <span class="assist-icon-letter" aria-hidden="true">あ</span>
              <span>読み仮名</span>
            </button>
          </div>

          <div class="convert-actions">
            <button type="button" class="icon-button primary icon-symbol-button" id="convertAllBtn" aria-label="選択中の文書を変換" title="変換">
              <MaterialIcon name="sync" />
              <span class="sr-only">変換</span>
            </button>
            <button type="button" class="icon-button icon-symbol-button" id="downloadAllBtn" aria-label="選択中の変換済み文書をダウンロード" title="変換済みファイルをパソコンへ保存" disabled>
              <MaterialIcon name="download" />
              <span class="sr-only">ダウンロード</span>
            </button>
          </div>
          <p class="action-caption">変換で文書を加工し、ダウンロードでパソコンへ保存します。</p>

          <div class="privacy-note">
            <strong>変換時の注意</strong>
            <p>フォント拡大と表示色はDOCXに反映します。読み仮名はプレビュー補助です。表・画像・複雑なテキストボックスは変換後に目視確認してください。</p>
          </div>
        </aside>

        <aside class="preview-panel" aria-labelledby="preview-title">
          <div class="section-title-row">
            <div>
              <p class="tool-label">Preview</p>
              <h2 id="preview-title">内容プレビュー</h2>
            </div>
            <span class="preview-mode" id="previewMode">標準</span>
          </div>
          <div class="preview-surface" id="previewSurface">
            <p class="preview-placeholder">文書を選択すると、本文の先頭を表示します。</p>
          </div>
          <div class="status-board" id="statusBoard">
            <span>待機中</span>
            <strong>フォントサイズを選び、変換を実行してください。</strong>
          </div>
        </aside>
      </div>
    </section>

    <div class="settings-drawer" id="settingsDrawer" hidden>
      <div class="settings-card" role="dialog" aria-modal="true" aria-labelledby="settings-title">
        <div class="section-title-row">
          <div>
            <p class="tool-label">Settings</p>
            <h2 id="settings-title">フォント加算値</h2>
          </div>
          <button class="icon-only" id="closeSettingsBtn" type="button" aria-label="設定を閉じる" title="閉じる">
            <MaterialIcon name="close" />
          </button>
        </div>
        <div class="setting-fields">
          <label>
            <span>大</span>
            <input id="largeDeltaInput" type="number" min="0" max="20" step="1" />
            <small>初期値 +6pt</small>
          </label>
          <label>
            <span>特大</span>
            <input id="xlargeDeltaInput" type="number" min="0" max="20" step="1" />
            <small>初期値 +10pt</small>
          </label>
        </div>
        <div class="drawer-actions">
          <button type="button" class="ghost-btn" id="resetSettingsBtn">初期値に戻す</button>
          <button type="button" class="primary-btn" id="saveSettingsBtn">保存</button>
        </div>
      </div>
    </div>

    <div class="settings-drawer" id="helpDrawer" hidden>
      <div class="settings-card help-card" role="dialog" aria-modal="true" aria-labelledby="help-title">
        <div class="section-title-row">
          <div>
            <p class="tool-label">Help</p>
            <h2 id="help-title">使い方</h2>
          </div>
          <button class="icon-only" id="closeHelpBtn" type="button" aria-label="ヘルプを閉じる" title="閉じる">
            <MaterialIcon name="close" />
          </button>
        </div>
        <ol class="help-steps">
          <li><strong>文書を追加</strong><span>上のファイル・フォルダボタン、または「読み込んだ文書」へドラッグ＆ドロップします。</span></li>
          <li><strong>見え方を選択</strong><span>文字サイズ、表示色、読み仮名を選び、右側の大きなプレビューで確認します。</span></li>
          <li><strong>変換</strong><span>選択した設定を反映したDOCXデータを、ブラウザ内で作ります。</span></li>
          <li><strong>ダウンロード</strong><span>変換後のDOCXをパソコンへ保存します。変換が終わるまで保存ボタンは押せません。</span></li>
        </ol>
        <p class="help-note">白地・黒地・低輝度は、本文と背景のコントラスト比7:1以上（WCAG AAA）です。見やすい配色には個人差があるため、実際の利用者が最も読みやすいものを選んでください。</p>
        <p class="help-note">読み仮名解析は初回のみ辞書の準備に少し時間がかかります。文書の内容は外部サーバーへ送信されません。</p>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .docx-app {
    --tool-bg: #f7f0e7;
    --tool-panel: #fffdf8;
    --tool-panel-strong: #ffffff;
    --tool-ink: #142523;
    --tool-muted: #5e6b68;
    --tool-teal: #0f4c5c;
    --tool-teal-2: #2e8792;
    --tool-button-bg: #0f4c5c;
    --tool-button-ink: #ffffff;
    --tool-gold: #9a6a15;
    --tool-red: #c7352f;
    --tool-line: rgba(15, 76, 92, 0.18);
    --tool-shadow: 0 20px 52px rgba(32, 45, 41, 0.13);
    background:
      radial-gradient(circle at 16% 8%, rgba(46, 135, 146, 0.12), transparent 28%),
      linear-gradient(180deg, color-mix(in srgb, var(--tool-panel) 82%, var(--tool-bg)) 0%, var(--tool-bg) 100%);
    color: var(--tool-ink);
    min-height: 100vh;
    padding-bottom: 80px;
  }

  .docx-app[data-contrast-mode="dark-high"] {
    --tool-bg: #071413;
    --tool-panel: #0f1f1d;
    --tool-panel-strong: #102927;
    --tool-ink: #f8fff9;
    --tool-muted: #c6d6d2;
    --tool-teal: #9fd8d2;
    --tool-teal-2: #b8e8e2;
    --tool-gold: #f2cf7f;
    --tool-button-bg: #f8fff9;
    --tool-button-ink: #050908;
    --tool-line: rgba(246, 255, 248, 0.2);
    --tool-shadow: 0 20px 52px rgba(0, 0, 0, 0.32);
  }

  .docx-app[data-contrast-mode="light-high"] {
    --tool-bg: #ffffff;
    --tool-panel: #ffffff;
    --tool-panel-strong: #ffffff;
    --tool-ink: #111111;
    --tool-muted: #303030;
    --tool-teal: #00485b;
    --tool-button-bg: #111111;
    --tool-button-ink: #ffffff;
    --tool-line: rgba(0, 0, 0, 0.34);
  }

  .docx-app[data-contrast-mode="low-glare"] {
    --tool-bg: #18201f;
    --tool-panel: #202b29;
    --tool-panel-strong: #18201f;
    --tool-ink: #e5dccb;
    --tool-muted: #d1c8b8;
    --tool-teal: #9fd8d2;
    --tool-teal-2: #b8e8e2;
    --tool-button-bg: #e5dccb;
    --tool-button-ink: #18201f;
    --tool-gold: #f2cf7f;
    --tool-line: rgba(229, 220, 203, 0.34);
    --tool-shadow: 0 20px 52px rgba(0, 0, 0, 0.34);
  }

  :global(html[data-docx-contrast-mode="dark-high"]),
  :global(html[data-docx-contrast-mode="dark-high"] body),
  :global(html[data-docx-contrast-mode="dark-high"] .site-header),
  :global(html[data-docx-contrast-mode="dark-high"] .site-header.scrolled),
  :global(html[data-docx-contrast-mode="dark-high"] .footer) {
    background: #050908 !important;
    color: #f8fff9 !important;
    color-scheme: dark;
  }

  :global(html[data-docx-contrast-mode="low-glare"]),
  :global(html[data-docx-contrast-mode="low-glare"] body),
  :global(html[data-docx-contrast-mode="low-glare"] .site-header),
  :global(html[data-docx-contrast-mode="low-glare"] .site-header.scrolled),
  :global(html[data-docx-contrast-mode="low-glare"] .footer) {
    background: #18201f !important;
    color: #e5dccb !important;
    color-scheme: dark;
  }

  :global(html[data-docx-contrast-mode="light-high"]),
  :global(html[data-docx-contrast-mode="light-high"] body),
  :global(html[data-docx-contrast-mode="light-high"] .site-header),
  :global(html[data-docx-contrast-mode="light-high"] .site-header.scrolled),
  :global(html[data-docx-contrast-mode="light-high"] .footer) {
    background: #ffffff !important;
    color: #111111 !important;
    color-scheme: light;
  }

  :global(html[data-docx-contrast-mode="dark-high"] .site-header :is(.logo, .logo-sub, .nav-links a, .lang-switch-capsule a, .material-symbols-rounded)),
  :global(html[data-docx-contrast-mode="dark-high"] .footer :is(h3, a, p)),
  :global(html[data-docx-contrast-mode="low-glare"] .site-header :is(.logo, .logo-sub, .nav-links a, .lang-switch-capsule a, .material-symbols-rounded)),
  :global(html[data-docx-contrast-mode="low-glare"] .footer :is(h3, a, p)) {
    color: inherit !important;
  }

  :global(html[data-docx-contrast-mode="light-high"] .site-header :is(.logo, .logo-sub, .nav-links a, .lang-switch-capsule a, .material-symbols-rounded)),
  :global(html[data-docx-contrast-mode="light-high"] .footer :is(h3, a, p)) {
    color: #111111 !important;
  }

  :global(html[data-docx-contrast-mode="dark-high"] .site-header :is(.logo-sub, .lang-switch-capsule)),
  :global(html[data-docx-contrast-mode="low-glare"] .site-header :is(.logo-sub, .lang-switch-capsule)) {
    background: #202b29 !important;
    border-color: rgba(229, 220, 203, 0.34) !important;
  }

  :global(html[data-docx-contrast-mode="light-high"] .site-header :is(.logo-sub, .lang-switch-capsule)) {
    background: #ffffff !important;
    border-color: #111111 !important;
  }

  :global(html[data-docx-contrast-mode="dark-high"] .site-header .nav-links a.nav-cta) {
    background: #f8fff9 !important;
    color: #050908 !important;
  }

  :global(html[data-docx-contrast-mode="low-glare"] .site-header .nav-links a.nav-cta) {
    background: #e5dccb !important;
    color: #18201f !important;
  }

  :global(html[data-docx-contrast-mode="light-high"] .site-header .nav-links a.nav-cta) {
    background: #111111 !important;
    color: #ffffff !important;
  }

  .docx-shell {
    width: min(1440px, calc(100% - 48px));
    margin: 0 auto;
  }

  .drop-overlay {
    position: fixed;
    inset: 84px 24px 24px;
    z-index: 1500;
    display: grid;
    place-content: center;
    justify-items: center;
    gap: 12px;
    border: 3px dashed var(--tool-teal-2);
    border-radius: 8px;
    background: color-mix(in srgb, var(--tool-panel-strong) 92%, transparent);
    color: var(--tool-ink);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
    pointer-events: none;
    backdrop-filter: blur(12px);
  }

  .drop-overlay[hidden] {
    display: none;
  }

  .drop-overlay :global(.material-symbols-rounded) {
    color: var(--tool-teal);
    font-size: 58px;
  }

  .drop-overlay strong {
    font-size: 1.45rem;
  }

  .drop-overlay span {
    color: var(--tool-muted);
    font-size: 0.9rem;
  }

  .docx-app *,
  .docx-app *::before,
  .docx-app *::after {
    box-sizing: border-box;
    min-width: 0;
  }

  .docx-app :where(p, h1, h2, h3, li, small) {
    overflow-wrap: anywhere;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .docx-hero {
    padding: 84px 0 32px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 210px;
    gap: 34px;
    align-items: end;
  }

  .tool-label {
    margin: 0 0 12px;
    color: var(--tool-gold);
    font-family: Outfit, system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-copy h1,
  .panel-heading h2,
  .section-title-row h2 {
    margin: 0;
    color: var(--tool-ink);
    font-family: "Yu Mincho", "YuMincho", "Hiragino Mincho ProN", serif;
    letter-spacing: 0;
  }

  .hero-copy h1 {
    font-size: clamp(2.6rem, 6vw, 5rem);
    line-height: 1.08;
  }

  .hero-copy p:not(.tool-label),
  .panel-heading p:not(.tool-label) {
    max-width: 780px;
    margin: 18px 0 0;
    color: var(--tool-muted);
    font-size: 1rem;
    line-height: 2;
  }

  .panel-heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .panel-heading-row .tool-label {
    margin-bottom: 0;
  }

  .help-button {
    width: 38px;
    height: 38px;
  }

  .hero-badges {
    display: grid;
    gap: 10px;
  }

  .hero-badges span,
  .loaded-state,
  .preview-mode {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 8px 14px;
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: color-mix(in srgb, var(--tool-panel) 90%, transparent);
    color: var(--tool-teal);
    font-weight: 800;
    font-size: 0.85rem;
  }

  .workspace-grid {
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr);
    gap: 22px;
    align-items: start;
  }

  .control-panel,
  .file-panel,
  .preview-panel,
  .settings-card {
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: color-mix(in srgb, var(--tool-panel) 94%, transparent);
    box-shadow: var(--tool-shadow);
  }

  .control-panel {
    position: sticky;
    top: 92px;
    display: grid;
    gap: 20px;
    padding: 24px;
  }

  .file-panel,
  .preview-panel {
    padding: 24px;
  }

  .control-panel .file-panel {
    padding: 14px;
    border-color: var(--tool-line);
    background: color-mix(in srgb, var(--tool-panel) 84%, transparent);
    box-shadow: none;
  }

  .control-panel .file-panel:has(.empty-state) {
    cursor: pointer;
  }

  .control-panel .file-panel.is-dragging {
    border-color: var(--tool-teal-2);
    background: color-mix(in srgb, var(--tool-panel) 80%, #d8f2ed);
    box-shadow: inset 0 0 0 2px rgba(46, 135, 146, 0.18);
  }

  .file-panel-heading {
    align-items: center;
    margin-bottom: 12px;
  }

  .file-panel-heading .tool-label {
    margin-bottom: 5px;
  }

  .file-panel-heading h2 {
    font-size: 1.1rem;
  }

  .file-panel-heading .loaded-state {
    min-height: 34px;
    padding: 5px 10px;
  }

  .section-title-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: start;
    margin-bottom: 20px;
  }

  .section-title-row.compact {
    align-items: center;
    margin-bottom: 14px;
  }

  .section-title-row h2,
  .panel-heading h2 {
    font-size: clamp(1.5rem, 2.3vw, 2rem);
    line-height: 1.25;
  }

  .preview-panel .section-title-row h2 {
    font-size: clamp(1.35rem, 1.8vw, 1.65rem);
    overflow-wrap: normal;
    word-break: keep-all;
  }

  .input-actions,
  .convert-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .convert-actions {
    grid-template-columns: 1fr 1fr;
  }

  .icon-button,
  .assist-button,
  .primary-btn,
  .ghost-btn {
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: var(--tool-panel-strong);
    color: var(--tool-teal);
