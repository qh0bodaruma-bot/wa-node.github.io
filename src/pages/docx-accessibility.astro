  @media (max-width: 1120px) {
    .hero-grid,
    .workspace-grid {
      grid-template-columns: 1fr;
    }

    .control-panel {
      position: static;
    }

    .hero-badges {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 680px) {
    .docx-shell {
      width: min(1180px, calc(100% - 24px));
    }

    .docx-hero {
      padding: 58px 0 24px;
    }

    .hero-copy h1 {
      max-width: 100%;
      font-size: 2rem;
      line-height: 1.16;
      overflow-wrap: anywhere;
      word-break: normal;
      line-break: loose;
    }

    .hero-copy p:not(.tool-label),
    .panel-heading p:not(.tool-label),
    .note-box p {
      max-width: 100%;
      word-break: break-all;
      line-break: anywhere;
    }

    .hero-badges,
    .input-actions {
      grid-template-columns: 1fr;
    }

    .convert-actions {
      grid-template-columns: 1fr 1fr;
    }

    .control-panel,
    .file-panel,
    .preview-panel,
    .settings-card {
      padding: 18px;
    }

    .mode-button {
      grid-template-columns: none;
      grid-template-rows: auto auto;
    }

    .row-actions {
      grid-column: 2;
      justify-content: flex-start;
    }

    .row-actions button {
      width: 40px;
    }

    .docx-app :global(.file-row) {
      grid-template-columns: 42px minmax(0, 1fr);
    }

    .docx-app :global(.row-actions) {
      grid-column: 2;
      justify-content: flex-start;
    }

    .docx-app :global(.row-actions button) {
      width: 40px;
    }

    .setting-fields label {
      grid-template-columns: 1fr;
    }

    .setting-fields small {
      grid-column: 1;
    }
  }
</style>

<script>
  import JSZip from 'jszip';

  const STORAGE_KEY = 'wa-node-docx-accessibility-settings-v1';
  const DEFAULT_SETTINGS = {
    mode: 'large',
    largeDelta: 6,
    xlargeDelta: 10,
    invertPreview: false,
    rubyPreview: false,
    invertOutput: false
  };

  const rubyDictionary = [
    ['視覚障碍者', 'しかくしょうがいしゃ'],
    ['視覚障害者', 'しかくしょうがいしゃ'],
    ['読み仮名', 'よみがな'],
    ['漢字', 'かんじ'],
    ['文書', 'ぶんしょ'],
    ['変換', 'へんかん'],
    ['設定', 'せってい'],
    ['標準', 'ひょうじゅん'],
    ['特大', 'とくだい'],
    ['反転', 'はんてん'],
    ['色調', 'しきちょう'],
    ['心理学', 'しんりがく'],
    ['業務', 'ぎょうむ'],
    ['改善', 'かいぜん'],
    ['導線', 'どうせん'],
    ['相談', 'そうだん'],
    ['制作', 'せいさく'],
    ['資料', 'しりょう'],
    ['確認', 'かくにん'],
    ['保存', 'ほぞん'],
    ['和', 'わ']
  ];

  function bootDocxApp() {
    const root = document.querySelector('[data-docx-app]');
    if (!root || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const state = {
      files: [],
      selectedId: null,
      settings: loadSettings()
    };

    const els = {
      fileInput: document.getElementById('docxFiles'),
      folderInput: document.getElementById('docxFolder'),
      fileList: document.getElementById('fileList'),
      fileCount: document.getElementById('fileCount'),
      convertAll: document.getElementById('convertAllBtn'),
      downloadAll: document.getElementById('downloadAllBtn'),
      settingsBtn: document.getElementById('settingsBtn'),
      drawer: document.getElementById('settingsDrawer'),
      closeSettings: document.getElementById('closeSettingsBtn'),
      saveSettings: document.getElementById('saveSettingsBtn'),
      resetSettings: document.getElementById('resetSettingsBtn'),
      largeInput: document.getElementById('largeDeltaInput'),
      xlargeInput: document.getElementById('xlargeDeltaInput'),
      largeLabel: document.getElementById('largeDeltaLabel'),
      xlargeLabel: document.getElementById('xlargeDeltaLabel'),
      invertPreview: document.getElementById('invertPreviewBtn'),
      rubyPreview: document.getElementById('rubyPreviewBtn'),
      preview: document.getElementById('previewSurface'),
      previewMode: document.getElementById('previewMode'),
      statusBoard: document.getElementById('statusBoard')
    };

    applySettingsToUi();
    render();

    els.fileInput.addEventListener('change', (event) => addFiles(event.target.files));
    els.folderInput.addEventListener('change', (event) => addFiles(event.target.files));

    document.querySelectorAll('.mode-button').forEach((button) => {
      button.addEventListener('click', () => {
        state.settings.mode = button.dataset.mode;
        saveSettings(state.settings);
        applySettingsToUi();
        renderPreview();
      });
    });

    els.invertPreview.addEventListener('click', () => {
      state.settings.invertPreview = !state.settings.invertPreview;
      state.settings.invertOutput = state.settings.invertPreview;
      saveSettings(state.settings);
      applySettingsToUi();
      renderPreview();
      updateStatus('反転', state.settings.invertPreview ? 'プレビューとdocx出力に反映します。' : '反転を解除しました。');
    });

    els.rubyPreview.addEventListener('click', () => {
      state.settings.rubyPreview = !state.settings.rubyPreview;
      saveSettings(state.settings);
      applySettingsToUi();
      renderPreview();
    });

    els.settingsBtn.addEventListener('click', openSettings);
    els.closeSettings.addEventListener('click', closeSettings);
    els.drawer.addEventListener('click', (event) => {
      if (event.target === els.drawer) closeSettings();
    });
    els.saveSettings.addEventListener('click', () => {
      state.settings.largeDelta = clampPt(els.largeInput.value, 6);
      state.settings.xlargeDelta = clampPt(els.xlargeInput.value, 10);
      saveSettings(state.settings);
      applySettingsToUi();
      closeSettings();
      renderPreview();
      updateStatus('設定保存', `大は+${state.settings.largeDelta}pt、特大は+${state.settings.xlargeDelta}ptで保存しました。`);
    });
    els.resetSettings.addEventListener('click', () => {
      state.settings.largeDelta = DEFAULT_SETTINGS.largeDelta;
      state.settings.xlargeDelta = DEFAULT_SETTINGS.xlargeDelta;
      saveSettings(state.settings);
      applySettingsToUi();
    });

    els.convertAll.addEventListener('click', convertAllFiles);
    els.downloadAll.addEventListener('click', downloadAllConverted);

    els.fileList.addEventListener('click', async (event) => {
      const button = event.target.closest('button[data-action]');
      if (!button) return;
      const item = state.files.find((file) => file.id === button.dataset.id);
      if (!item) return;
      if (button.dataset.action === 'select') {
        state.selectedId = item.id;
        if (!item.previewText && item.status !== 'reading') await readPreview(item);
        render();
      }
      if (button.dataset.action === 'convert') await convertFile(item);
      if (button.dataset.action === 'download') downloadItem(item);
      if (button.dataset.action === 'remove') {
        state.files = state.files.filter((file) => file.id !== item.id);
        if (state.selectedId === item.id) state.selectedId = state.files[0]?.id || null;
        render();
      }
    });

    els.fileList.addEventListener('change', (event) => {
      const input = event.target.closest('input[data-action="target"]');
      if (!input) return;
      const item = state.files.find((file) => file.id === input.dataset.id);
      if (!item) return;
      item.included = input.checked;
      render();
    });

    async function addFiles(fileList) {
      const incoming = [...fileList].filter((file) => file.name.toLowerCase().endsWith('.docx') && !file.name.startsWith('~$'));
      if (!incoming.length) {
        updateStatus('読み込みなし', '対象となる.docxファイルが見つかりませんでした。');
        return;
      }
      const existingKeys = new Set(state.files.map((file) => file.key));
      const additions = incoming
        .map((file) => ({
          id: `${Date.now()}-${Math.random().toString(36).slice(2)}`,
          key: `${file.name}-${file.size}-${file.lastModified}`,
          file,
          name: file.webkitRelativePath || file.name,
          shortName: file.name,
          size: file.size,
          status: 'ready',
          statusText: '読込済み',
          included: true,
          previewText: '',
          convertedBlob: null,
          convertedName: '',
          error: ''
        }))
        .filter((item) => !existingKeys.has(item.key));
      state.files.push(...additions);
      if (!state.selectedId && state.files[0]) {
        state.selectedId = state.files[0].id;
        await readPreview(state.files[0]);
      }
      updateStatus('読み込み完了', `${additions.length}件のdocxを追加しました。`);
      render();
    }

    async function readPreview(item) {
      item.status = 'reading';
      item.statusText = '解析中';
      renderFileList();
      try {
        const zip = await JSZip.loadAsync(await item.file.arrayBuffer());
        const doc = zip.file('word/document.xml');
        if (!doc) throw new Error('word/document.xmlが見つかりません。');
        item.previewText = extractText(await doc.async('string'));
        item.status = 'ready';
        item.statusText = '読込済み';
      } catch (error) {
        item.status = 'error';
        item.statusText = '読込エラー';
        item.error = error.message || String(error);
      }
    }

    async function convertAllFiles() {
      if (!state.files.length) {
        updateStatus('変換できません', '先にdocxファイルを読み込んでください。');
        return;
      }
      const targets = state.files.filter(isTargeted);
      if (!targets.length) {
        updateStatus('対象なし', '変換する文書を選択してください。');
        return;
      }
      for (const item of targets) await convertFile(item, false);
      const convertedCount = targets.filter((file) => file.convertedBlob).length;
      updateStatus('変換完了', `${convertedCount}件を変換しました。`);
      render();
    }

    async function convertFile(item, announce = true) {
      item.status = 'processing';
      item.statusText = '変換中';
      item.error = '';
      render();
      try {
        const zip = await JSZip.loadAsync(await item.file.arrayBuffer());
        const deltaPt = getCurrentDelta();
        const deltaHalfPoint = deltaPt * 2;
        const xmlFiles = Object.keys(zip.files).filter(isWordXmlTarget);
        for (const name of xmlFiles) {
          const file = zip.file(name);
          if (!file) continue;
          let xml = await file.async('string');
          xml = applyFontDelta(xml, deltaHalfPoint);
          if (state.settings.invertOutput && name !== 'word/styles.xml') {
            xml = applyInvertedColor(xml, name === 'word/document.xml');
          }
          zip.file(name, xml);
        }
        const blob = await zip.generateAsync({ type: 'blob', mimeType: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' });
        item.convertedBlob = blob;
        item.convertedName = buildOutputName(item.shortName, state.settings.mode, deltaPt, state.settings.invertOutput);
        item.status = 'converted';
        item.statusText = '変換済み';
        if (announce) updateStatus('変換完了', `${item.shortName} を ${getModeLabel()} に変換しました。`);
      } catch (error) {
        item.status = 'error';
        item.statusText = '変換エラー';
        item.error = error.message || String(error);
        if (announce) updateStatus('変換エラー', item.error);
      }
      render();
    }

    async function downloadAllConverted() {
      const converted = state.files.filter((file) => isTargeted(file) && file.convertedBlob);
      if (!converted.length) {
        updateStatus('ダウンロード不可', '選択中の文書を先に変換してください。');
        return;
      }
      if (converted.length === 1) {
        downloadBlob(converted[0].convertedBlob, converted[0].convertedName);
        return;
      }
      const zip = new JSZip();
      converted.forEach((item) => zip.file(item.convertedName, item.convertedBlob));
      const blob = await zip.generateAsync({ type: 'blob' });
      downloadBlob(blob, `wa-node-docx-converted-${new Date().toISOString().slice(0, 10)}.zip`);
    }

    function downloadItem(item) {
      if (!item.convertedBlob) {
        updateStatus('未変換', 'この文書はまだ変換されていません。');
        return;
      }
      downloadBlob(item.convertedBlob, item.convertedName);
    }

    function render() {
      renderFileList();
      renderPreview();
      const targetCount = state.files.filter(isTargeted).length;
      els.fileCount.textContent = `${targetCount}/${state.files.length}`;
      els.fileCount.setAttribute('aria-label', `変換対象 ${targetCount}件、読み込み ${state.files.length}件`);
    }

    function renderFileList() {
      if (!state.files.length) {
        els.fileList.innerHTML = `
            <article class="empty-state">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"/><path d="M14 2v5h5"/><path d="M9 13h6"/><path d="M9 17h4"/></svg>
            <strong>.docxファイルをドラッグ＆ドロップで追加</strong>
          </article>`;
        return;
      }
      els.fileList.innerHTML = state.files.map((item) => `
        <article class="file-row ${item.id === state.selectedId ? 'is-selected' : ''} ${isTargeted(item) ? 'is-targeted' : ''}">
          <label class="file-check" title="変換対象" aria-label="${escapeHtml(item.shortName)}を変換対象にする">
            <input type="checkbox" data-action="target" data-id="${item.id}" ${isTargeted(item) ? 'checked' : ''} />
            <span aria-hidden="true">✓</span>
          </label>
          <div class="file-main">
            <button type="button" data-action="select" data-id="${item.id}">${escapeHtml(item.name)}</button>
            <div class="file-meta">
              <span>${formatBytes(item.size)}</span>
              <span class="status-pill ${item.status === 'error' ? 'error' : ''}">${escapeHtml(item.statusText)}</span>
              ${item.convertedBlob ? `<span>${escapeHtml(item.convertedName)}</span>` : ''}
              ${item.error ? `<span>${escapeHtml(item.error)}</span>` : ''}
            </div>
          </div>
          <div class="row-actions" aria-label="${escapeHtml(item.shortName)}の操作">
            <button type="button" data-action="convert" data-id="${item.id}" title="変換" aria-label="変換">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 12a9 9 0 0 1-9 9 9.8 9.8 0 0 1-6.4-2.4"/><path d="M3 12a9 9 0 0 1 9-9 9.8 9.8 0 0 1 6.4 2.4"/><path d="M3 21v-6h6"/><path d="M21 3v6h-6"/></svg>
            </button>
            <button type="button" data-action="download" data-id="${item.id}" title="ダウンロード" aria-label="ダウンロード">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
            </button>
            <button type="button" data-action="remove" data-id="${item.id}" title="削除" aria-label="削除">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
          </div>
        </article>
      `).join('');
    }

    function isTargeted(item) {
      return item.included !== false;
    }

    function renderPreview() {
      const selected = state.files.find((file) => file.id === state.selectedId);
      root.classList.toggle('is-inverted', state.settings.invertPreview);
      els.preview.classList.toggle('is-inverted', state.settings.invertPreview);
      els.preview.style.setProperty('--preview-font-size', `${Math.min(34, 16 + getCurrentDelta())}px`);
      els.previewMode.textContent = getModeLabel();
      if (!selected) {
        els.preview.innerHTML = '<p class="preview-placeholder">文書を選択すると、本文の先頭を表示します。</p>';
        return;
      }
      if (selected.status === 'error') {
        els.preview.innerHTML = `<p class="preview-placeholder">${escapeHtml(selected.error || '読み込みに失敗しました。')}</p>`;
        return;
      }
      const text = selected.previewText || '本文テキストを抽出できませんでした。画像化された文書や複雑なレイアウトの可能性があります。';
      const paragraphs = text.split(/\n+/).filter(Boolean).slice(0, 12);
      els.preview.innerHTML = paragraphs.map((paragraph) => `<p>${formatPreview(paragraph, state.settings.rubyPreview)}</p>`).join('');
    }

    function openSettings() {
      els.largeInput.value = state.settings.largeDelta;
      els.xlargeInput.value = state.settings.xlargeDelta;
      els.drawer.hidden = false;
      els.largeInput.focus();
    }

    function closeSettings() {
      els.drawer.hidden = true;
    }

    function applySettingsToUi() {
      state.settings.invertOutput = state.settings.invertPreview;
      document.querySelectorAll('.mode-button').forEach((button) => {
        button.classList.toggle('is-active', button.dataset.mode === state.settings.mode);
      });
      els.largeLabel.textContent = `+${state.settings.largeDelta}pt`;
      els.xlargeLabel.textContent = `+${state.settings.xlargeDelta}pt`;
      els.invertPreview.setAttribute('aria-pressed', String(state.settings.invertPreview));
      els.rubyPreview.setAttribute('aria-pressed', String(state.settings.rubyPreview));
      root.classList.toggle('is-inverted', state.settings.invertPreview);
    }

    function updateStatus(label, text) {
      els.statusBoard.innerHTML = `<span>${escapeHtml(label)}</span><strong>${escapeHtml(text)}</strong>`;
    }

    function getCurrentDelta() {
      if (state.settings.mode === 'large') return state.settings.largeDelta;
      if (state.settings.mode === 'xlarge') return state.settings.xlargeDelta;
      return 0;
    }

    function getModeLabel() {
      if (state.settings.mode === 'large') return `大 +${state.settings.largeDelta}pt`;
      if (state.settings.mode === 'xlarge') return `特大 +${state.settings.xlargeDelta}pt`;
      return '標準 +0pt';
    }
  }

  function loadSettings() {
    try {
      const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      return {
        ...DEFAULT_SETTINGS,
        ...saved,
        largeDelta: clampPt(saved.largeDelta, DEFAULT_SETTINGS.largeDelta),
        xlargeDelta: clampPt(saved.xlargeDelta, DEFAULT_SETTINGS.xlargeDelta)
      };
    } catch {
      return { ...DEFAULT_SETTINGS };
    }
  }

  function saveSettings(settings) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(settings));
  }

  function clampPt(value, fallback) {
    const numeric = Number(value);
    if (!Number.isFinite(numeric)) return fallback;
    return Math.max(0, Math.min(20, Math.round(numeric)));
  }

  function isWordXmlTarget(name) {
    return /^word\/(document|styles|footnotes|endnotes|comments)\.xml$/.test(name)
      || /^word\/(header|footer)\d+\.xml$/.test(name);
  }

  function applyFontDelta(xml, deltaHalfPoint) {
    if (!deltaHalfPoint) return xml;
    return xml.replace(/<(w:sz|w:szCs)(\b[^>]*?\bw:val=")([0-9]+)("[^>]*?)\/>/g, (_match, tag, before, value, after) => {
      const next = Math.max(2, Math.min(200, Number(value) + deltaHalfPoint));
      return `<${tag}${before}${next}${after}/>`;
    });
  }

  function applyInvertedColor(xml, isDocumentXml) {
    let next = xml;
    if (isDocumentXml) {
      if (/<w:background\b[^>]*\/>/.test(next)) {
        next = next.replace(/<w:background\b[^>]*\/>/, '<w:background w:color="000000"/>');
      } else {
        next = next.replace(/(<w:document\b[^>]*>)/, '$1<w:background w:color="000000"/>');
      }
    }
    return next.replace(/<w:r\b[^>]*>[\s\S]*?<\/w:r>/g, (run) => {
      if (!/<w:t\b/.test(run)) return run;
      if (/<w:rPr\b[\s\S]*?<\/w:rPr>/.test(run)) {
        return run.replace(/<w:rPr\b[^>]*>[\s\S]*?<\/w:rPr>/, (rpr) => {
          const cleaned = rpr
            .replace(/<w:color\b[^>]*\/>/g, '')
            .replace(/<w:highlight\b[^>]*\/>/g, '');
          return cleaned.replace('</w:rPr>', '<w:color w:val="FFFFFF"/><w:highlight w:val="black"/></w:rPr>');
        });
      }
      return run.replace(/(<w:r\b[^>]*>)/, '$1<w:rPr><w:color w:val="FFFFFF"/><w:highlight w:val="black"/></w:rPr>');
    });
  }

  function extractText(xml) {
    const parser = new DOMParser();
    const doc = parser.parseFromString(xml, 'application/xml');
    const paragraphs = [...doc.getElementsByTagName('w:p')].map((paragraph) => {
      let text = '';
      paragraph.childNodes.forEach((node) => {
        text += collectText(node);
      });
      return text.trim();
    });
    return paragraphs.filter(Boolean).join('\n');
  }

  function collectText(node) {
    if (node.nodeType !== Node.ELEMENT_NODE) return '';
    const element = node;
    const name = element.nodeName;
    if (name === 'w:t') return element.textContent || '';
    if (name === 'w:tab') return '　';
    if (name === 'w:br' || name === 'w:cr') return '\n';
    let output = '';
    element.childNodes.forEach((child) => {
      output += collectText(child);
    });
    return output;
  }

  function formatPreview(text, rubyOn) {
    const escaped = escapeHtml(text);
    if (!rubyOn) return escaped;
    let result = escaped;
    rubyDictionary.forEach(([word, reading]) => {
      const safeWord = escapeRegExp(escapeHtml(word));
      result = result.replace(new RegExp(safeWord, 'g'), `<ruby>${escapeHtml(word)}<rt>${reading}</rt></ruby>`);
    });
    return result;
  }

  function buildOutputName(name, mode, deltaPt, invertOutput) {
    const base = name.replace(/\.docx$/i, '');
    const suffix = mode === 'standard' ? 'standard' : `${mode}_plus${deltaPt}pt`;
    return `${base}_${suffix}${invertOutput ? '_invert' : ''}.docx`;
  }

  function downloadBlob(blob, fileName) {
    const url = URL.createObjectURL(blob);
    const anchor = document.createElement('a');
    anchor.href = url;
    anchor.download = fileName;
    document.body.append(anchor);
    anchor.click();
    anchor.remove();
    URL.revokeObjectURL(url);
  }

  function formatBytes(bytes) {
    if (!bytes) return '0 KB';
    if (bytes < 1024 * 1024) return `${Math.ceil(bytes / 1024)} KB`;
    return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
  }

  function escapeHtml(value) {
    return String(value).replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[char]));
  }

  function escapeRegExp(value) {
    return String(value).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  document.addEventListener('DOMContentLoaded', bootDocxApp);
  document.addEventListener('astro:page-load', bootDocxApp);
  bootDocxApp();
</script>
