---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'DOCXアクセシブル変換アプリ｜和-Node';
const description = 'DOCXファイルをブラウザ内で読み込み、フォントサイズ拡大、反転、読み仮名プレビュー、変換済みDOCXのダウンロードを行うアクセシビリティ支援デモアプリです。';
---

<BaseLayout title={title} description={description} noindex={true}>
  <main class="docx-app" data-docx-app>
    <section class="docx-hero">
      <div class="docx-shell hero-grid">
        <div class="hero-copy">
          <p class="tool-label">Wa-Node Accessibility Tool</p>
          <h1>DOCX<wbr />アクセシブル<wbr />変換</h1>
          <p>
            Word文書をブラウザ内で読み込み、文字サイズの拡大、反転、読み仮名プレビューをまとめて確認できます。
            文書データはサーバーへ送信されません。
          </p>
        </div>
        <div class="hero-badges" aria-label="このアプリの前提">
          <span>DOCX専用</span>
          <span>端末内処理</span>
          <span>初期デモ</span>
        </div>
      </div>
    </section>

    <section class="docx-workspace" aria-labelledby="workspace-title">
      <div class="docx-shell workspace-grid">
        <aside class="control-panel" aria-label="ファイル読み込みと変換設定">
          <div class="panel-heading">
            <p class="tool-label">Input</p>
            <h2 class="sr-only" id="workspace-title">文書を読み込む</h2>
          </div>

          <div class="input-actions">
            <label class="icon-button primary icon-symbol-button" for="docxFiles" aria-label="DOCXファイルを選ぶ" title="ファイル">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"/><path d="M14 2v5h5"/><path d="M12 18v-6"/><path d="m9 15 3 3 3-3"/></svg>
              <span class="sr-only">ファイル</span>
              <input id="docxFiles" type="file" accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document" multiple />
            </label>

            <label class="icon-button icon-symbol-button" for="docxFolder" aria-label="フォルダを選ぶ" title="フォルダ">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M12 17v-6"/><path d="m9 14 3 3 3-3"/></svg>
              <span class="sr-only">フォルダ</span>
              <input id="docxFolder" type="file" accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document" multiple webkitdirectory directory />
            </label>
          </div>

          <div class="mode-panel" aria-labelledby="mode-title">
            <div class="section-title-row compact">
              <div>
                <p class="tool-label">Font Size</p>
                <h2 class="sr-only" id="mode-title">文字サイズ</h2>
              </div>
              <button class="icon-only" id="settingsBtn" type="button" aria-label="設定を開く" title="設定">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z"/><path d="M19.4 15a1.8 1.8 0 0 0 .36 1.98l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.8 1.8 0 0 0-1.98-.36 1.8 1.8 0 0 0-1.08 1.65V21a2 2 0 0 1-4 0v-.09A1.8 1.8 0 0 0 8.8 19.3a1.8 1.8 0 0 0-1.98.36l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.8 1.8 0 0 0 4.35 15a1.8 1.8 0 0 0-1.65-1.08H2.6a2 2 0 0 1 0-4h.09A1.8 1.8 0 0 0 4.3 8.8a1.8 1.8 0 0 0-.36-1.98l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.8 1.8 0 0 0 8.75 4.35a1.8 1.8 0 0 0 1.08-1.65V2.6a2 2 0 0 1 4 0v.09a1.8 1.8 0 0 0 1.08 1.65 1.8 1.8 0 0 0 1.98-.36l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.8 1.8 0 0 0-.36 1.98 1.8 1.8 0 0 0 1.65 1.08h.09a2 2 0 0 1 0 4h-.09A1.8 1.8 0 0 0 19.4 15Z"/></svg>
              </button>
            </div>
            <div class="font-modes" role="group" aria-label="文字サイズモード">
              <button type="button" class="mode-button" data-mode="standard">
                <span class="mode-icon">A</span>
                <strong>標準</strong>
                <small class="sr-only">+0pt</small>
              </button>
              <button type="button" class="mode-button" data-mode="large">
                <span class="mode-icon">A+</span>
                <strong>大</strong>
                <small class="sr-only" id="largeDeltaLabel">+6pt</small>
              </button>
              <button type="button" class="mode-button" data-mode="xlarge">
                <span class="mode-icon">A++</span>
                <strong>特大</strong>
                <small class="sr-only" id="xlargeDeltaLabel">+10pt</small>
              </button>
            </div>
          </div>

          <div class="assist-panel" aria-label="補助表示設定">
            <button type="button" class="assist-button" id="invertPreviewBtn" aria-pressed="false">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a9 9 0 1 0 0 18z"/><path d="M12 3a9 9 0 0 1 0 18"/></svg>
              <span>反転</span>
            </button>
            <button type="button" class="assist-button" id="rubyPreviewBtn" aria-pressed="false">
              <span class="assist-icon-letter" aria-hidden="true">あ</span>
              <span>読み仮名</span>
            </button>
          </div>

          <div class="convert-actions">
            <button type="button" class="icon-button primary icon-symbol-button" id="convertAllBtn" aria-label="選択中の文書を変換" title="変換">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 12a9 9 0 0 1-9 9 9.8 9.8 0 0 1-6.4-2.4"/><path d="M3 12a9 9 0 0 1 9-9 9.8 9.8 0 0 1 6.4 2.4"/><path d="M3 21v-6h6"/><path d="M21 3v6h-6"/></svg>
              <span class="sr-only">変換</span>
            </button>
            <button type="button" class="icon-button icon-symbol-button" id="downloadAllBtn" aria-label="選択中の変換済み文書をダウンロード" title="ダウンロード">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
              <span class="sr-only">ダウンロード</span>
            </button>
          </div>

          <div class="privacy-note">
            <strong>初期版の注意</strong>
            <p>フォント拡大と反転はdocxに反映します。読み仮名はプレビュー補助です。表・画像・複雑なテキストボックスは変換後に目視確認してください。</p>
          </div>
        </aside>

        <section class="file-panel" aria-labelledby="file-list-title">
          <div class="section-title-row">
            <div>
              <p class="tool-label">Files</p>
              <h2 id="file-list-title">読み込んだ文書</h2>
            </div>
            <p class="loaded-state" id="fileCount" aria-label="変換対象 0件、読み込み 0件">0/0</p>
          </div>
          <div class="file-list" id="fileList">
            <article class="empty-state">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"/><path d="M14 2v5h5"/><path d="M9 13h6"/><path d="M9 17h4"/></svg>
              <strong>.docxファイルをドラッグ＆ドロップで追加</strong>
            </article>
          </div>
        </section>

        <aside class="preview-panel" aria-labelledby="preview-title">
          <div class="section-title-row">
            <div>
              <p class="tool-label">Preview</p>
              <h2 id="preview-title">内容プレビュー</h2>
            </div>
            <span class="preview-mode" id="previewMode">標準</span>
          </div>
          <div class="preview-surface" id="previewSurface">
            <p class="preview-placeholder">文書を選択すると、本文の先頭を表示します。</p>
          </div>
          <div class="status-board" id="statusBoard">
            <span>待機中</span>
            <strong>フォントサイズを選び、変換を実行してください。</strong>
          </div>
        </aside>
      </div>
    </section>

    <div class="settings-drawer" id="settingsDrawer" hidden>
      <div class="settings-card" role="dialog" aria-modal="true" aria-labelledby="settings-title">
        <div class="section-title-row">
          <div>
            <p class="tool-label">Settings</p>
            <h2 id="settings-title">フォント加算値</h2>
          </div>
          <button class="icon-only" id="closeSettingsBtn" type="button" aria-label="設定を閉じる" title="閉じる">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
        <div class="setting-fields">
          <label>
            <span>大</span>
            <input id="largeDeltaInput" type="number" min="0" max="20" step="1" />
            <small>初期値 +6pt</small>
          </label>
          <label>
            <span>特大</span>
            <input id="xlargeDeltaInput" type="number" min="0" max="20" step="1" />
            <small>初期値 +10pt</small>
          </label>
        </div>
        <div class="drawer-actions">
          <button type="button" class="ghost-btn" id="resetSettingsBtn">初期値に戻す</button>
          <button type="button" class="primary-btn" id="saveSettingsBtn">保存</button>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .docx-app {
    --tool-bg: #f7f0e7;
    --tool-panel: #fffdf8;
    --tool-panel-strong: #ffffff;
    --tool-ink: #142523;
    --tool-muted: #5e6b68;
    --tool-teal: #0f4c5c;
    --tool-teal-2: #2e8792;
    --tool-gold: #9a6a15;
    --tool-red: #c7352f;
    --tool-line: rgba(15, 76, 92, 0.18);
    --tool-shadow: 0 20px 52px rgba(32, 45, 41, 0.13);
    background:
      radial-gradient(circle at 16% 8%, rgba(46, 135, 146, 0.12), transparent 28%),
      linear-gradient(180deg, #fffaf3 0%, var(--tool-bg) 100%);
    color: var(--tool-ink);
    min-height: 100vh;
    padding-bottom: 80px;
  }

  .docx-app.is-inverted {
    --tool-bg: #071413;
    --tool-panel: #0f1f1d;
    --tool-panel-strong: #102927;
    --tool-ink: #f6fff8;
    --tool-muted: #c6d6d2;
    --tool-line: rgba(246, 255, 248, 0.2);
    --tool-shadow: 0 20px 52px rgba(0, 0, 0, 0.32);
  }

  .docx-shell {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
  }

  .docx-app *,
  .docx-app *::before,
  .docx-app *::after {
    box-sizing: border-box;
    min-width: 0;
  }

  .docx-app :where(p, h1, h2, h3, li, small) {
    overflow-wrap: anywhere;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .docx-hero {
    padding: 84px 0 32px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 210px;
    gap: 34px;
    align-items: end;
  }

  .tool-label {
    margin: 0 0 12px;
    color: var(--tool-gold);
    font-family: Outfit, system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-copy h1,
  .panel-heading h2,
  .section-title-row h2 {
    margin: 0;
    color: var(--tool-ink);
    font-family: "Yu Mincho", "YuMincho", "Hiragino Mincho ProN", serif;
    letter-spacing: 0;
  }

  .hero-copy h1 {
    font-size: clamp(2.6rem, 6vw, 5rem);
    line-height: 1.08;
  }

  .hero-copy p:not(.tool-label),
  .panel-heading p:not(.tool-label) {
    max-width: 780px;
    margin: 18px 0 0;
    color: var(--tool-muted);
    font-size: 1rem;
    line-height: 2;
  }

  .hero-badges {
    display: grid;
    gap: 10px;
  }

  .hero-badges span,
  .loaded-state,
  .preview-mode {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 8px 14px;
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.62);
    color: var(--tool-teal);
    font-weight: 800;
    font-size: 0.85rem;
  }

  .workspace-grid {
    display: grid;
    grid-template-columns: 312px minmax(0, 1fr) 330px;
    gap: 22px;
    align-items: start;
  }

  .control-panel,
  .file-panel,
  .preview-panel,
  .settings-card {
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: color-mix(in srgb, var(--tool-panel) 94%, transparent);
    box-shadow: var(--tool-shadow);
  }

  .control-panel {
    position: sticky;
    top: 92px;
    display: grid;
    gap: 20px;
    padding: 24px;
  }

  .file-panel,
  .preview-panel {
    padding: 24px;
  }

  .section-title-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: start;
    margin-bottom: 20px;
  }

  .section-title-row.compact {
    align-items: center;
    margin-bottom: 14px;
  }

  .section-title-row h2,
  .panel-heading h2 {
    font-size: clamp(1.5rem, 2.3vw, 2rem);
    line-height: 1.25;
  }

  .preview-panel .section-title-row h2 {
    font-size: clamp(1.35rem, 1.8vw, 1.65rem);
    overflow-wrap: normal;
    word-break: keep-all;
  }

  .input-actions,
  .convert-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .convert-actions {
    grid-template-columns: 1fr 1fr;
  }

  .icon-button,
  .assist-button,
  .primary-btn,
  .ghost-btn {
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: var(--tool-panel-strong);
    color: var(--tool-teal);
    font: inherit;
    font-weight: 900;
    cursor: pointer;
    transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  }

  .icon-button {
    position: relative;
    display: flex;
    min-height: 58px;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 12px;
  }

  .icon-symbol-button {
    padding: 0;
  }

  .icon-button span,
  .assist-button span {
    white-space: nowrap;
  }

  .icon-button.primary,
  .primary-btn {
    border-color: var(--tool-teal);
    background: var(--tool-teal);
    color: #fff;
  }

  .icon-button:hover,
  .assist-button:hover,
  .primary-btn:hover,
  .ghost-btn:hover,
  .icon-only:hover {
    transform: translateY(-1px);
    border-color: var(--tool-teal-2);
  }

  .icon-button svg,
  .assist-button svg,
  .icon-only svg,
  .empty-state svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex: 0 0 auto;
  }

  .icon-button input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }

  .mode-panel,
  .assist-panel,
  .privacy-note {
    padding: 16px;
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.5);
  }

  .font-modes,
  .assist-panel,
  .file-list {
    display: grid;
    gap: 10px;
  }

  .font-modes {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .mode-button {
    display: grid;
    grid-template-rows: auto auto;
    justify-items: center;
    gap: 6px;
    align-items: center;
    min-height: 86px;
    padding: 10px 6px 8px;
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: var(--tool-panel-strong);
    color: var(--tool-ink);
    text-align: center;
    cursor: pointer;
  }

  .mode-button.is-active {
    border-color: var(--tool-teal);
    box-shadow: inset 0 0 0 2px rgba(15, 76, 92, 0.14);
  }

  .mode-icon {
    display: grid;
    width: 50px;
    height: 48px;
    place-items: center;
    border-radius: 8px;
    background: #eaf6f3;
    color: var(--tool-teal);
    font-family: Outfit, system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 900;
  }

  .mode-button strong {
    display: block;
    color: var(--tool-muted);
    font-size: 0.78rem;
    font-weight: 900;
    line-height: 1.1;
  }

  .icon-only {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: var(--tool-panel-strong);
    color: var(--tool-teal);
    cursor: pointer;
  }

  .assist-button {
    display: flex;
    min-height: 48px;
    align-items: center;
    justify-content: flex-start;
    gap: 10px;
    padding: 10px 12px;
  }

  .assist-button[aria-pressed="true"] {
    border-color: var(--tool-teal);
    background: #eaf6f3;
  }

  .assist-icon-letter {
    display: grid;
    width: 22px;
    height: 22px;
    place-items: center;
    color: currentColor;
    font-family: "Yu Gothic", "Hiragino Sans", system-ui, sans-serif;
    font-size: 1.08rem;
    font-weight: 900;
    line-height: 1;
  }

  .privacy-note strong {
    color: var(--tool-teal);
  }

  .privacy-note p {
    margin: 8px 0 0;
    color: var(--tool-muted);
    font-size: 0.86rem;
    line-height: 1.75;
  }

  .file-row,
  .empty-state {
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: var(--tool-panel-strong);
  }

  .file-row {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    padding: 14px;
  }

  .file-row.is-selected {
    border-color: var(--tool-teal);
    box-shadow: inset 4px 0 0 var(--tool-teal);
  }

  .file-row.is-targeted {
    background: color-mix(in srgb, var(--tool-panel-strong) 92%, #eaf6f3);
  }

  .file-check {
    position: relative;
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    cursor: pointer;
  }

  .file-check input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .file-check span {
    display: grid;
    width: 28px;
    height: 28px;
    place-items: center;
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: var(--tool-panel);
    color: transparent;
    font-size: 0.9rem;
    font-weight: 900;
  }

  .file-check input:checked + span {
    border-color: var(--tool-teal);
    background: var(--tool-teal);
    color: #fff;
  }

  .file-main {
    min-width: 0;
  }

  .file-main button {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    color: var(--tool-ink);
    font: inherit;
    font-weight: 900;
    text-align: left;
    cursor: pointer;
  }

  .file-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
    color: var(--tool-muted);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 4px 10px;
    border-radius: 999px;
    background: #eef6f4;
    color: var(--tool-teal);
  }

  .status-pill.error {
    background: #fff1ed;
    color: var(--tool-red);
  }

  .row-actions {
    display: flex;
    gap: 8px;
  }

  .row-actions button {
    display: grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: var(--tool-panel);
    color: var(--tool-teal);
    cursor: pointer;
  }

  .row-actions svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .empty-state {
    display: grid;
    place-items: center;
    min-height: 280px;
    padding: 32px;
    text-align: center;
  }

  .empty-state svg {
    width: 46px;
    height: 46px;
    color: var(--tool-teal-2);
  }

  .empty-state strong {
    margin-top: 12px;
    color: var(--tool-ink);
  }

  .empty-state p {
    max-width: 360px;
    margin: 8px auto 0;
    color: var(--tool-muted);
    line-height: 1.75;
  }

  .preview-surface {
    min-height: 430px;
    max-height: 570px;
    overflow: auto;
    padding: 24px;
    border: 1px solid var(--tool-line);
    border-radius: 8px;
    background: var(--tool-panel-strong);
    color: var(--tool-ink);
    line-height: 1.95;
    font-size: var(--preview-font-size, 16px);
  }

  .docx-app.is-inverted .preview-surface,
  .preview-surface.is-inverted {
