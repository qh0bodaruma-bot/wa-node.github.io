  /* JSで後から描画する行はAstroのscoped属性を持たないため、ページ内に限定して補足する。 */
  .docx-app :global(.file-list) {
    display: grid;
    gap: 10px;
  }

  .docx-app :global(.file-row),
  .docx-app :global(.empty-state) {
    border: 1px solid var(--tool-line);
