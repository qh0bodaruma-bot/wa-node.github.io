---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="LP制作・要件ヒアリング | 和-Node" description="理想のWebサイト・LP制作への第一歩。構成案作成ウィザードで、あなたのビジネスの強みをプロの視点で整理します。">
  <!-- Background Decoration -->
  <div class="bg-decoration">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="pattern-overlay"></div>
  </div>

  <div class="demo-banner">
    <strong class="banner-title">【制作例サンプル】</strong> これは和-Nodeの技術を体験できるデモアプリです。このようなカスタムツールの導入をご検討中の方は <a href="/#consultation-flow" class="banner-cta">こちらから無料相談</a>
  </div>

  <main class="wizard-page">
    <div class="wizard-card glass-card">
      
      <!-- Step 0: Welcome -->
      <div id="step-welcome" class="wizard-step active">
        <div class="welcome-visual" style="max-width: 400px; margin: 0 auto 32px; border-radius: 24px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.1);">
          <img src="/portfolio-lp/images/hero_saas.png" alt="LP Planning" style="width: 100%; height: auto; display: block;" />
        </div>
        <span class="eyebrow">Creative Direction</span>
        <h1 class="welcome-title">LP・構成案作成<br/><span class="accent-text">ウィザード</span></h1>
        <p class="welcome-desc">
          あなたのビジネスの想いや目的を、整理された「要件定義」へと変換します。<br />
          回答後に、和-Nodeへの相談にそのまま使えるサマリーを自動生成します。<br />
          <span class="small-info">所要時間：約3分</span>
        </p>
        <button class="primary-btn pulse" id="startBtn">ヒアリングを開始する</button>
      </div>

      <!-- Steps 1-9: Wizard Steps -->
      <div id="step-quiz" class="wizard-step">
        <div class="wizard-header">
          <div class="stepper-wrap">
            <div class="stepper-line">
              <div class="stepper-progress" id="stepper-progress"></div>
            </div>
            <div class="stepper-nodes" id="stepper-nodes">
              <!-- JS dynamic nodes -->
            </div>
          </div>
          <div class="step-info">
            <span id="step-label">Step 1</span>
            <span id="step-count">1 / 9</span>
          </div>
        </div>

        <form id="wizardForm" class="quiz-form">
          <div id="q-content" class="q-content">
            <!-- Questions will be injected here -->
          </div>
        </form>

        <div class="wizard-footer">
          <button id="backBtn" class="text-btn">← 戻る</button>
          <button id="nextBtn" class="primary-btn-sm">次へ進む →</button>
        </div>
      </div>

      <!-- Step 10: Result Summary -->
      <div id="step-result" class="wizard-step">
        <div class="result-container">
          <div class="doc-view glass-card">
            <div class="doc-ribbon">SUMMARY</div>
            <div class="doc-header">
              <h2>Web Production Strategy Brief</h2>
              <p>ヒアリングに基づいた構成要件のまとめ</p>
            </div>
            <div class="doc-body" id="summaryGrid">
              <!-- JS dynamic data -->
            </div>
            <div class="doc-ai-box">
              <div class="ai-label">💡 和-Nodeからの初期提案</div>
              <p id="recommendText"></p>
            </div>
          </div>

          <div class="result-actions">
            <div class="bonus-notice-box glass-card">
              <div class="bonus-tag">🎁 相談延長特典</div>
              <p>
                この要件サマリーをコピーして公式LINEにお送りください。<br/>
                合言葉 <strong>「わのーど診断」</strong> とともに、初回無料相談を <strong>「60分」</strong> に延長します。
              </p>
              <div class="summary-code-block" id="copyArea"></div>
              <button class="copy-btn" id="btnCopy">サマリーをコピーする</button>
            </div>

            <div class="final-cta">
              <a href="#consultation-flow" class="primary-btn">無料相談のステップを確認</a>
              <button class="retry-btn" id="retryBtn">もう一度入力する</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Consultation Flow Section -->
      <section id="consultation-flow" class="wanode-cta-box glass-card" style="margin-top: 60px; scroll-margin-top: 40px; padding: 40px; background: rgba(255,255,255,0.8); border: 1px solid var(--wiz-accent-light); border-radius: 32px;">
        <div class="bonus-tag" style="background: var(--wiz-accent); color: #fff; padding: 6px 16px; border-radius: 999px; font-size: 0.8rem; font-weight: 900; margin-bottom: 20px; display: inline-block;">🎁 ウィザード完了特典</div>
        <h3 style="font-size: 1.6rem; font-weight: 900; margin-bottom: 20px; color: var(--wiz-text);">要件サマリーを元に、最適なプランをご提案します</h3>
        <p style="font-size: 1rem; color: #555; line-height: 1.8; margin-bottom: 30px;">
          ウィザードのご利用ありがとうございました。作成されたサマリーを元に、より具体的な構成案や費用感をご相談いただけます。<br/>
          通常の30分無料相談を、<strong>「60分無料」</strong> に拡大させていただきます。
        </p>

        <div style="background: rgba(255,255,255,0.6); border: 1px solid var(--wiz-accent-light); border-radius: 20px; padding: 30px; margin-bottom: 30px; text-align: left;">
          <h4 style="margin-top: 0; color: var(--wiz-accent); font-size: 1.1rem; border-bottom: 1px solid var(--wiz-accent-light); padding-bottom: 10px; margin-bottom: 15px;">無料相談のステップ</h4>
          <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.95rem; color: #444;">
            <li style="margin-bottom: 12px; display: flex; align-items: flex-start; gap: 10px;">
              <span style="background: var(--wiz-accent); color: #fff; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.75rem; font-weight: 800;">1</span>
              <span><strong>初回30分無料：</strong> 現状のヒアリングと課題の整理（どなたでも）</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 10px;">
              <span style="background: var(--wiz-accent); color: #fff; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.75rem; font-weight: 800;">2</span>
              <span><strong>ウィザード特典＋30分：</strong> サマリーに基づいた構成案の深掘りアドバイス（1回限り）</span>
            </li>
          </ul>
        </div>

        <div class="cta-btns" style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
          <a href="https://lin.ee/o5QFPwc" target="_blank" rel="noopener" class="primary-btn" style="margin: 0; text-decoration: none;">LINEで60分相談を予約する</a>
          <a href="/#consultation-flow" class="secondary-btn" style="padding: 20px 40px; border: 2px solid var(--wiz-accent); color: var(--wiz-accent); border-radius: 999px; text-decoration: none; font-weight: 800;">無料相談のステップを確認</a>
        </div>
      </section>

    </div>
  </main>
</BaseLayout>

<style>
    :root {
      --wiz-accent: #8a5a32;
      --wiz-accent-light: #d8b98c;
      --wiz-text: #2c241e;
      --wiz-bg: #fdfaf7;
      --glass-bg: rgba(255, 255, 255, 0.8);
      --glass-border: rgba(255, 255, 255, 0.4);
    }

    /* Background Decoration */
    .bg-decoration {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      z-index: -1; background: var(--wiz-bg); overflow: hidden;
    }
    .glow { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.3; animation: float 20s infinite alternate; }
    .glow-1 { width: 600px; height: 600px; background: #ebd5b3; top: -10%; left: -10%; }
    .glow-2 { width: 500px; height: 500px; background: #d2e4d8; bottom: -10%; right: -10%; animation-delay: -5s; }
    .pattern-overlay {
      position: absolute; width: 100%; height: 100%;
      background-image: radial-gradient(var(--wiz-accent) 0.5px, transparent 0.5px);
      background-size: 40px 40px; opacity: 0.05;
    }
    @keyframes float { from { transform: translate(0,0); } to { transform: translate(40px, 80px); } }

    .demo-banner { background: rgba(0,0,0,0.02); border-bottom: 1px solid var(--line); padding: 12px; text-align: center; font-size: 0.85rem; backdrop-filter: blur(5px); }
    .banner-cta { color: var(--wiz-accent); font-weight: 800; text-decoration: underline; margin-left: 8px; }

    .wizard-page { max-width: 1000px; margin: 40px auto 100px; padding: 0 20px; }
    
    .glass-card { background: var(--glass-bg); backdrop-filter: blur(20px); border: 1px solid var(--glass-border); border-radius: 40px; box-shadow: 0 30px 60px rgba(0,0,0,0.05); }

    .wizard-card { padding: 60px 50px; min-height: 650px; display: flex; flex-direction: column; justify-content: center; position: relative; }

    .wizard-step { display: none; width: 100%; }
    .wizard-step.active { display: block; }

    /* Transitions */
    .fade-slide-in { animation: fadeSlideIn 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards; }
    .fade-slide-out { animation: fadeSlideOut 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards; }
    @keyframes fadeSlideIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeSlideOut { from { opacity: 1; transform: translateY(0); } to { opacity: 0; transform: translateY(-20px); } }

    /* Welcome */
    .float-icon { font-size: 72px; text-align: center; margin-bottom: 24px; animation: floatIcon 4s infinite ease-in-out; }
    @keyframes floatIcon { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }
    .eyebrow { display: block; text-align: center; font-size: 0.8rem; font-weight: 900; color: var(--wiz-accent); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 10px; }
    .welcome-title { font-size: 3.5rem; font-weight: 900; line-height: 1.1; margin-bottom: 24px; text-align: center; color: var(--wiz-text); }
    .accent-text { color: var(--wiz-accent); }
    .welcome-desc { font-size: 1.1rem; color: var(--muted); text-align: center; margin-bottom: 48px; line-height: 1.8; }
    .small-info { display: block; font-size: 0.85rem; margin-top: 15px; opacity: 0.6; }

    .primary-btn { display: block; width: fit-content; margin: 0 auto; padding: 20px 64px; background: var(--wiz-accent); color: #fff; border-radius: 999px; font-weight: 800; font-size: 1.2rem; border: none; cursor: pointer; box-shadow: 0 10px 30px rgba(138, 90, 50, 0.2); transition: 0.4s; text-decoration: none; }
    .primary-btn:hover { transform: translateY(-4px); box-shadow: 0 15px 40px rgba(138, 90, 50, 0.3); }

    /* Wizard UI */
    .wizard-header { margin-bottom: 50px; }
    .stepper-wrap { position: relative; margin-bottom: 20px; padding: 0 10px; }
    .stepper-line { position: absolute; top: 50%; left: 0; width: 100%; height: 2px; background: rgba(0,0,0,0.05); transform: translateY(-50%); z-index: 1; }
    .stepper-progress { position: absolute; top: 0; left: 0; height: 100%; background: var(--wiz-accent); width: 0%; transition: width 0.5s ease; }
    .stepper-nodes { display: flex; justify-content: space-between; position: relative; z-index: 2; }
    .step-node { width: 12px; height: 12px; background: #fff; border: 2px solid rgba(0,0,0,0.1); border-radius: 50%; transition: 0.4s; }
    .step-node.active { border-color: var(--wiz-accent); background: var(--wiz-accent); transform: scale(1.4); }
    .step-node.done { border-color: var(--wiz-accent); background: var(--wiz-accent-light); }

    .step-info { display: flex; justify-content: space-between; align-items: baseline; }
    #step-label { font-size: 1.2rem; font-weight: 900; color: var(--wiz-accent); }
    #step-count { font-size: 0.8rem; font-weight: 800; color: var(--muted); }

    /* Quiz Body */
    .q-content h2 { font-size: 1.8rem; font-weight: 900; margin-bottom: 30px; line-height: 1.3; color: var(--wiz-text); }
    
    .choices-grid { display: grid; grid-template-columns: 1fr; gap: 15px; }
    .choice-item {
      display: flex; align-items: center; gap: 20px; padding: 25px;
      background: #fff; border-radius: 20px; border: 2px solid transparent;
      cursor: pointer; transition: 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }
    .choice-item:hover { border-color: var(--wiz-accent-light); transform: translateX(5px); }
    .choice-item.selected { border-color: var(--wiz-accent); background: #fdfaf7; box-shadow: 0 8px 25px rgba(138, 90, 50, 0.08); }
    .choice-icon { font-size: 2rem; width: 40px; text-align: center; }
    .choice-text b { display: block; font-size: 1.1rem; margin-bottom: 4px; color: var(--wiz-text); }
    .choice-text span { font-size: 0.85rem; color: var(--muted); line-height: 1.4; }

    .input-field { width: 100%; padding: 24px; border: 2px solid rgba(0,0,0,0.05); border-radius: 20px; font-size: 1.1rem; font-family: inherit; background: #fff; transition: 0.3s; }
    .input-field:focus { outline: none; border-color: var(--wiz-accent); box-shadow: 0 0 0 5px rgba(138, 90, 50, 0.1); }
    .textarea-field { min-height: 180px; resize: vertical; }

    .wizard-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 50px; }
    .text-btn { background: none; border: none; color: var(--muted); font-weight: 800; cursor: pointer; opacity: 0.6; transition: 0.3s; font-size: 1rem; }
    .text-btn:hover { opacity: 1; color: var(--wiz-accent); }
    .primary-btn-sm { padding: 16px 40px; background: var(--wiz-accent); color: #fff; border-radius: 999px; font-weight: 800; border: none; cursor: pointer; font-size: 1.1rem; transition: 0.3s; }
    .primary-btn-sm:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(138, 90, 50, 0.2); }

    /* Result Result */
    .result-container { display: grid; grid-template-columns: 1fr 380px; gap: 40px; }
    .doc-view { background: #fff; padding: 60px 40px; position: relative; border-radius: 12px; }
    .doc-ribbon { position: absolute; top: 20px; right: -10px; background: var(--wiz-accent); color: #fff; padding: 4px 20px; font-weight: 900; font-size: 0.75rem; letter-spacing: 0.2em; transform: rotate(5deg); box-shadow: 2px 2px 5px rgba(0,0,0,0.1); }
    .doc-header { border-bottom: 3px solid var(--wiz-text); padding-bottom: 20px; margin-bottom: 40px; }
    .doc-header h2 { font-size: 1.6rem; font-weight: 900; color: var(--wiz-text); margin-bottom: 5px; font-family: "Playfair Display", serif; }
    .doc-header p { font-size: 0.85rem; color: var(--muted); font-weight: 700; margin: 0; }
    
    .doc-body { display: grid; gap: 20px; }
    .doc-row { display: grid; grid-template-columns: 140px 1fr; gap: 20px; border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 12px; }
    .doc-row label { font-size: 0.8rem; font-weight: 900; color: var(--muted); text-transform: uppercase; }
    .doc-row span { font-size: 1rem; font-weight: 800; color: var(--wiz-text); }

    .doc-ai-box { margin-top: 40px; padding: 25px; background: #fdfaf7; border-radius: 16px; border: 1px solid var(--wiz-accent-light); }
    .ai-label { font-size: 0.9rem; font-weight: 900; color: var(--wiz-accent); margin-bottom: 10px; }
    .doc-ai-box p { font-size: 1rem; line-height: 1.7; color: var(--wiz-text); font-weight: 700; margin: 0; }

    .bonus-notice-box { padding: 30px; text-align: center; border: 2px dashed var(--wiz-accent); margin-bottom: 30px; }
    .bonus-tag { background: var(--wiz-accent); color: #fff; display: inline-block; padding: 4px 16px; border-radius: 999px; font-size: 0.75rem; font-weight: 900; margin-bottom: 15px; }
    .bonus-notice-box p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin-bottom: 20px; }
    .summary-code-block { background: #f8f8f8; padding: 15px; border-radius: 12px; font-family: monospace; font-size: 0.75rem; text-align: left; white-space: pre-wrap; color: #666; margin-bottom: 15px; max-height: 150px; overflow-y: auto; }
    .copy-btn { width: 100%; padding: 14px; background: var(--wiz-text); color: #fff; border: none; border-radius: 999px; font-weight: 800; cursor: pointer; transition: 0.3s; }
    .copy-btn:hover { background: #000; }

    .final-cta { display: flex; flex-direction: column; gap: 15px; }
    .retry-btn { background: none; border: none; color: var(--muted); text-decoration: underline; font-weight: 700; cursor: pointer; }

    @media (max-width: 850px) {
      .result-container { grid-template-columns: 1fr; }
      .doc-row { grid-template-columns: 1fr; gap: 5px; }
      .welcome-title { font-size: 2.4rem; }
      .wizard-card { padding: 40px 20px; }
    }
</style>

<script is:inline>
    const questions = [
      { id: 'industry', title: '1. 業種・ビジネス内容', type: 'text', placeholder: '例：心理カウンセラー、士業、店舗経営など' },
      { id: 'goal', title: '2. 制作の主な目的', type: 'choice', options: [
        { label: '問い合わせ・予約獲得', val: 'リード獲得', icon: '📈', desc: '新規顧客からのアクションを最大化します。' },
        { label: '信頼感・専門性の向上', val: 'ブランディング', icon: '💎', desc: '実績紹介や名刺代わりとしての質を重視。' },
        { label: '商品・サービスの直接販売', val: '直接販売', icon: '🛒', desc: 'LP上での決済や申し込み完了までを設計。' }
      ]},
      { id: 'current', title: '3. 現在のサイト状況', type: 'choice', options: [
        { label: '新規立ち上げ', val: '新規', icon: '🌱', desc: '新ドメインでゼロから構築します。' },
        { label: '既存のリニューアル', val: 'リニューアル', icon: '🔄', desc: '今の課題を解決し、価値を高めます。' },
        { label: 'LPのみ追加制作', val: 'LP追加', icon: '📑', desc: '既存サイトとは別に集客特化ページを作成。' }
      ]},
      { id: 'scale', title: '4. 制作規模のイメージ', type: 'choice', options: [
        { label: '1ページのLP', val: 'LP (1枚)', icon: '📄', desc: '縦に長い一枚完結の強力な訴求。' },
        { label: '小規模サイト(2〜5P)', val: '2-5ページ', icon: '📁', desc: '主要ページを網羅した基本セット。' },
        { label: '中規模サイト(6P〜)', val: '6ページ以上', icon: '🗂', desc: 'サービス数が多い、ブログを併用したい場合。' }
      ]},
      { id: 'taste', title: '5. 理想のデザインイメージ', type: 'choice', options: [
        { label: 'やさしい・安心感', val: 'ソフト', icon: '🌿', desc: 'カウンセリングや教育系に最適。' },
        { label: '誠実・プロフェッショナル', val: 'トラスト', icon: '🤝', desc: '士業やコンサルティング業に。' },
        { label: 'シンプル・ミニマル', val: 'ミニマル', icon: '⚪️', desc: '本質を伝え、迷わせないデザイン。' },
        { label: '高級感・モダン', val: 'プレミアム', icon: '✨', desc: '高単価サービスやブランド訴求に。' }
      ]},
      { id: 'deadline', title: '6. ご希望の納期', type: 'choice', options: [
        { label: 'できるだけ早く(特急)', val: '特急希望', icon: '🚀', desc: '1.5倍速での制作（要相談）。' },
        { label: '1ヶ月以内', val: '1ヶ月', icon: '📅', desc: '標準的なスピード。' },
        { label: '2ヶ月程度', val: '2ヶ月', icon: '🗓', desc: 'じっくり作り込みたい場合。' },
        { label: '特に決まっていない', val: '未定', icon: '⌛️', desc: '相談しながら進めたい。' }
      ]},
      { id: 'budget', title: '7. 制作予算の目安', type: 'choice', options: [
        { label: '〜10万円', val: '10万以下', icon: '🥉', desc: 'シンプルな1枚もの。' },
        { label: '10〜20万円', val: '10-20万', icon: '🥈', desc: '標準的なLP制作。' },
        { label: '20万円〜', val: '20万以上', icon: '🥇', desc: '構成・コピー含めフルオーダー。' },
        { label: '相談して決めたい', val: '相談', icon: '💬', desc: '必要な機能から算出。' }
      ]},
      { id: 'points', title: '8. 特に重視したい点', type: 'choice', multi: true, options: [
        { label: '問い合わせ導線', val: 'CV導線', icon: '🎯' },
        { label: '読みやすいコピー', val: 'ライティング', icon: '✒️' },
        { label: 'スマホの使いやすさ', val: 'モバイル最適化', icon: '📱' },
        { label: 'SEO（検索対策）', val: 'SEO', icon: '🔍' },
        { label: '独自システム(診断等)', val: 'システム', icon: '🛠' }
      ]},
      { id: 'message', title: '9. その他・メッセージ', type: 'textarea', placeholder: '例：原稿準備も手伝ってほしい、車いすユーザー視点の意見が欲しい、など' }
    ];

    let currentIdx = -1; // -1: welcome
    let answers = {};

    function showStep(idx) {
      const welcome = document.getElementById('step-welcome');
      const quiz = document.getElementById('step-quiz');
      const result = document.getElementById('step-result');

      // Transitions
      [welcome, quiz, result].forEach(s => s.classList.remove('active', 'fade-slide-in'));
      
      if (idx === -1) {
        welcome.classList.add('active', 'fade-slide-in');
      } else if (idx === questions.length) {
        renderResult();
        result.classList.add('active', 'fade-slide-in');
      } else {
        quiz.classList.add('active', 'fade-slide-in');
        renderQuestion(idx);
      }
      currentIdx = idx;
    }

    function renderQuestion(idx) {
      const q = questions[idx];
      const qContent = document.getElementById('q-content');
      const stepLabel = document.getElementById('step-label');
      const stepCount = document.getElementById('step-count');
      const progress = document.getElementById('stepper-progress');
      const nodes = document.getElementById('stepper-nodes');

      stepLabel.textContent = `Step ${idx + 1}`;
      stepCount.textContent = `${idx + 1} / ${questions.length}`;
      progress.style.width = `${(idx / (questions.length - 1)) * 100}%`;

      // Stepper nodes
      nodes.innerHTML = questions.map((_, i) => `
        <div class="step-node ${i === idx ? 'active' : i < idx ? 'done' : ''}"></div>
      `).join('');

      let html = `<h2>${q.title}</h2>`;
      if (q.type === 'text') {
        html += `<input type="text" class="input-field" placeholder="${q.placeholder}" value="${answers[q.id] || ''}" id="input-${q.id}">`;
      } else if (q.type === 'textarea') {
        html += `<textarea class="input-field textarea-field" placeholder="${q.placeholder}" id="input-${q.id}">${answers[q.id] || ''}</textarea>`;
      } else if (q.type === 'choice') {
        html += `<div class="choices-grid">`;
        q.options.forEach(opt => {
          const isSelected = q.multi ? (answers[q.id] || []).includes(opt.val) : answers[q.id] === opt.val;
          html += `
            <div class="choice-item ${isSelected ? 'selected' : ''}" onclick="selectChoice('${q.id}', '${opt.val}', ${q.multi || false})">
              <div class="choice-icon">${opt.icon}</div>
              <div class="choice-text">
                <b>${opt.label}</b>
                ${opt.desc ? `<span>${opt.desc}</span>` : ''}
              </div>
            </div>
          `;
        });
        html += `</div>`;
      }
      qContent.innerHTML = html;

      document.getElementById('backBtn').style.visibility = idx >= 0 ? 'visible' : 'hidden';
      document.getElementById('nextBtn').textContent = idx === questions.length - 1 ? 'サマリーを生成する' : '次へ進む →';
    }

    window.selectChoice = (id, val, multi) => {
      if (multi) {
        if (!answers[id]) answers[id] = [];
        const idx = answers[id].indexOf(val);
        if (idx > -1) answers[id].splice(idx, 1);
        else answers[id].push(val);
      } else {
        answers[id] = val;
        // Auto next for single choices if it's not the last step
        if (currentIdx < questions.length - 1) {
           setTimeout(() => { document.getElementById('nextBtn').click(); }, 300);
        }
      }
      renderQuestion(currentIdx);
    };

    function renderResult() {
      const grid = document.getElementById('summaryGrid');
      const recText = document.getElementById('recommendText');
      const copyArea = document.getElementById('copyArea');

      const data = {
        '業種': answers.industry || '—',
        '主要目的': answers.goal || '—',
        '現状': answers.current || '—',
        '規模感': answers.scale || '—',
        'デザイン': answers.taste || '—',
        '納期': answers.deadline || '—',
        '予算': answers.budget || '—',
        '重視ポイント': (answers.points || []).join('、') || '—',
        '備考': answers.message || '—'
      };

      grid.innerHTML = Object.entries(data).map(([k, v]) => `
        <div class="doc-row"><label>${k}</label><span>${v}</span></div>
      `).join('');

      let rec = "まずは、心理導線LP制作から始めて、最も重要な「問い合わせ導線」を固めるのが良さそうです。";
      if(answers.scale === '6ページ以上') rec = "複数ページにわたる心理導線ホームページ制作が適しています。各ページから最終的なゴールへの導線を統合的に設計しましょう。";
      if((answers.points || []).includes('システム')) rec = "Web制作に加え、LINE Mini Appや外部診断システムとの連携を視野に入れた「ICT活用プラン」をご提案します。";

      recText.textContent = rec;
      
      const copyStr = `【制作要件ヒアリングサマリー】\n業種：${data['業種']}\n目的：${data['主要目的']}\n現状：${data['現状']}\n規模：${data['規模感']}\nデザイン：${data['デザイン']}\n納期：${data['納期']}\n予算：${data['予算']}\n重視：${data['重視ポイント']}\n備考：${data['備考']}\n\n【初期提案】\n${rec}`;
      copyArea.textContent = copyStr;
    }

    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('startBtn').addEventListener('click', () => showStep(0));
      document.getElementById('nextBtn').addEventListener('click', () => {
        // Save text values before moving
        const q = questions[currentIdx];
        if (q.type === 'text' || q.type === 'textarea') {
          answers[q.id] = document.getElementById(`input-${q.id}`).value;
        }
        showStep(currentIdx + 1);
      });
      document.getElementById('backBtn').addEventListener('click', () => {
        if (currentIdx === 0) showStep(-1);
        else showStep(currentIdx - 1);
      });
      document.getElementById('retryBtn').addEventListener('click', () => location.reload());

      document.getElementById('btnCopy').addEventListener('click', async () => {
        await navigator.clipboard.writeText(document.getElementById('copyArea').textContent);
        document.getElementById('btnCopy').textContent = 'コピーしました！';
        setTimeout(() => { document.getElementById('btnCopy').textContent = 'サマリーをコピーする'; }, 2000);
      });

      // Keyboard support
      document.addEventListener('keydown', (e) => {
        if (currentIdx >= 0 && currentIdx < questions.length) {
          if (e.key === 'Enter' && e.ctrlKey) document.getElementById('nextBtn').click();
          if (e.key === 'ArrowRight' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') document.getElementById('nextBtn').click();
          if (e.key === 'ArrowLeft' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') document.getElementById('backBtn').click();
        }
      });
    });
</script>
