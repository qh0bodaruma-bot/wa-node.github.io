---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="心理導線Web制作 要件ヒアリング｜和-Node" description="LP・ホームページ制作の要件を整理できるヒアリング体験。目的・予算・重視ポイントから、和-Nodeへの相談用サマリーを自動生成します。">
  <main>
    <section class="hero">
      <div class="wrap">
        <span class="eyebrow">Requirements Interview</span>
        <h1>Web制作要件ヒアリング</h1>
        <p class="lead">
          「どんなサイトにしたいか」を整理するためのステップです。<br />
          回答後に相談用サマリーを自動生成します。
        </p>
      </div>
    </section>

    <div class="wrap">
      <div class="wizard-container">
        <div class="stepper" id="stepper">
          <!-- JS dynamic -->
        </div>

        <form id="wizardForm">
          <div class="question-block active" data-step="1">
            <h2>1. 業種・ビジネスを教えてください</h2>
            <input type="text" name="industry" class="input-text" placeholder="例：個人カウンセラー、カフェ、整体院など" />
          </div>

          <div class="question-block" data-step="2">
            <h2>2. 制作の主な目的は何ですか？</h2>
            <div class="choices">
              <label class="choice-card"><input type="radio" name="goal" value="問い合わせ・予約を増やしたい" />
                <div class="choice-text"><strong>問い合わせ・予約の獲得</strong><span>新規のお客様からのアクションを重視します。</span></div>
              </label>
              <label class="choice-card"><input type="radio" name="goal" value="信頼感・専門性を伝えたい" />
                <div class="choice-text"><strong>信頼感の構築</strong><span>名刺代わりや、実績紹介としての役割を重視します。</span></div>
              </label>
              <label class="choice-card"><input type="radio" name="goal" value="商品・サービスを直接販売したい" />
                <div class="choice-text"><strong>直接販売・決済</strong><span>LPから購入や申し込みまで繋げたい場合に。</span></div>
              </label>
            </div>
          </div>

          <div class="question-block" data-step="3">
            <h2>3. 現在のサイト状況は？</h2>
            <div class="choices">
              <label class="choice-card"><input type="radio" name="current" value="新規立ち上げ" />
                <div class="choice-text"><strong>新規立ち上げ</strong><span>新しくドメインを取得して作成します。</span></div>
              </label>
              <label class="choice-card"><input type="radio" name="current" value="既存サイトのリニューアル" />
                <div class="choice-text"><strong>リニューアル</strong><span>今のサイトの課題を解決したい場合に。</span></div>
              </label>
              <label class="choice-card"><input type="radio" name="current" value="LPのみ追加" />
                <div class="choice-text"><strong>LPのみ追加</strong><span>既存サイトはそのまま、特定の集客ページを作りたい。</span></div>
              </label>
            </div>
          </div>

          <div class="question-block" data-step="4">
            <h2>4. 制作するページ規模のイメージ</h2>
            <div class="choices">
              <label class="choice-card"><input type="radio" name="scale" value="1ページのLP" />
                <div class="choice-text"><strong>1ページのLP</strong><span>縦に長い1枚のページ。訴求力重視。</span></div>
              </label>
              <label class="choice-card"><input type="radio" name="scale" value="2〜5ページ程度" />
                <div class="choice-text"><strong>小規模サイト（2〜5ページ）</strong><span>トップ、サービス、料金、プロフィール、問い合わせ。</span></div>
              </label>
              <label class="choice-card"><input type="radio" name="scale" value="6ページ以上" />
                <div class="choice-text"><strong>中規模以上（6ページ〜）</strong><span>事業内容が多い、実績を細かく載せたい場合など。</span></div>
              </label>
            </div>
          </div>

          <div class="question-block" data-step="5">
            <h2>5. 理想のデザインイメージは？</h2>
            <div class="choices">
              <label class="choice-card"><input type="radio" name="taste" value="やさしい・安心感" /><strong>やさしい・安心感</strong></label>
              <label class="choice-card"><input type="radio" name="taste" value="誠実・プロフェッショナル" /><strong>誠実・プロフェッショナル</strong></label>
              <label class="choice-card"><input type="radio" name="taste" value="シンプル・ミニマル" /><strong>シンプル・ミニマル</strong></label>
              <label class="choice-card"><input type="radio" name="taste" value="高級感・モダン" /><strong>高級感・モダン</strong></label>
            </div>
          </div>

          <div class="question-block" data-step="6">
            <h2>6. ご希望の納期目安</h2>
            <div class="choices">
              <label class="choice-card"><input type="radio" name="deadline" value="できるだけ早く（特急希望）" /><strong>できるだけ早く</strong></label>
              <label class="choice-card"><input type="radio" name="deadline" value="1ヶ月以内" /><strong>1ヶ月以内</strong></label>
              <label class="choice-card"><input type="radio" name="deadline" value="2ヶ月程度" /><strong>2ヶ月程度</strong></label>
              <label class="choice-card"><input type="radio" name="deadline" value="特に決まっていない" /><strong>特に決まっていない</strong></label>
            </div>
          </div>

          <div class="question-block" data-step="7">
            <h2>7. 制作予算の目安</h2>
            <div class="choices">
              <label class="choice-card"><input type="radio" name="budget" value="〜10万円" /><strong>〜10万円</strong></label>
              <label class="choice-card"><input type="radio" name="budget" value="10〜20万円" /><strong>10〜20万円</strong></label>
              <label class="choice-card"><input type="radio" name="budget" value="20万円〜" /><strong>20万円〜</strong></label>
              <label class="choice-card"><input type="radio" name="budget" value="相談して決めたい" /><strong>相談して決めたい</strong></label>
            </div>
          </div>

          <div class="question-block" data-step="8">
            <h2>8. 重視したいポイント（複数可）</h2>
            <div class="choices">
              <label class="choice-card"><input type="checkbox" name="points" value="問い合わせ導線" /><strong>問い合わせ導線</strong></label>
              <label class="choice-card"><input type="checkbox" name="points" value="読みやすい文章・コピー" /><strong>読みやすい文章・コピー</strong></label>
              <label class="choice-card"><input type="checkbox" name="points" value="スマホでの使いやすさ" /><strong>スマホでの使いやすさ</strong></label>
              <label class="choice-card"><input type="checkbox" name="points" value="SEO（検索対策）" /><strong>SEO（検索対策）</strong></label>
              <label class="choice-card"><input type="checkbox" name="points" value="予約・診断機能などのシステム" /><strong>システム連携（予約・診断）</strong></label>
            </div>
          </div>

          <div class="question-block" data-step="9">
            <h2>9. その他、気になる点やメッセージ</h2>
            <textarea name="message" class="textarea" placeholder="例：原稿の準備が不安です。車いすユーザー視点でのアドバイスも欲しいです。"></textarea>
          </div>

          <div class="actions">
            <button type="button" class="btn btn-prev" id="btnPrev">← 戻る</button>
            <button type="button" class="btn btn-next" id="btnNext">次へ進む →</button>
            <button type="submit" class="btn btn-next" id="btnSubmit" style="display:none">ヒアリングを完了する</button>
          </div>
        </form>

        <div class="summary-wrap" id="summaryWrap">
          <div class="result-doc">
            <div class="doc-header">
              <h3>Web Production Strategy Summary</h3>
            </div>
            <div class="data-grid" id="summaryGrid">
              <!-- JS Dynamic -->
            </div>
            <div class="recommend-box">
              <h4>🎯 和-Nodeからの初期提案</h4>
              <p id="recommendText"></p>
            </div>

            <div class="bonus-notice">
              <div class="bonus-badge">🎁 ヒアリング完了特典</div>
              <p>
                このサマリーをコピーして公式LINEにお送りいただくか、お問い合わせ時に合言葉 <strong>「わのーど診断」</strong> とお伝えください。<br />
                <strong>初回無料カウンセリングを30分延長（計60分無料）</strong> させていただきます。
              </p>
            </div>

            <div class="copy-area" id="copyArea"></div>
            <div class="actions">
              <button class="btn btn-next" id="btnCopy">サマリーをコピーする</button>
              <a class="btn btn-prev" href="https://docs.google.com/forms/d/e/1FAIpQLScUbeK9em6cjegU5ha5Sh2fWamrIbxDuhmHDJPIN_no5Sj8-w/viewform?usp=publish-editor" target="_blank">問い合わせフォームへ</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
    .wrap { max-width: 900px; margin: 0 auto; padding: 0 20px; }
    .hero { padding: 50px 0 30px; text-align: center; }
    .eyebrow {
      display: inline-block; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--accent); font-size: 0.82rem; font-weight: 800; background: var(--accent-soft);
      padding: 4px 12px; border-radius: 999px; margin-bottom: 16px;
    }
    .hero h1 { font-size: clamp(1.8rem, 4vw, 3rem); line-height: 1.2; margin: 0 0 16px; font-weight: 800; }
    .lead { font-size: 1rem; color: var(--muted); max-width: 700px; margin: 0 auto; }

    .wizard-container {
      background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius);
      padding: 40px; box-shadow: var(--shadow); margin-bottom: 80px; min-height: 500px; position: relative;
    }

    .stepper { display: flex; justify-content: space-between; margin-bottom: 40px; position: relative; }
    .stepper::before { content: ""; position: absolute; top: 15px; left: 0; right: 0; height: 2px; background: var(--line); z-index: 1; }
    
    .question-block { display: none; animation: fadeIn .4s ease; }
    .question-block.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .question-block h2 { font-size: 1.6rem; margin-bottom: 24px; line-height: 1.3; font-weight: 800; }

    .choices { display: grid; gap: 14px; }
    .choice-card {
      display: flex; align-items: flex-start; gap: 14px; padding: 18px;
      border: 1px solid var(--line); border-radius: 18px; background: var(--white); cursor: pointer; transition: 0.2s;
    }
    .choice-card:hover { border-color: var(--accent); background: var(--accent-soft); }
    .choice-card input { margin-top: 6px; accent-color: var(--accent); }
    .choice-text strong { display: block; font-size: 1.05rem; margin-bottom: 4px; }
    .choice-text span { display: block; font-size: 0.88rem; color: var(--muted); }

    .input-text, .textarea {
      width: 100%; padding: 16px; border: 1px solid var(--line); border-radius: 16px; font-size: 1rem; font-family: inherit; transition: 0.2s;
    }
    .input-text:focus, .textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-soft); }
    .textarea { min-height: 150px; resize: vertical; }

    .actions { display: flex; justify-content: space-between; margin-top: 40px; gap: 16px; }
    .btn {
      display: inline-flex; align-items: center; justify-content: center; padding: 14px 28px;
      border-radius: 999px; font-weight: 800; cursor: pointer; transition: 0.3s; border: none; font-size: 1rem;
    }
    .btn-prev { background: transparent; color: var(--accent); border: 1px solid var(--accent); }
    .btn-prev:hover { background: var(--accent-soft); }
    .btn-next { background: var(--accent); color: var(--white); flex: 1; }
    .btn-next:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(138, 90, 50, 0.3); }

    .summary-wrap { display: none; margin-top: 40px; }
    .summary-wrap.show { display: block; animation: fadeIn .6s ease; }
    .result-doc {
      background: #fff; border: 2px solid var(--line); border-radius: 20px; padding: 40px;
      position: relative; box-shadow: 0 30px 80px rgba(0,0,0,0.05);
    }
    .doc-header { border-bottom: 2px solid var(--text); padding-bottom: 16px; margin-bottom: 30px; }
    .doc-header h3 { margin: 0; font-size: 1.4rem; letter-spacing: 0.05em; font-weight: 800; }
    
    .data-grid { display: grid; gap: 16px; margin-bottom: 30px; }
    .data-row { display: grid; grid-template-columns: 180px 1fr; gap: 20px; border-bottom: 1px solid var(--line); padding-bottom: 8px; }
    .data-row b { font-size: 0.9rem; color: var(--muted); }
    .data-row span { font-weight: 700; color: var(--text); }

    .recommend-box { background: var(--accent-soft); border-left: 4px solid var(--accent); padding: 20px; border-radius: 0 12px 12px 0; margin-bottom: 30px; }
    .recommend-box h4 { margin: 0 0 8px; color: var(--accent); font-weight: 800; }

    .copy-area {
      width: 100%; background: #fdfaf7; border: 1px dashed var(--accent); border-radius: 12px;
      padding: 16px; font-family: monospace; font-size: 0.85rem; margin-bottom: 24px; color: var(--muted); white-space: pre-wrap;
    }

    .bonus-notice {
      background: #fff;
      border: 2px dashed var(--accent);
      border-radius: 16px;
      padding: 24px;
      margin: 24px 0 32px;
      text-align: center;
      position: relative;
    }
    .bonus-badge {
      position: absolute;
      top: -12px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--accent);
      color: #fff;
      padding: 4px 16px;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 800;
    }
    .bonus-notice p { margin: 0; font-size: 0.95rem; line-height: 1.6; color: var(--text); }
    .bonus-notice strong { color: var(--accent); }

    @media (max-width: 600px) {
      .wizard-container { padding: 24px; }
      .data-row { grid-template-columns: 1fr; gap: 4px; }
      .actions { flex-direction: column; }
    }
</style>

<script is:inline>
    let step = 1;
    const maxStep = 9;
    
    function initStepper() {
      const stepper = document.getElementById('stepper');
      if (!stepper) return;
      stepper.innerHTML = Array.from({length: maxStep}, (_, i) => `
        <div class="step-node" data-s="${i+1}" style="position:relative; z-index:2; width:32px; height:32px; background:#fff; border:2px solid var(--line); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.8rem; font-weight:800; color:var(--muted); transition:0.3s;">${i+1}</div>
      `).join('');
    }

    function updateUI() {
      const blocks = document.querySelectorAll('.question-block');
      const btnNext = document.getElementById('btnNext');
      const btnPrev = document.getElementById('btnPrev');
      const btnSubmit = document.getElementById('btnSubmit');

      blocks.forEach(b => b.classList.toggle('active', +b.dataset.step === step));
      document.querySelectorAll('.step-node').forEach(node => {
        const s = +node.dataset.s;
        if (s === step) {
            node.style.borderColor = 'var(--accent)';
            node.style.background = 'var(--accent)';
            node.style.color = '#fff';
            node.style.transform = 'scale(1.2)';
        } else if (s < step) {
            node.style.borderColor = 'var(--accent)';
            node.style.background = 'var(--accent-soft)';
            node.style.color = 'var(--accent)';
            node.style.transform = 'scale(1)';
        } else {
            node.style.borderColor = 'var(--line)';
            node.style.background = '#fff';
            node.style.color = 'var(--muted)';
            node.style.transform = 'scale(1)';
        }
      });
      if (btnPrev) btnPrev.style.visibility = step === 1 ? 'hidden' : 'visible';
      if (btnNext) btnNext.style.display = step === maxStep ? 'none' : 'inline-flex';
      if (btnSubmit) btnSubmit.style.display = step === maxStep ? 'inline-flex' : 'none';
      window.scrollTo({top: 200, behavior: 'smooth'});
    }

    document.addEventListener('DOMContentLoaded', () => {
        initStepper();
        updateUI();

        const btnNext = document.getElementById('btnNext');
        const btnPrev = document.getElementById('btnPrev');
        const form = document.getElementById('wizardForm');

        if (btnNext) btnNext.onclick = () => { if(step < maxStep) { step++; updateUI(); } };
        if (btnPrev) btnPrev.onclick = () => { if(step > 1) { step--; updateUI(); } };

        if (form) {
            form.onsubmit = (e) => {
                e.preventDefault();
                const getVal = (name) => {
                    const el = form.querySelector(`[name="${name}"]:checked`) || form.querySelector(`[name="${name}"]`);
                    return el ? el.value || '—' : '—';
                };
                const getChecks = (name) => {
                    return [...form.querySelectorAll(`[name="${name}"]:checked`)].map(e => e.value).join('、') || '—';
                };

                const data = {
                    industry: getVal('industry'),
                    goal: getVal('goal'),
                    current: getVal('current'),
                    scale: getVal('scale'),
                    taste: getVal('taste'),
                    deadline: getVal('deadline'),
                    budget: getVal('budget'),
                    points: getChecks('points'),
                    message: getVal('message')
                };

                let rec = "まずは、心理導線LP制作から始めて、最も重要な「問い合わせ導線」を固めるのが良さそうです。";
                if(data.scale.includes('6ページ')) rec = "複数ページにわたる心理導線ホームページ制作が適しています。各ページから最終的なゴールへの導線を統合的に設計しましょう。";
                if(data.points.includes('システム')) rec = "Web制作に加え、LINE Mini Appや外部予約システムとの連携を視野に入れた設計をご提案します。";

                document.getElementById('summaryGrid').innerHTML = Object.entries({
                    '業種・ビジネス': data.industry,
                    '目的': data.goal,
                    '現状': data.current,
                    '規模': data.scale,
                    'デザイン': data.taste,
                    '納期': data.deadline,
                    '予算': data.budget,
                    '重視点': data.points,
                    'メッセージ': data.message
                }).map(([k, v]) => `
                    <div class="data-row"><b>${k}</b><span>${v}</span></div>
                `).join('');

                document.getElementById('recommendText').textContent = rec;
                
                const copyStr = `【Web制作ヒアリングサマリー】\n業種：${data.industry}\n目的：${data.goal}\n現状：${data.current}\n規模：${data.scale}\nデザイン：${data.taste}\n納期：${data.deadline}\n予算：${data.budget}\n重視：${data.points}\n備考：${data.message}\n\n提案：${rec}`;
                document.getElementById('copyArea').textContent = copyStr;

                form.style.display = 'none';
                document.getElementById('stepper').style.display = 'none';
                document.getElementById('summaryWrap').classList.add('show');
            };
        }

        const btnCopy = document.getElementById('btnCopy');
        if (btnCopy) {
            btnCopy.onclick = async () => {
                await navigator.clipboard.writeText(document.getElementById('copyArea').textContent);
                btnCopy.textContent = 'コピー完了！';
            };
        }
    });
</script>
