    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function playPlanMotion(content) {
      if (!content || reduceMotion) return;
      const cards = content.querySelectorAll('.recommended-price-card');
      cards.forEach((card, index) => {
        card.style.setProperty('--motion-order', index);
        card.classList.remove('plan-card-enter');
        void card.offsetWidth;
        card.classList.add('plan-card-enter');
      });
    }

    tabButtons.forEach(button => {
      if (button.dataset.planTabBound === 'true') return;
      button.dataset.planTabBound = 'true';

      button.addEventListener('click', () => {
        const targetTab = button.getAttribute('data-plan-tab');

        // Deactivate all buttons
        tabButtons.forEach(btn => {
          btn.classList.remove('active');
          btn.setAttribute('aria-selected', 'false');
        });

        // Hide all contents
        planContents.forEach(content => {
          content.classList.remove('active-plan');
        });

        // Activate selected button & content
        button.classList.add('active');
        button.setAttribute('aria-selected', 'true');
        
        const targetContent = document.getElementById(`plan-content-${targetTab}`);
        if (targetContent) {
          targetContent.classList.add('active-plan');
          playPlanMotion(targetContent);
        }
      });
    });

    playPlanMotion(document.querySelector('.plan-content.active-plan'));
  }

  // Support page transition in Astro (swup/barba/native)
  document.addEventListener('astro:page-load', initPlanTabs);
  document.addEventListener('DOMContentLoaded', initPlanTabs);
  initPlanTabs();
</script>

