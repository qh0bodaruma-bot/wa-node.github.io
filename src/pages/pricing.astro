---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConsultationFlow from '../components/ConsultationFlow.astro';
import ProjectExecutionFlow from '../components/ProjectExecutionFlow.astro';
import MaterialIcon from '../components/MaterialIcon.astro';
import {
  createBreadcrumbSchema,
  createFAQSchema,
  createServiceSchema,
  createWebPageSchema,
  organizationSchema,
} from '../data/structuredData';

const title = "料金プラン・制作費用｜心理学を応用したWeb制作と「ビジネスの副操縦士」（戦略的パートナー）｜和-Node";
const description = "和-Nodeの料金プラン。行動心理に基づくWeb制作・導線設計（LP・HP）、ビジネスの副操縦士（月額制戦略的パートナー）コンサルティング、および組織支援の費用をご案内します。";
const image = "/images/ogp-pricing.png";
const structuredData = [
  organizationSchema,
  createWebPageSchema({ name: title, description, path: "/pricing/" }),
  createBreadcrumbSchema([
    { name: "ホーム", path: "/" },
    { name: "料金プラン・制作費用", path: "/pricing/" },
  ]),
  createServiceSchema({
    name: "行動心理に基づくWeb制作・LP制作",
    description:
      "心理学の知見を活かし、信頼形成、相談ボタン、フォーム、公開後の改善まで含めてWebサイトとLPを設計します。",
    path: "/pricing/#web-production",
    serviceType: "Web design and landing page production",
    priceFrom: "64000",
  }),
  createServiceSchema({
    name: "LP改善入口診断",
    description:
      "既存LPを対象に、ファーストビュー、相談ボタン、料金表、フォーム前の不安、スマホ表示、AI検索で拾われる構造を確認し、改善優先度を整理します。",
    path: "/pricing/#lp-diagnosis",
    serviceType: "Landing page improvement audit",
    priceFrom: "15000",
  }),
  createServiceSchema({
    name: "ビジネスの副操縦士（月額制戦略的パートナー）",
    description:
      "Web改善、AI・ICT活用、業務整理を月額で相談できる継続支援です。",
    path: "/pricing/#copilot",
    serviceType: "ICT consulting and business support",
    priceFrom: "15000",
  }),
  createFAQSchema([
    {
      question: "相談だけで終わっても大丈夫ですか？",
      answer: "大丈夫です。状況整理だけで十分な場合は、無理に制作や月額契約をおすすめしません。",
    },
    {
      question: "まだ何を頼むか決まっていなくても相談できますか？",
      answer:
        "はい。Web制作、LP制作、AI・ICT活用、公開後の改善のうち、今どこから始めるべきか一緒に整理します。",
    },
    {
      question: "15,000円でLPを作ってもらえますか？",
      answer:
        "15,000円は新規LP制作ではなく、既存LPを対象にした改善診断の入口価格です。新規LP制作はシンプルLP制作24,000円〜、選ばれる導線LP制作64,000円〜が目安です。",
    },
    {
      question: "LP改善診断では何がわかりますか？",
      answer:
        "ファーストビュー、相談ボタン、料金表、フォーム前の不安、スマホでの読みやすさ、AI検索で拾われる構造を確認し、優先して直すべき点を整理します。",
    },
    {
      question: "相談後に契約を迫られることはありますか？",
      answer: "ありません。必要な範囲・費用・進め方を確認し、ご納得いただいた場合のみ正式に開始します。",
    },
    {
      question: "不安を煽る表現や、強く誘導する導線も作れますか？",
      answer:
        "和-Nodeでは、いわゆるダーク心理学や、恐怖・断りにくさを利用して行動を迫る設計は行いません。一方で、見落としがちなリスクや機会損失は誠実に可視化し、訪問者が安心して比較・相談・判断できる導線を設計します。",
    },
  ]),
];
---

<BaseLayout title={title} description={description} image={image} structuredData={structuredData}>
  <main class="pricing-container" data-glossary-skip>
    <section class="hero">
      <div class="hero-inner">
        <p class="eyebrow">Pricing</p>
        <h1 class="premium-heading">料金プラン・制作費用</h1>
        <p class="lead">ホームページ制作、LP制作・改善、戦略的パートナー契約（ビジネスの副操縦士）の料金目安です。ご予算に合わせた柔軟な提案も可能です。</p>
        <p class="note">和-Nodeでは、心理学の知見を「不安を煽るため」ではなく、「安心して選べる導線をつくるため」に活用します。正式な制作・月額支援は、内容・範囲・追加作業の有無を確認し、費用にご納得いただいた後に開始します。</p>

        <div class="premium-ann-banner reveal">
          <div class="banner-inner">
            <span class="banner-badge">1st ANNIVERSARY</span>
            <div class="banner-main">
              <strong>制作メニュー・オプション 20% OFF 実施中</strong>
              <p>毎月3名様限定。丁寧な導線設計を、今だけの感謝価格で。 <span class="period">2026.7.31まで</span></p>
            </div>
            <a href="/campaign-anniversary/" class="banner-link">特設ページへ →</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section choice-guide">
      <p class="eyebrow">Start Here</p>
      <h2 class="premium-heading">迷ったら、まずは4つからお選びください</h2>
      <p class="choice-lead">細かなメニューを先に選ぶ必要はありません。今の目的に近い入口からご相談いただければ、最適なプランに整理します。</p>
      <div class="choice-grid">
        <a class="choice-card primary-choice card-border-gold" href="#web-production">
          <span class="choice-label">一番人気</span>
          <h3><span class="card-icon-window window-gold"><MaterialIcon name="language" /></span>ホームページを作りたい</h3>
          <p class="choice-fit">まず信頼されるサイトを作りたい方へ</p>
          <p>会社概要、サービス、料金、相談の流れなど、初見で信頼される事業の土台を整えます。</p>
          <strong>HP制作 40,000円〜</strong>
        </a>
        <a class="choice-card card-border-green" href="#lp-diagnosis">
          <span class="choice-label">診断入口</span>
          <h3><span class="card-icon-window window-green"><MaterialIcon name="monitoring" /></span>今あるLPを改善したい</h3>
          <p class="choice-fit">まず原因を見つけたい方へ</p>
          <p>15,000円〜は新規制作ではなく、既存LPの迷いどころを確認して改善優先度を出す入口です。</p>
          <strong>LP診断 15,000円〜</strong>
        </a>
        <a class="choice-card card-border-blue" href="#copilot">
          <span class="choice-label">継続改善</span>
          <h3><span class="card-icon-window window-blue"><MaterialIcon name="explore" /></span>作った後も相談したい</h3>
          <p class="choice-fit">公開後も改善や判断を相談したい方へ</p>
          <p>Web改善、AI活用、業務整理を月額で伴走する「ビジネスの副操縦士」です。</p>
          <strong>月額 15,000円〜</strong>
        </a>
        <a class="choice-card card-border-red" href="#ict-ai">
          <span class="choice-label">単発相談</span>
          <h3><span class="card-icon-window window-red"><MaterialIcon name="tips_and_updates" /></span>AI・ICTで業務を整えたい</h3>
          <p class="choice-fit">業務整理やAI活用から始めたい方へ</p>
          <p>ChatGPT、LINE、業務ツール、簡単な自動化などをスポットで整理します。</p>
          <strong>5,000円〜</strong>
        </a>
      </div>
      <p class="choice-footnote">迷った場合は「ホームページを作りたい」または「今あるLPを改善したい」からで大丈夫です。新規LP制作は、下のLP制作タブから選べます。</p>
      <div class="decision-guide" aria-label="目的別のおすすめ">
        <h3>目的別のおすすめ</h3>
        <div class="decision-grid">
          <a href="#lp-diagnosis">
            <span>LPの反応が鈍い理由を知りたい</span>
            <strong>LP改善入口診断</strong>
          </a>
          <a href="#web-production">
            <span>事業の土台を整えたい</span>
            <strong>選ばれる導線HP制作</strong>
          </a>
          <a href="#copilot">
            <span>公開後も改善したい</span>
            <strong>ビジネスの副操縦士</strong>
          </a>
        </div>
      </div>
    </section>

    <section class="section lp-diagnosis-section" id="lp-diagnosis">
      <p class="eyebrow">Entry Diagnosis</p>
      <h2 class="premium-heading">15,000円のLP改善診断で行うこと</h2>
      <p class="lp-diagnosis-lead">
        この15,000円〜は、LPを丸ごと新規制作する料金ではありません。すでにあるLPを前提に、
        「どこで迷いが生まれているか」「先に直すべき場所はどこか」を短時間で切り分ける入口価格です。
      </p>

      <div class="lp-diagnosis-grid">
        <article>
          <span>01</span>
          <h3>既存LPを前提にする</h3>
          <p>ゼロから構成・デザイン・実装を作るのではなく、今あるページのファーストビュー、相談ボタン、料金表、フォーム前の不安を確認します。</p>
        </article>
        <article>
          <span>02</span>
          <h3>見る場所を絞る</h3>
          <p>色彩、読みやすさ、スマホ表示、AI検索で拾われる見出しやFAQなど、問い合わせ前の迷いに関わる部分へ絞って確認します。</p>
        </article>
        <article>
          <span>03</span>
          <h3>成果物を軽くする</h3>
          <p>詳細なデザインカンプや実装ではなく、優先順位つきの改善メモ、すぐ直せる文言案、次の見積り判断材料にまとめます。</p>
        </article>
      </div>

      <div class="lp-diagnosis-price-box">
        <div class="lp-diagnosis-price-copy">
          <h3>価格が抑えられる理由</h3>
          <p>
            新規LP制作で発生する原稿整理、構成案、デザイン、コーディング、公開作業を含めず、
            原因の切り分けと優先順位づけに集中するため、15,000円〜で始められます。
          </p>
        </div>
        <div class="table-wrap mini lp-diagnosis-table">
          <table>
            <thead>
              <tr><th>メニュー</th><th>料金</th><th>主な内容</th></tr>
            </thead>
            <tbody>
              <tr><td>LP改善入口診断</td><td>15,000円〜</td><td>既存LPの主要導線を確認し、改善優先度メモを作成</td></tr>
              <tr><td>詳細導線診断</td><td>30,000円〜</td><td>競合・構成・CTA・料金表・フォームまで広げて確認</td></tr>
              <tr><td>改善設計パック</td><td>50,000円〜</td><td>改善ラフ、文言案、実装範囲、次回見積り前提まで整理</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="lp-diagnosis-boundary" aria-label="含まれるものと含まれないもの">
        <div>
          <strong>含まれるもの</strong>
          <p>現状LPの確認、改善優先度、文言・導線の方向性、制作へ進むかどうかの判断材料。</p>
        </div>
        <div>
          <strong>含まれないもの</strong>
          <p>新規LP制作、詳細デザインカンプ、コーディング、広告運用、問い合わせ数や順位の保証。</p>
        </div>
      </div>
    </section>

    <section class="section" id="web-production">
      <p class="eyebrow">01. Web & Lead Design</p>
      <h2 class="premium-heading">行動心理に基づくWeb制作・LP制作</h2>
      <p>「伝わらない」を減らし、相談につながりやすい情報設計へ。行動心理の視点を取り入れたWebサイトを制作します。</p>
      <div class="campaign-notice-box">
        <strong>【起業記念キャンペーン】制作費 20% OFF！</strong>
        <p>以下の通常価格より20%割引いたします（毎月3名様限定）。</p>
      </div>

      <!-- アンカリング効果（市場相場との比較） -->
      <div class="market-anchoring-box">
        <h3 class="anchoring-title">Webサイト制作の参考価格帯と和-Nodeの価格</h3>
        <p class="anchoring-intro">Web制作を依頼する際、「なぜこんなに安いの？」「品質は大丈夫？」と不安に思われるかもしれません。一般的な制作会社へ依頼する場合の参考価格帯と比べながら、和-Nodeが適正価格で丁寧に制作できる理由をご説明します。</p>
        
        <div class="anchoring-table-wrap">
          <div class="anchoring-row header">
            <div>制作タイプ</div>
            <div>一般的な制作会社の参考価格帯</div>
            <div>和-Node（キャンペーン価格）</div>
          </div>
          <div class="anchoring-row">
            <div class="type-name">シンプルHP制作</div>
            <div class="market-price">初期 30万〜50万円<br><span class="sub">保守：月額 1万〜3万円</span></div>
            <div class="wa-price">初期 40,000円〜<br><span class="sub">保守：任意（月額 1万円）</span></div>
          </div>
          <div class="anchoring-row">
            <div class="type-name">選ばれる導線LP（推奨）</div>
            <div class="market-price">初期 15万〜50万円<br><span class="sub">保守：月額 1万〜3万円</span></div>
            <div class="wa-price highlight">初期 64,000円〜<br><span class="sub">保守：任意（月額 1万円）</span></div>
          </div>
          <div class="anchoring-row">
            <div class="type-name">選ばれる導線HP制作</div>
            <div class="market-price">初期 50万〜120万円<br><span class="sub">保守：月額 1.5万〜5万円</span></div>
            <div class="wa-price">初期 144,000円〜<br><span class="sub">保守：任意（月額 1万円）</span></div>
          </div>
        </div>
        <p class="anchoring-caveat">※価格帯はページ数、原稿・画像の準備状況、予約・決済・CMSなどの機能、運用支援の範囲によって大きく変わります。条件が同じとは限らないため、比較の目安としてご覧ください。</p>

        <div class="anchoring-reason">
          <h4>和-Nodeが「丁寧な設計×適正価格」を実現できる理由</h4>
          <ul>
            <li><strong>余計な中間マージンや広告費のカット:</strong> 営業活動や過度なオフィス維持費を省き、紹介やWebからの直接依頼のみで運営しているため、余分なコストが上乗せされません。</li>
            <li><strong>Vanilla CSSと自社開発テンプレートの最適化:</strong> 無駄な重いCMS（WordPressなど）や余計なシステムを使わず、高速・軽量なコードを自社で最適化して構築するため、エンジニアの作業工数を大幅に短縮しています。</li>
            <li><strong>本質的な「選ばれる導線設計」に集中:</strong> 突飛な視覚効果や複雑すぎるデザインは省き、見込み客が迷わず安心して比較・相談しやすい設計に集中して構築します。</li>
          </ul>
        </div>
      </div>

      <!-- プラン切り替えスイッチ -->
      <div class="plan-tabs-wrapper reveal">
        <div class="plan-tabs" role="tablist">
          <button class="plan-tab-btn active" data-plan-tab="hp" role="tab" aria-selected="true">
            <MaterialIcon name="language" /> ホームページ（HP）制作
          </button>
          <button class="plan-tab-btn" data-plan-tab="lp" role="tab" aria-selected="false">
            <MaterialIcon name="ads_click" /> ランディングページ（LP）制作
          </button>
        </div>
      </div>

      <!-- HP制作プランカード -->
      <div id="plan-content-hp" class="plan-content active-plan">
        <div class="recommended-price-grid">
          <article class="recommended-price-card card-border-gold">
            <span class="price-badge-ume">梅プラン</span>
            <h3><span class="card-icon-window window-gold"><MaterialIcon name="article" /></span>シンプルHP制作</h3>
            <p class="p-price">40,000円〜 <small>キャンペーン価格</small></p>
            <div class="scope-badges" aria-label="最低価格で含まれる制作範囲">
              <b>3ページまで</b>
              <b>各1,500px程度</b>
              <b>合計4,500px程度</b>
            </div>
            <p>3ページまで、PC幅1440px基準で各ページ縦1,500px程度・合計4,500px程度までの小規模なホームページです。</p>
            <a class="scope-sample-link" href="/portfolio-lp/simple-hp-scope/index.html">3ページサンプルを見る →</a>
          </article>
          <article class="recommended-price-card highlight-take card-border-gold">
            <span class="price-badge-take">竹プラン ★ 推奨・一番人気</span>
            <h3><span class="card-icon-window window-gold"><MaterialIcon name="star" /></span>選ばれる導線HP制作</h3>
            <p class="p-price">144,000円〜 <small>キャンペーン価格</small></p>
            <p>5ページ程度の標準的なホームページ。行動心理をふまえ、見込み客が迷わず安心して相談や購入を検討しやすい情報設計を整えます。</p>
          </article>
          <article class="recommended-price-card card-border-blue">
            <span class="price-badge-matsu">松プラン</span>
            <h3><span class="card-icon-window window-blue"><MaterialIcon name="layers" /></span>HPパッケージ「Business 7」</h3>
            <p class="p-price">192,000円〜 <small>キャンペーン価格</small></p>
            <p>7ページ構成の充実プラン。標準SEO、プレミアム仕上げ、複数のお問い合わせ動線を含む本格パッケージです。</p>
          </article>
        </div>
      </div>

      <!-- LP制作プランカード -->
      <div id="plan-content-lp" class="plan-content">
        <div class="recommended-price-grid">
          <article class="recommended-price-card card-border-gold">
            <span class="price-badge-ume">梅プラン</span>
            <h3><span class="card-icon-window window-gold"><MaterialIcon name="article" /></span>シンプルLP制作</h3>
            <p class="p-price">24,000円〜 <small>キャンペーン価格</small></p>
            <div class="scope-badges" aria-label="最低価格で含まれる制作範囲">
              <b>1ページ</b>
              <b>縦2,500px程度</b>
              <b>5セクションまで</b>
            </div>
            <p>1ページ、PC幅1440px基準で縦2,500px程度・5セクションまでの簡易的なランディングページです。</p>
            <a class="scope-sample-link" href="/portfolio-lp/simple-lp-scope.html">2,500pxサンプルを見る →</a>
          </article>
          <article class="recommended-price-card highlight-take card-border-gold">
            <span class="price-badge-take">竹プラン ★ 推奨・一番人気</span>
            <h3><span class="card-icon-window window-gold"><MaterialIcon name="star" /></span>選ばれる導線LP制作</h3>
            <p class="p-price">64,000円〜 <small>キャンペーン価格</small></p>
            <p>行動心理をふまえ、最初に見える印象から信頼形成、相談ボタンまで一貫設計。相談・申込みにつながりやすい推奨プランです。</p>
          </article>
          <article class="recommended-price-card card-border-blue">
            <span class="price-badge-matsu">松プラン</span>
            <h3><span class="card-icon-window window-blue"><MaterialIcon name="layers" /></span>プレミアム選ばれる導線LP</h3>
            <p class="p-price">120,000円〜 <small>キャンペーン価格</small></p>
            <p>丁寧な導線LPに加え、問い合わせ後のGASメール自動送信やLINE連携などの自動化システム構築をセットにした業務効率化パックです。</p>
          </article>
        </div>
      </div>
      <section class="minimum-scope" aria-labelledby="minimum-scope-title">
        <div class="minimum-scope-heading">
          <p class="eyebrow">Minimum Scope</p>
          <h3 id="minimum-scope-title">最低価格で含まれる制作範囲</h3>
          <p>PC幅1440pxで見た縦の目安です。スマホ表示はレスポンシブ対応します。</p>
        </div>
        <div class="minimum-scope-grid">
          <div class="minimum-scope-item">
            <strong>シンプルLP制作 <span>24,000円〜</span></strong>
            <dl>
              <div><dt>ページ数</dt><dd>1ページ</dd></div>
              <div><dt>縦の目安</dt><dd>2,500px程度まで</dd></div>
              <div><dt>構成</dt><dd>5セクションまで</dd></div>
            </dl>
            <a class="minimum-scope-link" href="/portfolio-lp/simple-lp-scope.html">実際のサイズ感を見る →</a>
          </div>
