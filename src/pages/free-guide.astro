---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConsultationFlow from '../components/ConsultationFlow.astro';
---

<BaseLayout 
  title="【無料配布中】成約率を変える「心の壁」チェックリスト｜和-Node" 
  description="なぜあなたのサイトは選ばれないのか？車いすカウンセラーが明かす、訪問者の離脱を防ぎ、成約を劇的に高める「心理導線」の秘密を凝縮した特別資料を無料プレゼント。"
>
  <main class="resource-lp">
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-content reveal">
            <span class="badge">Limited Free Gift</span>
            <h1>あなたのサイトには、<br/><span class="accent-text">「目に見えない段差」</span>がありませんか？</h1>
            <p class="hero-lead">
              アクセスはあるのに、問い合わせが来ない。<br/>
              その原因はデザインではなく、ユーザーの「心理的な壁」にありました。<br/>
              心理学×ITの専門家がまとめた、成約率を底上げする秘策を今すぐ手に入れてください。
            </p>
            <div class="hero-cta">
              <a href="https://lin.ee/o5QFPwc" class="main-btn" data-ga-event="click_free_guide_hero">
                <span class="btn-text">無料で資料を手に入れる（LINE）</span>
                <span class="btn-sub">※登録後、すぐにダウンロードURLが届きます</span>
              </a>
              <p class="social-proof">累計ダウンロード数 30件突破 / 今月の無料配布枠 残り3名</p>
            </div>
          </div>
          <div class="hero-visual reveal">
            <!-- Replace with /images/guide-mockup.png after downloading the generated image -->
            <img src="https://images.unsplash.com/photo-1544716278-ca5e3f4abd8c?auto=format&fit=crop&q=80&w=1000&h=1200" alt="Premium Guide Mockup" class="mockup-img" />
            <div class="floating-badge">Checklist 10</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pain Points -->
    <section class="pain-section">
      <div class="container-narrow">
        <div class="section-title reveal">
          <span class="eyebrow">The Real Problem</span>
          <h2>「DXを進めたいが、現場が動かない」<br/>その正体は、技術への「不安」です。</h2>
        </div>
        <div class="pain-grid">
          <div class="pain-item reveal">
            <div class="pain-icon">✕</div>
            <p><strong>「便利なはずのITが、かえって負担になっている」</strong>現場の疲弊</p>
          </div>
          <div class="pain-item reveal">
            <div class="pain-icon">✕</div>
            <p><strong>「専門用語ばかりで、経営判断ができない」</strong>孤独な意思決定</p>
          </div>
          <div class="pain-item reveal">
            <div class="pain-icon">✕</div>
            <p><strong>「成果を急ぐあまり、チームの心が折れかけている」</strong>組織の危機</p>
          </div>
        </div>
        <p class="pain-conclusion reveal">
          Webサイトも、社内DXも同じです。人の心理を無視した「正論」だけでは、成果は出ません。<br/>
          この資料では、技術と心理の両面から、スムーズに人を動かすための「心の地図」を公開しています。
        </p>
      </div>
    </section>

    <!-- Content Showcase -->
    <section class="content-showcase">
      <div class="container">
        <div class="showcase-inner reveal">
          <div class="showcase-head">
            <span class="eyebrow">Special Content</span>
            <h2>資料の中身を、<br/>少しだけご紹介します。</h2>
          </div>
          <div class="feature-grid">
            <div class="feature-item">
              <div class="num">01</div>
              <h3>訪問者が「3秒」で離脱する心理的スイッチとは？</h3>
              <p>一瞬で「自分には不要だ」と判断されてしまう、致命的なミスを解説します。</p>
            </div>
            <div class="feature-item">
              <div class="num">02</div>
              <h3>ボタンの色より大切な「情報の黄金比」</h3>
              <p>心理学者が明かす、ユーザーが自然と納得して読み進めてしまう構成案。</p>
            </div>
            <div class="feature-item">
              <div class="num">03</div>
              <h3>信頼を確信に変える「実績の見せ方」</h3>
              <p>単なるリストアップではない、相手の心に響くストーリーテリングの手法。</p>
            </div>
            <div class="feature-item">
              <div class="num">04</div>
              <h3>【保存版】成約率を高める「心の壁」チェックリスト10選</h3>
              <p>今すぐ自分のサイトを点検し、改善できる具体的なアクションプラン。</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Profile -->
    <section class="profile-section">
      <div class="container-narrow">
        <div class="profile-card reveal">
          <div class="profile-image">
            <img src="/images/avatar.png" alt="代表 高野紘純" />
          </div>
          <div class="profile-content">
            <span class="eyebrow">Presenter</span>
            <h3>高野 紘純 <span>(Koji Takano)</span></h3>
            <p class="profile-desc">
              IT・Web制作歴20年以上のエンジニアであり、産業カウンセラー・JADP認定上級心理カウンセラー。車いすユーザーとしての「当事者視点」と、心理学・ITの両軸から、人の心に届く導線を設計しています。
            </p>
            <p class="profile-message">
              「良いものを作っているのに、届かない」。そのもどかしさを、技術と心理の力で解決するのが私の使命です。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta">
      <div class="container">
        <div class="cta-box reveal">
          <h2>Webサイトを、<br/><span class="accent-text">「24時間働く、最高の営業パートナー」</span>に変えませんか？</h2>
          <p>この資料が、あなたと未来のお客様を結ぶ第一歩になるはずです。</p>
          <a href="https://lin.ee/o5QFPwc" class="main-btn large" data-ga-event="click_free_guide_final">
            <span class="btn-text">今すぐ無料で資料をダウンロードする</span>
          </a>
          <p class="note">※和-Node公式LINEでの配布となります。しつこい勧誘はございませんのでご安心ください。</p>
        </div>
      </div>
    </section>

    <ConsultationFlow border={false} background="#fff" />
  </main>
</BaseLayout>

<style>
  .resource-lp { overflow: hidden; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
  .container-narrow { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  .eyebrow { font-size: 0.85rem; font-weight: 900; color: var(--accent2); letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 20px; display: block; }
  .accent-text { color: var(--accent2); }

  /* Hero */
  .hero-section { padding: 120px 0; background: linear-gradient(135deg, #2b241f 0%, #1a1512 100%); color: #fff; position: relative; }
  .hero-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; align-items: center; }
  .badge { background: var(--accent2); color: #fff; padding: 6px 16px; border-radius: 4px; font-weight: 800; font-size: 0.75rem; margin-bottom: 24px; display: inline-block; }
  .hero-section h1 { font-size: clamp(2rem, 5vw, 3.8rem); line-height: 1.2; font-weight: 900; margin-bottom: 30px; }
  .hero-lead { font-size: 1.15rem; color: #ccc; line-height: 1.8; margin-bottom: 40px; }
  
  .hero-cta { margin-top: 40px; }
  .social-proof { font-size: 0.85rem; color: var(--accent2); margin-top: 15px; font-weight: 700; opacity: 0.9; }
  
  .main-btn {
    display: inline-flex; flex-direction: column; align-items: center; justify-content: center;
    background: var(--accent2); color: #fff; padding: 24px 60px; border-radius: 999px;
    text-decoration: none; font-weight: 900; transition: 0.4s; box-shadow: 0 20px 40px rgba(216, 185, 140, 0.2);
  }
  .main-btn:hover { transform: translateY(-5px); box-shadow: 0 30px 60px rgba(216, 185, 140, 0.3); background: #fff; color: var(--accent2); }
  .btn-text { font-size: 1.3rem; }
  .btn-sub { font-size: 0.8rem; margin-top: 4px; opacity: 0.8; }

  .hero-visual { position: relative; }
  .mockup-img { width: 100%; border-radius: 20px; box-shadow: 0 40px 80px rgba(0,0,0,0.5); }
  .floating-badge {
    position: absolute; top: -20px; right: -20px; width: 120px; height: 120px;
    background: #fff; color: var(--accent); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: 1.2rem; transform: rotate(15deg);
    box-shadow: 0 10px 30px rgba(0,0,0,0.2); border: 4px solid var(--accent2);
  }

  /* Pain Section */
  .pain-section { padding: 120px 0; background: #fff; text-align: center; }
  .section-title h2 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 900; line-height: 1.3; margin-bottom: 60px; }
  .pain-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; margin-bottom: 60px; }
  .pain-item { background: #fdfaf7; padding: 40px 30px; border-radius: 24px; border: 1px solid var(--line); }
  .pain-icon { width: 40px; height: 40px; background: #fee2e2; color: #ef4444; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-weight: 900; }
  .pain-item p { font-size: 1rem; color: #444; margin: 0; line-height: 1.6; }
  .pain-conclusion { font-size: 1.2rem; color: var(--accent); font-weight: 700; line-height: 1.8; }

  /* Content Showcase */
  .content-showcase { padding: 120px 0; background: #faf8f5; }
  .showcase-inner { background: #fff; border-radius: 60px; padding: 100px 60px; box-shadow: var(--shadow); border: 1px solid var(--line); }
  .showcase-head { text-align: center; margin-bottom: 80px; }
  .showcase-head h2 { font-size: 2.5rem; font-weight: 900; }
  .feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 60px 40px; }
  .feature-item { position: relative; padding-left: 80px; }
  .num { position: absolute; left: 0; top: 0; font-size: 3rem; font-weight: 900; color: var(--soft); line-height: 1; }
  .feature-item h3 { font-size: 1.3rem; font-weight: 800; margin-bottom: 15px; color: var(--text); }
  .feature-item p { color: var(--muted); line-height: 1.7; margin: 0; }

  /* Profile */
  .profile-section { padding: 120px 0; background: #fff; }
  .profile-card { display: grid; grid-template-columns: 240px 1fr; gap: 40px; background: #fdfaf7; border-radius: 40px; padding: 60px; border: 1px solid var(--line); align-items: center; }
  .profile-image img { width: 240px; height: 240px; border-radius: 50%; object-fit: cover; border: 6px solid #fff; box-shadow: var(--shadow); }
  .profile-content h3 { font-size: 1.8rem; font-weight: 900; margin-bottom: 15px; }
  .profile-content h3 span { font-size: 1rem; color: var(--muted); font-weight: 400; }
  .profile-desc { font-size: 1rem; color: #555; line-height: 1.8; margin-bottom: 20px; }
  .profile-message { font-size: 1.1rem; color: var(--accent); font-weight: 800; font-style: italic; }

  /* Final CTA */
  .final-cta { padding: 140px 0; background: linear-gradient(135deg, #faf8f5 0%, #fff 100%); text-align: center; }
  .cta-box { max-width: 900px; margin: 0 auto; }
  .cta-box h2 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; line-height: 1.3; margin-bottom: 32px; }
  .cta-box p { font-size: 1.2rem; color: var(--muted); margin-bottom: 50px; }
  .main-btn.large { transform: scale(1.1); margin-bottom: 30px; }
  .note { font-size: 0.9rem; color: #999; }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; text-align: center; }
    .hero-visual { order: -1; }
    .showcase-inner { padding: 60px 20px; border-radius: 40px; }
    .feature-grid { grid-template-columns: 1fr; gap: 40px; }
    .profile-card { grid-template-columns: 1fr; text-align: center; padding: 40px 20px; }
    .profile-image { margin: 0 auto; }
  }

  .reveal { opacity: 0; transform: translateY(30px); transition: 1s cubic-bezier(0.23, 1, 0.32, 1); }
  .reveal.visible { opacity: 1; transform: translateY(0); }
</style>

<script is:inline>
  function setupReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }

  // Handle both initial load and Astro page transitions
  document.addEventListener('DOMContentLoaded', setupReveal);
  document.addEventListener('astro:page-load', setupReveal);
</script>

<noscript>
  <style>
    .reveal { opacity: 1 !important; transform: none !important; }
  </style>
</noscript>
