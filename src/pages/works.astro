---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConsultationFlow from '../components/ConsultationFlow.astro';
import MaterialIcon from '../components/MaterialIcon.astro';
import {
  createBreadcrumbSchema,
  createWebPageSchema,
  organizationSchema,
} from '../data/structuredData';

const title = "制作例・デモ｜行動心理に基づくWeb制作・LP制作サンプル｜和-Node";
const description = "行動心理に基づくWeb制作、LP制作サンプル、AI相談ナビ、各種診断ツール、KDP出版など、和-Nodeの制作例とインタラクティブなデモを紹介します。";
const image = "/images/ogp-works.png";
const structuredData = [
  organizationSchema,
  createWebPageSchema({ name: title, description, path: "/works/", type: "CollectionPage" }),
  createBreadcrumbSchema([
    { name: "ホーム", path: "/" },
    { name: "制作例・デモ", path: "/works/" },
  ]),
];
---

<BaseLayout title={title} description={description} image={image} structuredData={structuredData}>
  <!-- Background -->
  <div class="bg-decoration">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="grid-overlay"></div>
    <div class="sakura-container" id="sakura-container"></div>
  </div>

  <script is:inline>
    function initSakura() {
      const container = document.getElementById('sakura-container');
      if (!container) return;
      container.innerHTML = '';
      for (let i = 0; i < 20; i++) {
        const petal = document.createElement('div');
        petal.className = 'petal-subtle';
        petal.style.left = Math.random() * 100 + '%';
        petal.style.width = Math.random() * 8 + 4 + 'px';
        petal.style.height = petal.style.width;
        petal.style.animationDuration = Math.random() * 5 + 7 + 's';
        petal.style.animationDelay = Math.random() * 5 + 's';
        container.appendChild(petal);
      }
    }
    initSakura();
    document.addEventListener('astro:page-load', initSakura);
  </script>

  <main class="works-page" data-glossary-skip>
    <section class="section works-hero">
      <div class="container narrow">
        <span class="eyebrow">Works & Demos</span>
        <h1 class="premium-heading">制作例・デモ・<span class="title-nowrap">ツール</span></h1>
        <p class="lead">
          ホームページ制作・LP制作の見え方を中心に、和-Node独自の視点（心理学・AI・アクセシビリティ）を形にした<br class="pc-only" />
          制作サンプルとデモツールを公開しています。近い目的・設計意図・参考価格から、相談内容を整理できます。
        </p>
        <p class="price-guide-note">
          掲載価格は、同じ方向性で制作・実装する場合の参考価格帯です。LPサンプルの一部は架空の題材を使った表現例で、ページ数、原稿量、予約・LINE・AI連携の有無により変動します。
        </p>
      </div>
    </section>

    <div class="container">
      <section class="works-use-guide reveal" aria-labelledby="works-use-guide-title">
        <div>
          <span class="eyebrow">How to Read</span>
          <h2 id="works-use-guide-title">制作例の見方</h2>
        </div>
        <ol class="works-use-steps">
          <li>
            <span>01</span>
            <strong>近い目的を選ぶ</strong>
            <p>予約、相談、販売、診断など、業種よりも「起こしたい行動」で見ると選びやすくなります。</p>
          </li>
          <li>
            <span>02</span>
            <strong>見るポイントを比べる</strong>
            <p>カード内の「見るポイント」で、何を解決するためのデザインかを先に確認できます。</p>
          </li>
          <li>
            <span>03</span>
            <strong>参考価格で相談範囲を決める</strong>
            <p>近いサンプルを伝えていただくと、必要なページ数や機能を絞って話しやすくなります。</p>
          </li>
        </ol>
      </section>

      <section class="priority-works reveal" aria-labelledby="priority-works-title">
        <div class="priority-copy">
          <span class="eyebrow">First View</span>
          <h2 id="priority-works-title" class="premium-heading">迷ったら、まずはこの4つをご覧ください</h2>
          <p>まずはWeb制作・LP制作の見え方を中心に、必要に応じてAI・ICTの実装力も確認できます。</p>
        </div>
        <div class="priority-grid">
          <a href="/lab/" class="priority-card main card-border-green">
            <div class="priority-visual" aria-hidden="true">
              <strong>改善</strong>
              <small>観察 → 仮説 → 検証</small>
            </div>
            <span>改善過程を公開</span>
            <h3>
              <span class="card-icon-window window-green">
                <MaterialIcon name="difference" />
              </span>
              Web改善ラボ
            </h3>
            <ul class="priority-tags"><li>Before／After</li><li>改善理由</li><li>検証</li></ul>
            <p>何を見て、なぜ変え、どう確かめるか。見た目の差だけではない改善判断を公開します。</p>
            <div class="priority-price"><span>参考価格</span><strong>既存LP診断 15,000円〜 / LP制作 64,000円〜</strong></div>
          </a>
          <a href="/case-studies/b2b-corporate-renewal/" class="priority-card card-border-blue">
            <div class="priority-visual" aria-hidden="true">
              <strong>企業</strong>
              <small>課題 → 構成 → CMS</small>
            </div>
            <span>企業サイト・ケーススタディ</span>
            <h3>
              <span class="card-icon-window window-blue">
                <MaterialIcon name="account_tree" />
              </span>
              BtoB企業サイト再構成
            </h3>
            <ul class="priority-tags"><li>7ページ</li><li>情報設計</li><li>CMS想定</li></ul>
            <p>製品説明から相談導線へ組み直し、担当者が更新する画面まで示した自主制作例です。</p>
            <div class="priority-price"><span>参考価格</span><strong>企業サイト 120,000円〜</strong></div>
          </a>
          <a href="/case-studies/ad-lp-measurement/" class="priority-card card-border-gold">
            <div class="priority-visual" aria-hidden="true">
              <strong>広告</strong>
              <small>広告 → LP → 計測</small>
            </div>
            <span>広告改善・計測設計</span>
            <h3>
              <span class="card-icon-window window-gold">
                <MaterialIcon name="monitoring" />
              </span>
              広告・LP・計測改善
            </h3>
            <ul class="priority-tags"><li>Yahoo・LINE</li><li>CRO</li><li>GA4想定</li></ul>
            <p>広告文、LP、フォーム、問い合わせ品質を一つの改善ループとして示します。</p>
            <div class="priority-price"><span>参考価格</span><strong>広告・LP改善 30,000円〜</strong></div>
          </a>
          <a href="/case-studies/reservation-operations/" class="priority-card card-border-blue">
            <div class="priority-visual" aria-hidden="true">
              <strong>業務</strong>
              <small>予約 → 管理 → CSV</small>
            </div>
            <span>小規模業務システム</span>
            <h3>
              <span class="card-icon-window window-blue">
                <MaterialIcon name="event_note" />
              </span>
              予約受付・店舗管理
            </h3>
            <ul class="priority-tags"><li>受付</li><li>状態管理</li><li>CSV出力</li></ul>
            <p>お客様の予約画面と店舗側の処理画面を、実際に操作できる形でつなぎます。</p>
            <div class="priority-price"><span>参考価格</span><strong>小規模システム 80,000円〜</strong></div>
          </a>
        </div>
        <div class="priority-cta">
          <a href="/contact/?source=works">この方向で相談する</a>
        </div>
      </section>

      <!-- Filter Tabs -->
      <nav class="filter-nav" id="filter-nav">
        <button class="filter-btn active" data-filter="all">すべて</button>
        <button class="filter-btn" data-filter="web">Web & LP</button>
        <button class="filter-btn" data-filter="tool">診断・ツール</button>
        <button class="filter-btn" data-filter="system">AI・システム</button>
        <button class="filter-btn" data-filter="kdp">KDP出版</button>
      </nav>

      <div class="works-grid" id="works-grid">

        <!-- Category: Web (Improvement Lab) -->
        <article class="work-card reveal card-border-green" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg" style="background: #f4f8f6;">
              <img src="/images/ogp-lab.png" alt="Web改善ラボのBefore・After比較画面" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo"><span class="live-dot"></span>Web改善ポートフォリオ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Observation / Hypothesis / Verification</div>
            <h3>
              <span class="card-icon-window window-green">
                <MaterialIcon name="difference" />
              </span>
              Web改善ラボ
            </h3>
            <div class="work-snapshot">
              <span>見るポイント</span>
              <strong>修正の根拠と確かめ方がわかる</strong>
            </div>
            <dl class="design-chart">
              <div><dt>課題</dt><dd>完成画面だけでは、なぜその修正が必要か判断しにくい</dd></div>
              <div><dt>工夫</dt><dd>事実・仮説・変更・検証をBefore／Afterと一緒に公開</dd></div>
            </dl>
            <ul class="work-chips"><li>情報設計</li><li>UX</li><li>検証設計</li></ul>
            <p class="card-text">相談型サービスLPを題材に、Hero・料金・FAQ・CTAの小さな説明不足を、読み手の判断材料へ変える過程を確認できます。</p>
            <div class="price-hint"><span>参考価格</span><strong>既存LP診断 15,000円〜 / LP制作 64,000円〜</strong><small>現状改善のみか、新規制作込みかで変わります</small></div>
            <div class="card-footer">
              <span class="tech-tag">Before / After</span>
              <span class="tech-tag">Evidence</span>
              <a href="/lab/" class="card-link">改善過程を見る →</a>
            </div>
          </div>
        </article>

        <!-- Category: Web (B2B Corporate Case Study) -->
        <article class="work-card reveal card-border-blue" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/images/case-studies/b2b/hokushin-factory-hero.webp" alt="BtoB製造企業サイト再構成ケーススタディ" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo"><span class="live-dot"></span>企業サイト・ケーススタディ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">B2B / Information Architecture / CMS</div>
            <h3>
              <span class="card-icon-window window-blue">
                <MaterialIcon name="account_tree" />
              </span>
              BtoB企業サイト再構成
            </h3>
            <div class="work-snapshot">
              <span>見るポイント</span>
              <strong>設計判断・7ページ構成・更新画面まで見える</strong>
            </div>
            <dl class="design-chart">
              <div><dt>課題</dt><dd>製品情報を並べるだけでは、相談内容と技術の関係が伝わりにくい</dd></div>
              <div><dt>工夫</dt><dd>課題起点の情報設計と、担当者が更新できるCMS操作デモを実装</dd></div>
            </dl>
            <ul class="work-chips"><li>BtoB</li><li>情報設計</li><li>CMS更新想定</li></ul>
            <p class="card-text">架空の精密製造企業を題材に、企業サイト7ページ、問い合わせ導線、導入事例のCMS更新デモまで制作した自主制作ケーススタディです。</p>
            <div class="price-hint"><span>参考価格</span><strong>企業サイト 120,000円〜</strong><small>ページ数、CMS、原稿整理、既存サイト移行の範囲で変動</small></div>
            <div class="card-footer">
              <span class="tech-tag">Astro</span>
              <span class="tech-tag">Responsive</span>
              <a href="/case-studies/b2b-corporate-renewal/" class="card-link">設計意図を見る →</a>
            </div>
          </div>
        </article>

        <!-- Category: Tool (Advertising Improvement Case Study) -->
        <article class="work-card reveal card-border-gold" data-category="tool">
          <div class="card-visual-wrap">
            <div class="card-visual portfolio-process-visual portfolio-process-visual--ad">
              <span class="category-tag demo"><span class="live-dot"></span>広告改善・計測設計</span>
              <div aria-hidden="true">
                <span>AD</span><MaterialIcon name="arrow_forward" /><span>LP</span><MaterialIcon name="arrow_forward" /><span>CV</span>
              </div>
              <small>CTR・CPC・CVR・CPA</small>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Advertising / CRO / Measurement</div>
            <h3>
              <span class="card-icon-window window-gold"><MaterialIcon name="monitoring" /></span>
              広告・LP・計測改善
            </h3>
            <div class="work-snapshot"><span>見るポイント</span><strong>クリック後の詰まりまで追える</strong></div>
            <dl class="design-chart">
              <div><dt>課題</dt><dd>広告、LP、フォームを別々に見ると改善箇所を誤りやすい</dd></div>
              <div><dt>工夫</dt><dd>検索語句、KPI、LP行動、問い合わせ品質を一つの流れで確認</dd></div>
            </dl>
            <ul class="work-chips"><li>広告診断</li><li>CRO</li><li>計測設計</li></ul>
            <p class="card-text">Yahoo・LINE広告を想定し、広告文からLP、フォーム、問い合わせ品質までを週次で改善する判断例です。</p>
            <div class="price-hint"><span>参考価格</span><strong>広告・LP改善 30,000円〜</strong><small>計測設定・運用期間・広告媒体で変動</small></div>
            <div class="card-footer">
              <span class="tech-tag">CSV</span><span class="tech-tag">GA4想定</span>
              <a href="/case-studies/ad-lp-measurement/" class="card-link">設計意図を見る →</a>
            </div>
          </div>
        </article>

        <!-- Category: System (Reservation Operations Case Study) -->
        <article class="work-card reveal card-border-blue" data-category="system">
          <div class="card-visual-wrap">
            <div class="card-visual portfolio-process-visual portfolio-process-visual--system">
              <span class="category-tag demo"><span class="live-dot"></span>操作できる業務デモ</span>
              <div aria-hidden="true">
                <span><MaterialIcon name="calendar_add_on" />予約</span><MaterialIcon name="sync_alt" /><span><MaterialIcon name="dashboard" />管理</span>
              </div>
              <small>受付・状態変更・CSV出力</small>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Reservation / Admin / Operations</div>
            <h3>
              <span class="card-icon-window window-blue"><MaterialIcon name="event_note" /></span>
              予約受付・店舗管理システム
            </h3>
            <div class="work-snapshot"><span>見るポイント</span><strong>予約後の店舗業務まで操作できる</strong></div>
            <dl class="design-chart">
              <div><dt>課題</dt><dd>予約フォームだけ導入しても転記・確認・状態管理が残る</dd></div>
              <div><dt>工夫</dt><dd>お客様画面と店舗管理画面を一つのデータでつなぐ</dd></div>
            </dl>
            <ul class="work-chips"><li>予約受付</li><li>管理画面</li><li>CSV出力</li></ul>
            <p class="card-text">架空サロンを題材に、空き枠選択、受付完了、店舗側の状態変更、CSV出力をブラウザ内で試せます。</p>
            <div class="price-hint"><span>参考価格</span><strong>小規模業務システム 80,000円〜</strong><small>認証・通知・外部連携・データ保存方法で変動</small></div>
            <div class="card-footer">
              <span class="tech-tag">LocalStorage</span><span class="tech-tag">Admin UI</span>
              <a href="/case-studies/reservation-operations/" class="card-link">設計意図を見る →</a>
            </div>
          </div>
        </article>
        
        <!-- Category: Web (Psychology Demo) -->
        <article class="work-card reveal card-border-green" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg" style="background: linear-gradient(135deg, #fdfcf9 0%, #f5eee0 100%);">
              <img src="/images/works-psy-demo.png" alt="選ばれる導線デモ" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.style.display='none'" />
              <span class="category-tag demo"><span class="live-dot"></span>Web導線デモ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Psychology Logic</div>
            <h3>
              <span class="card-icon-window window-green">
                <MaterialIcon name="route" />
              </span>
              選ばれる導線デモ
            </h3>
            <div class="work-snapshot">
              <span>見るポイント</span>
              <strong>相談ボタンの理由がわかる</strong>
            </div>
            <dl class="design-chart">
              <div><dt>課題</dt><dd>良い情報があっても、相談ボタンまでの理由が見えにくい</dd></div>
              <div><dt>工夫</dt><dd>配置・言葉・根拠を順番に見せ、納得して次へ進める</dd></div>
            </dl>
            <ul class="work-chips"><li>心理根拠</li><li>情報設計</li><li>相談導線</li></ul>
            <p class="card-text">なぜそのボタンはそこにあるのか？心理学的根拠に基づいた情報配置の「正解」を、解説付きで体験できる特別なデモページです。</p>
            <div class="price-hint"><span>参考価格</span><strong>既存LP診断 15,000円〜 / LP制作 64,000円〜</strong><small>現状改善のみか、新規制作込みかで変わります</small></div>
            <div class="card-footer">
              <span class="tech-tag">UI/UX</span>
              <span class="tech-tag">Psychology</span>
              <a href="/psychology-demo/" class="card-link">デモを体験する →</a>
            </div>
          </div>
        </article>

        <!-- Category: Web (Salon Reservation Demo) -->
        <article class="work-card reveal card-border-green" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/portfolio-lp/images/hero_sekkotsu.png" alt="地域サロン・整体向け予約導線LPデモ" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo"><span class="live-dot"></span>業種別LPデモ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Local Salon / Reservation</div>
            <h3>
              <span class="card-icon-window window-green">
                <MaterialIcon name="event_available" />
              </span>
              地域サロン・整体向け予約導線LP
            </h3>
            <div class="work-snapshot">
              <span>見るポイント</span>
              <strong>来店前の不安を減らす流れ</strong>
            </div>
            <dl class="design-chart">
              <div><dt>課題</dt><dd>初回来店前に料金・流れ・場所の不安が残りやすい</dd></div>
              <div><dt>工夫</dt><dd>予約前に知りたい情報をスマホで追いやすく整理</dd></div>
            </dl>
            <ul class="work-chips"><li>料金</li><li>初回説明</li><li>LINE予約</li></ul>
            <p class="card-text">初回来店前の不安を減らすために、料金、流れ、アクセス、LINE予約導線をスマホで確認しやすく整理した架空サンプルです。</p>
            <div class="price-hint"><span>参考価格</span><strong>64,000円〜120,000円前後</strong><small>予約導線・LINE連携の範囲で変動</small></div>
            <div class="card-footer">
              <span class="tech-tag">LP Design</span>
              <span class="tech-tag">Reservation UX</span>
              <a href="/salon-reservation-demo/" class="card-link">デモを見る →</a>
            </div>
          </div>
        </article>

        <!-- Category: Web (Medical) -->
        <article class="work-card reveal card-border-gold" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/portfolio-lp/images/hero_clinic.png" alt="クリニック・医療系LP" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag sample">LP制作サンプル</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Medical / Clinic</div>
            <h3>
              <span class="card-icon-window window-gold">
                <MaterialIcon name="verified_user" />
              </span>
              クリニック・医療系LP
            </h3>
            <div class="work-snapshot">
              <span>見るポイント</span>
              <strong>安心感と予約導線の両立</strong>
            </div>
            <dl class="design-chart">
              <div><dt>課題</dt><dd>安心材料が足りないと、比較段階で予約に進みにくい</dd></div>
              <div><dt>工夫</dt><dd>信頼・確認事項・予約導線を落ち着いた順番で配置</dd></div>
            </dl>
            <ul class="work-chips"><li>信頼形成</li><li>医療配慮</li><li>予約ボタン</li></ul>
            <p class="card-text">美容クリニック、心療内科等を想定したLP制作サンプル。医療広告ガイドラインに配慮しつつ、安心感と予約導線を両立させた構成例です。</p>
