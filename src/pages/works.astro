---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConsultationFlow from '../components/ConsultationFlow.astro';
---

<BaseLayout title="制作実績・デモ｜和-Node" description="心理導線Web制作、診断ツール開発、KDP出版、LINE Mini Appなど、和-Nodeの幅広い制作実績とインタラクティブなデモアプリを紹介します。">
  <!-- Background -->
  <div class="bg-decoration">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="grid-overlay"></div>
    <div class="sakura-container" id="sakura-container"></div>
  </div>

  <script is:inline>
    function initSakura() {
      const container = document.getElementById('sakura-container');
      if (!container) return;
      container.innerHTML = '';
      for (let i = 0; i < 20; i++) {
        const petal = document.createElement('div');
        petal.className = 'petal-subtle';
        petal.style.left = Math.random() * 100 + '%';
        petal.style.width = Math.random() * 8 + 4 + 'px';
        petal.style.height = petal.style.width;
        petal.style.animationDuration = Math.random() * 5 + 7 + 's';
        petal.style.animationDelay = Math.random() * 5 + 's';
        container.appendChild(petal);
      }
    }
    initSakura();
    document.addEventListener('astro:page-load', initSakura);
  </script>

  <main class="works-page">
    <section class="section works-hero">
      <div class="container narrow">
        <!-- Anniversary Banner -->
        <div class="works-anniversary-banner reveal">
          <a href="/campaign-anniversary/">
            <span class="ann-label">1st Anniversary Campaign</span>
            <div class="ann-content">
              <strong>起業記念 20% OFF 実施中</strong>
              <span>制作実績と同クオリティのサイトを今だけ特別価格で。詳しくはこちら →</span>
            </div>
          </a>
        </div>

        <span class="eyebrow">Works & Demos</span>
        <h1 class="premium-heading">制作実績・デモ・サンプル</h1>
        <p class="lead">
          実案件の制作実績に加え、デザイン提案のためのサンプルや独自開発のデモツールを公開しています。<br />
          和-Nodeが提供する「伝わる導線」と「実用的な設計」を体験してください。
        </p>
      </div>
    </section>

    <div class="container">
      <!-- Filter Tabs -->
      <nav class="filter-nav" id="filter-nav">
        <button class="filter-btn active" data-filter="all">すべて</button>
        <button class="filter-btn" data-filter="web">Web & LP</button>
        <button class="filter-btn" data-filter="tool">診断・ツール</button>
        <button class="filter-btn" data-filter="kdp">KDP出版</button>
        <button class="filter-btn" data-filter="system">システム・AI</button>
      </nav>

      <div class="works-grid" id="works-grid">
        
        <!-- Category: Tool -->
        <article class="work-card reveal" data-category="tool">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg">
              <img src="/images/works-mental.png" alt="こころの疲労度診断" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo">自社開発デモ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Strategic Tool</div>
            <h3>こころの疲労度診断</h3>
            <p class="card-text">心理カウンセラーの知見を活かし、現在のストレス要因を可視化。グラスモーフィズムを用いたモダンなUIで、回答者の心理的ハードルを下げています。</p>
            <div class="card-footer">
              <span class="tech-tag">JavaScript</span>
              <span class="tech-tag">Astro</span>
              <a href="/mental_care" class="card-link">診断を体験する →</a>
            </div>
          </div>
        </article>

        <article class="work-card reveal" data-category="tool">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg">
              <img src="/images/works-accessibility.png" alt="バリアフリー診断" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo">自社開発デモ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Accessibility</div>
            <h3>バリアフリー診断</h3>
            <p class="card-text">車いすユーザー視点の25項目によるセルフチェック。物理的な障壁を「自分事」として捉え直すための、アクセシビリティに配慮した設計です。</p>
            <div class="card-footer">
              <span class="tech-tag">UI/UX</span>
              <span class="tech-tag">SVG Gauge</span>
              <a href="/barrier_free" class="card-link">診断を体験する →</a>
            </div>
          </div>
        </article>

        <article class="work-card reveal" data-category="tool">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg">
              <img src="/images/works-seo.png" alt="SEO内部対策診断" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo">自社開発デモ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">SEO Logic</div>
            <h3>SEO内部対策診断</h3>
            <p class="card-text">WordPressサイトのSEO状態を25項目でリアルタイム採点。テクニカルな情報を、段階的なステップとチャートで分かりやすく提示します。</p>
            <div class="card-footer">
              <span class="tech-tag">SEO</span>
              <span class="tech-tag">Logic</span>
              <a href="/seo_check" class="card-link">診断を体験する →</a>
            </div>
          </div>
        </article>

        <article class="work-card reveal" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/portfolio-lp/images/hero_clinic.png" alt="クリニック・医療系LP" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag real">実案件</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Medical / Clinic</div>
            <h3>クリニック・医療系LP</h3>
            <p class="card-text">美容クリニック、歯科医院、心療内科など。薬機法や医療広告ガイドラインに配慮しつつ、患者様の安心感と信頼を両立させた設計です。</p>
            <div class="card-footer">
              <div class="tech-stack"><span>#UX Design</span><span>#Trust</span></div>
              <a href="/portfolio-lp/lp_clinic.html" class="premium-link">作品を見る</a>
            </div>
          </div>
        </article>

        <article class="work-card reveal" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/portfolio-lp/images/hero_beauty.png" alt="美容・エステ・サロン系LP" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag sample">デザインサンプル</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Beauty / Salon</div>
            <h3>美容・エステ・サロン系LP</h3>
            <p class="card-text">エステ、ネイル、美容室。憧れと親しみやすさを視覚的に表現し、初回来店への心理的ハードルを下げる構成サンプルです。</p>
            <div class="card-footer">
              <div class="tech-stack"><span>#Visual Art</span><span>#CVR</span></div>
              <a href="/portfolio-lp/lp_beauty.html" class="premium-link">作品を見る</a>
            </div>
          </div>
        </article>

        <article class="work-card reveal" data-category="kdp">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/images/works-kdp.png" alt="Amazon KDP 出版実績" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag real">実案件</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Global Design</div>
            <h3>Amazon KDP 出版実績</h3>
            <p class="card-text">浮世絵や鳥獣戯画をモチーフにした、海外市場向け（US/FR）の書籍制作。表紙から内部構成まで、和の美しさを世界へ届けています。</p>
            <div class="card-footer">
              <span class="tech-tag">Global</span>
              <span class="tech-tag">Publishing</span>
              <a href="/kdp_books" class="card-link">作品一覧を見る →</a>
            </div>
          </div>
        </article>

        <article class="work-card reveal" data-category="system">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/images/works-system.png" alt="LINE カウンセリング予約システム" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag real">実案件</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">System Build</div>
            <h3>LINE カウンセリング予約システム</h3>
            <p class="card-text">LINEアプリ内で完結する予約・決済・診断システム。ユーザーの日常的なツールを窓口にすることで、利用のハードルを下げます。</p>
            <div class="card-footer">
              <div class="tech-stack"><span>#LIFF</span><span>#Node.js</span></div>
              <a href="/line_demo" class="premium-link">デモを見る</a>
            </div>
          </div>
        </article>

      </div>
    </div>

    <ConsultationFlow />

    <!-- Standard Packages CTA -->
    <section class="packages-cta reveal">
      <div class="container glass-panel">
        <div class="cta-label">ANNIVERSARY SPECIAL</div>
        <h2>キャンペーンでお得に制作しませんか？</h2>
        <p>今なら制作メニューが 20% OFF。実績のような高品質なサイトを、あなたのビジネスにも導入するチャンスです。</p>
        <div class="cta-btns">
          <a href="/campaign-anniversary/" class="btn-secondary-outline">キャンペーン詳細を見る</a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

    :root {
      --accent: #c5a059;
      --accent-dark: #b18e4a;
      --accent-red: #d14d3a;
      --glass: rgba(255, 255, 255, 0.85);
      --glass-border: rgba(197, 160, 89, 0.2);
      --tag-works: #2c7c5e;
      --tag-sample: #c5a059;
      --tag-demo: #2c5e7c;
    }

    .premium-heading {
      font-family: 'Shippori Mincho', serif !important;
      font-weight: 800 !important;
      letter-spacing: 0.05em;
    }

    /* Background Decoration */
    .bg-decoration {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      z-index: -1; background: #fdfcf9; overflow: hidden;
    }
    .bg-decoration::after {
      content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3FfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3F/filter%3E%3Frect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3F/svg%3E");
      opacity: 0.05; pointer-events: none;
    }
    .sakura-container {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
    }
    .petal-subtle {
      position: absolute; background: #ffb7c5; border-radius: 150% 0 150% 0;
      opacity: 0.4; animation: fall-subtle linear infinite;
    }
    @keyframes fall-subtle {
      0% { transform: translateY(-10vh) rotate(0deg); opacity: 0; }
      10% { opacity: 0.4; }
      90% { opacity: 0.4; }
      100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
    }

    .works-page { padding-bottom: 100px; font-family: 'Shippori Mincho', serif !important; }
    
    .works-hero { padding: 80px 0 60px; text-align: center; }
    
    /* Anniversary Banner */
    .works-anniversary-banner {
      margin-bottom: 40px;
    }
    .works-anniversary-banner a {
      display: block; background: #fff; border: 1px solid var(--accent-red);
      border-radius: 20px; padding: 20px 30px; text-decoration: none;
      transition: 0.4s; position: relative; overflow: hidden;
      box-shadow: 0 10px 30px rgba(209, 77, 58, 0.1);
    }
    .works-anniversary-banner a:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(209, 77, 58, 0.15); }
    .ann-label {
      display: inline-block; background: var(--accent-red); color: white;
      font-size: 0.75rem; font-weight: 800; padding: 4px 12px; border-radius: 4px;
      margin-bottom: 8px;
    }
    .ann-content { display: flex; align-items: center; justify-content: center; gap: 20px; color: #2c2c2c; }
    .ann-content strong { font-size: 1.2rem; color: var(--accent-red); }
    .ann-content span { font-size: 0.95rem; opacity: 0.8; }

    .eyebrow { font-size: 0.85rem; font-weight: 800; color: var(--accent); letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 16px; display: block; }
    .lead { font-size: 1.1rem; color: #555; line-height: 1.8; max-width: 800px; margin: 0 auto; }

    /* Filter Nav */
    .filter-nav { display: flex; justify-content: center; gap: 12px; margin-bottom: 80px; flex-wrap: wrap; }
    .filter-btn {
      padding: 12px 28px; border-radius: 999px; background: #fff;
      border: 1px solid var(--glass-border); color: #666; font-weight: 800;
      cursor: pointer; transition: 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }
    .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
    .filter-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); box-shadow: 0 8px 25px rgba(197, 160, 89, 0.3); }

    /* Works Grid */
    .works-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 40px; }

    .work-card {
      background: #fff; border: 1px solid var(--glass-border); border-radius: 30px;
      overflow: hidden; display: flex; flex-direction: column;
      transition: 0.5s cubic-bezier(0.23, 1, 0.32, 1);
      box-shadow: 0 20px 40px rgba(0,0,0,0.02);
    }
    .work-card:hover { transform: translateY(-12px); border-color: var(--accent); box-shadow: 0 30px 60px rgba(197, 160, 89, 0.1); }

    .card-visual-wrap { padding: 15px; }
    .card-visual { height: 180px; border-radius: 20px; overflow: hidden; position: relative; background: #f5f5f5; }
    
    .category-tag {
      position: absolute; top: 15px; left: 15px; font-size: 0.65rem; font-weight: 800;
      padding: 4px 12px; border-radius: 999px; z-index: 2;
    }
    .category-tag.real { background: var(--accent-red); color: #fff; }
    .category-tag.demo { background: var(--tag-demo); color: #fff; }
    .category-tag.sample { background: var(--accent); color: #fff; }

    .card-body { padding: 30px; flex: 1; display: flex; flex-direction: column; }
    .expert-label { font-size: 0.75rem; font-weight: 800; color: var(--accent); letter-spacing: 0.1em; margin-bottom: 10px; }
    .card-body h3 { font-size: 1.4rem; font-weight: 800; color: #2c2c2c; margin-bottom: 15px; line-height: 1.4; }
    .card-text { font-size: 0.95rem; color: #666; line-height: 1.7; margin-bottom: 24px; flex: 1; }

    .card-footer { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-top: auto; }
    .tech-tag { font-size: 0.7rem; font-weight: 800; color: #888; background: #f5f5f5; padding: 4px 10px; border-radius: 4px; }
    .card-link, .premium-link { margin-left: auto; font-size: 0.9rem; font-weight: 800; color: var(--accent); text-decoration: none; transition: 0.2s; }
    .card-link:hover, .premium-link:hover { color: var(--accent-red); transform: translateX(5px); }

    .packages-cta { margin-top: 120px; }
    .glass-panel {
      background: #3a2e26; color: white; border-radius: 40px; padding: 80px 40px;
      text-align: center; border: 1px solid var(--accent); position: relative; overflow: hidden;
    }
    .glass-panel::before {
      content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      background: radial-gradient(circle at top right, rgba(197, 160, 89, 0.15), transparent); pointer-events: none;
    }
    .cta-label { font-size: 0.8rem; font-weight: 800; color: var(--accent); letter-spacing: 0.3em; margin-bottom: 20px; }
    .glass-panel h2 { font-size: 2.2rem; margin-bottom: 24px; font-weight: 800; }
    .glass-panel p { font-size: 1.1rem; opacity: 0.8; line-height: 1.8; margin-bottom: 40px; }

    .btn-secondary-outline {
      display: inline-block; border: 2px solid var(--accent); color: var(--accent);
      padding: 15px 40px; border-radius: 50px; text-decoration: none;
      font-weight: 800; transition: 0.3s;
    }
    .btn-secondary-outline:hover { background: var(--accent); color: white; }

    .reveal { opacity: 0; transform: translateY(30px); transition: 0.8s cubic-bezier(0.23, 1, 0.32, 1); }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 768px) {
      .ann-content { flex-direction: column; gap: 5px; text-align: center; }
      .ann-content strong { font-size: 1.1rem; }
      .ann-content span { font-size: 0.85rem; }
      .works-grid { grid-template-columns: 1fr; }
      .glass-panel { padding: 60px 20px; }
    }
</style>

<script is:inline>
    function initWorks() {
      // Filter Logic
      const filterBtns = document.querySelectorAll('.filter-btn');
      const workCards = document.querySelectorAll('.work-card');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = btn.dataset.filter;
          filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          workCards.forEach(card => {
            if (filter === 'all' || card.dataset.category === filter) {
              card.style.display = 'flex';
              setTimeout(() => card.classList.add('visible'), 50);
            } else {
              card.style.display = 'none';
              card.classList.remove('visible');
            }
          });
        });
      });

      // Reveal Logic
      const io = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    }
    initWorks();
    document.addEventListener('astro:page-load', initWorks);
</script>
