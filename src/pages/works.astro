---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConsultationFlow from '../components/ConsultationFlow.astro';
import {
  createBreadcrumbSchema,
  createWebPageSchema,
  organizationSchema,
} from '../data/structuredData';

const title = "制作例・デモ｜行動心理に基づくWeb制作・LP制作サンプル｜和-Node";
const description = "行動心理に基づくWeb制作、LP制作サンプル、AI相談ナビ、各種診断ツール、KDP出版など、和-Nodeの制作例とインタラクティブなデモを紹介します。";
const structuredData = [
  organizationSchema,
  createWebPageSchema({ name: title, description, path: "/works/", type: "CollectionPage" }),
  createBreadcrumbSchema([
    { name: "ホーム", path: "/" },
    { name: "制作例・デモ", path: "/works/" },
  ]),
];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <!-- Background -->
  <div class="bg-decoration">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="grid-overlay"></div>
    <div class="sakura-container" id="sakura-container"></div>
  </div>

  <script is:inline>
    function initSakura() {
      const container = document.getElementById('sakura-container');
      if (!container) return;
      container.innerHTML = '';
      for (let i = 0; i < 20; i++) {
        const petal = document.createElement('div');
        petal.className = 'petal-subtle';
        petal.style.left = Math.random() * 100 + '%';
        petal.style.width = Math.random() * 8 + 4 + 'px';
        petal.style.height = petal.style.width;
        petal.style.animationDuration = Math.random() * 5 + 7 + 's';
        petal.style.animationDelay = Math.random() * 5 + 's';
        container.appendChild(petal);
      }
    }
    initSakura();
    document.addEventListener('astro:page-load', initSakura);
  </script>

  <main class="works-page">
    <section class="section works-hero">
      <div class="container narrow">
        <span class="eyebrow">Works & Demos</span>
        <h1 class="premium-heading">制作例・デモ・ツール</h1>
        <p class="lead">
          ホームページ制作・LP制作の見え方を中心に、和-Node独自の視点（心理学・AI・アクセシビリティ）を形にした<br class="pc-only" />
          制作サンプルとデモツールを公開しています。技術と知見の融合を体験してください。
        </p>
      </div>
    </section>

    <div class="container">
      <section class="priority-works reveal" aria-labelledby="priority-works-title">
        <div class="priority-copy">
          <span class="eyebrow">First View</span>
          <h2 id="priority-works-title" class="premium-heading">迷ったら、まずはこの3つをご覧ください</h2>
          <p>まずはWeb制作・LP制作の見え方を中心に、必要に応じてAI・ICTの実装力も確認できます。</p>
        </div>
        <div class="priority-grid">
          <a href="/psychology-demo/" class="priority-card main">
            <span>選ばれる導線の強み</span>
            <h3>選ばれる導線デモ</h3>
            <p>配置・言葉・CTAの理由を、心理学的な根拠と一緒に体験できます。</p>
          </a>
          <a href="/portfolio-lp/lp_clinic.html" class="priority-card">
            <span>LP制作サンプル</span>
            <h3>クリニック・医療系LP</h3>
            <p>信頼形成と予約導線を両立させた、LP制作の見え方を確認できます。</p>
          </a>
          <a href="/ai-chat-demo/" class="priority-card">
            <span>AI・ICT実装</span>
            <h3>AI相談内容整理ナビ</h3>
            <p>曖昧な相談内容を、Web制作やICT活用の観点で整理するデモです。</p>
          </a>
        </div>
        <div class="priority-cta">
          <a href="/contact/">この方向で相談する</a>
        </div>
      </section>

      <!-- Filter Tabs -->
      <nav class="filter-nav" id="filter-nav">
        <button class="filter-btn active" data-filter="all">すべて</button>
        <button class="filter-btn" data-filter="web">Web & LP</button>
        <button class="filter-btn" data-filter="tool">診断・ツール</button>
        <button class="filter-btn" data-filter="system">AI・システム</button>
        <button class="filter-btn" data-filter="kdp">KDP出版</button>
      </nav>

      <div class="works-grid" id="works-grid">
        
        <!-- Category: Web (Psychology Demo) -->
        <article class="work-card reveal" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg" style="background: linear-gradient(135deg, #fdfcf9 0%, #f5eee0 100%);">
              <img src="/images/works-psy-demo.png" alt="選ばれる導線デモ" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.style.display='none'" />
              <span class="category-tag demo">Web導線デモ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Psychology Logic</div>
            <h3>選ばれる導線デモ</h3>
            <p class="card-text">なぜそのボタンはそこにあるのか？心理学的根拠に基づいた情報配置の「正解」を、解説付きで体験できる特別なデモページです。</p>
            <div class="card-footer">
              <span class="tech-tag">UI/UX</span>
              <span class="tech-tag">Psychology</span>
              <a href="/psychology-demo/" class="card-link">デモを体験する →</a>
            </div>
          </div>
        </article>

        <!-- Category: Web (Medical) -->
        <article class="work-card reveal" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/portfolio-lp/images/hero_clinic.png" alt="クリニック・医療系LP" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag sample">LP制作サンプル</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Medical / Clinic</div>
            <h3>クリニック・医療系LP</h3>
            <p class="card-text">美容クリニック、心療内科等を想定したLP制作サンプル。医療広告ガイドラインに配慮しつつ、安心感と予約導線を両立させた構成例です。</p>
            <div class="card-footer">
              <div class="tech-stack"><span>#UX Design</span><span>#Trust</span></div>
              <a href="/portfolio-lp/lp_clinic.html" class="premium-link">作品を見る</a>
            </div>
          </div>
        </article>

        <!-- Category: System (AI Demo) -->
        <article class="work-card reveal" data-category="web">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/portfolio-lp/images/hero_corporate.png" alt="LP制作サンプル集" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag sample">LPサンプル集</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">LP Portfolio</div>
            <h3>LP制作サンプル集</h3>
            <p class="card-text">業種別のLP制作サンプルをまとめたギャラリーです。ファーストビュー、信頼形成、CTAまでの見せ方を比較できます。</p>
            <div class="card-footer">
              <span class="tech-tag">LP Design</span>
              <span class="tech-tag">Sample</span>
              <a href="/lp-portfolio/" class="card-link">サンプルを見る →</a>
            </div>
          </div>
        </article>

        <!-- Category: System (AI Demo) -->
        <article class="work-card reveal" data-category="system">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg">
              <img src="/images/works-system.png" alt="AI相談内容整理ナビ" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo">AIデモ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">AI Solution</div>
            <h3>AI相談内容整理ナビ</h3>
            <p class="card-text">ユーザーの漠然とした悩みを、Web制作やICT活用の切り口でAIが整理。OpenAI APIを活用した実用的なAI接客のデモアプリケーションです。</p>
            <div class="card-footer">
              <span class="tech-tag">OpenAI API</span>
              <span class="tech-tag">Astro</span>
              <a href="/ai-chat-demo/" class="card-link">ナビを試す →</a>
            </div>
          </div>
        </article>

        <!-- Category: Tool (Mental) -->
        <article class="work-card reveal" data-category="tool">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg">
              <img src="/images/works-mental.png" alt="こころの疲労度診断" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo">診断デモ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Mental Health</div>
            <h3>こころの疲労度診断</h3>
            <p class="card-text">産業カウンセラーの知見をシステム化。現在のストレス要因を可視化し、適切なケアへの気づきを促すインタラクティブな診断ツールです。</p>
            <div class="card-footer">
              <span class="tech-tag">Logic</span>
              <span class="tech-tag">Empathy UI</span>
              <a href="/mental_care/" class="card-link">診断を体験する →</a>
            </div>
          </div>
        </article>

        <!-- Category: Tool (Accessibility) -->
        <article class="work-card reveal" data-category="tool">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg">
              <img src="/images/works-accessibility.png" alt="バリアフリー診断" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo">診断デモ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Accessibility</div>
            <h3>セルフ・バリアフリー診断</h3>
            <p class="card-text">車いすユーザー視点でのアクセシビリティチェック。物理的な障壁を可視化し、改善の第一歩をサポートするための診断アプリです。</p>
            <div class="card-footer">
              <span class="tech-tag">UD Design</span>
              <span class="tech-tag">SVG Gauge</span>
              <a href="/barrier_free/" class="card-link">診断を体験する →</a>
            </div>
          </div>
        </article>

        <!-- Category: Tool (SEO) -->
        <article class="work-card reveal" data-category="tool">
          <div class="card-visual-wrap">
            <div class="card-visual tool-bg">
              <img src="/images/works-seo.png" alt="SEO/AEO内部診断" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag demo">SEO/AEOデモ</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">SEO / AEO Analysis</div>
            <h3>SEO/AEO内部診断</h3>
            <p class="card-text">Webサイトの健全性を30項目でチェック。検索エンジンだけでなく、AI検索に読まれやすい構造まで分かりやすく確認できます。</p>
            <div class="card-footer">
              <span class="tech-tag">SEO</span>
              <span class="tech-tag">AEO</span>
              <span class="tech-tag">Marketing</span>
              <a href="/seo_check/" class="card-link">診断を体験する →</a>
            </div>
          </div>
        </article>

        <!-- Category: KDP -->
        <article class="work-card reveal" data-category="kdp">
          <div class="card-visual-wrap">
            <div class="card-visual">
              <img src="/images/works-kdp.png" alt="Amazon KDP 出版実績" style="width: 100%; height: 100%; object-fit: cover;" />
              <span class="category-tag real">実案件</span>
            </div>
          </div>
          <div class="card-body">
            <div class="expert-label">Publishing</div>
            <h3>Amazon KDP 出版実績</h3>
            <p class="card-text">浮世絵や伝統文様をモチーフにした海外市場向け書籍制作。和の美しさを世界へ届けるブランディング支援の実績です。</p>
            <div class="card-footer">
              <span class="tech-tag">Global</span>
              <span class="tech-tag">Design</span>
              <a href="/kdp_books/" class="card-link">実績を見る →</a>
            </div>
          </div>
        </article>

      </div>
    </div>

    <ConsultationFlow />

    <!-- Standard Packages CTA -->
    <section class="packages-cta reveal">
      <div class="container glass-panel">
        <div class="cta-label">ANNIVERSARY SPECIAL</div>
        <h2>近い方向性をもとに相談できます</h2>
        <p>制作例やデモを見て「この方向に近い」と感じたものがあれば、そのまま無料相談でお知らせください。</p>
        <div class="cta-btns">
          <a href="/contact/" class="btn-secondary-outline">近い方向で相談する</a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

    :root {
      --accent: #c5a059;
      --accent-dark: #b18e4a;
      --accent-red: #d14d3a;
      --trust: #0f4c5c;
      --trust-mid: #1f6f78;
      --trust-line: rgba(15, 76, 92, 0.18);
      --glass: rgba(255, 255, 255, 0.85);
      --glass-border: rgba(197, 160, 89, 0.2);
      --tag-works: #2c7c5e;
      --tag-sample: #c5a059;
      --tag-demo: #2c5e7c;
      --text-deep: #1a1a1a;
    }

    .premium-heading {
      font-family: 'Shippori Mincho', serif !important;
      font-weight: 800 !important;
      letter-spacing: 0.05em;
    }

    /* Background Decoration */
    .bg-decoration {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      z-index: -1; background: #fdfcf9; overflow: hidden;
    }
    .bg-decoration::after {
      content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3FfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3F/filter%3E%3Frect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3F/svg%3E");
      opacity: 0.05; pointer-events: none;
    }
    .sakura-container {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
    }
    .petal-subtle {
      position: absolute; background: #ffb7c5; border-radius: 150% 0 150% 0;
      opacity: 0.4; animation: fall-subtle linear infinite;
    }
    @keyframes fall-subtle {
      0% { transform: translateY(-10vh) rotate(0deg); opacity: 0; }
      10% { opacity: 0.4; }
      90% { opacity: 0.4; }
      100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
    }

    .works-page { padding-bottom: 100px; font-family: 'Shippori Mincho', serif !important; }
    .works-hero { padding: 80px 0 60px; text-align: center; }
    
    .works-anniversary-banner { margin-bottom: 40px; }
    .works-anniversary-banner a {
      display: block; background: #fff; border: 1px solid var(--accent-red);
      border-radius: 20px; padding: 20px 30px; text-decoration: none;
      transition: 0.4s; box-shadow: 0 10px 30px rgba(209, 77, 58, 0.1);
    }
    .works-anniversary-banner a:hover { transform: translateY(-3px); }
    .ann-label {
      display: inline-block; background: var(--accent-red); color: white;
      font-size: 0.75rem; font-weight: 800; padding: 4px 12px; border-radius: 4px;
      margin-bottom: 8px;
    }
    .ann-content { display: flex; align-items: center; justify-content: center; gap: 20px; color: #2c2c2c; }
    .ann-content strong { font-size: 1.2rem; color: var(--accent-red); }

    .eyebrow { font-size: 0.85rem; font-weight: 800; color: var(--accent); letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 16px; display: block; }
    .lead { font-size: 1.1rem; color: #555; line-height: 1.8; max-width: 800px; margin: 0 auto; }

    .priority-works {
      margin-bottom: 60px;
      padding: 36px;
      background: rgba(255, 255, 255, 0.75);
      border: 1px solid var(--glass-border);
      border-radius: 28px;
      box-shadow: 0 18px 45px rgba(0, 0, 0, 0.03);
    }
    .priority-copy {
      max-width: 720px;
      margin: 0 auto 28px;
      text-align: center;
    }
    .priority-copy h2 {
      margin-bottom: 14px;
      color: var(--text-deep);
      font-size: 1.9rem;
    }
    .priority-copy p {
      margin: 0;
      color: #666;
      line-height: 1.8;
    }
    .priority-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
    }
    .priority-card {
      display: flex;
      min-height: 220px;
      flex-direction: column;
      justify-content: space-between;
      gap: 12px;
      padding: 26px 22px;
      background: #fff;
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      color: #333;
      text-decoration: none;
      transition: 0.3s;
    }
    .priority-card:hover {
      transform: translateY(-4px);
      border-color: var(--trust-mid);
      box-shadow: 0 18px 38px rgba(0, 0, 0, 0.06);
    }
    .priority-card.main {
      border: 2px solid var(--trust-line);
      background: linear-gradient(135deg, rgba(15, 76, 92, 0.06), rgba(197, 160, 89, 0.06)), #fff;
    }
    .priority-card span {
      align-self: flex-start;
      padding: 4px 10px;
      background: rgba(15, 76, 92, 0.08);
      border-radius: 999px;
      color: var(--trust);
      font-size: 0.72rem;
      font-weight: 800;
    }
    .priority-card h3 {
      margin: 0;
      color: var(--text-deep);
      font-size: 1.18rem;
      line-height: 1.45;
    }
    .priority-card p {
      margin: 0;
      color: #666;
      font-size: 0.9rem;
      line-height: 1.7;
    }
    .priority-cta {
      margin-top: 26px;
      text-align: center;
    }
    .priority-cta a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 12px 28px;
      border-radius: 999px;
      background: var(--trust);
      color: #fff;
      text-decoration: none;
      font-weight: 800;
      box-shadow: 0 12px 26px rgba(15, 76, 92, 0.18);
      transition: 0.3s;
    }
    .priority-cta a:hover {
      background: #123c45;
      transform: translateY(-2px);
    }

    /* Filter Nav */
    .filter-nav { display: flex; justify-content: center; gap: 12px; margin-bottom: 60px; flex-wrap: wrap; }
    .filter-btn {
      padding: 12px 28px; border-radius: 999px; background: #fff;
      border: 1px solid var(--glass-border); color: #666; font-weight: 800;
      cursor: pointer; transition: 0.3s;
    }
    .filter-btn.active { background: var(--trust); color: #fff; border-color: var(--trust); }

    /* Works Grid */
    .works-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 32px; }

    .work-card {
      background: #fff; border: 1px solid var(--glass-border); border-radius: 24px;
      overflow: hidden; display: flex; flex-direction: column;
      transition: 0.4s; box-shadow: 0 10px 20px rgba(0,0,0,0.02);
    }
    .work-card:hover { transform: translateY(-10px); border-color: var(--trust-mid); }

    .card-visual-wrap { padding: 12px; }
    .card-visual { height: 160px; border-radius: 16px; overflow: hidden; position: relative; background: #f5f5f5; }
    
    .category-tag {
      position: absolute; top: 12px; left: 12px; font-size: 0.65rem; font-weight: 800;
      padding: 4px 10px; border-radius: 999px; z-index: 2;
    }
    .category-tag.real { background: var(--accent-red); color: #fff; }
    .category-tag.demo { background: var(--tag-demo); color: #fff; }
    .category-tag.sample { background: var(--accent); color: #fff; }

    .card-body { padding: 24px; flex: 1; display: flex; flex-direction: column; }
    .expert-label { font-size: 0.75rem; font-weight: 800; color: var(--accent); letter-spacing: 0.1em; margin-bottom: 8px; }
    .card-body h3 { font-size: 1.25rem; font-weight: 800; margin-bottom: 12px; line-height: 1.4; }
    .card-text { font-size: 0.9rem; color: #666; line-height: 1.7; margin-bottom: 20px; flex: 1; }

    .card-footer { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-top: auto; }
    .tech-tag { font-size: 0.7rem; font-weight: 800; color: #888; background: #f5f5f5; padding: 4px 8px; border-radius: 4px; }
    .card-link, .premium-link { margin-left: auto; font-size: 0.85rem; font-weight: 800; color: var(--trust); text-decoration: none; }

    .packages-cta { margin-top: 100px; }
    .glass-panel {
      background: #3a2e26; color: white; border-radius: 32px; padding: 60px 20px;
      text-align: center; border: 1px solid var(--accent);
    }
    .cta-label { font-size: 0.8rem; font-weight: 800; color: var(--accent); letter-spacing: 0.3em; margin-bottom: 16px; }
    .glass-panel h2 { font-size: 1.8rem; margin-bottom: 20px; font-weight: 800; }
    .glass-panel p { font-size: 1rem; opacity: 0.8; margin-bottom: 32px; }

    .btn-secondary-outline {
      display: inline-block; border: 2px solid var(--accent); color: var(--accent);
      padding: 12px 36px; border-radius: 50px; text-decoration: none; font-weight: 800; transition: 0.3s;
    }
    .btn-secondary-outline:hover { background: var(--accent); color: white; }

    .reveal { opacity: 0; transform: translateY(20px); transition: 0.6s ease-out; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 768px) {
      .priority-works { padding: 28px 20px; }
      .priority-copy { text-align: left; }
      .priority-copy h2 { font-size: 1.55rem; }
      .priority-grid { grid-template-columns: 1fr; }
      .priority-card { min-height: auto; }
      .works-grid { grid-template-columns: 1fr; }
    }
</style>

<script is:inline>
    function initWorks() {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const workCards = document.querySelectorAll('.work-card');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = btn.dataset.filter;
          filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          workCards.forEach(card => {
            if (filter === 'all' || card.dataset.category === filter) {
              card.style.display = 'flex';
              setTimeout(() => card.classList.add('visible'), 50);
            } else {
              card.style.display = 'none';
              card.classList.remove('visible');
            }
          });
        });
      });

      const io = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    }
    initWorks();
    document.addEventListener('astro:page-load', initWorks);
</script>
