            <div class="mini-flow">
              <span>{serviceVisuals[lang][2].flow[0]}</span>
              <i></i>
              <span>{serviceVisuals[lang][2].flow[1]}</span>
              <i></i>
              <span>{serviceVisuals[lang][2].flow[2]}</span>
            </div>
          </div>
