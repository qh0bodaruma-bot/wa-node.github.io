        </h1>
        <p class="lead" set:html={t.hero.lead[lang]}></p>
        <div class="btns">
          <a class="btn primary" href={getLocalizedLink('/contact')}>{t.hero.btn_consult[lang]}</a>
          <a class="btn secondary" href={getLocalizedLink('/pricing')}>{t.hero.btn_price[lang]}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-strip" aria-label={lang === 'ja' ? '和-Nodeの安心材料' : 'Wa-Node trust signals'}>
    <div class="trust-strip-inner">
      {trustSignals[lang].map((signal) => (
        <div class="trust-signal">
          <strong>{signal.value}</strong>
          <span>{signal.label}</span>
        </div>
