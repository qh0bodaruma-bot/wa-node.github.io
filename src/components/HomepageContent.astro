</main>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

  :root {
    --accent: #8c6b1f;
    --accent-dark: #725719;
    --accent2: #c7352f;
    --accent2-dark: #b62f29;
    --trust: #0f4c5c;
    --trust-mid: #1f6f78;
    --trust-line: rgba(15, 76, 92, 0.18);
    --text: #333;
    --text-deep: #1a1a1a;
    --muted: #666;
    --line: rgba(140, 107, 31, 0.2);
    --soft: #f3eadf;
    --white: #ffffff;
    --paper: #f6efe5;
    --surface: #fffdf8;
    --surface-strong: #fffaf2;
    --surface-cool: #eef5f2;
    --card-border: rgba(15, 76, 92, 0.14);
    --card-border-warm: rgba(140, 107, 31, 0.24);
    --card-shadow: 0 16px 38px rgba(15, 76, 92, 0.075), 0 4px 14px rgba(70, 52, 32, 0.045);
    --card-shadow-hover: 0 24px 52px rgba(15, 76, 92, 0.12), 0 8px 20px rgba(70, 52, 32, 0.07);
    --radius: 16px;
  }

  body {
    font-family: 'Shippori Mincho', serif;
    color: var(--text);
    line-height: 1.8;
    background:
      linear-gradient(180deg, #fbf7ef 0%, var(--paper) 48%, #f2e8dc 100%);
  }
  .home-content {
    --home-action: #c7352f;
    --home-action-dark: #b62f29;
    --home-gold: #8c6b1f;
    --home-gold-dark: #725719;
    --home-cool: #eef5f2;
  }
  .section { padding: 80px 0; }
  .section-inner { max-width: 1000px; margin: 0 auto; padding: 0 20px; }

  h1, h2, h3, h4 { font-family: 'Shippori Mincho', serif; font-weight: 800; color: var(--text-deep); }
  h1 { font-size: clamp(2.2rem, 5vw, 4rem); line-height: 1.2; margin-bottom: 24px; }
  h2 { font-size: clamp(1.8rem, 4vw, 2.5rem); margin-bottom: 32px; }

  .tagline-top { font-size: 1.1rem; color: var(--home-gold); font-weight: 800; letter-spacing: 0.08em; margin-bottom: 8px; max-width: 100%; overflow-wrap: anywhere; line-break: strict; text-wrap: balance; }
  .lead { font-size: 1.2rem; color: var(--muted); margin-bottom: 40px; max-width: 700px; }
  .lead strong { color: var(--accent); }

  .btns { display: flex; gap: 16px; margin-top: 40px; }
  .btn { padding: 18px 36px; border-radius: 12px; font-weight: 800; text-decoration: none; transition: all 0.3s ease; text-align: center; }
  .btn.primary { background: var(--home-action); color: white; border: 1px solid var(--home-action); box-shadow: 0 10px 25px rgba(199, 53, 47, 0.24); }
  .btn.primary:hover { background: var(--home-action-dark); border-color: var(--home-action-dark); transform: translateY(-2px); box-shadow: 0 12px 30px rgba(199, 53, 47, 0.32); }
  .btn.secondary { border: 1px solid rgba(140, 107, 31, 0.5); color: var(--home-gold); background: transparent; }
  .btn.secondary:hover { border-color: var(--home-gold); background: rgba(140, 107, 31, 0.06); transform: translateY(-1px); }

  /* Hero */
  .hero { 
    --hero-accent: var(--home-action);
    padding: 160px 0 120px; 
    background: 
      linear-gradient(to right, rgba(253, 250, 245, 1) 40%, rgba(253, 250, 245, 0.9) 55%, rgba(253, 250, 245, 0.2) 80%, rgba(253, 250, 245, 0) 100%), 
      url('/images/hero.png') no-repeat right center/cover;
    min-height: 520px;
    display: flex;
    align-items: center;
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; padding: 0 40px; width: 100%; }
  .hero-content { max-width: 650px; }
  .hero-badge { display: inline-block; background: var(--hero-accent); color: white; padding: 6px 16px; border-radius: 4px; font-size: 0.85rem; font-weight: 800; margin-bottom: 24px; }
  .highlight-text { border-bottom: 3px double var(--home-gold); padding-bottom: 2px; color: var(--hero-accent); font-weight: 800; }

  /* ジャンプ率・タイポグラフィの心理設計クラス */
  .hero-title-chosen {
    font-size: clamp(2.6rem, 5.8vw, 4.8rem);
    font-weight: 900;
    color: var(--hero-accent);
    letter-spacing: -0.05em;
  }
  .hero-title-sub {
    font-size: clamp(1.1rem, 2.5vw, 1.8rem);
    font-weight: 500;
    color: var(--muted);
    margin-left: 2px;
  }
  .hero-title-psy {
    font-size: clamp(2.3rem, 5.2vw, 4.2rem);
    font-weight: 900;
    color: var(--text-deep);
    border-bottom: 3px double var(--home-gold);
    padding-bottom: 2px;
    letter-spacing: -0.02em;
  }
  .hero-title-base {
    font-size: clamp(1.6rem, 3.5vw, 2.8rem);
    font-weight: 800;
    color: var(--text-deep);
  }

  .trust-strip {
    background: linear-gradient(90deg, var(--surface) 0%, var(--surface-cool) 100%);
    border-bottom: 1px solid var(--trust-line);
    box-shadow: inset 0 -1px 0 rgba(255, 255, 255, 0.72);
  }
  .trust-strip-inner {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    max-width: 1000px;
    margin: 0 auto;
    border-left: 1px solid var(--trust-line);
  }
  .trust-signal {
    padding: 18px 24px;
    border-right: 1px solid var(--trust-line);
    text-align: center;
  }
  .trust-signal strong {
    display: block;
    color: var(--trust);
    font-size: 1.08rem;
    font-weight: 900;
    line-height: 1.4;
  }
  .trust-signal span {
    display: block;
    margin-top: 3px;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.5;
  }

  /* Agitation / Hook Section */
  .why-psy { background: var(--paper); border-bottom: 1px solid var(--line); }
  .why-psy-inner { max-width: 900px; margin: 0 auto; padding: 0 20px; }
