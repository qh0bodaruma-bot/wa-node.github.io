            <a href={getLocalizedLink('/easy-guide') + '#gas-section'} class="sub-link-text">{t.services.sub_link_gas[lang]}</a>
          </div>
          <a href={`${getLocalizedLink('/pricing')}#copilot`} class="card-link">{t.services.card3_link[lang]}</a>
        </article>
        <article class="consult-card">
          <div class="service-visual" aria-hidden="true">
            <span class="service-mark">{serviceVisuals[lang][3].mark}</span>
            <div class="mini-flow">
              <span>{serviceVisuals[lang][3].flow[0]}</span>
              <i></i>
              <span>{serviceVisuals[lang][3].flow[1]}</span>
              <i></i>
              <span>{serviceVisuals[lang][3].flow[2]}</span>
            </div>
          </div>
          <span class="card-tag">{t.services.card4_tag[lang]}</span>
          <h3>{t.services.card4_title[lang]}</h3>
          <p class="service-fit">{serviceAudiences[lang][3]}</p>
          <ul class="service-chips" aria-label={chipLabel[lang]}>
            {serviceVisuals[lang][3].chips.map((chip) => <li>{chip}</li>)}
          </ul>
          <p class="service-summary">{serviceVisuals[lang][3].summary}</p>
          <details class="service-details">
            <summary>{detailLabel[lang]}</summary>
            <p>{t.services.card4_desc[lang]}</p>
          </details>
          <a href={`${getLocalizedLink('/pricing')}#ict-ai`} class="card-link">{t.services.card4_link[lang]}</a>
        </article>
      </div>
    </div>
  </section>

  <!-- 3. Experience (Psychology & AI) -->
  <section class="section" id="experience" style="background: var(--paper);">
    <div class="section-inner">
      <div class="section-title" style="text-align: center;">
        <span class="eyebrow">{t.experience.eyebrow[lang]}</span>
        <h2>{t.experience.title[lang]}</h2>
      </div>
      <div class="action-buttons-grid reveal">
        <a href={getLocalizedLink('/psychology-demo')} class="action-card highlight-border">
          <div class="action-icon">💡</div>
          <h3>{t.experience.card1_title[lang]}</h3>
          <p>{t.experience.card1_desc[lang]}</p>
        </a>
        <a href={getLocalizedLink('/ai-chat-demo')} class="action-card">
          <div class="action-icon">🤖</div>
          <h3>{t.experience.card2_title[lang]}</h3>
          <p>{t.experience.card2_desc[lang]}</p>
        </a>
        <a href={getLocalizedLink('/simulator')} class="action-card">
          <div class="action-icon">💰</div>
          <h3>{t.experience.card3_title[lang]}</h3>
          <p>{t.experience.card3_desc[lang]}</p>
        </a>
      </div>
      <div style="text-align: center; margin-top: 40px;">
        <a href={getLocalizedLink('/works')} style="color: var(--accent); font-weight: 800; text-decoration: underline;">{t.experience.all_works[lang]}</a>
      </div>
    </div>
  </section>

  <!-- 5. Visual Proof (Offer) -->
  <section class="section visual-proof" style="background: var(--surface); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);">
    <div class="section-inner" style="max-width: 800px; text-align: center;">
      <span class="eyebrow" style="color: var(--accent2);">{t.proof.eyebrow[lang]}</span>
      <h2>{t.proof.title[lang]}</h2>
      <p style="font-size: 1.1rem; color: var(--text); line-height: 1.8; margin-bottom: 32px;" set:html={t.proof.desc[lang]}></p>
    </div>
  </section>

  <!-- 6. Consultation Flow (Simplified) -->
  <section class="section flow" id="flow">
    <div class="section-inner">
      <div class="section-title" style="text-align: center;">
        <span class="eyebrow">{t.flow.eyebrow[lang]}</span>
        <h2>{t.flow.title[lang]}</h2>
      </div>
      <div class="simple-flow-grid">
        <div class="flow-item">
          <span class="flow-num">1</span>
          <h4>{t.flow.step1_title[lang]}</h4>
          <p>{t.flow.step1_desc[lang]}</p>
        </div>
        <div class="flow-item">
          <span class="flow-num">2</span>
          <h4>{t.flow.step2_title[lang]}</h4>
          <p>{t.flow.step2_desc[lang]}</p>
        </div>
        <div class="flow-item">
          <span class="flow-num">3</span>
          <h4>{t.flow.step3_title[lang]}</h4>
          <p>{t.flow.step3_desc[lang]}</p>
        </div>
      </div>
      <div class="btns" style="justify-content: center; margin-top: 60px;">
        <a class="btn primary" href={getLocalizedLink('/contact')}>{t.flow.btn_cta[lang]}</a>
      </div>
    </div>
