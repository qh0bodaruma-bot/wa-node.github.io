---
<main class="home-content">
  <!-- 1. Hero Section -->
  <section class="section hero">
    <div class="hero-inner">
      <div class="hero-content reveal">
        <div class="hero-badge">{t.hero.badge[lang]}</div>
        <p class="tagline-top" data-glossary-skip>{t.hero.tagline[lang]}</p>
        <h1 data-glossary-skip>
          {lang === 'ja' ? (
            <>
              <span class="hero-title-chosen">心理学に強い</span>
              <br />
              <span class="hero-title-psy">Web制作・LP改善</span>
            </>
