          <h3>{t.services.card1_title[lang]}</h3>
          <p class="service-fit">{serviceAudiences[lang][0]}</p>
          <ul class="service-chips" aria-label={chipLabel[lang]}>
            {serviceVisuals[lang][0].chips.map((chip) => <li>{chip}</li>)}
          </ul>
