---
import t from '../i18n/translations.json';

interface Props {
  lang?: 'ja' | 'en' | 'fr';
}

const { lang = 'ja' } = Astro.props;

function getLocalizedLink(path: string) {
  const cleanPath = path.replace(/\/+/g, '/');
  if (lang === 'ja') {
    return cleanPath.endsWith('/') ? cleanPath : `${cleanPath}/`;
  }
  
  // en or fr: For existing multi-language pages
  const validPages = ['/', '', '/contact', '/works', '/pricing', '/about', '/kdp_books', '/psychology-demo', '/ai-chat-demo', '/simulator', '/demos', '/barrier_free', '/mental_care', '/corporate-mental', '/lp-portfolio'];
  const basePage = cleanPath.split(/[?#]/)[0];
  
  if (validPages.includes(basePage)) {
    const langPath = basePage === '/' || basePage === '' ? `/${lang}/` : `/${lang}${cleanPath}/`;
    return langPath.replace(/\/+/g, '/');
  }
  
  // For other pages that do not have multi-language files, fallback to Japanese page with ?lang parameter
  const fallbackPath = cleanPath.endsWith('/') ? cleanPath : `${cleanPath}/`;
  return `${fallbackPath}?lang=${lang}`;
}

const serviceAudiences = {
  ja: [
    'まず信頼されるサイトを作りたい方へ',
    '公開後も改善や判断を相談したい方へ',
    '業務整理やAI活用から始めたい方へ'
  ],
  en: [
    'For people who need a trustworthy site first',
    'For people who want ongoing decisions and improvements',
    'For people starting with workflow or AI support'
  ],
  fr: [
    'Pour creer d abord un site digne de confiance',
    'Pour continuer a ameliorer et decider apres lancement',
    'Pour commencer par l organisation et l IA'
  ]
};

const trustSignals = {
  ja: [
    { value: '20年以上', label: 'IT・Web制作の現場経験' },
    { value: '心理学', label: '信頼される導線設計に応用' },
    { value: '公開後', label: '改善・運用まで継続支援' }
  ],
  en: [
    { value: '20+ years', label: 'IT and web production experience' },
    { value: 'Psychology', label: 'Applied to trust-building flows' },
    { value: 'After launch', label: 'Ongoing improvement and support' }
  ],
  fr: [
    { value: '20+ ans', label: 'Experience IT et creation web' },
    { value: 'Psychologie', label: 'Appliquee aux parcours de confiance' },
    { value: 'Apres lancement', label: 'Amelioration et accompagnement' }
  ]
};
---
<main>
  <!-- 1. Hero Section -->
  <section class="section hero">
    <div class="hero-inner">
      <div class="hero-content reveal">
        <div class="hero-badge">{t.hero.badge[lang]}</div>
        <p class="tagline-top">{t.hero.tagline[lang]}</p>
        <h1>
          {lang === 'ja' ? (
            <>
              <span class="hero-title-chosen">「選ばれる」</span>
              <span class="hero-title-sub">には、</span>
              <br />
              <span class="hero-title-psy">心理学</span>
              <span class="hero-title-base">的な根拠がある。</span>
            </>
          ) : (
            <>
              {t.hero.title_part1[lang]}<br /><span class="highlight-text">{t.hero.title_highlight[lang]}</span>{t.hero.title_part2[lang]}
            </>
          )}
        </h1>
        <p class="lead" set:html={t.hero.lead[lang]}></p>
        <div class="btns">
          <a class="btn primary" href={getLocalizedLink('/contact')}>{t.hero.btn_consult[lang]}</a>
          <a class="btn secondary" href={getLocalizedLink('/pricing')}>{t.hero.btn_price[lang]}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-strip" aria-label={lang === 'ja' ? '和-Nodeの安心材料' : 'Wa-Node trust signals'}>
    <div class="trust-strip-inner">
      {trustSignals[lang].map((signal) => (
        <div class="trust-signal">
          <strong>{signal.value}</strong>
          <span>{signal.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- 1.5. Agitation Section (For frustrated/skeptical users) -->
  <section class="section why-psy">
    <div class="section-inner why-psy-inner">
      <div class="question-box">
        <span class="q-eyebrow">{t.why_psy.eyebrow[lang]}</span>
        <h2>{t.why_psy.title[lang]}</h2>
        <p class="q-lead">{t.why_psy.lead[lang]}</p>
      </div>
      <div class="concept-intro-grid">
        <div class="concept-intro-card highlight-card">
          <div class="card-num">💡</div>
          <h3>{t.why_psy.card1_title[lang]}</h3>
          <p>{t.why_psy.card1_desc[lang]}</p>
        </div>
        <div class="concept-intro-card">
          <div class="card-num">📈</div>
          <h3>{t.why_psy.card2_title[lang]}</h3>
          <p>{t.why_psy.card2_desc[lang]}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Services (Minimal) -->
  <section class="section" id="services">
    <div class="section-inner">
      <div class="section-title">
        <span class="eyebrow">{t.services.eyebrow[lang]}</span>
        <h2>{t.services.title[lang]}</h2>
      </div>
      <div class="consult-grid">
        <article class="consult-card highlight">
          <span class="card-tag">{t.services.card1_tag[lang]}</span>
          <h3>{t.services.card1_title[lang]}</h3>
          <p class="service-fit">{serviceAudiences[lang][0]}</p>
          <p>{t.services.card1_desc[lang]}</p>
          <div class="card-sub-links">
            <a href={getLocalizedLink('/easy-guide')} class="sub-link-text">{t.services.sub_link_hp_lp[lang]}</a>
          </div>
          <a href={`${getLocalizedLink('/pricing')}#web-production`} class="card-link">{t.services.card1_link[lang]}</a>
        </article>
        <article class="consult-card">
          <span class="card-tag">{t.services.card2_tag[lang]}</span>
          <h3>{t.services.card2_title[lang]}</h3>
          <p class="service-fit">{serviceAudiences[lang][1]}</p>
          <p>{t.services.card2_desc[lang]}</p>
          <div class="card-sub-links">
            <a href={getLocalizedLink('/easy-guide') + '#gas-section'} class="sub-link-text">{t.services.sub_link_gas[lang]}</a>
          </div>
          <a href={`${getLocalizedLink('/pricing')}#copilot`} class="card-link">{t.services.card2_link[lang]}</a>
        </article>
        <article class="consult-card">
          <span class="card-tag">{t.services.card3_tag[lang]}</span>
          <h3>{t.services.card3_title[lang]}</h3>
          <p class="service-fit">{serviceAudiences[lang][2]}</p>
          <p>{t.services.card3_desc[lang]}</p>
          <a href={`${getLocalizedLink('/pricing')}#ict-ai`} class="card-link">{t.services.card3_link[lang]}</a>
        </article>
      </div>
    </div>
  </section>

  <!-- 3. Experience (Psychology & AI) -->
  <section class="section" id="experience" style="background: var(--soft);">
    <div class="section-inner">
      <div class="section-title" style="text-align: center;">
        <span class="eyebrow">{t.experience.eyebrow[lang]}</span>
        <h2>{t.experience.title[lang]}</h2>
      </div>
      <div class="action-buttons-grid reveal">
        <a href={getLocalizedLink('/psychology-demo')} class="action-card highlight-border">
          <div class="action-icon">💡</div>
          <h3>{t.experience.card1_title[lang]}</h3>
          <p>{t.experience.card1_desc[lang]}</p>
        </a>
        <a href={getLocalizedLink('/ai-chat-demo')} class="action-card">
          <div class="action-icon">🤖</div>
          <h3>{t.experience.card2_title[lang]}</h3>
          <p>{t.experience.card2_desc[lang]}</p>
        </a>
        <a href={getLocalizedLink('/simulator')} class="action-card">
          <div class="action-icon">💰</div>
          <h3>{t.experience.card3_title[lang]}</h3>
          <p>{t.experience.card3_desc[lang]}</p>
        </a>
      </div>
      <div style="text-align: center; margin-top: 40px;">
        <a href={getLocalizedLink('/works')} style="color: var(--accent); font-weight: 800; text-decoration: underline;">{t.experience.all_works[lang]}</a>
      </div>
    </div>
  </section>

  <!-- 5. Visual Proof (Offer) -->
  <section class="section visual-proof" style="background: var(--white); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);">
    <div class="section-inner" style="max-width: 800px; text-align: center;">
      <span class="eyebrow" style="color: var(--accent2);">{t.proof.eyebrow[lang]}</span>
      <h2>{t.proof.title[lang]}</h2>
      <p style="font-size: 1.1rem; color: var(--text); line-height: 1.8; margin-bottom: 32px;" set:html={t.proof.desc[lang]}></p>
    </div>
  </section>

  <!-- 6. Consultation Flow (Simplified) -->
  <section class="section flow" id="flow">
    <div class="section-inner">
      <div class="section-title" style="text-align: center;">
        <span class="eyebrow">{t.flow.eyebrow[lang]}</span>
        <h2>{t.flow.title[lang]}</h2>
      </div>
      <div class="simple-flow-grid">
        <div class="flow-item">
          <span class="flow-num">1</span>
          <h4>{t.flow.step1_title[lang]}</h4>
          <p>{t.flow.step1_desc[lang]}</p>
        </div>
        <div class="flow-item">
          <span class="flow-num">2</span>
          <h4>{t.flow.step2_title[lang]}</h4>
          <p>{t.flow.step2_desc[lang]}</p>
        </div>
        <div class="flow-item">
          <span class="flow-num">3</span>
          <h4>{t.flow.step3_title[lang]}</h4>
          <p>{t.flow.step3_desc[lang]}</p>
        </div>
      </div>
      <div class="btns" style="justify-content: center; margin-top: 60px;">
        <a class="btn primary" href={getLocalizedLink('/contact')}>{t.flow.btn_cta[lang]}</a>
      </div>
    </div>
  </section>

</main>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

  :root {
    --accent: #c5a059;
    --accent-dark: #b18e4a;
    --accent2: #d14d3a;
    --trust: #0f4c5c;
    --trust-mid: #1f6f78;
    --trust-line: rgba(15, 76, 92, 0.18);
    --text: #333;
    --text-deep: #1a1a1a;
    --muted: #666;
    --line: rgba(197, 160, 89, 0.2);
    --soft: #fdfaf5;
    --white: #ffffff;
    --paper: #fdfcf9;
    --radius: 24px;
  }

  body { font-family: 'Shippori Mincho', serif; color: var(--text); line-height: 1.8; background: var(--paper); }
  .section { padding: 80px 0; }
  .section-inner { max-width: 1000px; margin: 0 auto; padding: 0 20px; }

  h1, h2, h3, h4 { font-family: 'Shippori Mincho', serif; font-weight: 800; color: var(--text-deep); }
  h1 { font-size: clamp(2.2rem, 5vw, 4rem); line-height: 1.2; margin-bottom: 24px; }
  h2 { font-size: clamp(1.8rem, 4vw, 2.5rem); margin-bottom: 32px; }

  .tagline-top { font-size: 1.1rem; color: var(--accent); font-weight: 800; letter-spacing: 0.1em; margin-bottom: 8px; }
  .lead { font-size: 1.2rem; color: var(--muted); margin-bottom: 40px; max-width: 700px; }
  .lead strong { color: var(--accent); }

  .btns { display: flex; gap: 16px; margin-top: 40px; }
  .btn { padding: 18px 36px; border-radius: 50px; font-weight: 800; text-decoration: none; transition: all 0.3s ease; text-align: center; }
  .btn.primary { background: var(--trust); color: white; border: 1px solid var(--trust); box-shadow: 0 10px 25px rgba(15, 76, 92, 0.25); }
  .btn.primary:hover { background: #123c45; border-color: #123c45; transform: translateY(-2px); box-shadow: 0 12px 30px rgba(15, 76, 92, 0.35); }
  .btn.secondary { border: 1px solid rgba(197, 160, 89, 0.5); color: var(--accent); background: transparent; }
  .btn.secondary:hover { border-color: var(--accent); background: rgba(197, 160, 89, 0.05); transform: translateY(-1px); }

  /* Hero */
  .hero { 
    padding: 160px 0 120px; 
    background: 
      linear-gradient(to right, rgba(253, 250, 245, 1) 40%, rgba(253, 250, 245, 0.9) 55%, rgba(253, 250, 245, 0.2) 80%, rgba(253, 250, 245, 0) 100%), 
      url('/images/hero.png') no-repeat right center/cover;
    min-height: 520px;
    display: flex;
    align-items: center;
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; padding: 0 40px; width: 100%; }
  .hero-content { max-width: 650px; }
  .hero-badge { display: inline-block; background: var(--accent2); color: white; padding: 6px 16px; border-radius: 4px; font-size: 0.85rem; font-weight: 800; margin-bottom: 24px; }
  .highlight-text { border-bottom: 3px double var(--accent); padding-bottom: 2px; color: var(--accent2); font-weight: 800; }

  /* ジャンプ率・タイポグラフィの心理設計クラス */
  .hero-title-chosen {
    font-size: clamp(2.6rem, 5.8vw, 4.8rem);
    font-weight: 900;
    color: var(--accent2);
    letter-spacing: -0.05em;
  }
  .hero-title-sub {
    font-size: clamp(1.1rem, 2.5vw, 1.8rem);
    font-weight: 500;
    color: var(--muted);
    margin-left: 2px;
  }
  .hero-title-psy {
    font-size: clamp(2.3rem, 5.2vw, 4.2rem);
    font-weight: 900;
    color: var(--text-deep);
    border-bottom: 3px double var(--accent);
    padding-bottom: 2px;
    letter-spacing: -0.02em;
  }
  .hero-title-base {
    font-size: clamp(1.6rem, 3.5vw, 2.8rem);
    font-weight: 800;
    color: var(--text-deep);
  }

  .trust-strip {
    background: var(--white);
    border-bottom: 1px solid var(--trust-line);
  }
  .trust-strip-inner {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    max-width: 1000px;
    margin: 0 auto;
    border-left: 1px solid var(--trust-line);
  }
  .trust-signal {
    padding: 18px 24px;
    border-right: 1px solid var(--trust-line);
    text-align: center;
  }
  .trust-signal strong {
    display: block;
    color: var(--trust);
    font-size: 1.08rem;
    font-weight: 900;
    line-height: 1.4;
  }
  .trust-signal span {
    display: block;
    margin-top: 3px;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.5;
  }

  /* Agitation / Hook Section */
  .why-psy { background: var(--white); border-bottom: 1px solid var(--line); }
  .why-psy-inner { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  .question-box { text-align: center; margin-bottom: 48px; }
  .q-eyebrow { font-size: 0.9rem; color: var(--accent2); font-weight: 800; letter-spacing: 0.1em; display: block; margin-bottom: 12px; }
  .q-lead { font-size: 1.2rem; color: var(--text-deep); margin-top: 16px; font-weight: 700; }
  
  .concept-intro-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 32px; }
  .concept-intro-card { background: var(--paper); padding: 40px; border-radius: var(--radius); border: 1px solid var(--line); transition: 0.3s; }
  .concept-intro-card:hover { transform: translateY(-5px); border-color: var(--accent); }
  .concept-intro-card.highlight-card { background: var(--soft); border-color: var(--accent); box-shadow: 0 15px 30px rgba(197, 160, 89, 0.08); }
  .card-num { font-size: 2.2rem; margin-bottom: 16px; }

  /* Profile Summary Section */
  .profile-summary { background: var(--soft); border-top: 1px solid var(--line); }
  .profile-summary-inner { max-width: 850px; display: flex; align-items: center; gap: 48px; margin: 0 auto; padding: 0 20px; }
  .profile-avatar-wrap { flex: 0 0 200px; width: 200px; height: 200px; border-radius: 30px; overflow: hidden; box-shadow: 0 15px 30px rgba(0,0,0,0.08); border: 3px solid var(--white); }
  .profile-avatar-img { width: 100%; height: 100%; object-fit: cover; }
  .profile-text-wrap { flex: 1; }
  .profile-desc { font-size: 1rem; color: var(--muted); margin: 16px 0 24px; line-height: 1.8; }
  .profile-link { font-weight: 800; color: var(--accent); text-decoration: underline; transition: 0.3s; }
  .profile-link:hover { color: var(--accent-dark); }

  /* Cards */
  .consult-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; margin-top: 40px; }
  .consult-card { background: var(--white); padding: 40px; border-radius: var(--radius); border: 1px solid var(--line); transition: 0.3s; }
  .consult-card:hover { transform: translateY(-5px); border-color: var(--trust-mid); }
  .consult-card.highlight { background: linear-gradient(135deg, rgba(15, 76, 92, 0.06), rgba(197, 160, 89, 0.06)), var(--white); border-color: var(--trust-line); }
  .card-tag { font-size: 0.75rem; font-weight: 800; color: var(--trust); letter-spacing: 0.1em; margin-bottom: 12px; display: block; }
  .service-fit {
    display: inline-block;
    margin: 0 0 14px;
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(15, 76, 92, 0.07);
    color: var(--trust);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.5;
  }
  .card-sub-links { margin-top: 12px; margin-bottom: 4px; }
  .sub-link-text { font-size: 0.85rem; font-weight: 800; color: var(--accent2); text-decoration: none; display: inline-block; transition: 0.3s; padding: 4px 0; }
  .sub-link-text:hover { color: var(--accent); text-decoration: underline; transform: translateX(2px); }
  .card-link { display: inline-block; margin-top: 16px; font-weight: 800; color: var(--trust); text-decoration: none; border-bottom: 1px solid var(--trust); }

  /* Experience Grid */
  .action-buttons-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px; }
  .action-card { background: #fff; border: 1px solid var(--line); border-radius: 20px; padding: 30px 20px; text-decoration: none; text-align: center; transition: 0.3s; color: inherit; }
  .action-card:hover { transform: translateY(-5px); border-color: var(--accent); }
  .action-card.highlight-border { border: 2px solid var(--accent); }
  .action-icon { font-size: 2.5rem; margin-bottom: 16px; display: block; }

  /* Flow */
  .simple-flow-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; margin-top: 40px; }
  .flow-item { text-align: center; position: relative; }
  .flow-num { width: 40px; height: 40px; background: var(--trust); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-weight: 800; }
  .flow-item h4 { margin-bottom: 12px; }
  .flow-item p { font-size: 0.9rem; color: var(--muted); }

  .eyebrow { font-size: 0.85rem; font-weight: 800; color: var(--accent); text-transform: uppercase; letter-spacing: 0.2em; margin-bottom: 12px; display: block; }

  @media (max-width: 768px) {
    .hero {
      padding: 80px 0;
      background: 
        linear-gradient(to bottom, rgba(253, 250, 245, 0.98) 50%, rgba(253, 250, 245, 0.8) 80%, rgba(253, 250, 245, 0.4) 100%), 
        url('/images/hero.png') no-repeat center center/cover;
      text-align: center;
      min-height: auto;
      overflow-x: hidden;
    }
    .hero .btns { flex-direction: column; width: min(100%, 280px); margin: 0 auto; box-sizing: border-box; align-items: stretch; gap: 12px; }
    .hero .btn { width: 100%; padding: 16px 22px; }
    .hero-inner { padding: 0 20px; width: 100%; box-sizing: border-box; }
    .hero-content { width: 100%; max-width: 340px; margin: 0 auto; box-sizing: border-box; }
    .hero h1 { max-width: 100%; margin-left: auto; margin-right: auto; text-wrap: balance; }
    .lead { max-width: 100%; box-sizing: border-box; word-break: normal; overflow-wrap: anywhere; line-break: strict; margin-left: auto; margin-right: auto; text-align: center; }
    .hero-title-chosen { font-size: clamp(2.2rem, 8vw, 3.2rem); }
    .hero-title-psy { font-size: clamp(2rem, 7vw, 3rem); }
    .trust-strip-inner {
      grid-template-columns: 1fr;
      border-left: 0;
    }
    .trust-signal {
      padding: 15px 20px;
      border-right: 0;
      border-bottom: 1px solid var(--trust-line);
    }
    .trust-signal:last-child { border-bottom: 0; }
    .action-buttons-grid, .simple-flow-grid, .concept-intro-grid { grid-template-columns: 1fr; }
    .flow-item:not(:last-child)::after { display: none; }
    .profile-summary-inner { flex-direction: column; text-align: center; gap: 24px; }
    .profile-avatar-wrap { flex: 0 0 160px; width: 160px; height: 160px; }
  }
</style>
