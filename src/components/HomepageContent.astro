<script is:inline>
  function initHomeInteractions() {
    const root = document.querySelector('.home-content');
    if (!root || root.dataset.homeInteractionsReady === 'true') return;
    root.dataset.homeInteractionsReady = 'true';

    const stage = root.querySelector('.transformation-stage');
    if (stage) {
      const buttons = stage.querySelectorAll('.journey-toggle button');
      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const phase = button.dataset.phase || 'after';
          stage.dataset.phase = phase;
          buttons.forEach((btn) => {
            const active = btn === button;
            btn.classList.toggle('active', active);
            btn.setAttribute('aria-pressed', active ? 'true' : 'false');
          });
        });
      });
    }

    const quickCheck = root.querySelector('.quick-check-panel');
    if (quickCheck) {
      const boxes = quickCheck.querySelectorAll('input[type="checkbox"]');
      const bar = quickCheck.querySelector('.check-progress span');
      const progressText = quickCheck.querySelector('.check-progress-text');
      const result = quickCheck.querySelector('.check-result');
      const updateCheck = () => {
        const checked = [...boxes].filter((box) => box.checked).length;
        if (bar) bar.style.width = `${(checked / boxes.length) * 100}%`;
        if (progressText) progressText.textContent = `${checked} / ${boxes.length} チェック済み`;
        if (result) {
          result.textContent = checked === boxes.length
            ? '土台は整っています。次は、相談につながる見せ方を一緒に磨けます。'
            : checked === 0
              ? 'まずは現在のサイトや構想をそのまま相談できます。'
              : '気になる箇所が見えてきました。優先順位をつけて整理できます。';
        }
      };
      boxes.forEach((box) => box.addEventListener('change', updateCheck));
      updateCheck();
    }

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      root.querySelectorAll('.motion-card').forEach((card) => {
        card.addEventListener('pointermove', (event) => {
          const rect = card.getBoundingClientRect();
          const x = (event.clientX - rect.left) / rect.width - 0.5;
          const y = (event.clientY - rect.top) / rect.height - 0.5;
          card.style.setProperty('--tilt-x', `${(-y * 3).toFixed(2)}deg`);
          card.style.setProperty('--tilt-y', `${(x * 3).toFixed(2)}deg`);
        });
        card.addEventListener('pointerleave', () => {
          card.style.setProperty('--tilt-x', '0deg');
          card.style.setProperty('--tilt-y', '0deg');
        });
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initHomeInteractions);
  document.addEventListener('astro:page-load', initHomeInteractions);
  initHomeInteractions();
</script>

