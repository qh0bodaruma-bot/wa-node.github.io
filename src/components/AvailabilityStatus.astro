---
// AvailabilityStatus.astro
interface Props {
  lang?: 'ja' | 'en' | 'fr';
}

const { lang = 'ja' } = Astro.props;

// 管理用のデータ
const schedule = {
  weekly: [
    { morning: "busy", afternoon: "ok", evening: "ok" },
    { morning: "ok", afternoon: "ok", evening: "ok" },
    { morning: "busy", afternoon: "ok", evening: "ok" },
    { morning: "ok", afternoon: "busy", evening: "ok" },
    { morning: "busy", afternoon: "ok", evening: "ok" },
    { morning: "busy", afternoon: "busy", evening: "busy" },
    { morning: "busy", afternoon: "busy", evening: "busy" },
  ]
};

const d = {
  ja: {
    title: "現在の予約・相談状況",
    update_date: "※状況は随時変動いたします。最新状況は公式LINEよりお問い合わせください。",
    label_available: "最短の相談可能日（目安）",
    label_start: "制作着手時期（目安）",
    next_date: "現在、最短で5月下旬以降",
    start_status: "6月上旬着手より受付中",
    time_morning: "午前",
    time_afternoon: "午後",
    time_evening: "夜間",
    legend_ok: "◎：空きあり",
    legend_few: "△：残りわずか",
    legend_busy: "ー：受付終了",
    note: "※夜間（19:00〜22:00）のご相談も承っております。<br />※お急ぎの場合は、フォームよりその旨をお知らせください。",
    days: ["月", "火", "水", "木", "金", "土", "日"]
  },
  en: {
    title: "Availability Status",
    update_date: "*Status changes frequently. Contact us via LINE or form for the latest slots.",
    label_available: "Next Available Date",
    label_start: "Project Commencement",
    next_date: "Late May onward",
    start_status: "Accepting early June slots",
    time_morning: "Morning",
    time_afternoon: "Afternoon",
    time_evening: "Evening",
    legend_ok: "◎: Available",
    legend_few: "△: Low slots",
    legend_busy: "ー: Closed",
    note: "*Evening consultation (19:00-22:00 JST) is also open.<br />*If urgent, please mention it in the form.",
    days: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
  },
  fr: {
    title: "Statut des Réservations",
    update_date: "*Le statut change fréquemment. Contactez-nous pour les derniers créneaux.",
    label_available: "Prochaine Disponibilité",
    label_start: "Début de Projet",
    next_date: "Fin mai et après",
    start_status: "Créneaux début juin ouverts",
    time_morning: "Matin",
    time_afternoon: "Après-midi",
    time_evening: "Soirée",
    legend_ok: "◎: Disponible",
    legend_few: "△: Limité",
    legend_busy: "ー: Fermé",
    note: "*Consultation en soirée (19:00-22:00 JST) également ouverte.<br />*Si urgent, veuillez le préciser dans le formulaire.",
    days: ["Lun", "Mar", "Mer", "Jeu", "Ven", "Sam", "Dim"]
  }
};

const t = d[lang];

const getStatusIcon = (status) => {
  if (status === 'ok') return '◎';
  if (status === 'few') return '△';
  return 'ー';
};

const getStatusClass = (status) => {
  return `status-icon ${status}`;
};

const labelMap = {
  ja: { ok: '空きあり', few: '残りわずか', busy: '受付終了' },
  en: { ok: 'Available', few: 'Low slots', busy: 'Closed' },
  fr: { ok: 'Disponible', few: 'Limité', busy: 'Fermé' }
};

const getStatusLabel = (status: 'ok' | 'few' | 'busy') => {
  return labelMap[lang][status];
};
---

<div class="availability-status glass-panel float-animation">
  <div class="status-header">
    <div class="status-badge">Current Status</div>
    <h3>{t.title}</h3>
    <p class="status-update-date">{t.update_date}</p>
  </div>

  <div class="summary-cards">
    <div class="summary-card">
      <span class="label">{t.label_available}</span>
      <span class="value">{t.next_date}</span>
    </div>
    <div class="summary-card">
      <span class="label">{t.label_start}</span>
      <span class="value">{t.start_status}</span>
    </div>
  </div>

  <div class="schedule-table-wrap">
    <table class="schedule-table">
      <thead>
        <tr>
          <th></th>
          {t.days.map(day => <th>{day}</th>)}
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="time-label">{t.time_morning}</td>
          {schedule.weekly.map(s => <td class={getStatusClass(s.morning)} aria-label={getStatusLabel(s.morning)}>{getStatusIcon(s.morning)}</td>)}
        </tr>
        <tr>
          <td class="time-label">{t.time_afternoon}</td>
          {schedule.weekly.map(s => <td class={getStatusClass(s.afternoon)} aria-label={getStatusLabel(s.afternoon)}>{getStatusIcon(s.afternoon)}</td>)}
        </tr>
        <tr>
          <td class="time-label">{t.time_evening}</td>
          {schedule.weekly.map(s => <td class={getStatusClass(s.evening)} aria-label={getStatusLabel(s.evening)}>{getStatusIcon(s.evening)}</td>)}
        </tr>
      </tbody>
    </table>
  </div>

  <div class="legend">
    <span>{t.legend_ok}</span>
    <span>{t.legend_few}</span>
    <span>{t.legend_busy}</span>
  </div>

  <p class="status-note" set:html={t.note}></p>
</div>

<style>
  .availability-status {
    padding: 40px;
    margin-bottom: 30px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--line);
    border-radius: 32px;
    backdrop-filter: blur(10px);
  }

  .status-header {
    text-align: center;
    margin-bottom: 30px;
  }

  .status-badge {
    display: inline-block;
    padding: 4px 12px;
    background: var(--accent2);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 900;
    border-radius: 999px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .availability-status h3 {
    font-size: 1.4rem;
    font-weight: 800;
    margin: 0 0 8px;
    color: var(--text);
  }

  .status-update-date {
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0;
  }

  .summary-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    margin-bottom: 30px;
  }

  .summary-card {
    background: #fff;
    padding: 20px;
    border-radius: 20px;
    border: 1px solid var(--line);
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.02);
  }

  .summary-card .label {
    display: block;
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 800;
    margin-bottom: 6px;
  }

  .summary-card .value {
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--accent);
  }

  .schedule-table-wrap {
    overflow-x: auto;
    background: #fff;
    border-radius: 20px;
    border: 1px solid var(--line);
    margin-bottom: 20px;
  }

  .schedule-table {
    width: 100%;
    border-collapse: collapse;
    text-align: center;
    font-size: 0.9rem;
  }

  .schedule-table th, .schedule-table td {
    padding: 15px 10px;
    border: 1px solid #f0f0f0;
  }

  .schedule-table th {
    background: #fdfaf7;
    font-weight: 800;
    color: var(--muted);
  }

  .time-label {
    font-weight: 800;
    color: var(--muted);
    background: #fdfaf7;
    width: 60px;
  }

  .status-icon {
    font-weight: 900;
  }

  .status-icon.ok { color: var(--accent2); }
  .status-icon.few { color: #f39c12; }
  .status-icon.busy { color: #ccc; }

  .legend {
    display: flex;
    justify-content: center;
    gap: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--muted);
    margin-bottom: 20px;
  }

  .status-note {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.6;
    text-align: center;
    margin: 0;
  }

  @media (max-width: 480px) {
    .summary-cards { grid-template-columns: 1fr; }
    .availability-status { padding: 30px 20px; }
  }
</style>
