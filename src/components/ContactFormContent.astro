<script is:inline>
  (function() {
    function initSourceContext() {
      const sourceSelect = document.getElementById('seen_source');
      const landingInput = document.getElementById('landing_url');
      const referrerInput = document.getElementById('referrer_url');

      if (landingInput) landingInput.value = window.location.href;
      if (referrerInput) referrerInput.value = document.referrer || '';
      if (!sourceSelect) return;

      const aliases = {
        psychology_demo: 'psychology_demo',
        demo: 'psychology_demo',
        demo60: 'psychology_demo',
        salon_demo: 'salon_demo',
        salon: 'salon_demo',
        lp_portfolio: 'lp_portfolio',
        portfolio: 'lp_portfolio',
        ai_chat_demo: 'ai_chat_demo',
        ai_chat: 'ai_chat_demo',
        simulator: 'tool_or_pricing',
        sim60: 'tool_or_pricing',
        seo_check: 'tool_or_pricing',
        seo60: 'tool_or_pricing',
        wasm_diagnosis: 'tool_or_pricing',
        wasm: 'tool_or_pricing',
        dx60: 'tool_or_pricing',
        pricing: 'tool_or_pricing',
        tool_or_pricing: 'tool_or_pricing',
        works: 'other',
        top: 'other',
        other: 'other'
      };

      function normalize(value) {
        if (!value) return '';
        const key = String(value).trim().replace(/-/g, '_');
        return aliases[key] || '';
      }

      function inferFromPath(url) {
        if (!url) return '';
        try {
          const path = new URL(url, window.location.origin).pathname;
          if (path.includes('/salon-reservation-demo')) return 'salon_demo';
          if (path.includes('/psychology-demo')) return 'psychology_demo';
          if (path.includes('/lp-portfolio')) return 'lp_portfolio';
          if (path.includes('/ai-chat-demo')) return 'ai_chat_demo';
          if (path.includes('/simulator') || path.includes('/seo_check') || path.includes('/wasm-diagnosis') || path.includes('/pricing')) return 'tool_or_pricing';
          return '';
        } catch (err) {
          return '';
        }
      }

      const params = new URLSearchParams(window.location.search);
      const selectedSource =
        normalize(params.get('source')) ||
        normalize(params.get('benefit')) ||
        normalize(params.get('plan')) ||
        inferFromPath(document.referrer);

      if (selectedSource && !sourceSelect.value) {
        sourceSelect.value = selectedSource;
      }
    }



      function initContactForm() {
        const form = document.querySelector('.contact-form');
        if (!form) return;

        const button = form.querySelector('.submit-btn');
        const buttonSpan = button ? button.querySelector('span') : null;
        const lang = form.getAttribute('data-lang') || 'ja';

        const errorMessages = {
          ja: '送信に失敗しました。お手数ですが時間をおいて再度お試しいただくか、LINEからお問い合わせください。',
          en: 'Failed to send. Please try again later or contact us via LINE.',
          fr: 'Échec de l\'envoi. Veuillez réessayer plus tard ou nous contacter via LINE.'
        };

        form.addEventListener('submit', function(e) {
          e.preventDefault();
          if (!button || !buttonSpan) return;

          // 送信中のUI表示と多重送信防止
          button.disabled = true;
          const originalText = button.getAttribute('data-original-text') || buttonSpan.textContent;
          const submittingText = button.getAttribute('data-submitting-text') || 'Sending...';
          buttonSpan.textContent = submittingText;
          button.style.opacity = '0.7';

          // Fetch APIで非同期送信
          const formData = new FormData(form);
          fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
              'Accept': 'application/json'
            }
          })
          .then(response => {
            if (response.ok) {
              // 送信成功時：言語に応じたThanksページに遷移
              const redirectPaths = {
                ja: '/thanks/',
                en: '/en/thanks/',
                fr: '/fr/thanks/'
              };
              window.location.href = redirectPaths[lang] || '/thanks/';
            } else {
              throw new Error('Formspree response not ok');
            }
          })
          .catch(err => {
            console.error('Form submission error:', err);
            alert(errorMessages[lang] || errorMessages.ja);
            // UIを元に戻す
            button.disabled = false;
            buttonSpan.textContent = originalText;
            button.style.opacity = '';
          });
        });
      }

      function checkBenefitParam() {
        const urlParams = new URLSearchParams(window.location.search);
        const benefit = urlParams.get('benefit');
        const container = document.getElementById('benefit-badge-container');
        const titleEl = document.getElementById('benefit-badge-title');
        const descEl = document.getElementById('benefit-badge-desc');
        const form = document.querySelector('.contact-form');
        const lang = form ? (form.getAttribute('data-lang') || 'ja') : 'ja';
        
        if (benefit && container && titleEl && descEl) {
          const texts = {
            seo60: {
              ja: {
                title: '【SEO/AEO診断完了特典】60分無料相談が適用されています',
                desc: '診断完了ありがとうございます。初回無料相談の時間を60分（30分拡大）に設定し、診断結果に基づく具体的な改善アドバイスを提示いたします。'
              },
              en: {
                title: '[SEO/AEO Diagnosis Benefit] 60-min Free Consultation Applied',
                desc: 'Thank you for using the diagnosis tool. We have extended your free consultation to 60 minutes to provide concrete improvement advice based on your results.'
              },
              fr: {
                title: '[Avantage Diagnostic SEO/AEO] Consultation Gratuite de 60 min Appliquée',
                desc: 'Merci d\'avoir utilisé l\'outil de diagnostic. Nous avons prolongé votre consultation gratuite à 60 minutes pour vous fournir des conseils d\'amélioration concrets basés sur vos résultats.'
              }
            },
            sim60: {
              ja: {
                title: '【料金試算完了特典】60分無料相談が適用されています',
                desc: 'シミュレーターのご利用ありがとうございます。初回無料相談の時間を60分（30分拡大）に設定し、概算に基づいた最適なプラン構築をアドバイスいたします。'
              },
              en: {
                title: '[Estimation Benefit] 60-min Free Consultation Applied',
                desc: 'Thank you for using the simulator. We have extended your free consultation to 60 minutes to advise you on the best plan setup based on the estimation.'
              },
              fr: {
                title: '[Avantage Estimation] Consultation Gratuite de 60 min Appliquée',
                desc: 'Merci d\'avoir utilisé le simulateur. Nous avons prolongé votre consultation gratuite à 60 minutes pour vous conseiller sur la meilleure configuration de plan basée sur l\'estimation.'
              }
            },
            dx60: {
              ja: {
                title: '【DX×メンタル診断完了特典】60分無料相談が適用されています',
                desc: '診断のご利用ありがとうございます。初回無料相談の時間を60分（30分拡大）に設定し、心と技術のボトルネックを整理した具体的なDX改善アプローチをアドバイスいたします。'
              },
              en: {
                title: '[DX & Mental Diagnosis Benefit] 60-min Free Consultation Applied',
                desc: 'Thank you for taking the diagnosis. We have extended your free consultation to 60 minutes to advise on concrete DX improvements by resolving both mind and technology bottlenecks.'
              },
              fr: {
                title: '[Avantage Diagnostic DX & Mental] Consultation Gratuite de 60 min Appliquée',
                desc: 'Merci d\'avoir fait le diagnostic. Nous avons prolongé votre consultation gratuite à 60 minutes pour vous conseiller sur des améliorations DX concrètes en résolvant les goulots d\'étranglement mentaux et techniques.'
              }
            },
            demo60: {
              ja: {
                title: '【デモ体験特典】60分無料相談が適用されています',
                desc: 'Before/Afterデモのご体験ありがとうございます。初回無料相談の時間を60分（30分拡大）に設定し、あなたのLPやHPの「選ばれる導線設計」について具体的なアドバイスを提示いたします。'
              },
              en: {
                title: '[Demo Experience Benefit] 60-min Free Consultation Applied',
                desc: 'Thank you for experiencing our Before/After demo. We have extended your free consultation to 60 minutes to provide concrete advice on your LP or website\'s high-converting funnel design.'
              },
              fr: {
                title: '[Avantage Démo] Consultation Gratuite de 60 min Appliquée',
                desc: 'Merci d\'avoir testé notre démo Before/After. Nous avons prolongé votre consultation gratuite à 60 minutes pour vous fournir des conseils concrets sur la conception d\'entonnoirs de conversion pour votre LP ou site.'
              }
            }
          };

          const selected = texts[benefit];
          if (selected) {
            const translation = selected[lang] || selected['ja'];
            titleEl.textContent = translation.title;
            descEl.textContent = translation.desc;
            container.style.display = 'block';
          }
          
          // 希望日時欄の補足メッセージも更新
          const dateDesc = document.querySelector('.date-candidates .field-desc');
          if (dateDesc && !dateDesc.querySelector('.benefit-applied-text')) {
            const dateNotice = {
              ja: '特典適用中：通常30分のところ、面談時間を60分（30分拡大）として優先調整いたします。',
              en: 'Benefit Applied: We will prioritize scheduling a 60-minute session (extended by 30 mins) instead of the regular 30 minutes.',
              fr: 'Avantage Appliqué: Nous planifierons en priorité une session de 60 minutes (prolongée de 30 min) au lieu des 30 minutes habituelles.'
            };
            dateDesc.innerHTML = `<strong class="benefit-applied-text" style="color: var(--accent-red); display: block; margin-bottom: 6px;">${dateNotice[lang] || dateNotice['ja']}</strong>` + dateDesc.innerHTML;
          }
        }
      }

      // 初回ロード時
      initSourceContext();
      initContactForm();
      checkBenefitParam();
      // Astro's transition support
      document.addEventListener('astro:page-load', function() {
        initSourceContext();
        initContactForm();
        checkBenefitParam();
      });
    })();
  </script>
