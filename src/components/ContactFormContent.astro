    consent_checkbox: "I agree to the terms and privacy conditions",
    btn_submit: "Submit Inquiry"
  },
  fr: {
    ann_badge: "1er ANNIVERSAIRE",
    ann_text: "Campagne Spéciale Active: Menu création web 20% DE RÉDUCTION",
    eyebrow: "Contact",
