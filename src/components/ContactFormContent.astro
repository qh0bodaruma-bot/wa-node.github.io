const t = f[lang];
---
<main class="contact-page">
  <header class="contact-header">
    <div class="container">
      <!-- Anniversary Mini Banner -->
      <div class="contact-ann-notice reveal">
        <span class="badge">{t.ann_badge}</span>
        <p set:html={t.ann_text}></p>
      </div>

      <span class="eyebrow">{t.eyebrow}</span>
      <h1 class="premium-heading">{t.heading_part1}<br/><span class="accent-text">{t.heading_part2}</span></h1>
      <p class="lead" set:html={t.lead}></p>
    </div>
  </header>

  <div class="container">
    <div class="contact-grid">
      <!-- Info Column -->
      <aside class="contact-info">
        <div class="info-card">
          <h3 class="premium-heading">{t.before_title}</h3>
          <p>{t.before_desc}</p>
          <ul class="benefit-list">
            {t.benefits.map((b) => (
              <li><span>{b}</span></li>
            ))}
          </ul>
        </div>

        <AvailabilityStatus lang={lang} />

        <div class="line-card">
          <h3>{t.line_title}</h3>
          <p>{t.line_desc}</p>
          <a href="https://lin.ee/o5QFPwc" target="_blank" rel="noopener" class="line-btn shine-effect">
            <img src="https://vignette.wikia.nocookie.net/line/images/b/bb/Line_logo.png/revision/latest?cb=20150524021545" alt="LINE" class="line-icon" style="filter: brightness(0) invert(1); width: 24px; height: 24px;" />
            {t.line_btn}
          </a>
        </div>
      </aside>

      <!-- Form Column -->
      <section class="form-section">
        <div class="glass-panel">
          <div class="form-intro" style="margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid var(--line);">
            <p style="font-weight: 800; color: var(--accent); margin-bottom: 8px;">{t.form_intro_title}</p>
            <p class="small" style="color: var(--muted); line-height: 1.6; margin-bottom: 20px;">{t.form_intro_desc}</p>
            
            <div class="form-flow-notice" style="background: rgba(197, 160, 89, 0.05); padding: 18px; border-radius: 16px; border: 1px solid var(--line); font-size: 0.85rem; color: #555; line-height: 1.6;">
              <strong style="color: var(--accent-dark); display: block; margin-bottom: 6px; font-weight: 800; font-family: 'Shippori Mincho', serif;">💡 {lang === 'ja' ? '送信後の流れ' : lang === 'fr' ? 'Déroulement après envoi' : 'Process After Submission'}</strong>
              <p style="margin: 0;">{t.submit_flow_desc}</p>
            </div>
          </div>
          <form action="https://formspree.io/f/xojrldrq" method="POST" class="contact-form" autocomplete="off">
            <input type="hidden" name="_next" value={lang === 'ja' ? 'https://www.wa-node.com/thanks/' : `https://www.wa-node.com/${lang}/thanks/`} />
            
            <div class="form-group">
              <label for="name">{t.label_name} <span class="required">{t.required}</span></label>
              <input type="text" id="name" name="name" required placeholder={t.placeholder_name} />
            </div>

            <div class="form-group">
              <label for="email">{t.label_email} <span class="required">{t.required}</span></label>
              <input type="email" id="email" name="email" required placeholder={t.placeholder_email} />
            </div>

            <div class="form-group">
              <label for="category">{t.label_category} <span class="required">{t.required}</span></label>
              <select id="category" name="category" required>
                <option value="" disabled selected>{t.placeholder_category}</option>
                <option value="web">{t.categories.web}</option>
                <option value="copilot">{t.categories.copilot}</option>
                <option value="line">{t.categories.line}</option>
                <option value="ai">{t.categories.ai}</option>
                <option value="counseling">{t.categories.counseling}</option>
                <option value="corporate">{t.categories.corporate}</option>
                <option value="other">{t.categories.other}</option>
              </select>
            </div>

            <div class="form-group">
              <label for="method">{t.label_method} <span class="required">{t.required}</span></label>
              <select id="method" name="method" required>
                <option value="" disabled selected>{t.placeholder_method}</option>
                <option value="google_meet">{t.methods.google_meet}</option>
                <option value="zoom">{t.methods.zoom}</option>
                <option value="line_video">{t.methods.line_video}</option>
                <option value="phone">{t.methods.phone}</option>
                <option value="face_to_face">{t.methods.face_to_face}</option>
                <option value="other">{t.methods.other}</option>
              </select>
            </div>

            <!-- 動的な連絡先詳細入力欄（電話・LINE選択時のみJavaScriptで表示制御） -->
            <div class="form-group" id="dynamic-contact-field" style="display: none; transition: all 0.3s ease;">
              <label for="contact_detail" id="dynamic-contact-label">ご連絡先詳細</label>
              <input 
                type="text" 
                id="contact_detail" 
                name="contact_detail" 
                placeholder="" 
                data-phone-label={t.label_phone}
                data-phone-placeholder={t.placeholder_phone}
                data-phone-desc={t.desc_phone}
                data-line-label={t.label_line}
                data-line-placeholder={t.placeholder_line}
                data-line-desc={t.desc_line}
                data-required-text={t.required}
              />
              <p class="field-desc" id="dynamic-contact-desc"></p>
            </div>

            <div class="form-group date-candidates">
              <label>{t.label_dates}</label>
              <div class="date-input-group">
                <div class="date-item">
                  <span>{t.date_1} <span class="required">{t.required}</span></span>
                  <input type="datetime-local" name="date_1" required />
                </div>
                <div class="date-item">
                  <span>{t.date_2}</span>
                  <input type="datetime-local" name="date_2" />
                </div>
                <div class="date-item">
                  <span>{t.date_3}</span>
                  <input type="datetime-local" name="date_3" />
                </div>
              </div>
              <p class="field-desc">{t.date_desc}</p>
            </div>

            <div class="form-group">
              <label for="message">{t.label_message} <span class="required">{t.required}</span></label>
              <textarea id="message" name="message" rows="6" placeholder={t.placeholder_message} required></textarea>
            </div>

            <div class="form-consent">
              <p class="privacy-note" set:html={t.consent_note}></p>
              <label class="checkbox-label">
                <input type="checkbox" required />
                <span>{t.consent_checkbox}</span>
              </label>
            </div>

            <button type="submit" class="submit-btn">
              <span>{t.btn_submit}</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            </button>
          </form>
        </div>
      </section>
    </div>
  </div>
</main>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

  :root {
    --accent: #c5a059;
    --accent-dark: #b18e4a;
    --accent-red: #d14d3a;
    --line: rgba(197, 160, 89, 0.2);
  }

  .premium-heading {
    font-family: 'Shippori Mincho', serif !important;
    font-weight: 800 !important;
    letter-spacing: 0.05em;
  }

  .contact-page {
    padding-bottom: 120px;
    background: #fdfcf9;
    font-family: 'Shippori Mincho', serif !important;
  }
  .contact-page::before {
    content: ""; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3FfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3F/filter%3E%3Frect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3F/svg%3E");
    opacity: 0.03; pointer-events: none; z-index: -1;
  }

  .contact-header { padding: 80px 0 60px; text-align: center; }
  
  /* Anniversary Mini Banner */
  .contact-ann-notice {
    display: inline-flex; align-items: center; gap: 12px;
    background: #fff; border: 1px solid var(--accent-red);
    padding: 8px 20px; border-radius: 50px; margin-bottom: 30px;
    box-shadow: 0 10px 20px rgba(209, 77, 58, 0.05);
  }
  .contact-ann-notice .badge {
    background: var(--accent-red); color: #fff; font-size: 0.65rem; font-weight: 800;
    padding: 2px 10px; border-radius: 4px;
  }
  .contact-ann-notice p { font-size: 0.85rem; color: #2c2c2c; margin: 0; }
  .contact-ann-notice strong { color: var(--accent-red); }

  .eyebrow { font-size: 0.85rem; font-weight: 800; color: var(--accent); letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 16px; display: block; }
  .contact-header h1 { font-size: clamp(2.2rem, 6vw, 3.6rem); font-weight: 800; line-height: 1.2; margin-bottom: 24px; }
  .accent-text { color: var(--accent-red); }
  .lead { font-size: 1.1rem; color: #555; line-height: 1.8; }

  .contact-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 60px; margin-top: 40px; }

  /* Info Column */
  .info-card, .line-card { background: #fff; border: 1px solid var(--line); border-radius: 32px; padding: 40px; margin-bottom: 30px; }
  .info-card h3, .line-card h3 { font-size: 1.4rem; margin-bottom: 20px; color: #2c2c2c; }
  
  .benefit-list { list-style: none; padding: 0; }
  .benefit-list li { position: relative; padding-left: 28px; margin-bottom: 16px; font-weight: 700; font-size: 0.95rem; }
  .benefit-list li::before { content: "✓"; position: absolute; left: 0; color: var(--accent-red); font-weight: 900; }

  .line-btn {
    display: flex; align-items: center; justify-content: center; gap: 12px;
    background: #06C755; color: #fff; text-decoration: none; padding: 18px; border-radius: 999px;
    font-weight: 800; transition: 0.3s;
  }
  .line-btn:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(6, 199, 85, 0.2); }

  /* Form Column */
  .glass-panel { background: #fff; border: 1px solid var(--line); border-radius: 40px; padding: 50px; box-shadow: 0 20px 50px rgba(0,0,0,0.02); }
  .form-group { margin-bottom: 30px; }
  .form-group label { display: block; font-weight: 800; font-size: 0.9rem; margin-bottom: 10px; color: #2c2c2c; }
  .required { color: var(--accent-red); font-size: 0.7rem; margin-left: 5px; }
  
  input, select, textarea {
    width: 100%; padding: 16px 20px; border-radius: 12px; border: 1px solid var(--line);
    background: #fdfcf9; font-size: 1rem; font-family: inherit; transition: 0.3s;
  }
  input:focus, select:focus, textarea:focus { outline: none; border-color: var(--accent-red); background: #fff; }
  
  .field-desc { font-size: 0.8rem; color: var(--muted); margin-top: 8px; line-height: 1.5; }

  .date-input-group { display: flex; flex-direction: column; gap: 12px; margin-top: 10px; }
  .date-item { display: flex; align-items: center; gap: 15px; }
  .date-item span { font-size: 0.85rem; font-weight: 800; color: var(--muted); width: 80px; flex-shrink: 0; }
  .date-item input { padding: 12px 15px; font-size: 0.9rem; }

  .submit-btn {
    width: 100%; padding: 22px; border-radius: 999px; border: none;
    background: var(--accent-dark); color: #fff; font-size: 1.1rem; font-weight: 800;
    cursor: pointer; transition: 0.4s; display: flex; align-items: center; justify-content: center; gap: 12px;
  }
  .submit-btn:hover { background: #2c2c2c; transform: translateY(-3px); }

  @media (max-width: 900px) {
    .container { padding: 0 15px; }
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .glass-panel { padding: 30px 20px; }
  }
</style>

<script is:inline>
  (function() {
    function initDynamicContactField() {
      const methodSelect = document.getElementById('method');
      const dynamicField = document.getElementById('dynamic-contact-field');
      const dynamicLabel = document.getElementById('dynamic-contact-label');
      const dynamicInput = document.getElementById('contact_detail');
      const dynamicDesc = document.getElementById('dynamic-contact-desc');
      if (!methodSelect || !dynamicField || !dynamicLabel || !dynamicInput || !dynamicDesc) return;

      function updateField() {
        const val = methodSelect.value;
        const phoneLabel = dynamicInput.getAttribute('data-phone-label');
        const phonePlaceholder = dynamicInput.getAttribute('data-phone-placeholder');
        const phoneDesc = dynamicInput.getAttribute('data-phone-desc');
        const lineLabel = dynamicInput.getAttribute('data-line-label');
        const linePlaceholder = dynamicInput.getAttribute('data-line-placeholder');
        const lineDesc = dynamicInput.getAttribute('data-line-desc');
        const reqText = dynamicInput.getAttribute('data-required-text');

        if (val === 'phone') {
          dynamicField.style.display = 'block';
          dynamicLabel.innerHTML = `${phoneLabel} <span class="required">${reqText}</span>`;
          dynamicInput.placeholder = phonePlaceholder;
          dynamicInput.required = true;
          dynamicDesc.textContent = phoneDesc;
        } else if (val === 'line_video') {
          dynamicField.style.display = 'block';
          dynamicLabel.innerHTML = `${lineLabel} <span class="required">${reqText}</span>`;
          dynamicInput.placeholder = linePlaceholder;
          dynamicInput.required = true;
          dynamicDesc.textContent = lineDesc;
        } else {
          dynamicField.style.display = 'none';
          dynamicInput.required = false;
          dynamicInput.placeholder = '';
          dynamicDesc.textContent = '';
        }
      }

      methodSelect.addEventListener('change', updateField);
      // 初期状態の反映（入力フォームに戻った場合などの保持対応）
      updateField();
    }

    // 初回ロード時
    initDynamicContactField();
    // Astroのトランジション（画面遷移時）対応
    document.addEventListener('astro:page-load', initDynamicContactField);
  })();
</script>
