};

const t = f[lang];
---
<main class="contact-page">
  <header class="contact-header">
    <div class="container">
      <span class="eyebrow">{t.eyebrow}</span>
      <h1 class="premium-heading">{t.heading_part1}<br/><span class="accent-text">{t.heading_part2}</span></h1>
      <p class="lead" set:html={t.lead}></p>
    </div>
  </header>

  <div class="container">
    <div class="contact-grid">
      <!-- Info Column -->
      <aside class="contact-info">
        <div class="info-card">
          <h2 class="premium-heading">{t.before_title}</h2>
          <p>{t.before_desc}</p>
          <ul class="benefit-list">
            {t.benefits.map((b) => (
              <li><span>{b}</span></li>
            ))}
          </ul>
        </div>

        <AvailabilityStatus lang={lang} />

        <div class="line-card">
          <h3>{t.line_title}</h3>
          <p>{t.line_desc}</p>
          <a href="https://lin.ee/o5QFPwc" target="_blank" rel="noopener" class="line-btn shine-effect">
            <svg class="line-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width: 24px; height: 24px; margin-right: 8px;">
              <path d="M24 10.304c0-5.369-5.383-9.738-12-9.738-6.616 0-12 4.369-12 9.738 0 4.814 3.904 8.846 9.449 9.58.373.08.882.247 1.01.594.116.313.076.804.037 1.135 0 0-.154.93-.188 1.127-.058.327-.272 1.341 1.173.732 1.445-.609 7.828-4.606 10.151-7.511C23.235 14.168 24 12.333 24 10.304zm-14.735 2.146c-.22 0-.398-.178-.398-.398V8.629c0-.22.178-.398.398-.398h2.68c.22 0 .398.178.398.398s-.178.398-.398.398h-2.282v1.196h2.282c.22 0 .398.178.398.398s-.178.398-.398.398h-2.282v1.406h2.282c.22 0 .398.178.398.398s-.178.398-.398.398h-2.68zm5.556 0c-.22 0-.398-.178-.398-.398V8.629c0-.22.178-.398.398-.398.22 0 .398.178.398.398v3.423c0 .22-.178.398-.398.398zm3.262 0c-.134 0-.263-.067-.34-.183l-2.028-3.083v2.868c0 .22-.178.398-.398.398-.22 0-.398-.178-.398-.398V8.629c0-.181.122-.34.298-.385.176-.045.36.035.452.19l2.016 3.064V8.629c0-.22.178-.398.398-.398.22 0 .398.178.398.398v3.423c0 .181-.122.34-.298.385-.054.014-.11.014-.164 0h.064zm-11.89 0c-.22 0-.398-.178-.398-.398V8.629c0-.22.178-.398.398-.398.22 0 .398.178.398.398v3.423c0 .22-.178.398-.398.398z"/>
            </svg>
            {t.line_btn}
          </a>
        </div>
      </aside>

      <!-- Form Column -->
      <section class="form-section">
        <div class="glass-panel">
          <div class="form-intro" style="margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid var(--line);">
            <h2 class="form-section-title">{t.form_heading}</h2>
            <p class="form-intro-title">{t.form_intro_title}</p>
            <p class="small" style="color: var(--muted); line-height: 1.6; margin-bottom: 0;">{t.form_intro_desc}</p>
          </div>
          <div class="server-choice-note" aria-label={lang === 'ja' ? '静的サイトと動的サイトの相談について' : 'Static and dynamic site consultation note'}>
            <strong>{t.server_note_title}</strong>
            <p>{t.server_note_desc}</p>
          </div>
          <div class="submit-flow-note consult-roadmap" aria-labelledby="consult-roadmap-title">
            <div class="consult-roadmap-copy">
              <strong id="consult-roadmap-title">{t.submit_flow_title}</strong>
              <p>{t.submit_flow_desc}</p>
            </div>
            <div class="consult-roadmap-visual">
              <svg class="consult-roadmap-line" viewBox="0 0 560 76" preserveAspectRatio="none" aria-hidden="true" focusable="false">
                <path class="consult-roadmap-path" d="M28 38 C90 12 126 64 186 38 S282 12 340 38 S438 64 532 38" />
              </svg>
              <ol class="consult-roadmap-steps" data-glossary-skip>
                {t.submit_flow_steps.map((step, index) => (
                  <li>
                    <span>{String(index + 1).padStart(2, '0')}</span>
                    <b>{step}</b>
                  </li>
                ))}
              </ol>
            </div>
          </div>
          <form action="https://formspree.io/f/xojrldrq" method="POST" class="contact-form" autocomplete="off" data-lang={lang}>
            <input type="hidden" name="_next" value={lang === 'ja' ? 'https://www.wa-node.com/thanks/' : `https://www.wa-node.com/${lang}/thanks/`} />
            <input type="hidden" id="landing_url" name="landing_url" value="" />
            <input type="hidden" id="referrer_url" name="referrer_url" value="" />

            <!-- Dynamic Benefit Badge -->
            <div id="benefit-badge-container" style="display: none; margin-bottom: 24px;">
              <div class="benefit-dynamic-badge">
                <span class="badge-icon"><MaterialIcon name="redeem" /></span>
                <div class="badge-content">
                  <strong id="benefit-badge-title">特典が適用されています</strong>
                  <p id="benefit-badge-desc">初回無料相談の時間を60分（30分拡大）に設定し、優先的に日程調整いたします。</p>
                </div>
              </div>
            </div>

            <section class="precheck-card" aria-labelledby="precheck-title">
              <div class="precheck-header">
                <span>{t.precheck_badge}</span>
                <h3 id="precheck-title">{t.precheck_title}</h3>
                <p>{t.precheck_desc}</p>
              </div>
              <div class="precheck-grid">
                <div class="form-group precheck-form-group" data-step="Q1">
                  <label for="category">{t.label_category}</label>
                  <select id="category" name="category">
                    <option value="" selected>{t.precheck_placeholder}</option>
                    <option value="web">{t.categories.web}</option>
                    <option value="copilot">{t.categories.copilot}</option>
                    <option value="line">{t.categories.line}</option>
                    <option value="ai">{t.categories.ai}</option>
                    <option value="other">{t.categories.other}</option>
                  </select>
                  {t.category_hint && <p class="field-desc">{t.category_hint}</p>}
                </div>
                <div class="form-group precheck-form-group" data-step="Q2">
                  <label for="current_issue">{t.label_issue}</label>
                  <select id="current_issue" name="current_issue">
                    <option value="" selected>{t.precheck_placeholder}</option>
                    <option value="traffic">{t.issues.traffic}</option>
                    <option value="inquiry">{t.issues.inquiry}</option>
                    <option value="message">{t.issues.message}</option>
                    <option value="workflow">{t.issues.workflow}</option>
                    <option value="other">{t.issues.other}</option>
                  </select>
                </div>
                <div class="form-group precheck-form-group" data-step="Q3">
                  <label for="consultation_takeaway">{t.label_takeaway}</label>
                  <select id="consultation_takeaway" name="consultation_takeaway">
                    <option value="" selected>{t.precheck_placeholder}</option>
                    <option value="direction">{t.takeaways.direction}</option>
                    <option value="cost">{t.takeaways.cost}</option>
                    <option value="idea">{t.takeaways.idea}</option>
                    <option value="fit">{t.takeaways.fit}</option>
                  </select>
                </div>
              </div>
              {t.precheck_reassurance && <p class="precheck-reassurance">{t.precheck_reassurance}</p>}
            </section>

            <div class="form-start-divider">
              <span>{t.form_start_label}</span>
              <p>{t.form_start_desc}</p>
            </div>

            <div class="scope-note-card">
              <strong>{t.scope_note_title}</strong>
              <p>{t.scope_note_desc}</p>
              <p class="scope-closing">{t.scope_note_closing}</p>
            </div>


            
            <div class="form-group">
              <label for="name">{t.label_name} <span class="required">{t.required}</span></label>
              <input type="text" id="name" name="name" required placeholder={t.placeholder_name} />
            </div>

            <div class="form-group">
              <label for="email">{t.label_email} <span class="required">{t.required}</span></label>
              <input type="email" id="email" name="email" required placeholder={t.placeholder_email} />
            </div>

            <input type="hidden" id="seen_source" name="seen_source" value="" />

            <div class="form-group">
              <label for="consultation_method">{t.label_method}</label>
              <select id="consultation_method" name="consultation_method">
                <option value="" selected>{t.placeholder_method}</option>
                <option value="google_meet">{t.methods.google_meet}</option>
                <option value="zoom">{t.methods.zoom}</option>
                <option value="line_video">{t.methods.line_video}</option>
                <option value="phone">{t.methods.phone}</option>
                <option value="face_to_face">{t.methods.face_to_face}</option>
                <option value="other">{t.methods.other}</option>
              </select>
              <p class="field-desc">{t.method_hint}</p>
            </div>

            <div class="form-group date-candidates">
              <label>{t.label_dates}</label>
              <div class="date-input-group">
                <div class="date-item">
                  <span>{t.date_1}</span>
                  <input type="datetime-local" name="date_1" />
                </div>
                <div class="date-item">
                  <span>{t.date_2}</span>
                  <input type="datetime-local" name="date_2" />
                </div>
                <div class="date-item">
                  <span>{t.date_3}</span>
                  <input type="datetime-local" name="date_3" />
                </div>
              </div>
              <p class="field-desc">{t.date_desc}</p>
            </div>

            <div class="consult-examples-card" aria-label={t.consult_examples_title}>
              <strong>{t.consult_examples_title}</strong>
              <p>{t.consult_examples_desc}</p>
              <ul>
                {t.consult_examples.map((example) => (
                  <li>{example}</li>
                ))}
              </ul>
            </div>

            <div class="safety-note-card">
              <strong>{t.safety_note_title}</strong>
              <p>{t.safety_note_desc}</p>
            </div>

            <div class="form-group">
              <label for="message">{t.label_message} <span class="required">{t.required}</span></label>
              <textarea id="message" name="message" rows="6" placeholder={t.placeholder_message} required></textarea>
            </div>

            <div class="form-consent">
              <p class="privacy-note" set:html={t.consent_note}></p>
              <label class="checkbox-label">
                <input type="checkbox" required />
                <span>{t.consent_checkbox}</span>
              </label>
            </div>



            <button type="submit" class="submit-btn" 
              data-submitting-text={lang === 'ja' ? '送信中...' : lang === 'fr' ? 'Envoi en cours...' : 'Sending...'}
              data-original-text={t.btn_submit}>
              <span>{t.btn_submit}</span>
              <MaterialIcon name="send" />
            </button>
          </form>
        </div>
      </section>
    </div>
  </div>
</main>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;700;800&display=swap');

  :root {
    --accent: #8c6b1f;
    --accent-dark: #725719;
    --accent-red: #c7352f;
    --accent-red-dark: #b62f29;
    --trust: #0f4c5c;
    --trust-mid: #1f6f78;
    --trust-green: #2f6f5e;
    --line: rgba(140, 107, 31, 0.2);
    --trust-line: rgba(15, 76, 92, 0.18);
  }

  /* Benefit Dynamic Badge Style */
  .benefit-dynamic-badge {
    display: flex;
    align-items: center;
    gap: 20px;
    background: linear-gradient(135deg, rgba(199, 53, 47, 0.08), rgba(238, 245, 242, 0.88));
    border: 2px solid var(--accent-red);
    border-radius: 24px;
    padding: 24px;
    box-shadow: 0 10px 25px rgba(199, 53, 47, 0.08);
    margin-bottom: 24px;
    animation: pulse-border 3s infinite alternate;
  }
  .benefit-dynamic-badge .badge-icon {
    font-size: 2.2rem;
    flex-shrink: 0;
  }
  .benefit-dynamic-badge .badge-content {
    flex: 1;
    text-align: left;
  }
  .benefit-dynamic-badge strong {
    display: block;
    color: var(--accent-red);
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 6px;
    font-family: 'Shippori Mincho', serif !important;
  }
  .benefit-dynamic-badge p {
    margin: 0;
    color: #444;
    font-size: 0.88rem;
    line-height: 1.6;
  }
  @keyframes pulse-border {
    from { border-color: var(--accent-red); }
    to { border-color: var(--accent); }
  }

  .premium-heading {
    font-family: 'Shippori Mincho', serif !important;
    font-weight: 800 !important;
    letter-spacing: 0.05em;
  }

  .contact-page {
    width: 100vw;
    max-width: 100%;
    overflow-x: hidden;
    padding-bottom: 120px;
    background: #fdfcf9;
    font-family: 'Shippori Mincho', serif !important;
  }
  .contact-page::before {
    content: ""; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3FfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3F/filter%3E%3Frect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3F/svg%3E");
    opacity: 0.03; pointer-events: none; z-index: -1;
  }

  .contact-header { padding: 80px 0 60px; text-align: center; }
  
  /* Anniversary Mini Banner */
  .contact-ann-notice {
    display: inline-flex; align-items: center; gap: 12px;
    background: #fff; border: 1px solid var(--accent-red);
    padding: 8px 20px; border-radius: 50px; margin-bottom: 30px;
    box-shadow: 0 10px 20px rgba(199, 53, 47, 0.05);
  }
  .contact-ann-notice .badge {
    background: var(--accent-red); color: #fff; font-size: 0.65rem; font-weight: 800;
    padding: 2px 10px; border-radius: 4px;
  }
  .contact-ann-notice p { font-size: 0.85rem; color: #2c2c2c; margin: 0; }
  .contact-ann-notice strong { color: var(--accent-red); }

  .eyebrow { font-size: 0.85rem; font-weight: 800; color: var(--accent); letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 16px; display: block; }
  .contact-header h1 { font-size: clamp(2.2rem, 6vw, 3.6rem); font-weight: 800; line-height: 1.2; margin-bottom: 24px; }
  .accent-text { color: var(--accent-red); }
  .lead { font-size: 1.1rem; color: #555; line-height: 1.8; }

  .contact-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 60px; margin-top: 40px; }
  .contact-grid > * { min-width: 0; }

  /* Info Column */
  .info-card, .line-card { background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 40px; margin-bottom: 30px; }
  .info-card h2, .line-card h3 { font-size: 1.4rem; margin-bottom: 20px; color: #2c2c2c; }
  
  .benefit-list { list-style: none; padding: 0; }
  .benefit-list li { position: relative; padding-left: 28px; margin-bottom: 16px; font-weight: 700; font-size: 0.95rem; }
  .benefit-list li::before { content: "✓"; position: absolute; left: 0; color: var(--accent-red); font-weight: 900; }

  .line-btn {
    display: flex; align-items: center; justify-content: center; gap: 12px;
    background: #06C755; color: #fff; text-decoration: none; padding: 18px; border-radius: 12px;
    font-weight: 800; transition: 0.3s;
  }
  .line-btn:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(6, 199, 85, 0.2); }

  /* Form Column */
  .glass-panel { background: #fff; border: 1px solid var(--line); border-radius: 20px; padding: 50px; box-shadow: 0 20px 50px rgba(0,0,0,0.02); }
  .form-section-title {
    margin: 0 0 10px;
    color: var(--trust);
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1.45;
  }
  .form-intro-title {
    margin: 0 0 8px;
    color: #2c2c2c;
    font-weight: 800;
    line-height: 1.6;
  }
  .submit-flow-note {
    display: grid;
    gap: 8px;
    margin: -8px 0 26px;
    padding: 16px 18px;
    border: 1px solid rgba(15, 76, 92, 0.18);
    border-left: 4px solid var(--trust);
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(238, 245, 242, 0.84), rgba(255, 255, 255, 0.96));
  }
  .submit-flow-note strong {
    color: var(--trust);
    font-size: 0.92rem;
    font-weight: 900;
  }
  .submit-flow-note p {
    margin: 0;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.75;
  }
  .consult-roadmap {
    overflow: hidden;
  }
  .consult-roadmap-copy {
    position: relative;
    z-index: 2;
  }
  .consult-roadmap-visual {
    position: relative;
    margin-top: 14px;
    padding: 8px 0 2px;
  }
  .consult-roadmap-line {
    position: absolute;
    top: 12px;
    left: 7%;
    width: 86%;
    height: 62px;
    pointer-events: none;
  }
  .consult-roadmap-path {
    fill: none;
    stroke: rgba(15, 76, 92, 0.24);
    stroke-width: 5;
    stroke-linecap: round;
    stroke-dasharray: 12 14;
    animation: consultFlow 8s linear infinite;
  }
  .consult-roadmap-steps {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(5, minmax(78px, 1fr));
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .consult-roadmap-steps li {
    display: grid;
    min-height: 86px;
    align-content: center;
    justify-items: center;
    gap: 8px;
    padding: 12px 8px;
    border: 1px solid rgba(15, 76, 92, 0.16);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 10px 24px rgba(15, 76, 92, 0.06);
    text-align: center;
  }
  .consult-roadmap-steps span {
    display: grid;
    width: 30px;
    height: 30px;
    place-items: center;
    border-radius: 999px;
    background: var(--trust);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 900;
    line-height: 1;
  }
  .consult-roadmap-steps b {
    color: #2c2c2c;
    font-size: 0.8rem;
    font-weight: 900;
    line-height: 1.35;
  }
  @keyframes consultFlow {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -52; }
  }
  .server-choice-note {
    display: grid;
    gap: 8px;
    margin: -10px 0 24px;
    padding: 16px 18px;
    border: 1px solid rgba(140, 107, 31, 0.2);
    border-left: 4px solid var(--accent);
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(140, 107, 31, 0.055), rgba(255, 255, 255, 0.96));
  }
  .server-choice-note strong {
    color: var(--accent-dark);
    font-size: 0.92rem;
    font-weight: 900;
  }
  .server-choice-note p {
    margin: 0;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.75;
  }
  .precheck-card {
    position: relative;
    overflow: hidden;
    margin-bottom: 30px;
    padding: 30px 26px 24px;
    border: 2px solid var(--trust-line);
    border-radius: 16px;
    background:
      linear-gradient(135deg, rgba(238, 245, 242, 0.92), rgba(255, 253, 248, 0.9)),
      #fffdf8;
    box-shadow: 0 18px 45px rgba(15, 76, 92, 0.08);
  }
  .precheck-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 8px;
    background: linear-gradient(90deg, var(--trust), var(--accent-red));
  }
  .precheck-header {
    margin-bottom: 18px;
    text-align: center;
  }
  .precheck-header span {
    display: inline-block;
    margin-bottom: 8px;
    padding: 4px 12px;
    border-radius: 999px;
    background: var(--trust);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .precheck-header h3 {
    margin: 0 0 8px;
    color: #2c2c2c;
    font-size: 1.35rem;
    font-weight: 800;
  }
  .precheck-header p {
    margin: 0;
    color: #666;
    font-size: 0.88rem;
    line-height: 1.65;
  }
  .precheck-grid {
    display: grid;
    gap: 14px;
  }
  .precheck-card .form-group,
  .precheck-form-group {
    margin-bottom: 0;
  }
  .precheck-form-group {
    position: relative;
    padding: 16px 16px 16px 64px;
    border: 1px solid var(--trust-line);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.9);
  }
  .precheck-form-group::before {
    content: attr(data-step);
    position: absolute;
    top: 16px;
    left: 16px;
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border-radius: 999px;
    background: var(--trust);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 900;
  }
  .precheck-form-group select {
    background: #fff;
  }
  .precheck-reassurance {
    margin: 18px 0 0;
    padding: 14px 16px;
    border-left: 3px solid var(--trust);
    border-radius: 0 10px 10px 0;
    background: rgba(15, 76, 92, 0.07);
    color: var(--trust);
    font-size: 0.9rem;
    font-weight: 800;
    line-height: 1.7;
  }
  .form-start-divider {
    margin: 34px 0 28px;
    padding-top: 26px;
    border-top: 1px solid var(--line);
    text-align: center;
  }
  .form-start-divider span {
    display: inline-block;
    margin-bottom: 8px;
    padding: 6px 16px;
    border-radius: 4px;
    background: #2c2c2c;
    color: #fff;
    font-size: 0.82rem;
    font-weight: 800;
  }
  .form-start-divider p {
    margin: 0;
    color: #666;
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .scope-note-card {
    margin: 0 0 30px;
    padding: 18px 20px;
