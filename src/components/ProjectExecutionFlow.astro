const t = f[lang];
---

<section id={id} class="execution-flow-section">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Project Flow</span>
      <h2 class="premium-heading ShipporiMincho">{t.title}</h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>

    <!-- Interactive Navigation Tabs -->
    <div class="flow-tabs-wrapper reveal">
      <div class="flow-tabs" role="tablist">
        <button class="flow-tab-btn active" data-tab="web" role="tab" aria-selected="true">
          {t.tab_web}
        </button>
        <button class="flow-tab-btn" data-tab="copilot" role="tab" aria-selected="false">
          {t.tab_copilot}
        </button>
      </div>
    </div>

    <!-- Web/LP Timelines -->
    <div id="flow-content-web" class="flow-content active-flow">
      <div class="flow-meta">
        <span class="duration-badge">{t.web_duration}</span>
      </div>

      <div class="timeline">
        {t.web_steps.map((item) => (
          <div class="timeline-item reveal">
            <div class="timeline-step">
              <span class="step-num">{item.step}</span>
            </div>
            
            <div class="timeline-body">
              <h3 class="step-title ShipporiMincho">{item.title}</h3>
              
              {item.payment && (
                <div class="payment-box">
                  <span class="payment-badge">{t.badge_payment}</span>
                  <p class="payment-text">{item.payment}</p>
                </div>
              )}

              <div class="task-grid">
                <div class="task-col our-task-col">
                  <span class="task-header-badge">{t.label_our_task}</span>
                  <p class="task-desc">{item.our_task}</p>
                </div>
                <div class="task-col client-task-col">
                  <span class="task-header-badge client">{t.label_client_task}</span>
                  <p class="task-desc">{item.client_task}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Business Copilot Timelines -->
    <div id="flow-content-copilot" class="flow-content">
      <div class="flow-meta">
        <span class="duration-badge copilot">{t.copilot_duration}</span>
      </div>

      <div class="timeline">
        {t.copilot_steps.map((item) => (
          <div class="timeline-item reveal">
            <div class="timeline-step">
              <span class="step-num">{item.step}</span>
            </div>
            
            <div class="timeline-body">
              <h3 class="step-title ShipporiMincho">{item.title}</h3>
              
              {item.payment && (
                <div class="payment-box">
                  <span class="payment-badge">{t.badge_payment}</span>
                  <p class="payment-text">{item.payment}</p>
                </div>
              )}

              <div class="task-grid">
                <div class="task-col our-task-col">
                  <span class="task-header-badge">{t.label_our_task}</span>
                  <p class="task-desc">{item.our_task}</p>
                </div>
                <div class="task-col client-task-col">
                  <span class="task-header-badge client">{t.label_client_task}</span>
                  <p class="task-desc">{item.client_task}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function initFlowTabs() {
    const tabButtons = document.querySelectorAll('.flow-tab-btn');
    const flowContents = document.querySelectorAll('.flow-content');

    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        const targetTab = button.getAttribute('data-tab');

        // Deactivate all buttons
        tabButtons.forEach(btn => {
          btn.classList.remove('active');
          btn.setAttribute('aria-selected', 'false');
        });

        // Hide all contents
        flowContents.forEach(content => {
          content.classList.remove('active-flow');
        });

        // Activate selected button & content
        button.classList.add('active');
        button.setAttribute('aria-selected', 'true');
        
        const targetContent = document.getElementById(`flow-content-${targetTab}`);
        if (targetContent) {
          targetContent.classList.add('active-flow');
        }
      });
    });
  }

  // Support page transition in Astro (swup/barba/native)
  document.addEventListener('astro:page-load', initFlowTabs);
  // Fallback for regular load
  document.addEventListener('DOMContentLoaded', initFlowTabs);
  // Immediate run
  initFlowTabs();
</script>

<style>
  .execution-flow-section {
    padding: 120px 0;
    background-color: var(--soft);
    border-top: 1px solid var(--line);
    overflow: hidden;
  }
  
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .section-header {
