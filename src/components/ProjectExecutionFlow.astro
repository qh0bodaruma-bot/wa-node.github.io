    margin-bottom: 12px;
  }
  .section-subtitle {
    font-size: 1.05rem;
    color: var(--muted);
    margin-top: 16px;
  }

  /* Premium Tabs */
  .flow-tabs-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 50px;
  }
  .flow-tabs {
    display: flex;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 99px;
    padding: 6px;
    box-shadow: var(--shadow-sm);
  }
  .flow-tab-btn {
    padding: 14px 32px;
    border: none;
    background: transparent;
    color: var(--muted);
    font-size: 0.95rem;
    font-weight: 800;
    border-radius: 99px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .flow-tab-btn.active {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 4px 12px rgba(197, 160, 89, 0.3);
  }

  /* Metadata badges */
  .flow-meta {
    display: flex;
    justify-content: center;
    margin-bottom: 40px;
  }
  .duration-badge {
    display: inline-block;
    padding: 8px 24px;
    background: rgba(197, 160, 89, 0.08);
    border: 1.5px solid var(--accent);
    color: var(--accent-dark);
    font-weight: 800;
    font-size: 0.9rem;
    border-radius: 99px;
  }
  .duration-badge.copilot {
    background: rgba(99, 153, 34, 0.08);
    border-color: var(--accent2);
    color: var(--accent2-dark);
  }

  /* Flow content visibility */
  .flow-content {
    display: none;
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .flow-content.active-flow {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  /* Timeline Tree */
  .timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    padding-left: 50px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    top: 5px;
    bottom: 5px;
    left: 14px;
    width: 2px;
    background: var(--line);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 60px;
  }
  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-step {
    position: absolute;
    left: -50px;
    top: 0;
    width: 30px;
    height: 30px;
    background: #fff;
    border: 2px solid var(--accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: var(--shadow-sm);
  }
  .step-num {
    font-size: 0.7rem;
    font-weight: 900;
    color: var(--accent-dark);
    font-family: 'Shippori Mincho', serif;
  }
  #flow-content-copilot .timeline-step {
    border-color: var(--accent2);
  }
  #flow-content-copilot .step-num {
    color: var(--accent2-dark);
  }

  /* Timeline card body */
  .timeline-body {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 28px;
    padding: 40px;
    box-shadow: var(--shadow-sm);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .timeline-body:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: rgba(197, 160, 89, 0.3);
  }
  #flow-content-copilot .timeline-body:hover {
    border-color: rgba(99, 153, 34, 0.3);
