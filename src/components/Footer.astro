---
import Qualifications from './Qualifications.astro';
import t from '../i18n/translations.json';

interface Props {
  lang?: 'ja' | 'en' | 'fr';
}

const { lang = 'ja' } = Astro.props;

function getLocalizedLink(path: string) {
  const cleanPath = path.replace(/\/+/g, '/');
  if (lang === 'ja') {
    return cleanPath.endsWith('/') ? cleanPath : `${cleanPath}/`;
  }
  
  // en or fr: For existing multi-language pages
  const validPages = ['/', '', '/contact', '/pricing', '/ai-chat-demo', '/corporate-mental'];
  const basePage = cleanPath.split(/[?#]/)[0];
  
  if (validPages.includes(basePage)) {
    const langPath = basePage === '/' || basePage === '' ? `/${lang}/` : `/${lang}${cleanPath}/`;
    return langPath.replace(/\/+/g, '/');
  }
  
  // For other pages that do not have multi-language files, fallback to their Japanese counterpart with lang param
  const fallbackPath = cleanPath.endsWith('/') ? cleanPath : `${cleanPath}/`;
  return `${fallbackPath}?lang=${lang}`;
}
---
