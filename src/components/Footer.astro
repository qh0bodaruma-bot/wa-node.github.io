---
import Qualifications from './Qualifications.astro';
---
<footer class="footer">
  <div class="section-inner">
    <Qualifications />

    <div class="footer-grid">
      <div class="footer-col">
        <h3>制作・サービス</h3>
        <ul>
          <li><a href="/portfolio-lp/">LP制作ポートフォリオ</a></li>
          <li><a href="/kdp_books">KDP出版実績</a></li>
          <li><a href="/pricing">料金プラン一覧</a></li>
          <li><a href="/corporate-mental">法人メンタル窓口</a></li>
          <li><a href="/#line-mini-app">LINE Mini App制作</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>診断・ツール</h3>
        <ul>
          <li><a href="/barrier_free">バリアフリー診断</a></li>
          <li><a href="/mental_care">こころの疲労度診断</a></li>
          <li><a href="/seo_check">SEO内部対策診断</a></li>
          <li><a href="/lp_wizard">制作ヒアリング体験</a></li>
          <li><a href="/simulator">料金シミュレーター</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>規約・ポリシー</h3>
        <ul>
          <li><a href="/terms">利用規約</a></li>
          <li><a href="/privacy">プライバシーポリシー</a></li>
          <li><a href="/security-policy">情報セキュリティ方針</a></li>
          <li><a href="/tokutei">特定商取引法に基づく表記</a></li>
          <li><a href="/cancel-policy">キャンセル・返金ポリシー</a></li>
          <li><a href="/terms_miniapp">LINE Mini App 利用規約</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>和-Nodeについて</h3>
        <ul>
          <li><a href="/">トップページ</a></li>
          <li><a href="/#about">代表プロフィール</a></li>
          <li><a href="https://x.com/wa_node" target="_blank" rel="noopener">X（旧Twitter）</a></li>
          <li><a href="/counseling-notes">カウンセリング利用時の注意事項</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-badges">
        <a href="/security-policy"><img src="/images/security_action_hitotsuboshi-large_color.jpg" alt="SECURITY ACTION 一つ星"></a>
      </div>
      <p class="copyright">© 2026 和-Node. All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary-dark, #1f2a22);
    color: #fff;
    padding: 80px 0 40px;
  }
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 60px;
  }
  .footer-col h3 {
    font-size: 1rem;
    color: var(--accent2);
    margin-bottom: 20px;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-col li {
    margin-bottom: 12px;
  }
  .footer-col a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    transition: 0.3s;
  }
  .footer-col a:hover {
    color: #fff;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-badges img {
    height: 60px;
  }
  .copyright {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
