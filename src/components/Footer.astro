---
import Qualifications from './Qualifications.astro';
import t from '../i18n/translations.json';

interface Props {
  lang?: 'ja' | 'en' | 'fr';
}

const { lang = 'ja' } = Astro.props;

function getLocalizedLink(path: string) {
  const prefix = lang === 'ja' ? '' : `/${lang}`;
  const finalPath = `${prefix}${path}`.replace(/\/+/g, '/');
  return finalPath.endsWith('/') ? finalPath : `${finalPath}/`;
}
---
<footer class="footer">
  <div class="section-inner">
    <div class="footer-brand">
      <div class="logo">和-Node</div>
      <p class="tagline">{t.footer.tagline[lang]}</p>
      <div class="footer-info">
        <p class="info-item">{t.footer.founder[lang]}</p>
        <p class="info-item">〒509-0207 岐阜県可児市今渡2347番地1</p>
        <p class="info-item">Tel: 080-3599-5388</p>
        <p class="info-item">Email: <a href="mailto:contacts@wa-node.com">contacts@wa-node.com</a></p>
      </div>
    </div>

    <div class="footer-grid">
      <div class="footer-col">
        <h3>{t.footer.col1[lang]}</h3>
        <ul>
          <li><a href={getLocalizedLink('/pricing')}>{t.footer.col1_item1[lang]}</a></li>
          <li><a href={getLocalizedLink('/pricing')}>{t.footer.col1_item2[lang]}</a></li>
          <li><a href={getLocalizedLink('/pricing')}>{t.footer.col1_item3[lang]}</a></li>
          <li><a href={getLocalizedLink('/works')}>{t.footer.col1_item4[lang]}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>{t.footer.col2[lang]}</h3>
        <ul>
          <li><a href={getLocalizedLink('/psychology-demo')}>{t.footer.col2_item1[lang]}</a></li>
          <li><a href={getLocalizedLink('/ai-chat-demo')}>{t.footer.col2_item2[lang]}</a></li>
          <li><a href={getLocalizedLink('/lp_wizard')}>{t.footer.col2_item3[lang]}</a></li>
          <li><a href={getLocalizedLink('/simulator')}>{t.footer.col2_item4[lang]}</a></li>
          <li><a href={getLocalizedLink('/seo_check')}>{t.footer.col2_item5[lang]}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>{t.footer.col3[lang]}</h3>
        <ul>
          <li><a href={getLocalizedLink('/corporate-mental')}>{t.footer.col3_item1[lang]}</a></li>
          <li><a href={getLocalizedLink('/barrier_free')}>{t.footer.col3_item2[lang]}</a></li>
          <li><a href={getLocalizedLink('/mental_care')}>{t.footer.col3_item3[lang]}</a></li>
          <li><a href={getLocalizedLink('/kdp_books')}>{t.footer.col3_item4[lang]}</a></li>
          <li><a href={getLocalizedLink('/free-guide')}>{t.footer.col3_item5[lang]}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>{t.footer.col4[lang]}</h3>
        <ul>
          <li><a href={getLocalizedLink('/about')}>{t.footer.col4_item1[lang]}</a></li>
          <li><a href={getLocalizedLink('/terms')}>{t.footer.col4_item2[lang]}</a></li>
          <li><a href={getLocalizedLink('/privacy')}>{t.footer.col4_item3[lang]}</a></li>
          <li><a href={getLocalizedLink('/security-policy')}>{t.footer.col4_item4[lang]}</a></li>
          <li><a href={getLocalizedLink('/tokutei')}>{t.footer.col4_item5[lang]}</a></li>
          <li><a href={getLocalizedLink('/terms_miniapp')}>{t.footer.col4_item6[lang]}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-badges">
        <a href="/security-policy"><img src="/images/security_action_hitotsuboshi-large_color.jpg" alt="SECURITY ACTION 一つ星"></a>
      </div>
      <p class="copyright">© 2026 和-Node. All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #0a0a0a;
    color: #fff;
    padding: 100px 0 40px;
  }
  .footer-brand {
    margin-bottom: 60px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .footer-brand .logo {
    font-size: 1.8rem;
    font-weight: 900;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
  }
  .footer-brand .tagline {
    font-size: 0.9rem;
    color: var(--accent2);
    font-weight: 700;
    margin-bottom: 24px;
  }
  .footer-info {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.8;
  }
  .footer-info .info-item {
    margin: 0;
  }
  .footer-info a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: underline;
  }
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 60px;
  }
  .footer-col h3 {
    font-size: 1rem;
    color: var(--accent2);
    margin-bottom: 20px;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-col li {
    margin-bottom: 12px;
  }
  .footer-col a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    transition: 0.3s;
  }
  .footer-col a:hover {
    color: #fff;
  }
  .footer-col .qual-list li {
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .qual-list li::before {
    content: "✓";
    color: var(--accent2);
    font-weight: 900;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-badges img {
    height: 60px;
  }
  .copyright {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
