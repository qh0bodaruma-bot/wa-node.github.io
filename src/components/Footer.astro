<style>
  .footer {
    background-color: #0a0a0a;
    color: #fff;
    padding: 100px 0 40px;
  }
  .footer-brand {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 40px;
    margin-bottom: 60px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .brand-main {
    flex: 1;
    max-width: 400px;
  }
  .footer-brand .logo {
    font-size: 1.8rem;
    font-weight: 900;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
  }
  .footer-brand .tagline {
    font-size: 0.9rem;
    color: var(--accent2);
    font-weight: 700;
    margin-bottom: 24px;
  }
  .footer-info {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.8;
  }
  .footer-info .info-item {
    margin: 0;
  }
  .footer-info a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: underline;
  }
  .footer-founder-card {
    flex: 1.3;
    display: flex;
    gap: 20px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 24px;
    border-radius: 20px;
    max-width: 620px;
  }
  .founder-avatar-wrap {
    flex: 0 0 80px;
    width: 80px;
    height: 80px;
    border-radius: 16px;
    overflow: hidden;
    border: 1.5px solid rgba(197, 160, 89, 0.3);
  }
  .founder-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .founder-body {
    flex: 1;
  }
  .founder-role {
    font-size: 0.7rem;
    color: var(--accent2);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 4px;
  }
  .founder-name {
    font-size: 1.1rem;
    font-weight: 800;
    color: #fff;
    margin: 0 0 8px 0;
  }
  .founder-text {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    margin: 0 0 12px 0;
  }
  .founder-link-btn {
    font-size: 0.8rem;
    color: var(--accent2);
    font-weight: 800;
    text-decoration: underline;
    transition: 0.3s;
  }
  .founder-link-btn:hover {
    color: #fff;
  }
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 60px;
  }
  .footer-col h3 {
    font-size: 1rem;
    color: var(--accent2);
    margin-bottom: 20px;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-col li {
    margin-bottom: 12px;
  }
  .footer-col a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    transition: 0.3s;
  }
  .footer-col a:hover {
    color: #fff;
  }
  .footer-col .qual-list li {
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .qual-list li::before {
    content: "✓";
    color: var(--accent2);
    font-weight: 900;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-badges img {
    height: 60px;
  }
  .copyright {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 768px) {
    .footer-brand {
      flex-direction: column;
      gap: 30px;
    }
    .brand-main {
      max-width: 100%;
    }
    .footer-founder-card {
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
    }
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
  @media (max-width: 480px) {
    .footer-founder-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
