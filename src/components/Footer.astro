---
import t from '../i18n/translations.json';
import { MULTILANG_PAGES } from '../i18n/navigation';

interface Props {
  lang?: 'ja' | 'en' | 'fr';
}

const { lang = 'ja' } = Astro.props;

function getLocalizedLink(path: string) {
  const [beforeHash, hashFragment] = path.split('#');
  const hash = hashFragment ? `#${hashFragment}` : '';
  const queryIndex = beforeHash.indexOf('?');
  const pathname = queryIndex >= 0 ? beforeHash.slice(0, queryIndex) : beforeHash;
  const search = queryIndex >= 0 ? beforeHash.slice(queryIndex) : '';
  const cleanPath = pathname.replace(/\/+/g, '/');
  const pathWithSlash = cleanPath === '/' || cleanPath.endsWith('/') ? cleanPath : `${cleanPath}/`;

  if (lang === 'ja') {
    return `${pathWithSlash}${search}${hash}`;
  }
  
  // en or fr: For existing multi-language pages
  const validPages = [...MULTILANG_PAGES, ''];
  const basePage = cleanPath.replace(/\/$/, '');
  
  if (validPages.includes(basePage)) {
    const langPath = basePage === '/' || basePage === '' ? `/${lang}/` : `/${lang}${pathWithSlash}`;
    return `${langPath.replace(/\/+/g, '/')}${search}${hash}`;
  }
  
  // For other pages that do not have multi-language files, fallback to their Japanese counterpart with lang param
  const separator = search ? '&' : '?';
  return `${pathWithSlash}${search}${separator}lang=${lang}${hash}`;
}
---
<footer class="footer">
  <div class="section-inner">
    <div class="footer-grid">
      <div class="footer-col">
        <h3>{t.footer.col1[lang]}</h3>
        <ul>
          <li><a href={getLocalizedLink('/pricing#web-production')}>{t.footer.col1_item1[lang]}</a></li>
          <li><a href={getLocalizedLink('/pricing#web-production')}>{t.footer.col1_item2[lang]}</a></li>
          <li><a href={getLocalizedLink('/pricing#copilot')}>{t.footer.col1_item3[lang]}</a></li>
          <li><a href={getLocalizedLink('/pricing#project-flow')}>{t.footer.col1_item_flow[lang]}</a></li>
          <li><a href={getLocalizedLink('/works')}>{t.footer.col1_item4[lang]}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>{lang === 'ja' ? '相談前に見る' : lang === 'en' ? 'Start Here' : 'Commencer ici'}</h3>
        <ul>
          <li><a href={getLocalizedLink('/contact')}>{lang === 'ja' ? '無料相談' : lang === 'en' ? 'Free Consultation' : 'Consultation gratuite'}</a></li>
          <li><a href={getLocalizedLink('/pricing')}>{lang === 'ja' ? '料金を見る' : lang === 'en' ? 'See Pricing' : 'Voir les tarifs'}</a></li>
          <li><a href={getLocalizedLink('/works')}>{lang === 'ja' ? '制作例・デモを見る' : lang === 'en' ? 'Works & Demos' : 'Réalisations & démos'}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>{lang === 'ja' ? '補足コンテンツ' : lang === 'en' ? 'Resources' : 'Ressources'}</h3>
        <ul>
          <li><a href={getLocalizedLink('/blog')}>{lang === 'ja' ? '和-Node 知恵袋（ブログ）' : 'Blog'}</a></li>
          <li><a href={getLocalizedLink('/psychology-demo')}>{t.footer.col2_item1[lang]}</a></li>
          <li><a href={getLocalizedLink('/wasm-diagnosis')}>{t.footer.col2_item6[lang]}</a></li>
          <li><a href={getLocalizedLink('/tech-stack')}>{t.footer.col4_item_tech[lang]}</a></li>
          <li><a href={getLocalizedLink('/easy-guide')}>{t.footer.col4_item0[lang]}</a></li>
          <li><a href={getLocalizedLink('/kdp_books')}>{t.footer.col3_item4[lang]}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>{t.footer.col4[lang]}</h3>
        <ul>
          <li><a href={getLocalizedLink('/terms')}>{t.footer.col4_item2[lang]}</a></li>
          <li><a href={getLocalizedLink('/privacy')}>{t.footer.col4_item3[lang]}</a></li>
          <li><a href={getLocalizedLink('/security-policy')}>{t.footer.col4_item4[lang]}</a></li>
          <li><a href={getLocalizedLink('/tokutei')}>{t.footer.col4_item5[lang]}</a></li>
          <li><a href={getLocalizedLink('/terms_miniapp')}>{t.footer.col4_item6[lang]}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-badges">
        <a href="/security-policy/"><img src="/images/security-action-one-star.webp" alt="SECURITY ACTION 一つ星" width="160" height="160" loading="lazy" decoding="async"></a>
      </div>
      <p class="copyright">© 2026 和-Node. All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    --footer-accent: #d8b98c;
    background-color: #0a0a0a;
    color: #fff;
    padding: 100px 0 40px;
  }
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 60px;
  }
  .footer-col h3 {
    font-size: 1rem;
    color: var(--footer-accent);
    margin-bottom: 20px;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-col li {
    margin-bottom: 12px;
  }
  .footer-col a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    transition: 0.3s;
  }
  .footer-col a:hover {
    color: #fff;
  }
  .footer-col .qual-list li {
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .qual-list li::before {
    content: "✓";
    color: var(--footer-accent);
    font-weight: 900;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-badges img {
    height: 60px;
  }
  .copyright {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 768px) {
    .brand-main {
      max-width: 100%;
    }
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
