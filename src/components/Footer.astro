---
import Qualifications from './Qualifications.astro';
---
<footer class="footer">
  <div class="section-inner">
    <div class="footer-brand">
      <div class="logo">和-Node</div>
      <p class="tagline">心理学×Web制作｜選ばれる導線と継続的な伴走で、ビジネスを整える。</p>
      <div class="footer-info">
        <p class="info-item">代表：高野 紘純</p>
        <p class="info-item">〒509-0207 岐阜県可児市今渡2347番地1</p>
        <p class="info-item">Tel: 080-3599-5388</p>
        <p class="info-item">Email: <a href="mailto:contacts@wa-node.com">contacts@wa-node.com</a></p>
      </div>
    </div>

    <div class="footer-grid">
      <div class="footer-col">
        <h3>制作・サービス</h3>
        <ul>
          <li><a href="/pricing">心理導線Web制作</a></li>
          <li><a href="/pricing">月額ICT・AI伴走</a></li>
          <li><a href="/works">制作実績・サンプル</a></li>
          <li><a href="/corporate-mental">組織コミュニケーション支援</a></li>
          <li><a href="/kdp_books">KDP出版実績</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>診断・ツール</h3>
        <ul>
          <li><a href="/barrier_free">バリアフリー診断</a></li>
          <li><a href="/mental_care">こころの疲労度診断</a></li>
          <li><a href="/seo_check">SEO内部対策診断</a></li>
          <li><a href="/lp_wizard">制作ヒアリング体験</a></li>
          <li><a href="/simulator">料金シミュレーター</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>規約・ポリシー</h3>
        <ul>
          <li><a href="/terms">利用規約</a></li>
          <li><a href="/privacy">プライバシーポリシー</a></li>
          <li><a href="/security-policy">情報セキュリティ方針</a></li>
          <li><a href="/tokutei">特定商取引法に基づく表記</a></li>
          <li><a href="/cancel-policy">キャンセル・返金ポリシー</a></li>
          <li><a href="/terms_miniapp">LINE Mini App 利用規約</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>和-Nodeについて</h3>
        <ul>
          <li><a href="/">トップページ</a></li>
          <li><a href="/about">事業概要・運営者情報・代表プロフィール</a></li>
          <li><a href="https://x.com/wa_node" target="_blank" rel="noopener">X（旧Twitter）</a></li>
          <li><a href="https://note.com/wa_node" target="_blank" rel="noopener">note（公式）</a></li>
          <li><a href="/counseling-notes">カウンセリング利用時の注意事項</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-badges">
        <a href="/security-policy"><img src="/images/security_action_hitotsuboshi-large_color.jpg" alt="SECURITY ACTION 一つ星"></a>
      </div>
      <p class="copyright">© 2026 和-Node. All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #0a0a0a;
    color: #fff;
    padding: 100px 0 40px;
  }
  .footer-brand {
    margin-bottom: 60px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .footer-brand .logo {
    font-size: 1.8rem;
    font-weight: 900;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
  }
  .footer-brand .tagline {
    font-size: 0.9rem;
    color: var(--accent2);
    font-weight: 700;
    margin-bottom: 24px;
  }
  .footer-info {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.8;
  }
  .footer-info .info-item {
    margin: 0;
  }
  .footer-info a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: underline;
  }
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 60px;
  }
  .footer-col h3 {
    font-size: 1rem;
    color: var(--accent2);
    margin-bottom: 20px;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-col li {
    margin-bottom: 12px;
  }
  .footer-col a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    transition: 0.3s;
  }
  .footer-col a:hover {
    color: #fff;
  }
  .footer-col .qual-list li {
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .qual-list li::before {
    content: "✓";
    color: var(--accent2);
    font-weight: 900;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-badges img {
    height: 60px;
  }
  .copyright {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
