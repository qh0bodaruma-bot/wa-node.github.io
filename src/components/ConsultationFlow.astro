---
// src/components/ConsultationFlow.astro
interface Props {
  id?: string;
  background?: string;
  border?: boolean;
  lang?: 'ja' | 'en' | 'fr';
}

const { 
  id = "consultation-flow", 
  background = "rgba(255, 253, 248, 0.9)", 
  border = true,
  lang = 'ja'
} = Astro.props;

// 翻訳データの定義
const t = {
  ja: {
    kicker: "Consultation Flow",
    title: "ご相談の流れ",
    lead: "まずは無料相談（最大60分）で、あなたのビジネスの現状と理想を整理します。",
    step1_title: "無料相談",
    step1_desc: "オンラインにて課題をヒアリング。今やるべきことを整理します。",
    step2_title: "方向性整理・ご提案",
    step2_desc: "必要に応じて簡易メモ・概要案を添え、最適なプランを提示します。",
    step3_title: "スマートな開発とサポート",
    step3_desc: "内容にご納得いただければ、Web制作やビジネスの副操縦士としての各種支援をスタートします。",
    note1: "※無理な勧誘は一切行いません。まずは「壁打ち相手」としてお気軽にご活用ください。",
    note2: "※無料相談後にお渡しする場合がある資料は、方向性を確認するための簡易メモ・概要案です。詳細な構成案、設計書、原稿整理、デザイン作成は、ご契約後の正式な制作工程として扱います。",
    micro_copy: "※専門的なIT知識や難しい言葉は一切不要です。「何から相談していいか分からない」状態でも、私たちの『副操縦士』が優しく状況を整理しますので、どうぞご安心ください。",
    btn_line: "LINEで相談予約（最大60分）",
    btn_form: "フォームから申し込む",
    form_link: "/contact/"
  },
  en: {
    kicker: "Consultation Flow",
    title: "Consultation Flow",
    lead: "We clarify your current business challenges and goals during a free consultation (up to 60 minutes).",
    step1_title: "Free Consultation",
    step1_desc: "We clarify your challenges online and outline your immediate priorities.",
    step2_title: "Proposal & Strategy",
    step2_desc: "We present the most optimized plan, accompanied by a brief draft mockup if needed.",
    step3_title: "Smart Development & Support",
    step3_desc: "Once satisfied with the proposal, we launch the website production or ongoing partnership.",
    note1: "*Absolutely no high-pressure sales. Feel free to use this session simply to bounce ideas off us.",
    note2: "*The materials provided after the free consultation are basic drafts to confirm direction. Detailed structures, blueprints, copywriting, and final design work will be handled as part of the formal development process post-contract.",
    micro_copy: "*No professional IT knowledge or complex jargon is required. Even if you don't know where to start, our 'Co-pilot' will gently guide you through the process.",
    btn_line: "Book via LINE (Max 60 min)",
    btn_form: "Book via Web Form",
    form_link: "/en/contact/"
  },
  fr: {
    kicker: "Déroulement",
    title: "Déroulement de la Consultation",
    lead: "Nous clarifions vos défis actuels et vos objectifs lors d'une consultation gratuite (jusqu'à 60 minutes).",
    step1_title: "Consultation Gratuite",
    step1_desc: "Nous analysons vos besoins en ligne et définissons vos priorités immédiates.",
    step2_title: "Proposition & Orientation",
    step2_desc: "Nous présentons l'offre la plus adaptée, accompagnée d'une ébauche de maquette si nécessaire.",
    step3_title: "Développement & Support",
    step3_desc: "Dès que l'offre vous convient, nous lançons la création web ou notre partenariat de co-pilotage.",
    note1: "*Aucune pression commerciale. Profitez simplement de cet échange pour clarifier vos idées.",
    note2: "*Les documents fournis après la consultation gratuite sont des ébauches destinées à valider l'orientation. La structure détaillée, le cahier des charges, la rédaction et le design final font partie du processus officiel après signature.",
    micro_copy: "*Aucune compétence technique ou jargon complexe n'est requis. Même si vous hésitez sur le point de départ, notre « Co-pilote » clarifiera la situation en douceur.",
    btn_line: "Réserver via LINE (Max 60 min)",
    btn_form: "Réserver via Formulaire",
    form_link: "/fr/contact/"
  }
};

const curT = t[lang];
---

<section id={id} class="consultation-section" style={border ? 'border-top: 1px solid var(--line);' : ''}>
  <div class="consultation-wrap">
    <div class="section-head">
      <p class="kicker">{curT.kicker}</p>
      <h2>{curT.title}</h2>
      <p class="muted">{curT.lead}</p>
    </div>
    
    <div class="consultation-card" style={`background: ${background};`}>
      <div class="flow-steps-compact">
        <div class="flow-step">
          <div class="step-circle">1</div>
          <div class="step-body">
            <h3>{curT.step1_title}</h3>
            <p>{curT.step1_desc}</p>
          </div>
        </div>
        <div class="flow-step">
          <div class="step-circle">2</div>
          <div class="step-body">
            <h3>{curT.step2_title}</h3>
            <p>{curT.step2_desc}</p>
          </div>
        </div>
        <div class="flow-step">
          <div class="step-circle">3</div>
          <div class="step-body">
            <h3>{curT.step3_title}</h3>
            <p>{curT.step3_desc}</p>
          </div>
        </div>
      </div>

      <div class="consultation-note">
        <p>{curT.note1}</p>
        <p style="margin-top: 12px; font-size: 0.8rem; font-weight: 500; text-align: left; line-height: 1.6; color: #666; max-width: 680px; margin-left: auto; margin-right: auto; border-top: 1px dashed rgba(197, 160, 89, 0.3); padding-top: 10px;">
          {curT.note2}
        </p>
      </div>
      
      <!-- 自己効力感向上のマイクロコピー -->
      <p class="micro-copy" style="text-align: center; font-size: 0.85rem; color: var(--trust); font-weight: 700; margin-bottom: 16px; letter-spacing: 0.02em; line-height: 1.6; max-width: 680px; margin-left: auto; margin-right: auto;">
        {curT.micro_copy}
      </p>

      <div class="cta-btns">
        <a class="btn-primary shine-effect" href="https://lin.ee/o5QFPwc" target="_blank" rel="noopener">{curT.btn_line}</a>
        <a class="btn-secondary" href={curT.form_link}>{curT.btn_form}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .consultation-section { padding: 100px 0; background: #fff; }
  .consultation-wrap { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  .section-head { text-align: center; margin-bottom: 50px; }
  .kicker { color: var(--trust, #0f4c5c); font-weight: 700; letter-spacing: .1em; font-size: 0.9rem; margin-bottom: 12px; }
  h2 { font-size: 2rem; font-weight: 900; margin-bottom: 16px; color: var(--text-deep); }
  .muted { color: #666; font-size: 1rem; }

  .consultation-card { padding: 50px; border: 1px solid var(--line); border-radius: 32px; box-shadow: 0 20px 40px rgba(0,0,0,0.02); }
  
  .flow-steps-compact { display: flex; flex-direction: column; gap: 30px; margin-bottom: 40px; }
  .flow-step { display: flex; gap: 24px; align-items: flex-start; }
  .step-circle { 
    flex: 0 0 40px; height: 40px; background: var(--trust, #0f4c5c); color: #fff;
    border-radius: 50%; display: flex; align-items: center; justify-content: center; 
    font-weight: 800; font-size: 1.1rem;
  }
  .step-body h3 { font-size: 1.2rem; margin-bottom: 6px; font-weight: 800; color: var(--text-deep); }
  .step-body p { font-size: 0.95rem; color: #555; margin: 0; }

  .consultation-note { text-align: center; margin-bottom: 40px; padding: 16px; background: var(--soft); border-radius: 12px; }
  .consultation-note p { font-size: 0.85rem; color: var(--muted); margin: 0; font-weight: 700; }

  .cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .btn-primary, .btn-secondary {
    padding: 16px 40px; border-radius: 999px; font-weight: 800; text-decoration: none; 
    transition: 0.3s; text-align: center; min-width: 260px;
  }
  .btn-primary { background: var(--trust, #0f4c5c); color: #fff; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(15, 76, 92, 0.2); background: #123c45; }
  .btn-secondary { background: #fff; color: var(--trust, #0f4c5c); border: 2px solid var(--trust, #0f4c5c); }
  .btn-secondary:hover { background: var(--trust, #0f4c5c); color: #fff; }

  @media (max-width: 600px) {
    .consultation-card { padding: 30px 20px; }
    .btn-primary, .btn-secondary { width: 100%; min-width: 0; }
    .flow-step { gap: 16px; }
  }
</style>
