---
// src/components/AiChatWidget.astro
// 和-Node AI コンシェルジュ ウィジェット
---

<div class="ai-chat-widget" id="ai-chat-widget">
  <!-- フローティングボタン -->
  <button class="chat-trigger" id="chat-trigger" aria-label="AI相談を開始する">
    <div class="trigger-icon">
      <span class="icon-main">🧠</span>
      <span class="icon-sub">AI</span>
    </div>
    <span class="trigger-text">夜間のご相談・課題整理はこちら</span>
  </button>

  <!-- チャットウィンドウ -->
  <div class="chat-window" id="chat-window" aria-hidden="true">
    <div class="chat-header">
      <div class="header-info">
        <span class="status-dot"></span>
        <h3>和-Node AI コンシェルジュ</h3>
      </div>
      <button class="close-btn" id="close-chat" aria-label="閉じる">&times;</button>
    </div>

    <div class="chat-messages" id="chat-messages">
      <div class="message system">
        <div class="message-content">
          こんばんは。和-Node AIコンシェルジュです。夜分に失礼いたします。<br />
          何かお困りごとはありますか？今の想いをそのままお聞かせください。
        </div>
      </div>
    </div>

    <div class="chat-input-area">
      <div class="input-wrapper">
        <textarea 
          id="chat-input" 
          placeholder="例：HP制作を検討中ですが、何から始めたらいいか… / 深夜にすみません、少し悩みを整理したくて…" 
          rows="1"
        ></textarea>
        <button id="send-btn" disabled aria-label="送信">
          <svg viewBox="0 0 24 24" width="24" height="24">
            <path fill="currentColor" d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
          </svg>
        </button>
      </div>
      <p class="input-note">※AIによる自動応答です。具体的な見積もり等は無料相談をご利用ください。</p>
    </div>
  </div>
</div>

<style>
  .ai-chat-widget {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 2000;
    font-family: 'Shippori Mincho', serif;
  }

  /* フローティングボタン */
  .chat-trigger {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    background: #fff;
    border: 2px solid var(--accent);
    border-radius: 50px;
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(197, 160, 89, 0.2);
    transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    white-space: nowrap;
  }

  .chat-trigger:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 35px rgba(197, 160, 89, 0.3);
    background: var(--soft);
  }

  .trigger-icon {
    position: relative;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
  }

  .icon-sub {
    position: absolute;
    top: -5px;
    right: -10px;
    background: var(--accent2);
    color: white;
    font-size: 0.6rem;
    font-weight: 900;
    padding: 2px 5px;
    border-radius: 4px;
  }

  .trigger-text {
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--text-deep);
  }

  /* チャットウィンドウ */
  .chat-window {
    position: absolute;
    bottom: 80px;
    right: 0;
    width: 400px;
    max-width: calc(100vw - 60px);
    height: 600px;
    max-height: calc(100vh - 120px);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--line);
    border-radius: 32px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px) scale(0.95);
    transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .chat-window.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  /* ヘッダー */
  .chat-header {
    padding: 24px;
    background: var(--white);
    border-bottom: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-info {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: #4cd137;
    border-radius: 50%;
    box-shadow: 0 0 10px rgba(76, 209, 55, 0.5);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.2); opacity: 0.7; }
    100% { transform: scale(1); opacity: 1; }
  }

  .chat-header h3 {
    font-size: 1rem;
    margin: 0;
    color: var(--accent);
    font-weight: 800;
  }

  .close-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--muted);
    transition: 0.3s;
  }

  .close-btn:hover { color: var(--accent2); }

  /* メッセージエリア */
  .chat-messages {
    flex: 1;
    padding: 24px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
    scroll-behavior: smooth;
  }

  .message {
    max-width: 85%;
    padding: 12px 18px;
    border-radius: 20px;
    font-size: 0.95rem;
    line-height: 1.6;
    animation: messageIn 0.3s ease-out forwards;
  }

  @keyframes messageIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .message.system {
    align-self: flex-start;
    background: var(--soft);
    border-bottom-left-radius: 4px;
    color: var(--text);
    border: 1px solid var(--line);
  }

  .message.user {
    align-self: flex-end;
    background: var(--accent);
    color: white;
    border-bottom-right-radius: 4px;
  }

  /* 入力エリア */
  .chat-input-area {
    padding: 20px 24px;
    background: var(--white);
    border-top: 1px solid var(--line);
  }

  .input-wrapper {
    display: flex;
    gap: 12px;
    align-items: flex-end;
    background: #f9f9f9;
    padding: 10px 16px;
    border-radius: 24px;
    border: 1px solid var(--line);
    transition: 0.3s;
  }

  .input-wrapper:focus-within {
    border-color: var(--accent);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(197, 160, 89, 0.1);
  }

  #chat-input {
    flex: 1;
    background: none;
    border: none;
    resize: none;
    padding: 8px 0;
    font-family: inherit;
    font-size: 0.95rem;
    max-height: 120px;
    outline: none;
  }

  #send-btn {
    background: var(--accent);
    color: white;
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: 0.3s;
    margin-bottom: 2px;
  }

  #send-btn:disabled {
    background: #ccc;
    cursor: not-allowed;
  }

  #send-btn:hover:not(:disabled) {
    transform: scale(1.1);
    background: var(--accent-dark);
  }

  .input-note {
    font-size: 0.7rem;
    color: var(--muted);
    margin: 8px 0 0;
    text-align: center;
  }

  /* スマホ対応 */
  @media (max-width: 768px) {
    .ai-chat-widget { bottom: 20px; right: 20px; }
    .chat-trigger { padding: 10px 15px; }
    .trigger-text { display: none; }
    .chat-window {
      bottom: 70px;
      right: 0;
      width: calc(100vw - 40px);
      height: calc(100vh - 120px);
    }
  }
</style>

<script is:inline>
  // Cloudflare Workers の URL (ここに貼り付けてください)
  const WORKERS_URL = "https://wa-node.q-h0bodaruma.workers.dev";

  function initAiChat() {
    const trigger = document.getElementById('chat-trigger');
    const window = document.getElementById('chat-window');
    const closeBtn = document.getElementById('close-chat');
    const input = document.getElementById('chat-input');
    const sendBtn = document.getElementById('send-btn');
    const messagesContainer = document.getElementById('chat-messages');

    let isProcessing = false;
    let chatHistory = [];

    // 開閉ロジック
    trigger.addEventListener('click', () => {
      window.classList.toggle('active');
      if (window.classList.contains('active')) {
        input.focus();
      }
    });

    closeBtn.addEventListener('click', () => {
      window.classList.remove('active');
    });

    // 入力監視
    input.addEventListener('input', () => {
      input.style.height = 'auto';
      input.style.height = input.scrollHeight + 'px';
      sendBtn.disabled = !input.value.trim() || isProcessing;
    });

    // メッセージ追加関数
    function addMessage(content, role) {
      const msgDiv = document.createElement('div');
      msgDiv.className = `message ${role}`;
      const contentDiv = document.createElement('div');
      contentDiv.className = 'message-content';
      contentDiv.innerHTML = content.replace(/\n/g, '<br />');
      msgDiv.appendChild(contentDiv);
      messagesContainer.appendChild(msgDiv);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
      return contentDiv;
    }

    // 通信ロジック
    async function sendMessage() {
      const text = input.value.trim();
      if (!text || isProcessing) return;

      isProcessing = true;
      sendBtn.disabled = true;
      input.value = '';
      input.style.height = 'auto';

      // ユーザーメッセージ表示
      addMessage(text, 'user');
      chatHistory.push({ role: 'user', content: text });

      // AIメッセージのプレースホルダー
      const aiMsgContent = addMessage('...', 'system');
      aiMsgContent.innerHTML = '';
      
      try {
        const response = await fetch(WORKERS_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: chatHistory })
        });

        if (!response.ok) throw new Error('通信エラーが発生しました');

        // ストリーミング処理
        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        let aiFullText = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          const chunk = decoder.decode(value, { stream: true });
          const lines = chunk.split('\n');

          for (const line of lines) {
            if (line.startsWith('data: ')) {
              const dataStr = line.slice(6);
              if (dataStr === '[DONE]') break;

              try {
                const data = JSON.parse(dataStr);
                const content = data.choices[0].delta.content || '';
                aiFullText += content;
                aiMsgContent.innerHTML = aiFullText.replace(/\n/g, '<br />');
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
              } catch (e) {
                console.error('JSON parse error', e);
              }
            }
          }
        }

        chatHistory.push({ role: 'assistant', content: aiFullText });

      } catch (err) {
        aiMsgContent.innerHTML = '<span style="color: var(--accent2);">申し訳ありません。一時的に接続が不安定なようです。時間をおいて再度お試しいただくか、LINEよりお問い合わせください。</span>';
      } finally {
        isProcessing = false;
        sendBtn.disabled = !input.value.trim();
      }
    }

    sendBtn.addEventListener('click', sendMessage);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });
  }

  // 初期化（Astroのページ遷移に対応）
  document.addEventListener('astro:page-load', initAiChat);
</script>
