---
// SakuraCanvas.astro
---
<canvas id="sakura-canvas" class="sakura-canvas"></canvas>

<style>
  .sakura-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 0; /* 背景（body）のすぐ上、コンテンツの裏 */
    opacity: 0.85;
  }
</style>

<script>
  class SakuraParticle {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    x: number = 0;
    y: number = 0;
    size: number = 0;
    speedX: number = 0;
    speedY: number = 0;
    opacity: number = 0;
    angle: number = 0;
    spin: number = 0;
    color: string = '';

    constructor(canvas: HTMLCanvasElement, ctx: CanvasRenderingContext2D) {
      this.canvas = canvas;
      this.ctx = ctx;
      this.reset();
      // 初回は画面全体に散らす
      this.y = Math.random() * this.canvas.height;
    }

    reset() {
      this.x = Math.random() * this.canvas.width;
      this.y = -20;
      this.size = Math.random() * 8 + 6; // 6px〜14px
      this.speedX = Math.random() * 1.2 - 0.4; // やや右か左に流れる
      this.speedY = Math.random() * 1.0 + 0.6; // ゆっくり落ちる速度
      this.opacity = Math.random() * 0.4 + 0.2; // 20%〜60%の透明度
      this.angle = Math.random() * 360;
      this.spin = Math.random() * 1.2 - 0.6; // 回転速度

      // 和-Nodeに馴染むカラーバリエーション
      const rands = Math.random();
      if (rands < 0.5) {
        this.color = `rgba(255, 225, 225, ${this.opacity})`; // 淡いさくらピンク
      } else if (rands < 0.8) {
        this.color = `rgba(216, 185, 140, ${this.opacity * 0.7})`; // ゴールドベージュ (accent2)
      } else {
        this.color = `rgba(199, 53, 47, ${this.opacity * 0.45})`; // 朱赤 (action, かなり薄め)
      }
    }

    update() {
      this.x += this.speedX + Math.sin(this.angle * 0.015) * 0.4;
      this.y += this.speedY;
      this.angle += this.spin;

      // 画面外に出たらリセット
      if (this.y > this.canvas.height + 20 || this.x > this.canvas.width + 20 || this.x < -20) {
        this.reset();
      }
    }

    draw() {
      this.ctx.save();
      this.ctx.translate(this.x, this.y);
      this.ctx.rotate((this.angle * Math.PI) / 180);
      
      this.ctx.fillStyle = this.color;
      this.ctx.beginPath();
      
      // 美しい桜の花びら形状を描く
      this.ctx.moveTo(0, 0);
      this.ctx.bezierCurveTo(-this.size, -this.size / 2, -this.size / 2, -this.size * 1.5, 0, -this.size * 1.6);
      this.ctx.bezierCurveTo(this.size / 2, -this.size * 1.5, this.size, -this.size / 2, 0, 0);
      
      this.ctx.closePath();
      this.ctx.fill();
      this.ctx.restore();
    }
  }

  function initSakura() {
    const canvas = document.getElementById('sakura-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let animationId: number;
    let particles: SakuraParticle[] = [];
    const maxParticles = 16; // 画面上に漂う最大数（上品に散らすため少なめ）

    function resize() {
      if (!canvas) return;
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }

    window.addEventListener('resize', resize);
    resize();

    // 粒子生成
    for (let i = 0; i < maxParticles; i++) {
      particles.push(new SakuraParticle(canvas, ctx));
    }

    function animate() {
      if (!ctx || !canvas) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      particles.forEach((p) => {
        p.update();
        p.draw();
      });

      animationId = requestAnimationFrame(animate);
    }

    animate();

    // クリーンアップ
    return () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', resize);
    };
  }

  let cleanup: (() => void) | undefined;

  // 初回ロード時とView Transitions遷移時に実行
  document.addEventListener('DOMContentLoaded', () => {
    if (cleanup) cleanup();
    cleanup = initSakura();
  });

  document.addEventListener('astro:page-load', () => {
    if (cleanup) cleanup();
    cleanup = initSakura();
  });
</script>
