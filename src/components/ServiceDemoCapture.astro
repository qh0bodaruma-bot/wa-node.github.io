---
interface Props {
  mode: 'before' | 'after';
}

const { mode } = Astro.props;
const isAfter = mode === 'after';

const content = isAfter
  ? {
      modeLabel: 'After / 改善案',
      heroLead: 'HP・LPの反応が気になる地域事業者の方へ',
      heroTitle: '何を直すべきか、30分で一緒に整理します',
      heroText: 'ページを画面共有で確認し、読み手が迷う場所と、最初に試す改善を一枚のメモにまとめます。',
      heroCta: '30分の無料相談を予約する',
      heroNote: '入力は約2分。相談後の契約は必須ではありません。',
      points: [
        ['30分', '現状と優先順位を整理'],
        ['改善メモ1枚', '事実・仮説・変更・確認方法'],
        ['契約不要', '相談後に依頼しない選択も可能'],
      ],
      introLead: '最初にお渡しするもの',
      introTitle: '「なんとなく直す」から、理由を説明できる改善へ',
      introText: 'デザインの好みだけで決めず、画面上の事実、読み手が迷うという仮説、最初に試す変更を分けて整理します。',
      services: [
        ['01', '現状を一緒に見る', 'Hero、料金、FAQ、CTAを、初めて来た読み手の順番で確認します。'],
        ['02', '優先順位を決める', '全部を作り直さず、相談や比較を止めている可能性が高い場所から選びます。'],
        ['03', '改善メモに残す', '修正案だけでなく、変更後に見る数字や問い合わせ内容まで記録します。'],
      ],
      priceLead: '料金の目安',
      priceTitle: '必要な範囲から、小さく始められます',
      priceText: '契約前に目的と変更範囲を確認し、追加費用が生じる条件も見積書へ記載します。',
      prices: [
        ['改善相談', '8,800円〜', '画面確認・改善メモ', 'まず一か所を整理したい方'],
        ['LP部分改修', '32,000円〜', 'コピー・配置の部分修正', '既存ページを活かしたい方'],
        ['LP新規制作', '64,000円〜', '構成・文章・デザイン', 'ページ全体を作りたい方'],
      ],
      caseLead: '状況の近い事例から確認',
      caseTitle: '件数より、自分との近さで比較する',
      cases: [
        ['地域サービス', '料金が分からず、相談前に離れていた', '料金の目安と初回の流れを先に表示'],
        ['専門サービス', '実績は多いが、自分向けか判断できなかった', '課題と制約が近い事例を探せる形へ変更'],
        ['小規模事業', 'CTAを押した後の営業が不安だった', '所要時間と相談後に断れる条件を明記'],
      ],
      faqLead: '相談前に確認したいこと',
      faqTitle: '不安が残ったまま、申し込まなくても大丈夫です',
      faqs: [
        ['追加費用はいつ発生しますか？', '見積りに含まれない作業が必要な場合は、着手前に内容と金額を確認します。'],
        ['相談後に断っても大丈夫ですか？', '問題ありません。相談だけで整理できた場合は、そのまま終了できます。'],
        ['原稿や画像がなくても相談できますか？', 'はい。現在ある素材と、不足している素材を一緒に確認します。'],
        ['まだ依頼内容が固まっていません。', '相談内容を決めるための時間として利用できます。'],
      ],
      formLead: '無料相談',
      formTitle: '今の状況を、話せる範囲で教えてください',
      formText: '入力は約2分です。送信後、2営業日以内に日程候補をご案内します。',
      submit: '無料相談の日程候補を受け取る',
      submitNote: '送信だけで契約は成立しません。',
    }
  : {
      modeLabel: 'Before / 変更前',
      heroLead: 'ビジネスの可能性を広げる',
      heroTitle: 'あなたの未来に寄り添います',
      heroText: '豊富な経験と確かな技術で、お客様に最適なソリューションをご提案します。',
      heroCta: 'お問い合わせ',
      heroNote: 'お気軽にご相談ください。',
      points: [
        ['豊富な実績', '多数のご相談に対応'],
        ['確かな技術', '高品質なサービス'],
        ['丁寧な対応', 'お客様に寄り添います'],
      ],
      introLead: '私たちのサービス',
      introTitle: 'お客様の課題を、トータルでサポートします',
      introText: '幅広いニーズに対応し、経験豊富なスタッフがお客様に最適なご提案をいたします。',
      services: [
        ['01', 'コンサルティング', 'お客様のご要望を丁寧にヒアリングし、最適なプランをご提案します。'],
        ['02', 'Webサポート', '豊富な経験を活かし、高品質なWebサービスをご提供します。'],
        ['03', 'アフターフォロー', '制作後も丁寧なサポートで、お客様のビジネスを応援します。'],
      ],
      priceLead: '料金について',
      priceTitle: 'お客様に合わせてお見積りします',
      priceText: 'ご要望によって金額が変わります。詳しくはお問い合わせください。',
      prices: [
        ['相談プラン', '要問い合わせ', '詳しくはお問い合わせください', '幅広く対応します'],
        ['改善プラン', '要問い合わせ', '詳しくはお問い合わせください', '最適なご提案をします'],
        ['制作プラン', '要問い合わせ', '詳しくはお問い合わせください', '高品質に仕上げます'],
      ],
      caseLead: '実績紹介',
      caseTitle: '多くのお客様から選ばれています',
      cases: [
        ['制作実績', '多数の制作実績があります', 'お客様から高い評価をいただいています'],
        ['相談実績', '幅広い業種に対応しています', '経験豊富なスタッフが対応します'],
        ['満足度', '多くのお客様にご満足いただいています', '安心してご相談ください'],
      ],
      faqLead: 'よくある質問',
      faqTitle: 'ご質問にお答えします',
      faqs: [
        ['営業時間を教えてください。', '平日9時から18時まで営業しています。'],
        ['対応地域はどこですか？', '詳しくはお問い合わせください。'],
        ['オンライン対応はできますか？', 'オンラインでも対応しています。'],
        ['どのような相談ができますか？', '幅広いご相談に対応しています。'],
      ],
      formLead: 'お問い合わせ',
      formTitle: 'まずはお気軽にお問い合わせください',
      formText: 'ご相談、ご質問、お見積りなど、フォームよりお問い合わせいただけます。',
      submit: 'お問い合わせ',
      submitNote: '順次ご返信いたします。',
    };
---

<main class:list={['demo-page', isAfter ? 'is-after' : 'is-before']} data-demo-mode={mode}>
  <div class="demo-label">教材用架空ページ <span>{content.modeLabel}</span></div>

  <header class="demo-header">
    <a class="demo-logo" href="#top" aria-label="まちのWeb相談室 トップ">まちのWeb相談室</a>
    <nav aria-label="ページ内ナビゲーション">
      <a href="#service">サービス</a>
      <a href="#price">料金</a>
      <a href="#case">事例</a>
      <a href="#faq">FAQ</a>
    </nav>
    <a class="demo-header-cta" href="#contact">{isAfter ? '無料相談を予約' : 'お問い合わせ'}</a>
  </header>

  <section class="demo-hero" id="top" data-capture-point="hero">
    <div class="demo-hero__image" aria-hidden="true">
      <img src="/images/lab/demo-service-hero.webp" alt="" width="1672" height="941" />
    </div>
    <div class="demo-hero__content">
      <p class="demo-eyebrow">{content.heroLead}</p>
      <h1>{content.heroTitle}</h1>
      <p class="demo-hero__text">{content.heroText}</p>
      <a class="demo-button" href="#contact">{content.heroCta}</a>
      <small>{content.heroNote}</small>
    </div>
  </section>

  <section class="demo-points" aria-label="サービスの特徴">
    {content.points.map(([value, label], index) => (
      <div><span>0{index + 1}</span><strong>{value}</strong><p>{label}</p></div>
    ))}
  </section>

  <section class="demo-section demo-intro" id="service" data-capture-point="service">
    <div class="demo-section__head">
      <p class="demo-eyebrow">{content.introLead}</p>
      <h2>{content.introTitle}</h2>
      <p>{content.introText}</p>
    </div>
    <div class="demo-service-grid">
      {content.services.map(([number, title, text]) => (
        <article>
          <span>{number}</span>
          <h3>{title}</h3>
          <p>{text}</p>
          <a href={isAfter ? '#contact' : '#contact'}>{isAfter ? '相談内容を確認する' : '詳しく見る'} <b>→</b></a>
        </article>
      ))}
    </div>
  </section>

  <section class="demo-section demo-price" id="price" data-capture-point="pricing">
    <div class="demo-section__head demo-section__head--split">
      <div><p class="demo-eyebrow">{content.priceLead}</p><h2>{content.priceTitle}</h2></div>
      <p>{content.priceText}</p>
    </div>
    <div class="demo-price-grid">
      {content.prices.map(([name, price, detail, audience], index) => (
        <article class={isAfter && index === 0 ? 'is-primary' : ''}>
          <span>PLAN 0{index + 1}</span>
          <h3>{name}</h3>
          <strong>{price}</strong>
          <p>{detail}</p>
          <small>{audience}</small>
          <a href="#contact">{isAfter ? 'この範囲で相談する' : 'お問い合わせ'}</a>
        </article>
      ))}
    </div>
    <p class="demo-price-note">{isAfter ? '※表示価格は教材用の架空例です。実際の見積りでは作業範囲と追加条件を確認します。' : '※詳しい料金については、お問い合わせください。'}</p>
  </section>

  <section class="demo-section demo-cases" id="case" data-capture-point="case">
    <div class="demo-section__head">
      <p class="demo-eyebrow">{content.caseLead}</p>
      <h2>{content.caseTitle}</h2>
    </div>
    <div class="demo-case-list">
      {content.cases.map(([kind, problem, change], index) => (
        <article>
          <span>CASE 0{index + 1}</span>
          <div><small>{kind}</small><h3>{problem}</h3></div>
          <p>{change}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="demo-section demo-faq" id="faq" data-capture-point="faq">
    <div class="demo-section__head demo-section__head--split">
      <div><p class="demo-eyebrow">{content.faqLead}</p><h2>{content.faqTitle}</h2></div>
      <p>{isAfter ? '相談するか決める前に、気になることを確認できます。' : 'そのほかのご質問は、お問い合わせフォームからご連絡ください。'}</p>
    </div>
    <div class="demo-faq-list">
      {content.faqs.map(([question, answer], index) => (
        <details open={index === 0}>
          <summary><span>Q{index + 1}</span>{question}</summary>
          <p>{answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="demo-contact" id="contact" data-capture-point="cta">
    <div class="demo-contact__copy">
      <p class="demo-eyebrow">{content.formLead}</p>
      <h2>{content.formTitle}</h2>
      <p>{content.formText}</p>
      <ol>
        <li><span>1</span>{isAfter ? 'フォーム送信' : 'お問い合わせ'}</li>
        <li><span>2</span>{isAfter ? '日程候補をご案内' : '担当者が確認'}</li>
        <li><span>3</span>{isAfter ? '30分のオンライン相談' : '順次ご返信'}</li>
      </ol>
    </div>
    <form class="demo-form" onsubmit="return false">
      <label>お名前<input type="text" placeholder="例：山田 太郎" /></label>
      <label>メールアドレス<input type="email" placeholder="example@email.com" /></label>
      <label>{isAfter ? '現在気になっていること' : 'お問い合わせ内容'}<textarea rows="5" placeholder={isAfter ? '料金が分かりにくい、相談が増えない、など' : 'お問い合わせ内容をご入力ください'}></textarea></label>
      <button type="submit">{content.submit}</button>
      <small>{content.submitNote}</small>
    </form>
  </section>

  <footer class="demo-footer">
    <strong>まちのWeb相談室</strong>
    <p>教材用に作成した架空のサービスページです。</p>
    <span>© Demo for Wa-Node Course</span>
  </footer>
</main>

<style>
  .demo-page {
    --ink: #142521;
    --muted: #586964;
    --line: #ced9d5;
    --green: #0f4c5c;
    --green-soft: #edf4f2;
    --red: #c7352f;
    min-width: 320px;
    overflow: hidden;
    background: #fff;
    color: var(--ink);
  }

  .demo-label {
    display: flex;
    min-height: 34px;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: #132622;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .demo-label span {
    padding: 2px 8px;
    border: 1px solid rgba(255, 255, 255, 0.48);
    border-radius: 2px;
  }

  .demo-header {
    display: grid;
    width: min(1200px, calc(100% - 48px));
    min-height: 74px;
    grid-template-columns: 1fr auto auto;
    gap: 38px;
    align-items: center;
    margin: 0 auto;
  }

  .demo-header a {
    color: var(--ink);
    text-decoration: none;
  }

  .demo-logo {
    font-size: 1.1rem;
    font-weight: 900;
  }

  .demo-header nav {
    display: flex;
    gap: 26px;
  }

  .demo-header nav a {
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .demo-header-cta,
  .demo-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    background: var(--red);
    color: #fff !important;
    font-weight: 900;
    text-decoration: none;
  }

  .demo-header-cta {
    min-height: 40px;
    padding: 8px 14px;
    font-size: 0.78rem;
  }

  .demo-hero {
    position: relative;
    min-height: 840px;
    overflow: hidden;
    border-top: 1px solid var(--line);
  }

  .demo-hero__image,
  .demo-hero__image::after {
    position: absolute;
    inset: 0;
  }

  .demo-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .demo-hero__image::after {
    content: '';
    background: linear-gradient(90deg, rgba(255,255,255,0.98) 0%, rgba(255,255,255,0.94) 34%, rgba(255,255,255,0.15) 66%, rgba(255,255,255,0) 100%);
  }

  .demo-hero__content {
    position: relative;
    z-index: 1;
    width: min(1200px, calc(100% - 48px));
    padding: 110px 54% 90px 0;
    margin: 0 auto;
  }

  .demo-eyebrow {
    margin: 0 0 16px;
    color: var(--green);
    font-size: 0.76rem;
    font-weight: 900;
  }

  .demo-hero h1 {
    max-width: 620px;
    margin: 0 0 24px;
    font-size: clamp(2.8rem, 5.5vw, 5rem);
    line-height: 1.22;
    letter-spacing: 0;
  }

  .demo-hero__text {
    max-width: 590px;
    margin: 0 0 30px;
    color: #465651;
    font-size: 1.05rem;
    line-height: 1.95;
  }

  .demo-button {
    min-height: 56px;
    padding: 13px 22px;
  }

  .demo-hero__content > small {
    display: block;
    max-width: 540px;
    margin-top: 11px;
    color: var(--muted);
    font-size: 0.76rem;
    line-height: 1.7;
  }

  .demo-points {
    display: grid;
    width: min(1200px, calc(100% - 48px));
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: -62px auto 0;
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
    background: #fff;
    position: relative;
    z-index: 2;
  }

  .demo-points > div {
    min-height: 145px;
    padding: 25px 28px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .demo-points span,
  .demo-service-grid article > span,
  .demo-price-grid article > span,
  .demo-case-list article > span {
    color: var(--red);
    font-size: 0.68rem;
    font-weight: 900;
  }

  .demo-points strong {
    display: block;
    margin: 12px 0 6px;
    font-size: 1.28rem;
  }

  .demo-points p,
  .demo-section p {
    color: var(--muted);
    line-height: 1.85;
  }

  .demo-points p {
    margin: 0;
    font-size: 0.82rem;
  }

  .demo-section {
    padding: 120px max(24px, calc((100% - 1200px) / 2));
  }

  .demo-intro {
    min-height: 900px;
  }

  .demo-price {
    min-height: 1020px;
  }

  .demo-cases {
    min-height: 1010px;
  }

  .demo-faq {
    min-height: 890px;
  }

  .demo-section__head {
    max-width: 790px;
    margin-bottom: 52px;
  }

  .demo-section__head--split {
    display: grid;
    max-width: none;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.55fr);
    gap: 80px;
    align-items: end;
  }

  .demo-section__head h2,
  .demo-contact h2 {
    margin: 0 0 20px;
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    line-height: 1.28;
    letter-spacing: 0;
  }

  .demo-section__head > p,
  .demo-section__head--split > p {
    margin: 0;
    font-size: 1rem;
  }

  .demo-service-grid,
  .demo-price-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .demo-service-grid article,
  .demo-price-grid article {
    min-height: 340px;
    padding: 34px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .demo-service-grid h3,
  .demo-price-grid h3 {
    margin: 34px 0 14px;
    font-size: 1.4rem;
  }

  .demo-service-grid p {
    min-height: 92px;
  }

  .demo-service-grid a {
    display: inline-flex;
    gap: 12px;
    color: var(--green);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .demo-price {
    background: #f3f7f5;
  }

  .demo-price-grid {
    background: #fff;
  }

  .demo-price-grid article {
    min-height: 440px;
  }

  .demo-price-grid article.is-primary {
    border-top: 4px solid var(--green);
  }

  .demo-price-grid article > strong {
    display: block;
    min-height: 60px;
    margin: 28px 0 12px;
    color: var(--green);
    font-size: 1.9rem;
  }

  .demo-price-grid article > p {
    min-height: 68px;
  }

  .demo-price-grid article > small {
    display: block;
    min-height: 42px;
    color: var(--muted);
    line-height: 1.6;
  }

  .demo-price-grid article > a {
    display: flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    margin-top: 30px;
    border: 1px solid var(--green);
    border-radius: 3px;
    color: var(--green);
    font-size: 0.82rem;
    font-weight: 900;
    text-decoration: none;
  }

  .demo-price-note {
    margin: 18px 0 0;
    font-size: 0.76rem;
  }

  .demo-case-list {
    border-top: 1px solid var(--line);
  }

  .demo-case-list article {
    display: grid;
    min-height: 180px;
    grid-template-columns: 100px minmax(0, 1fr) minmax(300px, 0.75fr);
    gap: 30px;
    align-items: center;
    border-bottom: 1px solid var(--line);
  }

  .demo-case-list small {
    color: var(--green);
    font-weight: 900;
  }

  .demo-case-list h3 {
    margin: 8px 0 0;
    font-size: 1.25rem;
    line-height: 1.5;
  }

  .demo-case-list p {
    margin: 0;
  }

  .demo-faq {
    background: #f3f7f5;
  }

  .demo-faq-list {
    border-top: 1px solid var(--line);
  }

  .demo-faq-list details {
    border-bottom: 1px solid var(--line);
    background: #fff;
  }

  .demo-faq-list summary {
    display: flex;
    min-height: 82px;
    gap: 20px;
    align-items: center;
    padding: 20px 26px;
    font-weight: 900;
    cursor: pointer;
  }

  .demo-faq-list summary span {
    color: var(--red);
    font-size: 0.72rem;
  }

  .demo-faq-list details p {
    margin: 0;
    padding: 0 26px 26px 68px;
  }

  .demo-contact {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(420px, 1fr);
    gap: 90px;
    padding: 120px max(24px, calc((100% - 1200px) / 2));
    background: var(--green);
    color: #fff;
  }

  .demo-contact .demo-eyebrow {
    color: #f4ca63;
