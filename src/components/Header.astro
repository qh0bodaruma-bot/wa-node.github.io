---
---
<header class="site-header" id="site-header">
  <div class="header-inner">
    <a class="logo" href="/">
      和-Node<span class="logo-sub">心理 × AI × ICT</span>
    </a>

    <button class="menu-toggle" id="menu-toggle" aria-label="メニューを開く">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <nav class="nav" id="site-nav">
      <div class="nav-links">
        <a href="/#philosophy">想い</a>
        <a href="/#services">サービス</a>
        <a href="/#works">制作例</a>
        <a href="/pricing">料金</a>
        <a href="/simulator">シミュレーター</a>
        <a href="/#about">代表について</a>
        <a href="/#contact" class="nav-cta">相談する</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(255, 253, 249, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(234, 223, 212, 0.5);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .site-header.scrolled {
    background: rgba(255, 253, 249, 0.95);
    box-shadow: 0 10px 30px rgba(70, 52, 32, 0.08);
    padding: 2px 0;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 18px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: padding 0.4s ease;
  }

  .logo {
    font-weight: 800;
    color: var(--text);
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .logo-sub {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 0.05em;
    background: var(--soft);
    padding: 2px 10px;
    border-radius: 999px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-links a {
    color: var(--text);
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
    transition: 0.3s;
    position: relative;
  }

  .nav-links a:not(.nav-cta)::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent);
    transition: 0.3s;
  }

  .nav-links a:not(.nav-cta):hover::after {
    width: 100%;
  }

  .nav-links a:hover {
    color: var(--accent);
  }

  .nav-cta {
    background: var(--accent);
    color: #fff !important;
    padding: 10px 24px;
    border-radius: 999px;
    box-shadow: 0 4px 15px rgba(138, 90, 50, 0.2);
  }

  .nav-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(138, 90, 50, 0.3);
  }

  /* Hamburger Menu */
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 1100;
  }

  .bar {
    width: 24px;
    height: 2px;
    background: var(--text);
    transition: 0.3s;
    border-radius: 2px;
  }

  @media (max-width: 960px) {
    .logo-sub { display: none; }
    .nav-links { gap: 20px; }
  }

  @media (max-width: 820px) {
    .menu-toggle { display: flex; }
    
    .nav {
      position: fixed;
      top: 0;
      right: -100%;
      width: 80%;
      max-width: 320px;
      height: 100vh;
      background: var(--white);
      padding: 100px 40px;
      box-shadow: -10px 0 30px rgba(0,0,0,0.1);
      transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 1050;
    }

    .nav.active {
      right: 0;
    }

    .nav-links {
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
    }

    .nav-links a {
      font-size: 1.1rem;
    }

    /* Animation */
    .menu-toggle.active .bar:nth-child(1) { transform: translateY(8px) rotate(45deg); }
    .menu-toggle.active .bar:nth-child(2) { opacity: 0; }
    .menu-toggle.active .bar:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('menu-toggle');
    const nav = document.getElementById('site-nav');
    const links = document.querySelectorAll('.nav-links a');

    if (!toggle || !nav || !header) return;

    // Scroll Effect
    const handleScroll = () => {
      if (window.scrollY > 50) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', handleScroll);

    // Mobile Menu Toggle
    const handleToggle = () => {
      toggle.classList.toggle('active');
      nav.classList.toggle('active');
      document.body.style.overflow = nav.classList.contains('active') ? 'hidden' : '';
    };
    toggle.addEventListener('click', handleToggle);

    // Close menu on link click
    links.forEach(link => {
      link.addEventListener('click', () => {
        toggle.classList.remove('active');
        nav.classList.remove('active');
        document.body.style.overflow = '';
      });
    });
  }

  // DOMが読み込まれたら実行
  document.addEventListener('DOMContentLoaded', initHeader);
  
  // 万が一すでに読み込まれている場合用
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initHeader();
  }
</script>
