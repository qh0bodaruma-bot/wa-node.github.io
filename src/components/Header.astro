---
<header class="site-header" id="site-header">
  <div class="header-inner">
    <a class="logo" href="/">
      和-Node<span class="logo-sub">心理 × AI × ICT</span>
    </a>

    <button class="menu-toggle" id="menu-toggle" aria-label="メニューを開く">
      <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect class="bar-top" x="5" y="7" width="20" height="2" rx="1" fill="#2b241f"/>
        <rect class="bar-mid" x="5" y="14" width="20" height="2" rx="1" fill="#2b241f"/>
        <rect class="bar-bot" x="5" y="21" width="20" height="2" rx="1" fill="#2b241f"/>
      </svg>
    </button>

    <nav class="nav" id="site-nav">
      <div class="nav-links">
        <a href="/#philosophy">想い</a>
        <a href="/#services">サービス</a>
        <a href="/#works">制作例</a>
        <a href="/demos">デモHP</a>
        <a href="/pricing">料金</a>
        <a href="/simulator">シミュレーター</a>
        <a href="/free-guide" style="color: var(--accent2); font-weight: 800;">🎁 無料特典</a>
        <a href="/#about">代表について</a>
        <a href="/contact" class="nav-cta">相談する</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(255, 253, 249, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(234, 223, 212, 0.5);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .site-header.scrolled {
    background: rgba(255, 253, 249, 0.98);
    box-shadow: 0 10px 30px rgba(70, 52, 32, 0.08);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-weight: 800;
    color: #2b241f;
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .logo-sub {
    font-size: 0.72rem;
    color: #6d6259;
    background: #f1e6da;
    padding: 2px 10px;
    border-radius: 999px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-links a {
    color: #2b241f;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: 0.3s;
    position: relative;
  }

  .nav-links a:not(.nav-cta)::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: #8a5a32;
    transition: 0.3s ease;
  }

  .nav-links a:not(.nav-cta):hover::after {
    width: 100%;
  }

  .nav-links a:hover {
    color: #8a5a32;
  }

  .nav-cta {
    background: #8a5a32;
    color: #fff !important;
    padding: 8px 22px;
    border-radius: 999px;
    box-shadow: 0 4px 15px rgba(138, 90, 50, 0.2);
    transition: 0.3s ease;
  }

  /* Hamburger Menu */
  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px;
    z-index: 1100;
    transition: 0.3s ease;
  }

  .menu-toggle:hover {
    transform: scale(1.1);
  }

  .menu-toggle svg rect {
    transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  .menu-toggle.active .bar-top { transform: translateY(7px) rotate(45deg); }
  .menu-toggle.active .bar-mid { opacity: 0; }
  .menu-toggle.active .bar-bot { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 820px) {
    .menu-toggle { display: block; }
    
    .nav {
      position: fixed;
      top: 0;
      right: -100%;
      width: 80%;
      max-width: 300px;
      height: 100vh;
      background: #fff;
      padding: 80px 30px;
      box-shadow: -10px 0 30px rgba(0,0,0,0.05);
      transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 1050;
    }

    .nav.active {
      right: 0;
    }

    .nav-links {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
  }
</style>

<script is:inline>
  (function() {
    function initHeader() {
      const toggle = document.getElementById('menu-toggle');
      const nav = document.getElementById('site-nav');
      const header = document.getElementById('site-header');
      if (!toggle || !nav || !header) return;

      // 二重イベント登録防止
      const newToggle = toggle.cloneNode(true);
      toggle.parentNode.replaceChild(newToggle, toggle);

      newToggle.addEventListener('click', () => {
        newToggle.classList.toggle('active');
        nav.classList.toggle('active');
        document.body.style.overflow = nav.classList.contains('active') ? 'hidden' : '';
      });

      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) header.classList.add('scrolled');
        else header.classList.remove('scrolled');
      });

      nav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          newToggle.classList.remove('active');
          nav.classList.remove('active');
          document.body.style.overflow = '';
        });
      });
    }

    initHeader();
    document.addEventListener('DOMContentLoaded', initHeader);
    document.addEventListener('astro:after-swap', initHeader);
  })();
</script>
