<header class="site-header">
  <div class="header-inner">
    <a class="logo" href="/">和-Node 心理 × AI × ICT</a>
    <nav class="nav">
      <a href="/#about">代表について</a>
      <a href="/#services">サービス</a>
      <a href="/#line-mini-app">LINE Mini App</a>
      <a href="/#works">制作例</a>
      <a href="/pricing">料金</a>
      <a href="/#contact">相談する</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 253, 249, 0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .logo { font-weight: 800; color: var(--text); font-size: 1.2rem; }
  .nav { display: flex; gap: 24px; flex-wrap: wrap; font-size: 0.92rem; }
  .nav a { color: var(--text); font-weight: 700; }

  @media (max-width: 768px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .nav {
      gap: 12px;
    }
  }
</style>
