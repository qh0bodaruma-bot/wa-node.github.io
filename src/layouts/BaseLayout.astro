---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import { ViewTransitions } from 'astro:transitions';
import { MULTILANG_PAGES } from '../i18n/navigation';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  lang?: 'ja' | 'en' | 'fr';
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { 
  title = "和-Node｜心理学 × ICT × AI で、ビジネスと心を整えるコンサルティング", 
  description = "和-Nodeは、心理学を応用して「伝わるWeb導線」「続くICT活用」「安心できる相談支援」をプロデュースするコンサルティングサービスです。技術と心理の両面から、あなたと組織の課題を整えます。",
  image = "/images/ogp-service.png",
  url = Astro.url.href,
  lang = 'ja',
  noindex = false,
  structuredData
} = Astro.props;

const structuredDataItems = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];

const urlLang = Astro.url.searchParams.get('lang');
const currentLang = urlLang === 'en' || urlLang === 'fr' ? urlLang : lang;

const urlObj = new URL(url);
const pathWithoutLocale = urlObj.pathname.replace(/^\/(en|fr)\//, '/').replace(/\/$/, '');
const normalizedPath = pathWithoutLocale === '' ? '/' : pathWithoutLocale;
const hasTranslation = MULTILANG_PAGES.includes(normalizedPath);

const getLocalizedHref = (l: string) => {
  const cleanPath = pathWithoutLocale === '' ? '/' : pathWithoutLocale + '/';
  if (l === 'ja') return new URL(cleanPath, urlObj.origin).href;
  return new URL(`/${l}${cleanPath}`, urlObj.origin).href;
};
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="0rBuRrl1I5-_XMfRp59rq2vD-BPOFfAWnCJEf2KOzbI" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:site_name" content="wa-node" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url)} />

    <link rel="canonical" href={url} />
    {hasTranslation && (
      <>
        <link rel="alternate" hreflang="ja" href={getLocalizedHref('ja')} />
        <link rel="alternate" hreflang="en" href={getLocalizedHref('en')} />
        <link rel="alternate" hreflang="fr" href={getLocalizedHref('fr')} />
        <link rel="alternate" hreflang="x-default" href={getLocalizedHref('ja')} />
      </>
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;800&display=swap" rel="stylesheet" />
    {structuredDataItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <GoogleAnalytics />
    <ViewTransitions />
    <script is:inline>
      function initReveal() {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
            }
          });
        }, observerOptions);

        const revealElements = document.querySelectorAll('.reveal');
        revealElements.forEach(el => observer.observe(el));
      }

      // Initial load
      document.addEventListener('DOMContentLoaded', initReveal);
      // View Transitions navigation
      document.addEventListener('astro:page-load', initReveal);

      // Global Progress Bar for View Transitions
      (function() {
        document.addEventListener('astro:before-preparation', () => {
          const bar = document.getElementById('global-progress-bar');
          if (bar) {
            bar.style.width = '0%';
            bar.classList.remove('finish');
            bar.classList.add('active');
            // 擬似的にプログレスを進行させる
            setTimeout(() => {
              bar.style.width = '70%';
            }, 10);
          }
        });

        document.addEventListener('astro:after-preparation', () => {
          const bar = document.getElementById('global-progress-bar');
          if (bar) {
            bar.classList.add('finish');
            bar.style.width = '100%';
            setTimeout(() => {
              bar.classList.remove('active', 'finish');
              bar.style.width = '0%';
            }, 400);
          }
        });
      })();
    </script>
  </head>
  <body>
    <div id="global-progress-bar" class="global-progress-bar" aria-hidden="true"></div>
    <Header lang={currentLang} />
    <slot />
    <Footer lang={currentLang} />
  </body>
</html>
