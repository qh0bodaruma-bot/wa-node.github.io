---
// src/layouts/HydrogenLayout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | HYDROGEN-X</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Outfit:wght@300;500;700&display=swap" rel="stylesheet">
    <style is:global>
        :root {
            --primary: #00d4ff;
            --primary-dark: #008fb3;
            --bg-deep: #0b1120;
            --bg-card: rgba(255, 255, 255, 0.05);
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
            --accent: #10b981;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-deep);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        h1, h2, h3, h4 { font-family: 'Outfit', sans-serif; font-weight: 700; }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

        /* Animations */
        .reveal { opacity: 0; transform: translateY(30px); transition: opacity 1s ease, transform 1s ease; }
        .reveal.active { opacity: 1; transform: translateY(0); }

        .btn {
            display: inline-flex; align-items: center; padding: 0.8rem 2rem;
            border-radius: 9999px; font-weight: 600; text-decoration: none;
            transition: var(--transition); cursor: pointer; border: none; font-size: 0.9rem;
        }
        .btn-primary { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: #fff; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(0, 212, 255, 0.4); }

        .glass {
            background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 1.5rem;
        }

        header { position: fixed; top: 0; width: 100%; z-index: 1000; padding: 1.5rem 0; transition: var(--transition); }
        header.scrolled { background: rgba(11, 17, 32, 0.9); backdrop-filter: blur(12px); padding: 0.8rem 0; border-bottom: 1px solid rgba(255, 255, 255, 0.05); }

        .nav-inner { display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 1.4rem; font-weight: 700; color: var(--primary); text-decoration: none; font-family: 'Outfit', sans-serif; letter-spacing: 0.05em; }

        .nav-links { display: flex; gap: 2rem; align-items: center; }
        .nav-links a { color: var(--text-dim); text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: var(--transition); letter-spacing: 0.05em; }
        .nav-links a:hover { color: var(--primary); }

        /* Mobile Menu Button */
        .menu-toggle {
            display: none; width: 32px; height: 32px; background: transparent; border: none; cursor: pointer; position: relative; z-index: 1100;
        }
        .menu-toggle span { display: block; width: 100%; height: 2px; background: var(--text-main); margin: 6px 0; transition: var(--transition); }

        /* Mobile Menu Container */
        .mobile-nav {
            position: fixed; top: 0; right: -100%; width: 100%; height: 100vh; background: var(--bg-deep);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            gap: 2rem; transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1); z-index: 1050;
        }
        .mobile-nav.active { right: 0; }
        .mobile-nav a { font-size: 1.5rem; color: #fff; text-decoration: none; font-family: 'Outfit', sans-serif; }

        .lang-toggle { display: flex; gap: 0.5rem; background: rgba(255, 255, 255, 0.05); padding: 0.2rem; border-radius: 999px; }
        .lang-btn { padding: 0.3rem 0.8rem; border-radius: 999px; font-size: 0.7rem; font-weight: 600; cursor: pointer; transition: var(--transition); border: none; background: transparent; color: var(--text-dim); }
        .lang-btn.active { background: var(--primary); color: #fff; }

        footer { background: #050810; padding: 6rem 0 3rem; border-top: 1px solid rgba(255, 255, 255, 0.05); margin-top: 8rem; }
        .footer-grid { display: grid; grid-template-columns: 2fr repeat(3, 1fr); gap: 4rem; margin-bottom: 4rem; }

        @media (max-width: 992px) { 
            .nav-links { display: none; }
            .menu-toggle { display: block; }
            
            /* Animation for hamburger */
            .menu-toggle.active span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
            .menu-toggle.active span:nth-child(2) { opacity: 0; }
            .menu-toggle.active span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
        }
    </style>
</head>
<body>

    <header id="header">
        <div class="container nav-inner">
            <a href="/hydrogen" class="logo">HYDROGEN-X</a>
            
            <nav class="nav-links">
                <a href="/hydrogen/business" data-ja="事業概要" data-en="Business">事業概要</a>
                <a href="/hydrogen/products" data-ja="製品・サービス" data-en="Products">製品・サービス</a>
                <a href="/hydrogen/company" data-ja="会社情報" data-en="Company">会社情報</a>
                <a href="/hydrogen/news" data-ja="ニュース" data-en="News">ニュース</a>
                <div class="lang-toggle">
                    <button class="lang-btn active" onclick="setLang('ja')">JP</button>
                    <button class="lang-btn" onclick="setLang('en')">EN</button>
                </div>
                <a href="/hydrogen/contact" class="btn btn-primary" style="padding: 0.6rem 1.5rem;" data-ja="お問い合わせ" data-en="Contact">お問い合わせ</a>
            </nav>

            <button class="menu-toggle" id="menuToggle" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
        </div>
    </header>

    <div class="mobile-nav" id="mobileNav">
        <a href="/hydrogen/business" onclick="toggleMenu()" data-ja="事業概要" data-en="Business">事業概要</a>
        <a href="/hydrogen/products" onclick="toggleMenu()" data-ja="製品・サービス" data-en="Products">製品・サービス</a>
        <a href="/hydrogen/company" onclick="toggleMenu()" data-ja="会社情報" data-en="Company">会社情報</a>
        <a href="/hydrogen/news" onclick="toggleMenu()" data-ja="ニュース" data-en="News">ニュース</a>
        <a href="/hydrogen/contact" onclick="toggleMenu()" data-ja="お問い合わせ" data-en="Contact">お問い合わせ</a>
        <div class="lang-toggle" style="margin-top: 1rem;">
            <button class="lang-btn active" onclick="setLang('ja')">JP</button>
            <button class="lang-btn" onclick="setLang('en')">EN</button>
        </div>
    </div>

    <slot />

    <footer>
        <div class="container">
            <div class="footer-grid">
                <div>
                    <div class="logo" style="margin-bottom: 1.5rem;">HYDROGEN-X</div>
                    <p style="color: var(--text-dim); font-size: 0.9rem;">Leading the global energy transition through innovative hydrogen technology.</p>
                </div>
                <div class="footer-link-group">
                    <h4 data-ja="技術情報" data-en="Technology">技術情報</h4>
                    <ul style="list-style: none; margin-top: 1rem;">
                        <li><a href="/hydrogen/business" style="color: var(--text-dim); text-decoration: none; font-size: 0.9rem;">製造装置</a></li>
                    </ul>
                </div>
                <!-- ... other footer links ... -->
            </div>
            <div style="text-align: center; color: var(--text-dim); font-size: 0.8rem; padding-top: 3rem; border-top: 1px solid rgba(255, 255, 255, 0.05);">
                &copy; 2026 HYDROGEN-X Inc. All Rights Reserved.
            </div>
        </div>
    </footer>

    <script is:inline>
        function setLang(lang) {
            document.querySelectorAll('[data-ja]').forEach(el => {
                const targetText = lang === 'en' ? el.getAttribute('data-en') : el.getAttribute('data-ja');
                if (targetText) el.innerHTML = targetText;
            });
            document.querySelectorAll('.lang-btn').forEach(btn => {
                btn.classList.toggle('active', btn.textContent.toLowerCase() === lang);
            });
            localStorage.setItem('hydrogen-lang', lang);
        }

        // Apply saved lang
        const savedLang = localStorage.getItem('hydrogen-lang');
        if (savedLang) setLang(savedLang);

        // Mobile Menu Toggle
        const menuToggle = document.getElementById('menuToggle');
        const mobileNav = document.getElementById('mobileNav');

        function toggleMenu() {
            menuToggle.classList.toggle('active');
            mobileNav.classList.toggle('active');
            document.body.style.overflow = mobileNav.classList.contains('active') ? 'hidden' : 'auto';
        }

        menuToggle.addEventListener('click', toggleMenu);

        // Scroll Reveal
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        window.addEventListener('scroll', () => {
            document.getElementById('header').classList.toggle('scrolled', window.scrollY > 50);
        });
    </script>
</body>
</html>
