---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "和-Node｜LIFF App", 
  description = "和-NodeのLINE内ミニアプリ・診断ツールです。" 
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&family=Caveat:wght@400;700&display=swap" rel="stylesheet" />
    
    <script charset="utf-8" src="https://static.line-scdn.net/liff/edge/2/sdk.js" is:inline></script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-color: #f0f0f3;
    --text-color: #2c2c2a;
    --accent-color: #c8a84b;
    --shadow-light: #ffffff;
    --shadow-dark: #d1d1d6;
    --line-green: #06C755;
    --tech-blue: #4a90e2;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }

  body {
    font-family: 'Noto Sans JP', sans-serif;
    background-color: var(--bg-color);
    color: var(--text-color);
    overflow-x: hidden;
  }
</style>
